#!/bin/bash
# Cot pre-commit hook
# Runs tests and formatting checks before allowing commits
#
# To enable: git config core.hooksPath .githooks

set -e

echo "=== Cot Pre-commit Checks ==="
echo

# Check if zig is available
if ! command -v zig &> /dev/null; then
    echo "ERROR: zig not found in PATH"
    exit 1
fi

# Run formatting check
echo "[1/3] Checking code formatting..."
if ! zig fmt --check src/ 2>/dev/null; then
    echo "ERROR: Code formatting issues found."
    echo "Run 'zig fmt src/' to fix formatting."
    exit 1
fi
echo "      Formatting OK"
echo

# Build the project
echo "[2/3] Building project..."
if ! zig build 2>&1; then
    echo "ERROR: Build failed."
    exit 1
fi
echo "      Build OK"
echo

# Run tests
echo "[3/3] Running tests..."
if ! zig build test 2>&1; then
    echo "ERROR: Tests failed."
    exit 1
fi
echo "      Tests OK"
echo

echo "=== All checks passed! ==="
