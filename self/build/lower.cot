/// AST-to-IR lowering pass for the self-hosted Cot compiler.
/// Transforms type-checked AST into flat IR (intermediate representation).
/// Ported from compiler/frontend/lower.zig

import "std/list"
import "std/map"
import "std/string"
import "std/fs"
import "ir"
import "../parse/ast"
import "../check/types"
import "../parse/source"
import "../check/errors"
import "../check/checker"
import "../parse/token"

// Constants null_node, null_local, null_block imported from ir.cot
// Type constants (VOID, I64, BOOL, etc.) imported from types.cot
// Type tag constants (TAG_STRUCT, etc.) imported from types.cot

// ============================================================================
// Supporting types
// ============================================================================

/// Cleanup entry for deferred operations (defer, errdefer, ARC release).
struct CleanupEntry {
    kind: int,
    value: int,
    type_idx: int,
    local_idx: int,
    func_name: string,
}

/// Cleanup kind constants
const CLEANUP_DEFER: int = 0
const CLEANUP_ERRDEFER: int = 1
const CLEANUP_RELEASE: int = 2
const CLEANUP_SCOPE_DESTROY: int = 3
const CLEANUP_ARC_RELEASE: int = 2

/// Loop context for break/continue targets.
struct LoopContext {
    cond_block: int,
    exit_block: int,
    cleanup_depth: int,
    label: string,
}

struct LabeledBlockCtx {
    label: string,
    exit_block: int,
    result_local: int,
    result_type: int,
    cleanup_depth: int,
}

/// Captured variable info for closures.
struct CaptureInfo {
    name: string,
    local_idx: int,
    type_idx: int,
}

/// Dict entry: a type-dependent operation (binary op or method call) in a generic body.
/// Copied from lower.zig:474-482
const DICT_BINARY_OP: int = 0
const DICT_METHOD_CALL: int = 1

struct DictEntry {
    kind: int,               // DICT_BINARY_OP or DICT_METHOD_CALL
    op: int,                 // BinaryOp enum value (for binary_op)
    method_name: string,     // method name (for method_call)
    type_param_idx: int,     // which type param this entry applies to
}

/// Stencil analysis results (3-tier).
/// Copied from lower.zig:488-496
const STENCIL_SHAPE_ONLY: int = 0      // Tier 1: no type-dependent ops (alias only)
const STENCIL_DICT: int = 1            // Tier 2: binary ops/method calls (share body + fn-ptr args)
const STENCIL_NOT_STENCILABLE: int = 2 // Tier 3: closures, async, switch on T (full mono)

/// Global init entry for __cot_init_globals.
struct GlobalInit {
    global_idx: int,
    value_node: int,
    type_idx: int,
    name: string,
    span: Span,
}

/// Map Token op to dict helper name suffix.
/// Copied from lower.zig:8375-8390
fn dictOpName(op: int) string {
    const tok = @enumFromInt(op) as Token
    return switch (tok) {
        Token.eql => "eq",
        Token.neq => "ne",
        Token.lss => "lt",
        Token.gtr => "gt",
        Token.leq => "le",
        Token.geq => "ge",
        Token.add => "add",
        Token.sub => "sub",
        Token.mul => "mul",
        Token.quo => "div",
        Token.rem => "mod",
        else => "unknown",
    }
}

// ============================================================================
// Lowerer
// ============================================================================

struct Lowerer {
    tree: *Ast,
    types: *TypeRegistry,
    err: *ErrorReporter,
    chk: *Checker,
    temp_counter: int,
    test_mode: bool,
    fail_fast: bool,
    bench_mode: bool,
    current_test_name: string,
    closure_counter: int,
    current_switch_enum_type: int,
    next_error_idx: int,
    release_mode: bool,
    loop_stack: List(LoopContext),
    labeled_block_stack: List(LabeledBlockCtx),
    cleanup_stack: List(CleanupEntry),
    const_values: Map(string, int),
    float_const_values: Map(string, int),
    float_const_types: Map(string, int),
    test_names: List(string),
    test_display_names: List(string),
    bench_names: List(string),
    bench_display_names: List(string),
    lowered_generics: Map(string, int),
    global_error_table: Map(string, int),
    weak_locals: Map(int, int),
    comptime_value_vars: Map(string, int),
    global_comptime_values: Map(string, int),
    pending_global_inits: List(GlobalInit),
    pending_auto_deinits: List(string),
    module_name: string,
    tree_module_map: Map(int, string),
    spawn_counter: int,
    // Shape stenciling state
    shape_stencils: Map(string, string),      // shape_key → first stencil name
    shape_aliases: Map(string, string),       // concrete_name → stencil name (alias)
    generated_dict_helpers: Map(string, int), // dedup: helper_name → 1
    shape_analysis_cache: Map(int, int),      // generic_node → stencil result (int)
    stencil_dict_entries: List(DictEntry),    // entries from last analyzeStencilability
    dict_arg_names: Map(string, string),      // concrete_name → comma-separated helper names
    current_dict_entries: List(DictEntry),    // active dict entries during stenciled fn body
    current_dict_params: List(int),           // active dict param locals during stenciled fn body
    has_dict_context: bool,                   // true when inside a dict-stenciled function
    gc_mode: bool,                            // true when targeting WasmGC (structs/unions are GC refs)
    builder: Builder,

    fn isWasmGC() bool {
        return self.gc_mode
    }

    fn setGcMode(enabled: bool) void {
        self.gc_mode = enabled
    }

    fn setTestMode(enabled: bool) void {
        self.test_mode = enabled
    }

    fn setFailFast(enabled: bool) void {
        self.fail_fast = enabled
    }

    fn setBenchMode(enabled: bool) void {
        self.bench_mode = enabled
    }

    // ========================================================================
    // Module qualification (Go LinkFuncName pattern)
    // ========================================================================

    /// Qualify bare function name with module prefix.
    /// Returns bare name for single-file builds (module_name is empty).
    fn qualifyName(bare: string) string {
        if (self.module_name == "") { return bare }
        return self.module_name ++ "." ++ bare
    }

    /// Resolve the qualified IR name for a function call target.
    /// Looks up the Symbol in checker scope to find which module defined it.
    fn resolveCallName(bare: string) string {
        if (self.module_name == "") { return bare }
        if (shouldSkipQualification(bare)) { return bare }
        // Look up in checker scope to find which module defined this function
        if (self.chk.lookupSymbol(bare)) |sym| {
            if (sym.is_extern or sym.is_export) { return bare }
            if (sym.source_tree != 0) {
                if (self.tree_module_map.contains(sym.source_tree)) {
                    return self.tree_module_map.get(sym.source_tree) ++ "." ++ bare
                }
            }
        }
        // Local function or not found: qualify with own module
        return self.qualifyName(bare)
    }

    /// Qualify a type name with its DEFINING module (not necessarily the current module).
    /// Used for ARC metadata names and auto-deinit function names.
    fn qualifyTypeName(type_name: string) string {
        if (self.module_name == "") { return type_name }
        if (self.chk.lookupSymbol(type_name)) |sym| {
            if (sym.source_tree != 0) {
                if (self.tree_module_map.contains(sym.source_tree)) {
                    return self.tree_module_map.get(sym.source_tree) ++ "." ++ type_name
                }
            }
        }
        return self.qualifyName(type_name)
    }

    /// Resolve a method's IR name via the defining module.
    /// Three fallbacks: (1) method's source_tree, (2) type symbol lookup, (3) function name lookup.
    fn resolveMethodName(type_name: string, func_name: string, method_source_tree: int) string {
        if (self.module_name == "") { return func_name }
        if (shouldSkipQualification(func_name)) { return func_name }
        // Primary: use the method's source_tree recorded at registration time
        if (method_source_tree != 0) {
            if (self.tree_module_map.contains(method_source_tree)) {
                return self.tree_module_map.get(method_source_tree) ++ "." ++ func_name
            }
        }
        // Fallback 1: Look up the TYPE symbol in scope
        if (self.chk.lookupSymbol(type_name)) |sym| {
            if (sym.is_extern or sym.is_export) { return func_name }
            if (sym.source_tree != 0) {
                if (self.tree_module_map.contains(sym.source_tree)) {
                    return self.tree_module_map.get(sym.source_tree) ++ "." ++ func_name
                }
            }
        }
        if (self.chk.lookupSymbol(func_name)) |fn_sym| {
            if (fn_sym.is_extern or fn_sym.is_export) { return func_name }
            if (fn_sym.source_tree != 0) {
                if (self.tree_module_map.contains(fn_sym.source_tree)) {
                    return self.tree_module_map.get(fn_sym.source_tree) ++ "." ++ func_name
                }
            }
        }
        return self.qualifyName(func_name)
    }

    // ========================================================================
    // Top-level lowering
    // ========================================================================

    /// Lower all declarations and return the completed IR.
    fn lower() IR {
        self.lowerToBuilder()
        return self.builder.getIR()
    }

    /// Lower all root declarations into the builder.
    fn lowerToBuilder() void {
        for i in 0..self.tree.file_decls.count {
            const decl_idx = self.tree.file_decls.get(i)
            eprintln("[lower] decl ${i}/${self.tree.file_decls.count}")
            self.lowerDecl(decl_idx)
        }
        self.lowerQueuedGenericFunctions()
        self.emitPendingAutoDeinits()
    }

    /// Generate test runner: main() that calls each test and reports pass/fail.
    fn generateTestRunner() void {
        if (self.test_names.count == 0) { return }
        const span = Span.zero()
        const err_void_type = self.types.makeErrorUnion(VOID)
        self.builder.startFunc("main", VOID, I64, span)
        if (self.builder.func()) |fb| {
            self.clearPerFunctionState()
            const ptr_type = self.types.makePointer(U8)

            // Initialize globals
            var init_args: List(int) = .{}
            fb.emitCall("__cot_init_globals", init_args, false, VOID, span)

            // Counters
            const fail_count = fb.addLocalWithSize("__fail_count", I64, true, 8)
            const zero_init = fb.emitConstInt(0, I64, span)
            fb.emitStoreLocal(fail_count, zero_init, span)
            const pass_count = fb.addLocalWithSize("__pass_count", I64, true, 8)
            fb.emitStoreLocal(pass_count, zero_init, span)

            for i in 0..self.test_names.count {
                const test_name = self.test_names.get(i)
                const display_name = self.test_display_names.get(i)

                // Print test name
                const str_idx = fb.addStringLiteral(display_name)
                const str_slice = fb.emitConstSlice(str_idx, span)
                const name_ptr = fb.emitSlicePtr(str_slice, ptr_type, span)
                const name_len = fb.emitSliceLen(str_slice, span)
                var pn_args: List(int) = .{}
                pn_args.append(name_ptr)
                pn_args.append(name_len)
                fb.emitCall("__test_print_name", pn_args, false, VOID, span)

                // Call test function — returns EU ptr
                var no_args: List(int) = .{}
                const eu_ptr = fb.emitCall(test_name, no_args, false, err_void_type, span)

                // Check EU tag
                const tag_val = fb.emitPtrLoadValue(eu_ptr, I64, span)
                const zero = fb.emitConstInt(0, I64, span)
                const is_error = fb.emitBinary(BinaryOp.ne, tag_val, zero, BOOL, span)

                const fail_block = fb.newBlock("test.fail")
                const pass_block = fb.newBlock("test.pass")
                const merge_block = fb.newBlock("test.merge")
                fb.emitBranch(is_error, fail_block, pass_block, span)

                // Fail block
                fb.setBlock(fail_block)
                var fail_args: List(int) = .{}
                fb.emitCall("__test_fail", fail_args, false, VOID, span)
                const cur_fail = fb.emitLoadLocal(fail_count, I64, span)
                const one_f = fb.emitConstInt(1, I64, span)
                const new_fail = fb.emitBinary(BinaryOp.add, cur_fail, one_f, I64, span)
                fb.emitStoreLocal(fail_count, new_fail, span)
                if (self.fail_fast) {
                    const ff_pass = fb.emitLoadLocal(pass_count, I64, span)
                    const ff_fail = fb.emitLoadLocal(fail_count, I64, span)
                    var ff_args: List(int) = .{}
                    ff_args.append(ff_pass)
                    ff_args.append(ff_fail)
                    fb.emitCall("__test_summary", ff_args, false, VOID, span)
                    const ff_exit = fb.emitLoadLocal(fail_count, I64, span)
                    fb.emitRet(ff_exit, span)
                } else {
                    fb.emitJump(merge_block, span)
                }

                // Pass block
                fb.setBlock(pass_block)
                var pass_args: List(int) = .{}
                fb.emitCall("__test_pass", pass_args, false, VOID, span)
                const cur_pass = fb.emitLoadLocal(pass_count, I64, span)
                const one_p = fb.emitConstInt(1, I64, span)
                const new_pass = fb.emitBinary(BinaryOp.add, cur_pass, one_p, I64, span)
                fb.emitStoreLocal(pass_count, new_pass, span)
                fb.emitJump(merge_block, span)

                fb.setBlock(merge_block)
            }

            // Print summary
            const final_pass = fb.emitLoadLocal(pass_count, I64, span)
            const final_fail = fb.emitLoadLocal(fail_count, I64, span)
            var summary_args: List(int) = .{}
            summary_args.append(final_pass)
            summary_args.append(final_fail)
            fb.emitCall("__test_summary", summary_args, false, VOID, span)

            // Return fail count as exit code
            const final_count = fb.emitLoadLocal(fail_count, I64, span)
            fb.emitRet(final_count, span)
        }
        self.builder.endFunc()
    }

    /// Generate bench runner: main() that warms up, calibrates, and measures each benchmark.
    fn generateBenchRunner() void {
        if (self.bench_names.count == 0) { return }
        const span = Span.zero()
        self.builder.startFunc("main", VOID, I64, span)
        if (self.builder.func()) |fb| {
            self.clearPerFunctionState()
            const ptr_type = self.types.makePointer(U8)

            // Initialize globals
            var init_args: List(int) = .{}
            fb.emitCall("__cot_init_globals", init_args, false, VOID, span)

            const discard_local = fb.addLocalWithSize("__bench_discard", I64, true, 8)
            const loop_counter = fb.addLocalWithSize("__bench_i", I64, true, 8)

            for i in 0..self.bench_names.count {
                const bench_name = self.bench_names.get(i)
                const display_name = self.bench_display_names.get(i)

                // Print bench name
                const str_idx = fb.addStringLiteral(display_name)
                const str_slice = fb.emitConstSlice(str_idx, span)
                const name_ptr = fb.emitSlicePtr(str_slice, ptr_type, span)
                const name_len = fb.emitSliceLen(str_slice, span)
                var pn_args: List(int) = .{}
                pn_args.append(name_ptr)
                pn_args.append(name_len)
                fb.emitCall("__bench_print_name", pn_args, false, VOID, span)

                // Warmup: call bench_fn() × 3
                for w in 0..3 {
                    var no_args: List(int) = .{}
                    const r = fb.emitCall(bench_name, no_args, false, I64, span)
                    fb.emitStoreLocal(discard_local, r, span)
                }

                // Calibrate
                var cs_args: List(int) = .{}
                fb.emitCall("__bench_calibrate_start", cs_args, false, VOID, span)
                var cal_args: List(int) = .{}
                const cal_r = fb.emitCall(bench_name, cal_args, false, I64, span)
                fb.emitStoreLocal(discard_local, cal_r, span)
                var ce_args: List(int) = .{}
                fb.emitCall("__bench_calibrate_end", ce_args, false, VOID, span)

                // Measure
                var ms_args: List(int) = .{}
                fb.emitCall("__bench_measure_start", ms_args, false, VOID, span)

                // i = 0
                const zero = fb.emitConstInt(0, I64, span)
                fb.emitStoreLocal(loop_counter, zero, span)

                const loop_cond_block = fb.newBlock("bench.loop.cond")
                const loop_body_block = fb.newBlock("bench.loop.body")
                const loop_exit_block = fb.newBlock("bench.loop.exit")
                fb.emitJump(loop_cond_block, span)

                fb.setBlock(loop_cond_block)
                var gn_args: List(int) = .{}
                const n_val = fb.emitCall("__bench_get_n", gn_args, false, I64, span)
                const i_val = fb.emitLoadLocal(loop_counter, I64, span)
                const cond = fb.emitBinary(BinaryOp.lt, i_val, n_val, BOOL, span)
                fb.emitBranch(cond, loop_body_block, loop_exit_block, span)

                fb.setBlock(loop_body_block)
                var body_args: List(int) = .{}
                const body_r = fb.emitCall(bench_name, body_args, false, I64, span)
                fb.emitStoreLocal(discard_local, body_r, span)
                const i_reload = fb.emitLoadLocal(loop_counter, I64, span)
                const one = fb.emitConstInt(1, I64, span)
                const i_next = fb.emitBinary(BinaryOp.add, i_reload, one, I64, span)
                fb.emitStoreLocal(loop_counter, i_next, span)
                fb.emitJump(loop_cond_block, span)

                fb.setBlock(loop_exit_block)
                var me_args: List(int) = .{}
                fb.emitCall("__bench_measure_end", me_args, false, VOID, span)
            }

            // Summary
            const bench_count = fb.emitConstInt(self.bench_names.count, I64, span)
            var sum_args: List(int) = .{}
            sum_args.append(bench_count)
            fb.emitCall("__bench_summary", sum_args, false, VOID, span)

            const ret_zero = fb.emitConstInt(0, I64, span)
            fb.emitRet(ret_zero, span)
        }
        self.builder.endFunc()
    }

    /// Generate __cot_init_globals: stores non-folded global initializers.
    fn generateGlobalInits() void {
        self.generateGlobalInitsNamed("__cot_init_globals")
    }

    fn generateGlobalInitsNamed(name: string) void {
        const span = Span.zero()
        self.builder.startFunc(name, VOID, VOID, span)
        if (self.builder.func()) |fb| {
            self.clearPerFunctionState()
            for i in 0..self.pending_global_inits.count {
                const gi = self.pending_global_inits.get(i)
                // Skip invalid node indices (can happen with cross-file generic globals)
                if (gi.value_node < 0 or gi.value_node >= self.tree.nodes.count) { continue }
                const node = self.tree.getNode(gi.value_node)
                switch (node) { Node.expr |e| => {
                    const value = self.lowerExpr(e, gi.value_node)
                    if (value != null_node) {
                        fb.emitGlobalStore(gi.global_idx, gi.name, value, gi.span)
                    }
                }, else => {} }
            }
            fb.emitRet(null_node, span)
        }
        self.builder.endFunc()
    }

    // ========================================================================
    // Declaration lowering
    // ========================================================================

    fn lowerDecl(idx: int) void {
        if (idx == null_node) { return }
        const node = self.tree.getNode(idx)
        switch (node) {
            Node.decl |d| => switch (d) {
                Decl.fn_decl |fd| => { self.lowerFnDecl(fd) },
                Decl.var_decl |vd| => { self.lowerGlobalVarDecl(vd) },
                Decl.struct_decl |sd| => { self.lowerStructDecl(sd) },
                Decl.enum_decl |ed| => { self.lowerEnumDecl(ed) },
                Decl.impl_block |ib| => { self.lowerImplBlock(ib) },
                Decl.impl_trait |it| => { self.lowerImplTraitBlock(it) },
                Decl.test_decl |td| => { if (self.test_mode) { self.lowerTestDecl(td) } },
                Decl.bench_decl |bd| => { if (self.bench_mode) { self.lowerBenchDecl(bd) } },
                else => {},
            },
            else => {},
        }
    }

    // ========================================================================
    // Function lowering
    // ========================================================================

    fn lowerFnDecl(fn_decl: FnDecl) void {
        if (fn_decl.is_extern) { return }
        if (fn_decl.type_params.count > 0) { return }  // Generic — lowered on demand
        if ((self.test_mode or self.bench_mode) and fn_decl.name == "main") { return }

        // Async functions get special lowering (native fiber pattern)
        if (fn_decl.is_async) {
            self.lowerAsyncFiber(fn_decl)
            return
        }

        const return_type = if (fn_decl.return_type != null_node) {
            self.resolveTypeNode(fn_decl.return_type)
        } else { VOID }


        const uses_sret = self.needsSret(return_type)
        const wasm_return_type = if (uses_sret) { VOID } else { return_type }

        const qualified_name = self.qualifyName(fn_decl.name)
        self.builder.startFunc(qualified_name, VOID, wasm_return_type, fn_decl.span)
        if (self.builder.func()) |fb| {
            if (uses_sret) { fb.sret_return_type = return_type }
            fb.is_destructor = strEndsWith(fn_decl.name, "_deinit")
            fb.is_export = fn_decl.is_export
            self.clearPerFunctionState()

            // SRET: hidden first parameter
            if (uses_sret) {
                fb.addParam("__sret", I64, 8)
            }

            // Add regular parameters
            for i in 0..fn_decl.params.count {
                const param_idx = fn_decl.params.get(i)
                self.addParamFromNode(param_idx)
            }

            if (fn_decl.body != null_node) {
                self.lowerBlockNode(fn_decl.body)

                if (fb.is_destructor) {
                    self.emitFieldReleases(fn_decl.name, fn_decl.span)
                }

                if (return_type == VOID and fb.needsTerminator()) {
                    self.emitCleanups(0)
                    fb.emitRet(null_node, fn_decl.span)
                }
            }
        }
        self.builder.endFunc()
    }

    fn lowerMethodWithName(fn_decl: FnDecl, synth_name: string, is_destructor: bool) void {
        eprintln("[lower] lmwn: resolve return type")
        const return_type = if (fn_decl.return_type != null_node) {
            self.resolveTypeNode(fn_decl.return_type)
        } else { VOID }

        const uses_sret = self.needsSret(return_type)
        const wasm_return_type = if (uses_sret) { VOID } else { return_type }

        eprintln("[lower] lmwn: startFunc")
        self.builder.startFunc(synth_name, VOID, wasm_return_type, fn_decl.span)
        if (self.builder.func()) |fb| {
            fb.is_destructor = is_destructor
            if (uses_sret) { fb.sret_return_type = return_type }
            eprintln("[lower] lmwn: clearPerFunctionState")
            self.clearPerFunctionState()

            if (uses_sret) {
                fb.addParam("__sret", I64, 8)
            }

            eprintln("[lower] lmwn: adding ${fn_decl.params.count} params")
            for i in 0..fn_decl.params.count {
                const param_idx = fn_decl.params.get(i)
                self.addParamFromNode(param_idx)
            }

            if (fn_decl.body != null_node) {
                self.lowerBlockNode(fn_decl.body)

                if (is_destructor) {
                    self.emitFieldReleases(synth_name, fn_decl.span)
                }

                if (return_type == VOID and fb.needsTerminator()) {
                    self.emitCleanups(0)
                    fb.emitRet(null_node, fn_decl.span)
                }
            }
        }
        self.builder.endFunc()
    }

    // ========================================================================
    // Struct/Enum/Impl lowering
    // ========================================================================

    fn lowerStructDecl(struct_decl: StructDecl) void {
        if (struct_decl.type_params.count > 0) { return }  // Generic — instantiated on demand
        const struct_type_idx = self.types.lookupByName(struct_decl.name)
        if (struct_type_idx < 0) {
            self.builder.addStruct(StructDef { name: struct_decl.name, type_idx: 0, span: struct_decl.span })
        } else {
            self.builder.addStruct(StructDef { name: struct_decl.name, type_idx: struct_type_idx, span: struct_decl.span })
        }

        // Nested declarations (inferred impl)
        for i in 0..struct_decl.nested_decls.count {
            const nested_idx = struct_decl.nested_decls.get(i)
            switch (self.tree.getNode(nested_idx)) {
                Node.decl |nd| => switch (nd) {
                    Decl.struct_decl |ns| => {
                        const qualified = struct_decl.name ++ "_" ++ ns.name
                        const ns_type = self.types.lookupByName(qualified)
                        var ns_type_idx = 0
                        if (ns_type >= 0) { ns_type_idx = ns_type }
                        self.builder.addStruct(StructDef { name: qualified, type_idx: ns_type_idx, span: ns.span })
                    },
                    Decl.fn_decl |fd| => {
                        const bare_name = struct_decl.name ++ "_" ++ fd.name
                        const synth_name = self.qualifyName(bare_name)
                        eprintln("[lower] method: ${synth_name}")
                        self.lowerMethodWithName(fd, synth_name, fd.name == "deinit")
                        eprintln("[lower] method done: ${synth_name}")
                    },
                    else => {},
                },
                else => {},
            }
        }
    }

    fn lowerEnumDecl(ed: EnumDecl) void {
        // Enum variants don't generate code — registered during checking
        // But nested fn_decl methods (inferred impl) do
        for i in 0..ed.nested_decls.count {
            const nested_idx = ed.nested_decls.get(i)
            switch (self.tree.getNode(nested_idx)) {
                Node.decl |nd| => switch (nd) {
                    Decl.fn_decl |fd| => {
                        const synth_name = self.qualifyName(ed.name ++ "_" ++ fd.name)
                        self.lowerMethodWithName(fd, synth_name, fd.name == "deinit")
                    },
                    else => {},
                },
                else => {},
            }
        }
    }

    fn lowerImplBlock(impl_block: ImplBlock) void {
        if (impl_block.type_params.count > 0) { return }  // Generic — lowered via queue
        for i in 0..impl_block.methods.count {
            const method_idx = impl_block.methods.get(i)
            switch (self.tree.getNode(method_idx)) {
                Node.decl |d| => switch (d) {
                    Decl.fn_decl |fd| => {
                        const synth_name = self.qualifyName(impl_block.type_name ++ "_" ++ fd.name)
                        self.lowerMethodWithName(fd, synth_name, fd.name == "deinit")
                    },
                    else => {},
                },
                else => {},
            }
        }
    }

    fn lowerImplTraitBlock(impl_trait: ImplTraitBlock) void {
        for i in 0..impl_trait.methods.count {
            const method_idx = impl_trait.methods.get(i)
            switch (self.tree.getNode(method_idx)) {
                Node.decl |d| => switch (d) {
                    Decl.fn_decl |fd| => {
                        const synth_name = self.qualifyName(impl_trait.target_type ++ "_" ++ fd.name)
                        self.lowerMethodWithName(fd, synth_name, fd.name == "deinit")
                    },
                    else => {},
                },
                else => {},
            }
        }
    }

    // ========================================================================
    // Test/Bench lowering
    // ========================================================================

    fn lowerTestDecl(test_decl: TestDecl) void {
        const test_name = sanitizeName("test_", test_decl.name)
        self.test_names.append(test_name)
        self.test_display_names.append(test_decl.name)

        // Test functions return !void (error union)
        const err_void_type = self.types.makeErrorUnion(VOID)

        self.builder.startFunc(test_name, VOID, err_void_type, test_decl.span)
        if (self.builder.func()) |fb| {
            self.current_test_name = test_decl.name
            self.clearPerFunctionState()

            if (test_decl.body != null_node) {
                self.lowerBlockNode(test_decl.body)

                if (fb.needsTerminator()) {
                    self.emitCleanups(0)
                    // Return success: error union tag=0
                    const eu_size = self.types.sizeOf(err_void_type)
                    const tmp_local = fb.addLocalWithSize("__test_ok", err_void_type, false, eu_size)
                    const tag_zero = fb.emitConstInt(0, I64, test_decl.span)
                    fb.emitStoreLocalField(tmp_local, 0, 0, tag_zero, test_decl.span)
                    const zero_payload = fb.emitConstInt(0, I64, test_decl.span)
                    fb.emitStoreLocalField(tmp_local, 1, 8, zero_payload, test_decl.span)
                    const ret_ptr = fb.emitAddrLocal(tmp_local, I64, test_decl.span)
                    fb.emitRet(ret_ptr, test_decl.span)
                }
            }
            self.current_test_name = ""
        }
        self.builder.endFunc()
    }

    fn lowerBenchDecl(bench_decl: BenchDecl) void {
        const bench_name = sanitizeName("bench_", bench_decl.name)
        self.bench_names.append(bench_name)
        self.bench_display_names.append(bench_decl.name)

        self.builder.startFunc(bench_name, VOID, I64, bench_decl.span)
        if (self.builder.func()) |fb| {
            self.clearPerFunctionState()

            if (bench_decl.body != null_node) {
                self.lowerBlockNode(bench_decl.body)

                if (fb.needsTerminator()) {
                    self.emitCleanups(0)
                    const zero = fb.emitConstInt(0, I64, bench_decl.span)
                    fb.emitRet(zero, bench_decl.span)
                }
            }
        }
        self.builder.endFunc()
    }

    // ========================================================================
    // Global variable lowering
    // ========================================================================

    fn lowerGlobalVarDecl(var_decl: VarDecl) void {
        var type_idx = VOID
        if (var_decl.type_expr != null_node) {
            type_idx = self.resolveTypeNode(var_decl.type_expr)
        } else if (var_decl.value != null_node) {
            type_idx = self.inferExprType(var_decl.value)
        }

        if (var_decl.is_const) {
            // Check for compile-time known integer constant
            if (self.chk.lookupSymbol(var_decl.name)) |sym| {
                if (sym.is_const_val) {
                    self.const_values.set(var_decl.name, sym.const_value)
                    return
                }
                if (sym.float_const_value != 0) {
                    self.float_const_values.set(var_decl.name, sym.float_const_value)
                    self.float_const_types.set(var_decl.name, sym.type_idx)
                    return
                }
            }

            // Float consts: parse literal value and store in float_const_values
            if ((type_idx == F32 or type_idx == F64) and var_decl.value != null_node) {
                if (self.evalFloatLiteral(var_decl.value)) |fval| {
                    self.float_const_values.set(var_decl.name, @bitCast(int, fval))
                    self.float_const_types.set(var_decl.name, type_idx)
                    return
                }
            }

            // Comptime block producing structured values
            if (var_decl.value != null_node) {
                var is_comptime = false
                switch (self.tree.getNode(var_decl.value)) { Node.expr |e| => switch (e) { Expr.comptime_block |_| => { is_comptime = true }, else => {} }, else => {} }
                if (is_comptime) {
                    // Store in global_comptime_values for on-demand materialization
                    // TODO: evalComptimeValue in checker when comptime evaluation is fully ported
                    return
                }
            }
        }

        const type_size = self.types.sizeOf(type_idx)
        const global_idx = self.builder.globals.count
        self.builder.addGlobal(Global.initWithSize(var_decl.name, type_idx, var_decl.is_const, var_decl.span, type_size))

        // Queue non-folded initializers for __cot_init_globals
        if (var_decl.value != null_node) {
            // Skip error_set declarations (compile-time only)
            if (type_idx != VOID and self.types.get(type_idx).tag != TAG_ERROR_SET) {
                self.pending_global_inits.append(GlobalInit {
                    global_idx: global_idx,
                    value_node: var_decl.value,
                    type_idx: type_idx,
                    name: var_decl.name,
                    span: var_decl.span,
                })
            }
        }
    }

    // ========================================================================
    // Block and statement lowering
    // ========================================================================

    /// Lower a block node — dispatches to statement or expression lowering.
    /// Returns true if the block terminated (return/break/continue).
    fn lowerBlockNode(idx: int) bool {
        if (self.builder.func() == null) { return false }
        if (idx == null_node) { return false }
        const node = self.tree.getNode(idx)

        // Statement
        const maybe_stmt = asStmt(node)
        if (maybe_stmt) |s| { return self.lowerStmt(s) }

        // Expression
        const maybe_expr = asExpr(node)
        if (maybe_expr) |e| {
            switch (e) {
                Expr.block_expr |be| => {
                    if (self.builder.func()) |fb| {
                        const scope_depth = fb.markScopeEntry()
                        var terminated = false
                        for i in 0..be.stmts.count {
                            const stmt_idx = be.stmts.get(i)
                            const stmt_node = self.tree.getNode(stmt_idx)
                            const inner_stmt = asStmt(stmt_node)
                            if (inner_stmt) |s| {
                                if (self.lowerStmt(s)) { terminated = true }
                            } else {
                                switch (stmt_node) {
                                    Node.decl |d| => switch (d) {
                                        Decl.struct_decl |sd| => { self.lowerStructDecl(sd) },
                                        else => {},
                                    },
                                    else => {},
                                }
                            }
                            if (terminated) { break }
                        }
                        if (!terminated and be.result_expr != null_node) {
                            self.lowerExprNode(be.result_expr)
                        }
                        fb.restoreScope(scope_depth)
                        return terminated
                    }
                },
                else => { self.lowerExprNode(idx) },
            }
        }
        return false
    }

    /// Lower a statement. Returns true if it terminates the block.
    fn lowerStmt(stmt: Stmt) bool {
        const fb = self.builder.func() orelse return false
        switch (stmt) {
            Stmt.return_stmt |ret| => {
                self.lowerReturn(ret)
                return true
            },
            Stmt.var_stmt |v| => {
                self.lowerLocalVarDecl(v)
                return false
            },
            Stmt.assign_stmt |a| => {
                self.lowerAssign(a)
                return false
            },
            Stmt.if_stmt |i| => {
                return self.lowerIf(i)
            },
            Stmt.while_stmt |w| => {
                self.lowerWhile(w)
                return false
            },
            Stmt.for_stmt |f| => {
                self.lowerFor(f)
                return false
            },
            Stmt.block_stmt |block| => {
                if (self.builder.func()) |fb| {
                    const cleanup_depth = self.cleanup_stack.count
                    const scope_depth = fb.markScopeEntry()
                    for i in 0..block.stmts.count {
                        const stmt_idx = block.stmts.get(i)
                        const stmt_node = self.tree.getNode(stmt_idx)
                        const inner_stmt = asStmt(stmt_node)
                        if (inner_stmt) |s| {
                            if (self.lowerStmt(s)) {
                                fb.restoreScope(scope_depth)
                                return true
                            }
                        } else {
                            switch (stmt_node) {
                                Node.decl |d| => switch (d) {
                                    Decl.struct_decl |sd| => { self.lowerStructDecl(sd) },
                                    else => {},
                                },
                                else => {},
                            }
                        }
                    }
                    self.emitCleanups(cleanup_depth)
                    fb.restoreScope(scope_depth)
                }
                return false
            },
            Stmt.break_stmt |bs| => {
                self.lowerBreak(bs.label, bs.value)
                return true
            },
            Stmt.continue_stmt |cs| => {
                self.lowerContinue(cs.label)
                return true
            },
            Stmt.expr_stmt |es| => {
                // Track current block before lowering — @trap()/@panic() create dead blocks
                var prev_block = null_block
                if (self.builder.func()) |fb2| { prev_block = fb2.currentBlock() }
                self.lowerExprNode(es.expr)
                // If block changed (e.g. @trap() switched to dead block), treat as terminated
                if (self.builder.func()) |fb2| {
                    if (prev_block != null_block and fb2.currentBlock() != prev_block) {
                        return true
                    }
                }
                return false
            },
            Stmt.defer_stmt |ds| => {
                const kind = if (ds.is_errdefer) { CLEANUP_ERRDEFER } else { CLEANUP_DEFER }
                self.cleanup_stack.append(CleanupEntry {
                    kind: kind,
                    value: ds.expr,
                    type_idx: VOID,
                    local_idx: null_local,
                    func_name: "",
                })
                return false
            },
            Stmt.destructure_stmt |ds| => {
                self.lowerDestructureStmt(ds)
                return false
            },
            else => { return false },
        }
    }

    // ========================================================================
    // Statement lowering
    // ========================================================================

    fn lowerReturn(ret: ReturnStmt) void {
        if (self.builder.func()) |fb| {
            // Determine function return type
            // Zig ref: lower.zig lines 1720-1764
            const func_return_type = fb.return_type
            const ret_type_info = self.types.get(func_return_type)
            const is_error_union_fn = ret_type_info.tag == TAG_ERROR_UNION
            const sret_type = if (fb.sret_return_type) |st| { st } else { VOID }

            if (ret.value == null_node) {
                // Void return — but check if func returns !void
                if (is_error_union_fn) {
                    self.emitErrorVoidSuccessReturn(func_return_type, ret.span)
                    return
                }
                if (sret_type != VOID) {
                    const eu_info = self.types.get(sret_type)
                    if (eu_info.tag == TAG_ERROR_UNION) {
                        self.emitErrorVoidSuccessReturn(sret_type, ret.span)
                        return
                    }
                }
                self.emitCleanups(0)
                fb.emitRet(null_node, ret.span)
                return
            }

            // Check if return value is an error literal (already EU ptr)
            var is_error_lit = false
            switch (self.tree.getNode(ret.value)) { Node.expr |e| => switch (e) {
                Expr.error_literal |_| => { is_error_lit = true },
                else => {},
            }, else => {} }

            if (is_error_lit and is_error_union_fn) {
                // error.X in error union function — lowerExprNode returns EU pointer
                const val = self.lowerExprNode(ret.value)
                self.emitCleanups(0)
                fb.emitRet(val, ret.span)
                return
            }

            // Check if function returns error union and value is success payload
            if (is_error_union_fn) {
                // Success value in !T function → wrap as [tag=0][payload]
                // Zig ref: lower.zig lines 1730-1748
                const val = self.lowerExprNode(ret.value)
                if (val == null_node) {
                    self.emitCleanups(0)
                    fb.emitRet(null_node, ret.span)
                    return
                }
                const eu_size = self.types.sizeOf(func_return_type)
                const tmp = fb.addLocalWithSize("__ret_eu", func_return_type, false, eu_size)
                const zero = fb.emitConstInt(0, I64, ret.span)
                fb.emitStoreLocalField(tmp, 0, 0, zero, ret.span)
                // Check if payload is compound (string = ptr+len)
                const eu_elem = switch (ret_type_info) { Type.error_union |eu| => eu.elem, else => VOID }
                if (eu_elem == STRING) {
                    // Compound: decompose string into ptr (offset 8) + len (offset 16)
                    const ptr_val = fb.emitSlicePtr(val, I64, ret.span)
                    const len_val = fb.emitSliceLen(val, ret.span)
                    fb.emitStoreLocalField(tmp, 1, 8, ptr_val, ret.span)
                    fb.emitStoreLocalField(tmp, 2, 16, len_val, ret.span)
                } else {
                    fb.emitStoreLocalField(tmp, 1, 8, val, ret.span)
                }
                const ret_ptr = fb.emitAddrLocal(tmp, I64, ret.span)
                self.emitCleanups(0)
                fb.emitRet(ret_ptr, ret.span)
                return
            }

            if (is_error_lit) {
                const val = self.lowerExprNode(ret.value)
                self.emitCleanups(0)
                fb.emitRet(val, ret.span)
                return
            }

            // Check SRET for non-EU compound returns
            if (sret_type != VOID) {

                // Non-EU SRET: copy to __sret buffer
                const val = self.lowerExprNode(ret.value)
                if (val != null_node) {
                    // Copy to caller's __sret buffer
                    if (fb.lookupLocal("__sret")) |sret_local| {
                        const sret_ptr = fb.emitLoadLocal(sret_local, I64, ret.span)
                        fb.emitPtrStoreValue(sret_ptr, val, ret.span)
                    }
                }
                self.emitCleanups(0)
                fb.emitRet(null_node, ret.span)
                return
            }

            // Regular return
            const val = self.lowerExprNode(ret.value)
            self.emitCleanups(0)
            fb.emitRet(val, ret.span)
        }
    }

    fn emitErrorVoidSuccessReturn(eu_type: int, span: Span) void {
        const fb = self.builder.func() orelse return null_node
        const eu_size = self.types.sizeOf(eu_type)
        const tmp = fb.addLocalWithSize("__ret_ok", eu_type, false, eu_size)
        const zero = fb.emitConstInt(0, I64, span)
        fb.emitStoreLocalField(tmp, 0, 0, zero, span)
        const zero_payload = fb.emitConstInt(0, I64, span)
        fb.emitStoreLocalField(tmp, 1, 8, zero_payload, span)
        const ret_ptr = fb.emitAddrLocal(tmp, I64, span)
        self.emitCleanups(0)
        fb.emitRet(ret_ptr, span)
    }

    fn lowerLocalVarDecl(v: VarStmt) void {
        if (self.builder.func()) |fb| {
            var type_idx = VOID
            if (v.type_expr != null_node) {
                type_idx = self.resolveTypeNode(v.type_expr)
            } else if (v.value != null_node) {
                type_idx = self.inferExprType(v.value)
            }
            const size = self.types.sizeOf(type_idx)
            const local_idx = fb.addLocalWithSize(v.name, type_idx, !v.is_const, size)

            if (v.value != null_node) {
                const val = self.lowerExprNode(v.value)
                if (val != null_node) {
                    fb.emitStoreLocal(local_idx, val, v.span)
                }
            }

            // Register scope_destroy for structs with deinit() (Zig ref: lower.zig:2364-2365)
            self.maybeRegisterScopeDestroy(local_idx, type_idx)
        }
    }

    fn lowerAssign(a: AssignStmt) void {
        if (self.builder.func()) |fb| {
            // Discard pattern: `_ = expr;` — evaluate expr for side effects, discard result.
            // Same semantics as Zig's `_ = foo();` (Zig ref: lower.zig:3028-3032)
            var is_discard = false
            switch (self.tree.getNode(a.target)) { Node.expr |e| => switch (e) { Expr.ident |id| => {
                if (id.name == "_") { is_discard = true }
            }, else => {} }, else => {} }
            if (is_discard) {
                _ = self.lowerExprNode(a.value)
                return
            }

            // Handle compound operators: +=, -=, etc.
            const is_compound = (a.op != Token.assign)

            // Simple variable assignment
            var id_name = ""
            var is_ident = false
            switch (self.tree.getNode(a.target)) { Node.expr |e| => switch (e) { Expr.ident |id| => { id_name = id.name; is_ident = true }, else => {} }, else => {} }

            if (is_ident) {
                if (fb.lookupLocal(id_name)) |local_idx| {
                    if (is_compound) {
                        const old_val = fb.emitLoadLocal(local_idx, fb.locals.get(local_idx).type_idx, a.span)
                        const rhs = self.lowerExprNode(a.value)
                        if (rhs == null_node) { return }
                        const op = tokenToBinaryOp(a.op)
                        const result = fb.emitBinary(op, old_val, rhs, fb.locals.get(local_idx).type_idx, a.span)
                        fb.emitStoreLocal(local_idx, result, a.span)
                    } else {
                        const val = self.lowerExprNode(a.value)
                        if (val == null_node) { return }
                        fb.emitStoreLocal(local_idx, val, a.span)
                    }
                    return
                }
                // Global variable assignment
                if (self.builder.lookupGlobal(id_name)) |g| {
                    const val = self.lowerExprNode(a.value)
                    if (val == null_node) { return }
                    fb.emitGlobalStore(g.idx, id_name, val, a.span)
                    return
                }
            }

            // Dispatch on target node type
            switch (self.tree.getNode(a.target)) { Node.expr |e| => switch (e) {
                Expr.field_access |fa| => {
                    self.lowerFieldAssign(fa, a, is_compound)
                    return
                },
                Expr.index_expr |ie| => {
                    self.lowerIndexAssign(ie, a, is_compound)
                    return
                },
                Expr.deref |dr| => {
                    const ptr_val = self.lowerExprNode(dr.operand)
                    const val = self.lowerExprNode(a.value)
                    if (ptr_val != null_node and val != null_node) {
                        fb.emitPtrStoreValue(ptr_val, val, a.span)
                    }
                    return
                },
                else => {},
            }, else => {} }
        }
    }

    fn lowerFieldAssign(fa: FieldAccessExpr, a: AssignStmt, is_compound: bool) void {
        const fb = self.builder.func() orelse return null_node
        const base_type = self.inferExprType(fa.base)
        const type_info = self.types.get(base_type)

        // Pointer-to-struct field assignment
        if (type_info.tag == TAG_POINTER) {
            const pointee_type = switch (type_info) { Type.pointer |p| => p.elem, else => VOID }
            const pointee_info = self.types.get(pointee_type)
            if (pointee_info.tag == TAG_STRUCT) {
                const field_idx = self.findStructFieldIdx(pointee_type, fa.field)
                if (field_idx >= 0) {
                    if (self.getStructField(pointee_type, field_idx)) |field| {
                        if (self.extractIdentName(fa.base)) |base_name| {
                            if (fb.lookupLocal(base_name)) |local_idx| {
                                if (is_compound) {
                                    const old_val = fb.emitPtrField(local_idx, field_idx, field.offset, field.type_idx, a.span)
                                    const rhs = self.lowerExprNode(a.value)
                                    if (rhs == null_node) { return }
                                    const op = tokenToBinaryOp(a.op)
                                    const result = fb.emitBinary(op, old_val, rhs, field.type_idx, a.span)
                                    fb.emitPtrFieldStore(local_idx, field_idx, field.offset, result, a.span)
                                } else {
                                    const val = self.lowerExprNode(a.value)
                                    if (val == null_node) { return }
                                    fb.emitPtrFieldStore(local_idx, field_idx, field.offset, val, a.span)
                                }
                                return
                            }
                        }

                        // Expression base
                        const base_ptr = self.lowerExprNode(fa.base)
                        if (base_ptr == null_node) { return }
                        const offset_val = fb.emitConstInt(field.offset, I64, a.span)
                        const field_addr = fb.emitBinary(BinaryOp.add, base_ptr, offset_val, I64, a.span)
                        const val = self.lowerExprNode(a.value)
                        if (val != null_node) {
                            fb.emitPtrStoreValue(field_addr, val, a.span)
                        }
                    }
                }
                return
            }
        }

        // Direct struct field assignment (value type in local)
        if (type_info.tag == TAG_STRUCT) {
            const field_idx = self.findStructFieldIdx(base_type, fa.field)
            if (field_idx >= 0) {
                if (self.getStructField(base_type, field_idx)) |field| {
                    if (self.extractIdentName(fa.base)) |base_name| {
                        if (fb.lookupLocal(base_name)) |local_idx| {
                            if (is_compound) {
                                const old_val = fb.emitFieldLocal(local_idx, field_idx, field.offset, field.type_idx, a.span)
                                const rhs = self.lowerExprNode(a.value)
                                if (rhs == null_node) { return }
                                const op = tokenToBinaryOp(a.op)
                                const result = fb.emitBinary(op, old_val, rhs, field.type_idx, a.span)
                                fb.emitStoreLocalField(local_idx, field_idx, field.offset, result, a.span)
                            } else {
                                const val = self.lowerExprNode(a.value)
                                if (val == null_node) { return }
                                fb.emitStoreLocalField(local_idx, field_idx, field.offset, val, a.span)
                            }
                            return
                        }
                    }
                }
            }
        }
    }

    fn lowerIndexAssign(ie: IndexExpr, a: AssignStmt, is_compound: bool) void {
        const fb = self.builder.func() orelse return null_node
        const base_type = self.inferExprType(ie.base)
        const type_info = self.types.get(base_type)

        var elem_type = I64
        if (type_info.tag == TAG_ARRAY) {
            switch (type_info) { Type.array |arr| => { elem_type = arr.elem }, else => {} }
        } else if (type_info.tag == TAG_SLICE) {
            switch (type_info) { Type.slice |s| => { elem_type = s.elem }, else => {} }
        }
        const elem_size = self.types.sizeOf(elem_type)

        const index = self.lowerExprNode(ie.idx)
        if (index == null_node) { return }

        // Check if base is local ident
        if (self.extractIdentName(ie.base)) |base_name| {
            if (fb.lookupLocal(base_name)) |local_idx| {
                if (is_compound) {
                    const old_val = fb.emitIndexLocal(local_idx, index, elem_size, elem_type, a.span)
                    const rhs = self.lowerExprNode(a.value)
                    if (rhs == null_node) { return }
                    const op = tokenToBinaryOp(a.op)
                    const result = fb.emitBinary(op, old_val, rhs, elem_type, a.span)
                    fb.emitStoreIndexLocal(local_idx, index, result, elem_size, a.span)
                } else {
                    const val = self.lowerExprNode(a.value)
                    if (val == null_node) { return }
                    fb.emitStoreIndexLocal(local_idx, index, val, elem_size, a.span)
                }
                return
            }
        }

        // Expression base
        const base = self.lowerExprNode(ie.base)
        if (base == null_node) { return }
        const val = self.lowerExprNode(a.value)
        if (val == null_node) { return }
        fb.emitStoreIndexValue(base, index, val, elem_size, a.span)
    }

    fn lowerIf(i: IfStmt) bool {
        if (self.builder.func()) |fb| {
            // Optional capture: if (expr) |val| { ... }
            if (i.capture != "") {
                return self.lowerIfOptional(i)
            }

            const cond = self.lowerExprNode(i.condition)
            if (cond == null_node) { return false }

            const then_block = fb.newBlock("if.then")
            const merge_block = fb.newBlock("if.end")

            // Only create else block if there's an else branch;
            // otherwise branch directly to merge (matches Zig compiler)
            if (i.else_branch != null_node) {
                const else_block = fb.newBlock("if.else")
                fb.emitBranch(cond, then_block, else_block, i.span)

                fb.setBlock(then_block)
                const then_terminated = self.lowerBlockNode(i.then_branch)
                if (!then_terminated) {
                    fb.emitJump(merge_block, i.span)
                }

                fb.setBlock(else_block)
                const else_terminated = self.lowerBlockNode(i.else_branch)
                if (!else_terminated) {
                    fb.emitJump(merge_block, i.span)
                }
                if (then_terminated and else_terminated) {
                    return true
                }
            } else {
                fb.emitBranch(cond, then_block, merge_block, i.span)

                fb.setBlock(then_block)
                const then_terminated = self.lowerBlockNode(i.then_branch)
                if (!then_terminated) {
                    fb.emitJump(merge_block, i.span)
                }
            }

            fb.setBlock(merge_block)
        }
        return false
    }

    /// Lower if-statement with optional capture: if (opt) |val| { ... }
    fn lowerIfOptional(i: IfStmt) bool {
        const fb = self.builder.func() orelse return false
        const opt_type_idx = self.inferExprType(i.condition)
        const opt_info = self.types.get(opt_type_idx)
        var elem_type = opt_type_idx
        switch (opt_info) { Type.optional |opt| => { elem_type = opt.elem }, else => {} }
        const is_compound_opt = (opt_info.tag == TAG_OPTIONAL and !self.isPtrLikeOptional(opt_type_idx))

        if (i.capture_is_ptr) {
            // Pointer capture: resolve address of condition
            const opt_addr = self.resolveConditionAddr(i.condition, opt_type_idx, i.span)
            if (opt_addr == null_node) { return false }

            // Check non-null from address
            var is_non_null = null_node
            if (is_compound_opt) {
                const tag = fb.emitPtrLoadValue(opt_addr, I64, i.span)
                const zero = fb.emitConstInt(0, I64, i.span)
                is_non_null = fb.emitBinary(BinaryOp.ne, tag, zero, BOOL, i.span)
            } else {
                const val = fb.emitPtrLoadValue(opt_addr, elem_type, i.span)
                const null_val = fb.emitConstNull(I64, i.span)
                is_non_null = fb.emitBinary(BinaryOp.ne, val, null_val, BOOL, i.span)
            }

            const then_block = fb.newBlock("if.opt.then")
            var else_block = null_block
            if (i.else_branch != null_node) { else_block = fb.newBlock("if.opt.else") }
            const merge_block = fb.newBlock("if.opt.end")
            var target_else = merge_block
            if (else_block != null_block) { target_else = else_block }
            fb.emitBranch(is_non_null, then_block, target_else, i.span)

            // Then block: bind capture to payload address
            fb.setBlock(then_block)
            const scope_depth = fb.markScopeEntry()
            const ptr_type = self.types.makePointer(elem_type)
            var payload_addr = opt_addr
            if (is_compound_opt) {
                payload_addr = fb.emitAddrOffset(opt_addr, 8, ptr_type, i.span)
            }
            const capture_local = fb.addLocalWithSize(i.capture, ptr_type, false, 8)
            fb.emitStoreLocal(capture_local, payload_addr, i.span)
            const then_t = self.lowerBlockNode(i.then_branch)
            if (!then_t) { fb.emitJump(merge_block, i.span) }
            fb.restoreScope(scope_depth)

            if (else_block != null_block) {
                fb.setBlock(else_block)
                const else_t = self.lowerBlockNode(i.else_branch)
                if (!else_t) { fb.emitJump(merge_block, i.span) }
            }

            fb.setBlock(merge_block)
            return false
        }

        // Value capture
        const opt_val = self.lowerExprNode(i.condition)
        if (opt_val == null_node) { return false }

        const is_gc_ref_opt = self.isGcRefOptional(opt_type_idx)
        var is_non_null = null_node
        if (is_compound_opt) {
            const opt_local = fb.addLocalWithSize("__opt_if", opt_type_idx, false, self.types.sizeOf(opt_type_idx))
            fb.emitStoreLocal(opt_local, opt_val, i.span)
            const tag = fb.emitFieldLocal(opt_local, 0, 0, I64, i.span)
            const zero = fb.emitConstInt(0, I64, i.span)
            is_non_null = fb.emitBinary(BinaryOp.ne, tag, zero, BOOL, i.span)
        } else if (is_gc_ref_opt) {
            // WasmGC nullable ref: ref.is_null + not
            const is_null = fb.emitGcRefIsNull(opt_val, i.span)
            is_non_null = fb.emitUnary(UnaryOp.@"not", is_null, BOOL, i.span)
        } else {
            const null_val = fb.emitConstNull(I64, i.span)
            is_non_null = fb.emitBinary(BinaryOp.ne, opt_val, null_val, BOOL, i.span)
        }

        const then_block = fb.newBlock("if.opt.then")
        var else_block = null_block
        if (i.else_branch != null_node) { else_block = fb.newBlock("if.opt.else") }
        const merge_block = fb.newBlock("if.opt.end")
        var target_else = merge_block
        if (else_block != null_block) { target_else = else_block }
        fb.emitBranch(is_non_null, then_block, target_else, i.span)

        // Then block: unwrap and bind capture
        fb.setBlock(then_block)
        const scope_depth = fb.markScopeEntry()
        var unwrapped = opt_val
        if (is_compound_opt) {
            if (fb.lookupLocal("__opt_if")) |opt_local| {
                unwrapped = fb.emitFieldLocal(opt_local, 1, 8, elem_type, i.span)
            }
        }
        const capture_local = fb.addLocalWithSize(i.capture, elem_type, false, self.types.sizeOf(elem_type))
        fb.emitStoreLocal(capture_local, unwrapped, i.span)
        const then_t = self.lowerBlockNode(i.then_branch)
        if (!then_t) { fb.emitJump(merge_block, i.span) }
        fb.restoreScope(scope_depth)

        if (else_block != null_block) {
            fb.setBlock(else_block)
            const else_t = self.lowerBlockNode(i.else_branch)
            if (!else_t) { fb.emitJump(merge_block, i.span) }
        }

        fb.setBlock(merge_block)
        return false
    }

    /// Resolve condition to an address (for pointer capture).
    fn resolveConditionAddr(condition: int, opt_type_idx: int, span: Span) int {
        const fb = self.builder.func() orelse return null_node
        const node = self.tree.getNode(condition)
        switch (node) { Node.expr |e| => switch (e) {
            Expr.ident |id| => {
                if (fb.lookupLocal(id.name)) |local_idx| {
                    const ptr_type = self.types.makePointer(opt_type_idx)
                    return fb.emitAddrLocal(local_idx, ptr_type, span)
                }
            },
            Expr.field_access |fa| => {
                // Get address of the field
                const base_type = self.inferExprType(fa.base)
                const base_info = self.types.get(base_type)
                if (base_info.tag == TAG_POINTER) {
                    const base = self.lowerExprNode(fa.base)
                    if (base != null_node) {
                        const pointee = switch (base_info) { Type.pointer |p| => p.elem, else => VOID }
                        const field_idx = self.findStructFieldIdx(pointee, fa.field)
                        if (field_idx >= 0) {
                            if (self.getStructField(pointee, field_idx)) |field| {
                                const ptr_type = self.types.makePointer(field.type_idx)
                                return fb.emitAddrOffset(base, field.offset, ptr_type, span)
                            }
                        }
                    }
                }
            },
            else => {},
        }, else => {} }
        return null_node
    }

    fn lowerWhile(w: WhileStmt) void {
        // Optional capture: while (expr) |val| { ... }
        if (w.capture != "") {
            self.lowerWhileOptional(w)
            return
        }
        if (self.builder.func()) |fb| {
            const cond_block = fb.newBlock("while.cond")
            const body_block = fb.newBlock("while.body")
            const exit_block = fb.newBlock("while.end")
            var cont_block = cond_block
            if (w.continue_expr != null_node) { cont_block = fb.newBlock("while.cont") }

            fb.emitJump(cond_block, w.span)
            fb.setBlock(cond_block)

            const cond = self.lowerExprNode(w.condition)
            if (cond != null_node) {
                fb.emitBranch(cond, body_block, exit_block, w.span)
            }

            self.loop_stack.append(LoopContext {
                cond_block: cont_block,
                exit_block: exit_block,
                cleanup_depth: self.cleanup_stack.count,
                label: w.label,
            })

            fb.setBlock(body_block)
            const body_terminated = self.lowerBlockNode(w.body)
            if (!body_terminated) {
                fb.emitJump(cont_block, w.span)
            }

            // Continue expression block
            if (w.continue_expr != null_node) {
                fb.setBlock(cont_block)
                self.lowerContinueExpr(w.continue_expr)
                fb.emitJump(cond_block, w.span)
            }

            self.loop_stack.pop()
            fb.setBlock(exit_block)
        }
    }

    /// Lower while-optional: while (expr) |val| { ... }
    fn lowerWhileOptional(w: WhileStmt) void {
        if (self.builder.func()) |fb| {
            const cond_block = fb.newBlock("while.opt.cond")
            const body_block = fb.newBlock("while.opt.body")
            const exit_block = fb.newBlock("while.opt.end")
            var cont_block = cond_block
            if (w.continue_expr != null_node) { cont_block = fb.newBlock("while.opt.cont") }

            const opt_type_idx = self.inferExprType(w.condition)
            const opt_info = self.types.get(opt_type_idx)
            var elem_type = opt_type_idx
            switch (opt_info) { Type.optional |opt| => { elem_type = opt.elem }, else => {} }
            const is_compound_opt = (opt_info.tag == TAG_OPTIONAL and !self.isPtrLikeOptional(opt_type_idx))

            if (w.capture_is_ptr) {
                // Pointer capture
                const opt_addr = self.resolveConditionAddr(w.condition, opt_type_idx, w.span)
                if (opt_addr == null_node) { return }

                fb.emitJump(cond_block, w.span)
                fb.setBlock(cond_block)

                var is_non_null = null_node
                if (is_compound_opt) {
                    const tag = fb.emitPtrLoadValue(opt_addr, I64, w.span)
                    const zero = fb.emitConstInt(0, I64, w.span)
                    is_non_null = fb.emitBinary(BinaryOp.ne, tag, zero, BOOL, w.span)
                } else {
                    const val = fb.emitPtrLoadValue(opt_addr, elem_type, w.span)
                    const null_val = fb.emitConstNull(I64, w.span)
                    is_non_null = fb.emitBinary(BinaryOp.ne, val, null_val, BOOL, w.span)
                }
                fb.emitBranch(is_non_null, body_block, exit_block, w.span)

                self.loop_stack.append(LoopContext {
                    cond_block: cont_block, exit_block: exit_block,
                    cleanup_depth: self.cleanup_stack.count, label: w.label,
                })
                fb.setBlock(body_block)
                const scope_depth = fb.markScopeEntry()
                const ptr_type = self.types.makePointer(elem_type)
                var payload_addr = opt_addr
                if (is_compound_opt) {
                    payload_addr = fb.emitAddrOffset(opt_addr, 8, ptr_type, w.span)
                }
                const capture_local = fb.addLocalWithSize(w.capture, ptr_type, false, 8)
                fb.emitStoreLocal(capture_local, payload_addr, w.span)
                const body_t = self.lowerBlockNode(w.body)
                if (!body_t) { fb.emitJump(cont_block, w.span) }
                fb.restoreScope(scope_depth)

                if (w.continue_expr != null_node) {
                    fb.setBlock(cont_block)
                    self.lowerContinueExpr(w.continue_expr)
                    fb.emitJump(cond_block, w.span)
                }
                self.loop_stack.pop()
                fb.setBlock(exit_block)
                return
            }

            // Value capture
            const opt_local = fb.addLocalWithSize("__while_opt", opt_type_idx, true, self.types.sizeOf(opt_type_idx))

            fb.emitJump(cond_block, w.span)
            fb.setBlock(cond_block)

            const opt_val = self.lowerExprNode(w.condition)
            if (opt_val == null_node) { return }
            fb.emitStoreLocal(opt_local, opt_val, w.span)

            var is_non_null = null_node
            if (is_compound_opt) {
                const tag = fb.emitFieldLocal(opt_local, 0, 0, I64, w.span)
                const zero = fb.emitConstInt(0, I64, w.span)
                is_non_null = fb.emitBinary(BinaryOp.ne, tag, zero, BOOL, w.span)
            } else {
                const null_val = fb.emitConstNull(I64, w.span)
                is_non_null = fb.emitBinary(BinaryOp.ne, opt_val, null_val, BOOL, w.span)
            }
            fb.emitBranch(is_non_null, body_block, exit_block, w.span)

            self.loop_stack.append(LoopContext {
                cond_block: cont_block, exit_block: exit_block,
                cleanup_depth: self.cleanup_stack.count, label: w.label,
            })
            fb.setBlock(body_block)
            const scope_depth = fb.markScopeEntry()
            var unwrapped = opt_val
            if (is_compound_opt) {
                unwrapped = fb.emitFieldLocal(opt_local, 1, 8, elem_type, w.span)
            }
            const capture_local = fb.addLocalWithSize(w.capture, elem_type, false, self.types.sizeOf(elem_type))
            fb.emitStoreLocal(capture_local, unwrapped, w.span)
            const body_t = self.lowerBlockNode(w.body)
            if (!body_t) { fb.emitJump(cont_block, w.span) }
            fb.restoreScope(scope_depth)

            if (w.continue_expr != null_node) {
                fb.setBlock(cont_block)
                self.lowerContinueExpr(w.continue_expr)
                fb.emitJump(cond_block, w.span)
            }
            self.loop_stack.pop()
            fb.setBlock(exit_block)
        }
    }

    /// Lower a continue expression (assignment or expression)
    fn lowerContinueExpr(node_idx: int) void {
        const node = self.tree.getNode(node_idx)
        switch (node) {
            Node.stmt |s| => { self.lowerStmt(s) },
            Node.expr |_| => { self.lowerExprNode(node_idx) },
            else => {},
        }
    }

    fn lowerFor(f: ForStmt) void {
        if (self.builder.func()) |fb| {
            // Inline for — compile-time unroll
            if (f.is_inline) {
                self.lowerInlineFor(f)
                return
            }

            if (isRange(f)) {
                self.lowerForRange(f)
                return
            }

            const iter_type = self.inferExprType(f.iterable)
            const iter_info = self.types.get(iter_type)

            // Map iteration
            if (iter_info.tag == TAG_MAP) {
                switch (iter_info) {
                    Type.map_type |mt| => { self.lowerForMap(f, iter_type, mt) },
                    else => {},
                }
                return
            }

            // Array or slice iteration
            var elem_type = VOID
            var is_array = false
            var is_slice = false
            var array_length = 0
            switch (iter_info) {
                Type.array |a| => { elem_type = a.elem; is_array = true; array_length = a.length },
                Type.slice |s| => { elem_type = s.elem; is_slice = true },
                else => { return },
            }
            const elem_size = self.types.sizeOf(elem_type)

            // Index counter
            const idx_local = fb.addLocalWithSize("__for_idx", I64, true, 8)
            const zero = fb.emitConstInt(0, I64, f.span)
            fb.emitStoreLocal(idx_local, zero, f.span)

            // Length
            const len_local = fb.addLocalWithSize("__for_len", I64, false, 8)
            if (is_array) {
                const len_val = fb.emitConstInt(array_length, I64, f.span)
                fb.emitStoreLocal(len_local, len_val, f.span)
            } else if (is_slice) {
                // Get slice from iterable ident
                var slice_name = ""
                switch (self.tree.getNode(f.iterable)) { Node.expr |e| => switch (e) {
                    Expr.ident |id| => { slice_name = id.name },
                    else => {},
                }, else => {} }
                if (slice_name != "") {
                    if (fb.lookupLocal(slice_name)) |slice_local| {
                        const slice_val = fb.emitLoadLocal(slice_local, iter_type, f.span)
                        const len_val = fb.emitSliceLen(slice_val, f.span)
                        fb.emitStoreLocal(len_local, len_val, f.span)
                    }
                }
            }

            const cond_block = fb.newBlock("for.cond")
            const body_block = fb.newBlock("for.body")
            const incr_block = fb.newBlock("for.incr")
            const exit_block = fb.newBlock("for.end")

            fb.emitJump(cond_block, f.span)
            fb.setBlock(cond_block)
            const idx_val = fb.emitLoadLocal(idx_local, I64, f.span)
            const len_val_cond = fb.emitLoadLocal(len_local, I64, f.span)
            const cond = fb.emitBinary(BinaryOp.lt, idx_val, len_val_cond, BOOL, f.span)
            fb.emitBranch(cond, body_block, exit_block, f.span)

            self.loop_stack.append(LoopContext {
                cond_block: incr_block,
                exit_block: exit_block,
                cleanup_depth: self.cleanup_stack.count,
                label: f.label,
            })

            fb.setBlock(body_block)
            const binding_local = fb.addLocalWithSize(f.binding, elem_type, false, elem_size)
            const cur_idx = fb.emitLoadLocal(idx_local, I64, f.span)

            // Bind index variable if present
            if (f.index_binding != "") {
                const idx_binding_local = fb.addLocalWithSize(f.index_binding, I64, false, 8)
                fb.emitStoreLocal(idx_binding_local, cur_idx, f.span)
            }

            // Load element
            if (is_array) {
                var arr_name = ""
                switch (self.tree.getNode(f.iterable)) { Node.expr |e| => switch (e) {
                    Expr.ident |id| => { arr_name = id.name },
                    else => {},
                }, else => {} }
                if (arr_name != "") {
                    if (fb.lookupLocal(arr_name)) |arr_local| {
                        const elem_val = fb.emitIndexLocal(arr_local, cur_idx, elem_size, elem_type, f.span)
                        fb.emitStoreLocal(binding_local, elem_val, f.span)
                    }
                }
            } else if (is_slice) {
                var slice_name = ""
                switch (self.tree.getNode(f.iterable)) { Node.expr |e| => switch (e) {
                    Expr.ident |id| => { slice_name = id.name },
                    else => {},
                }, else => {} }
                if (slice_name != "") {
                    if (fb.lookupLocal(slice_name)) |slice_local| {
                        const slice_val = fb.emitLoadLocal(slice_local, iter_type, f.span)
                        const ptr_type = self.types.makePointer(elem_type)
                        const ptr_val = fb.emitSlicePtr(slice_val, ptr_type, f.span)
                        const elem_val = fb.emitIndexValue(ptr_val, cur_idx, elem_size, elem_type, f.span)
                        fb.emitStoreLocal(binding_local, elem_val, f.span)
                    }
                }
            }

            const body_t = self.lowerBlockNode(f.body)
            if (!body_t) { fb.emitJump(incr_block, f.span) }

            // Increment
            fb.setBlock(incr_block)
            const idx_before = fb.emitLoadLocal(idx_local, I64, f.span)
            const one = fb.emitConstInt(1, I64, f.span)
            const idx_after = fb.emitBinary(BinaryOp.add, idx_before, one, I64, f.span)
            fb.emitStoreLocal(idx_local, idx_after, f.span)
            fb.emitJump(cond_block, f.span)

            self.loop_stack.pop()
            fb.setBlock(exit_block)
        }
    }

    /// Lower numeric range for loop: for i in start..end
    fn lowerForRange(f: ForStmt) void {
        const fb = self.builder.func() orelse return null_node
        const start_val = self.lowerExprNode(f.range_start)
        const end_val = self.lowerExprNode(f.range_end)
        if (start_val == null_node or end_val == null_node) { return }

        const idx_local = fb.addLocalWithSize(f.binding, I64, true, 8)
        fb.emitStoreLocal(idx_local, start_val, f.span)

        // Store end in a local
        const end_local = fb.addLocalWithSize("__for_end", I64, false, 8)
        fb.emitStoreLocal(end_local, end_val, f.span)

        const cond_block = fb.newBlock("for.cond")
        const body_block = fb.newBlock("for.body")
        const incr_block = fb.newBlock("for.incr")
        const exit_block = fb.newBlock("for.end")

        fb.emitJump(cond_block, f.span)
        fb.setBlock(cond_block)
        const idx_val = fb.emitLoadLocal(idx_local, I64, f.span)
        const end_val_cond = fb.emitLoadLocal(end_local, I64, f.span)
        const cond = fb.emitBinary(BinaryOp.lt, idx_val, end_val_cond, BOOL, f.span)
        fb.emitBranch(cond, body_block, exit_block, f.span)

        self.loop_stack.append(LoopContext {
            cond_block: incr_block,
            exit_block: exit_block,
            cleanup_depth: self.cleanup_stack.count,
            label: f.label,
        })

        fb.setBlock(body_block)
        const body_t = self.lowerBlockNode(f.body)
        if (!body_t) { fb.emitJump(incr_block, f.span) }

        fb.setBlock(incr_block)
        const idx_before = fb.emitLoadLocal(idx_local, I64, f.span)
        const one = fb.emitConstInt(1, I64, f.span)
        const idx_after = fb.emitBinary(BinaryOp.add, idx_before, one, I64, f.span)
        fb.emitStoreLocal(idx_local, idx_after, f.span)
        fb.emitJump(cond_block, f.span)

        self.loop_stack.pop()
        fb.setBlock(exit_block)
    }

    /// Inline for — compile-time loop unrolling.
    /// Ref: lower.zig:3791-3817
    fn lowerInlineFor(f: ForStmt) void {
        // Range case: eval bounds at compile time, emit body N times
        if (isRange(f)) {
            const start_val = self.evalConstInt(f.range_start)
            const end_val = self.evalConstInt(f.range_end)
            if (start_val == null or end_val == null) { return }
            var i = start_val.?
            while (i < end_val.?) {
                self.const_values.set(f.binding, i)
                self.lowerBlockNode(f.body)
                i = i + 1
            }
            self.const_values.remove(f.binding)
            return
        }
        // Comptime array iteration — deferred until comptime evaluation is ported
    }

    /// Try to evaluate an expression as a compile-time constant integer.
    fn evalConstInt(idx: int) ?int {
        if (idx == null_node) { return null }
        switch (self.tree.getNode(idx)) { Node.expr |e| => switch (e) {
            Expr.literal |l| => {
                if (l.kind == LiteralKind.@"int") {
                    return parseIntLit(l.value)
                }
            },
            Expr.ident |id| => {
                if (self.const_values.contains(id.name)) {
                    return self.const_values.get(id.name)
                }
                // Check checker's const symbols
                if (self.chk.lookupSymbol(id.name)) |sym| {
                    if (sym.is_const_val) { return sym.const_value }
                }
            },
            else => {},
        }, else => {} }
        return null
    }

    /// Lower `for k, v in map { }` — iterates occupied slots in hash table.
    /// Map struct layout: keys(0), values(8), states(16), count(24), capacity(32).
    /// States: 0=empty, 1=occupied, 2=tombstone.
    /// Ref: lower.zig:3886-4011
    fn lowerForMap(f: ForStmt, iter_type: int, map_info: CotMapType) void {
        const fb = self.builder.func() orelse return null_node
        const key_type = map_info.key
        const val_type = map_info.value
        const key_size = self.types.sizeOf(key_type)
        const val_size = self.types.sizeOf(val_type)

        // Get the map local
        var map_name = ""
        switch (self.tree.getNode(f.iterable)) { Node.expr |e| => switch (e) {
            Expr.ident |id| => { map_name = id.name },
            else => {},
        }, else => {} }
        if (map_name == "") { return }
        const map_local_opt = fb.lookupLocal(map_name)
        if (map_local_opt == null) { return }
        const map_local = map_local_opt.?

        // Read map fields into locals BEFORE the loop
        const idx_name = "__map_idx_" ++ intToString(self.temp_counter)
        self.temp_counter = self.temp_counter + 1
        const idx_local = fb.addLocalWithSize(idx_name, I64, true, 8)
        const zero = fb.emitConstInt(0, I64, f.span)
        fb.emitStoreLocal(idx_local, zero, f.span)

        // Read capacity
        const cap_name = "__map_cap_" ++ intToString(self.temp_counter)
        self.temp_counter = self.temp_counter + 1
        const cap_local = fb.addLocalWithSize(cap_name, I64, false, 8)
        const cap_field = fb.emitFieldLocal(map_local, 4, 32, I64, f.span)
        fb.emitStoreLocal(cap_local, cap_field, f.span)

        // Read keys/values/states pointers
        const keys_name = "__map_keys_" ++ intToString(self.temp_counter)
        self.temp_counter = self.temp_counter + 1
        const keys_local = fb.addLocalWithSize(keys_name, I64, false, 8)
        const keys_field = fb.emitFieldLocal(map_local, 0, 0, I64, f.span)
        fb.emitStoreLocal(keys_local, keys_field, f.span)

        const vals_name = "__map_vals_" ++ intToString(self.temp_counter)
        self.temp_counter = self.temp_counter + 1
        const vals_local = fb.addLocalWithSize(vals_name, I64, false, 8)
        const vals_field = fb.emitFieldLocal(map_local, 1, 8, I64, f.span)
        fb.emitStoreLocal(vals_local, vals_field, f.span)

        const states_name = "__map_states_" ++ intToString(self.temp_counter)
        self.temp_counter = self.temp_counter + 1
        const states_local = fb.addLocalWithSize(states_name, I64, false, 8)
        const states_field = fb.emitFieldLocal(map_local, 2, 16, I64, f.span)
        fb.emitStoreLocal(states_local, states_field, f.span)

        // Create loop blocks
        const cond_block = fb.newBlock("map.cond")
        const body_block = fb.newBlock("map.body")
        const incr_block = fb.newBlock("map.incr")
        const exit_block = fb.newBlock("map.end")

        fb.emitJump(cond_block, f.span)

        // Condition: idx < capacity
        fb.setBlock(cond_block)
        const idx_cond = fb.emitLoadLocal(idx_local, I64, f.span)
        const cap_cond = fb.emitLoadLocal(cap_local, I64, f.span)
        const cond = fb.emitBinary(BinaryOp.lt, idx_cond, cap_cond, BOOL, f.span)
        fb.emitBranch(cond, body_block, exit_block, f.span)

        // Push loop context
        self.loop_stack.append(LoopContext {
            cond_block: incr_block,
            exit_block: exit_block,
            cleanup_depth: self.cleanup_stack.count,
            label: f.label,
        })

        // Body: check state[idx] == 1 (occupied)
        fb.setBlock(body_block)
        const cur_idx = fb.emitLoadLocal(idx_local, I64, f.span)

        const states_base = fb.emitLoadLocal(states_local, I64, f.span)
        const state_val = fb.emitIndexValue(states_base, cur_idx, 8, I64, f.span)
        const one = fb.emitConstInt(1, I64, f.span)
        const is_occupied = fb.emitBinary(BinaryOp.eq, state_val, one, BOOL, f.span)

        const occupied_block = fb.newBlock("map.occupied")
        fb.emitBranch(is_occupied, occupied_block, incr_block, f.span)

        // Occupied block: load key and value, execute body
        fb.setBlock(occupied_block)
        const idx_load = fb.emitLoadLocal(idx_local, I64, f.span)

        // Load key and value
        const keys_base = fb.emitLoadLocal(keys_local, I64, f.span)
        const key_val = fb.emitIndexValue(keys_base, idx_load, key_size, key_type, f.span)
        const vals_base = fb.emitLoadLocal(vals_local, I64, f.span)
        const val_val = fb.emitIndexValue(vals_base, idx_load, val_size, val_type, f.span)

        // Bind value (binding = second name = value)
        const val_local = fb.addLocalWithSize(f.binding, val_type, false, val_size)
        fb.emitStoreLocal(val_local, val_val, f.span)

        // Bind key (index_binding = first name = key)
        if (f.index_binding != "") {
            const key_local = fb.addLocalWithSize(f.index_binding, key_type, false, key_size)
            fb.emitStoreLocal(key_local, key_val, f.span)
        }

        // Execute loop body
        const body_t = self.lowerBlockNode(f.body)
        if (!body_t) { fb.emitJump(incr_block, f.span) }

        // Increment: idx += 1
        fb.setBlock(incr_block)
        const idx_before = fb.emitLoadLocal(idx_local, I64, f.span)
        const inc = fb.emitConstInt(1, I64, f.span)
        const idx_after = fb.emitBinary(BinaryOp.add, idx_before, inc, I64, f.span)
        fb.emitStoreLocal(idx_local, idx_after, f.span)
        fb.emitJump(cond_block, f.span)

        // Exit
        self.loop_stack.pop()
        fb.setBlock(exit_block)
    }

    fn lowerBreak(label: string, value: int) void {
        if (self.builder.func()) |fb| {
            // Check labeled block stack first (break :label value)
            if (label != "") {
                var bi = self.labeled_block_stack.count - 1
                while (bi >= 0) {
                    const blk_ctx = self.labeled_block_stack.get(bi)
                    if (blk_ctx.label == label) {
                        // Store value to result local, then jump to exit block
                        if (value != null_node) {
                            const val = self.lowerExprNode(value)
                            if (val != null_node) {
                                fb.emitStoreLocal(blk_ctx.result_local, val, Span.zero())
                            }
                        }
                        self.emitCleanupsNoPop(blk_ctx.cleanup_depth)
                        fb.emitJump(blk_ctx.exit_block, Span.zero())
                        return
                    }
                    bi = bi - 1
                }
            }

            // Fall through to loop break handling
            if (self.loop_stack.count == 0) { return }
            // Find matching loop context
            var i = self.loop_stack.count - 1
            while (i >= 0) {
                const ctx = self.loop_stack.get(i)
                if (label == "" or label == ctx.label) {
                    // Emit cleanups without popping — other paths still need them
                    self.emitCleanupsNoPop(ctx.cleanup_depth)
                    fb.emitJump(ctx.exit_block, Span.zero())
                    return
                }
                i = i - 1
            }
        }
    }

    fn lowerContinue(label: string) void {
        if (self.builder.func()) |fb| {
            if (self.loop_stack.count == 0) { return }
            var i = self.loop_stack.count - 1
            while (i >= 0) {
                const ctx = self.loop_stack.get(i)
                if (label == "" or label == ctx.label) {
                    self.emitCleanupsNoPop(ctx.cleanup_depth)
                    fb.emitJump(ctx.cond_block, Span.zero())
                    return
                }
                i = i - 1
            }
        }
    }

    fn lowerDestructureStmt(ds: DestructureStmt) void {
        if (self.builder.func()) |fb| {
            // Lower the value being destructured
            const value = self.lowerExprNode(ds.value)
            if (value == null_node) { return }

            const value_type = self.inferExprType(ds.value)
            const type_info = self.types.get(value_type)

            // Store value in a temp local so we can extract fields
            const tmp = fb.addLocalWithSize("__destruct", value_type, false, self.types.sizeOf(value_type))
            fb.emitStoreLocal(tmp, value, ds.span)

            // Bind each destructured name to the corresponding field
            for i in 0..ds.bindings.count {
                const binding_idx = ds.bindings.get(i)
                const binding_node = self.tree.getNode(binding_idx)
                var bind_name = ""
                switch (binding_node) { Node.expr |e| => switch (e) {
                    Expr.ident |id| => { bind_name = id.name },
                    else => {},
                }, else => {} }
                if (bind_name == "" or bind_name == "_") { continue }

                // Determine field type and offset
                var field_type = I64
                var field_offset = i * 8
                switch (type_info) {
                    Type.tuple |t| => {
                        if (i < t.elem_count) {
                            field_type = t.getElemType(i)
                            // Compute offset: sum sizes of preceding elements
                            field_offset = 0
                            for fi in 0..i {
                                field_offset = field_offset + self.types.sizeOf(t.getElemType(fi))
                            }
                        }
                    },
                    Type.struct_type |st| => {
                        if (i < st.field_count) {
                            const f = st.getField(i)
                            field_type = f.type_idx
                            field_offset = f.offset
                        }
                    },
                    else => {},
                }

                const field_val = fb.emitFieldLocal(tmp, i, field_offset, field_type, ds.span)
                const bind_local = fb.addLocalWithSize(bind_name, field_type, !ds.is_const, self.types.sizeOf(field_type))
                fb.emitStoreLocal(bind_local, field_val, ds.span)
            }
        }
    }

    // ========================================================================
    // Expression lowering
    // ========================================================================

    /// Lower an expression AST node to an IR node index.
    fn lowerExprNode(idx: int) int {
        if (idx == null_node) { return null_node }
        const node = self.tree.getNode(idx)
        const maybe_expr = asExpr(node)
        if (maybe_expr) |e| { return self.lowerExpr(e, idx) }
        return null_node
    }

    /// Lower an expression variant to IR. Returns IR node index.
    fn lowerExpr(expr: Expr, idx: int) int {
        if (self.builder.func()) |fb| {
            switch (expr) {
                Expr.literal |lit| => { return self.lowerLiteral(lit, idx) },
                Expr.ident |id| => { return self.lowerIdent(id) },
                Expr.binary |bin| => { return self.lowerBinary(bin, idx) },
                Expr.unary |un| => { return self.lowerUnary(un, idx) },
                Expr.paren |p| => { return self.lowerExprNode(p.inner) },
                Expr.call |c| => { return self.lowerCall(c, idx) },
                Expr.field_access |fa| => { return self.lowerFieldAccess(fa, idx) },
                Expr.index_expr |ie| => { return self.lowerIndex(ie, idx) },
                Expr.struct_init |si| => { return self.lowerStructInit(si, idx) },
                Expr.if_expr |ie| => { return self.lowerIfExpr(ie, idx) },
                Expr.block_expr |be| => { return self.lowerBlockExpr(be) },
                Expr.addr_of |ao| => { return self.lowerAddrOf(ao, idx) },
                Expr.deref |dr| => { return self.lowerDeref(dr, idx) },
                Expr.slice_expr |se| => { return self.lowerSliceExpr(se, idx) },
                Expr.array_literal |al| => { return self.lowerArrayLiteral(al, idx) },
                Expr.string_interp |si| => { return self.lowerStringInterp(si, idx) },
                Expr.try_expr |te| => { return self.lowerTryExpr(te, idx) },
                Expr.catch_expr |ce| => { return self.lowerCatchExpr(ce, idx) },
                Expr.orelse_expr |oe| => { return self.lowerOrElseExpr(oe, idx) },
                Expr.error_literal |el| => { return self.lowerErrorLiteral(el, idx) },
                Expr.builtin_call |bc| => { return self.lowerBuiltinCall(bc, idx) },
                Expr.switch_expr |se| => { return self.lowerSwitchExpr(se, idx) },
                Expr.new_expr |ne| => { return self.lowerNewExpr(ne, idx) },
                Expr.tuple_literal |tl| => { return self.lowerTupleLiteral(tl, idx) },
                Expr.closure_expr |ce| => { return self.lowerClosureExpr(ce) },
                Expr.spawn_expr |se| => { return self.lowerSpawnExpr(se) },
                Expr.select_expr |se| => { return self.lowerSelectExpr(se) },
                Expr.await_expr |ae| => { return self.lowerAwaitExpr(ae, idx) },
                else => {
                    return null_node
                },
            }
        }
        return null_node
    }

    // ========================================================================
    // Literal lowering
    // ========================================================================

    fn lowerLiteral(lit: Literal, idx: int) int {
        const fb = self.builder.func() orelse return null_node
        const span = lit.span
        switch (lit.kind) {
            LiteralKind.@"int" => {
                const type_idx = self.inferExprType(idx)
                const val = parseIntLit(lit.value)
                return fb.emitConstInt(val, type_idx, span)
            },
            LiteralKind.@"float" => {
                const type_idx = self.inferExprType(idx)
                const val = parseFloatLit(lit.value)
                return fb.emitConstFloat(val, type_idx, span)
            },
            LiteralKind.@"string" => {
                const unescaped = parseStringLiteral(lit.value)
                const str_idx = fb.addStringLiteral(unescaped)
                return fb.emitConstSlice(str_idx, span)
            },
            LiteralKind.true_lit => {
                return fb.emitConstBool(true, span)
            },
            LiteralKind.false_lit => {
                return fb.emitConstBool(false, span)
            },
            LiteralKind.null_lit => {
                const type_idx = self.inferExprType(idx)
                return fb.emitConstNull(type_idx, span)
            },
            else => {
                return null_node
            },
        }
    }

    fn lowerIdent(id: Ident) int {
        const fb = self.builder.func() orelse return null_node
        // Check const_values first (compile-time known constants)
        if (self.const_values.contains(id.name)) {
            const val = self.const_values.get(id.name)
            return fb.emitConstInt(val, I64, id.span)
        }
        // Check float const values
        if (self.float_const_values.contains(id.name)) {
            const val = self.float_const_values.get(id.name)
            const type_idx = if (self.float_const_types.contains(id.name)) {
                self.float_const_types.get(id.name)
            } else { F64 }
            const fval = @bitCast(f64, val)
            return fb.emitConstFloat(fval, type_idx, id.span)
        }
        // Look up local variable
        if (fb.lookupLocal(id.name)) |local_idx| {
            const local = fb.locals.get(local_idx)
            return fb.emitLoadLocal(local_idx, local.type_idx, id.span)
        }
        // Look up global
        if (self.builder.lookupGlobal(id.name)) |result| {
            return fb.emitGlobalRef(result.idx, id.name, result.global.type_idx, id.span)
        }
        // Function reference
        return fb.emitFuncAddr(id.name, I64, id.span)
    }

    // ========================================================================
    // Binary/Unary expression lowering
    // ========================================================================

    fn lowerBinary(bin: Binary, idx: int) int {
        const fb = self.builder.func() orelse return null_node
        const tok = bin.op

        // Short-circuit logical and/or
        if (tok == Token.land or tok == Token.kw_and or tok == Token.lor or tok == Token.kw_or) {
            return self.lowerShortCircuit(bin)
        }

        // String concatenation (++ or + on strings)
        if (tok == Token.concat or tok == Token.add) {
            const left_type = self.inferExprType(bin.left)
            if (left_type == STRING) {
                return self.lowerStringConcat(bin)
            }
        }

        // String equality (== or != on strings)
        if (tok == Token.eql or tok == Token.neq) {
            const left_type = self.inferExprType(bin.left)
            if (left_type == STRING) {
                return self.lowerStringCompare(bin)
            }
        }

        // Generic binary expression
        const left = self.lowerExprNode(bin.left)
        const right = self.lowerExprNode(bin.right)
        if (left == null_node or right == null_node) { return null_node }

        const result_type = self.inferBinaryType(bin.op, bin.left, bin.right)

        // Dict dispatch: if inside a dict-stenciled body and this op is on a type-param type,
        // emit indirect call through the dictionary fn-ptr param instead of a direct binary op.
        if (self.has_dict_context) {
            const left_type_idx = self.inferExprType(bin.left)
            if (self.chk.hasTypeSubstitution()) {
                // Check if left type matches any substituted type param
                for si in 0..self.chk.type_sub_vals.count {
                    if (self.chk.type_sub_vals.get(si) == left_type_idx) {
                        // Find matching dict entry for this binary op (entry.op is Token value)
                        for di in 0..self.current_dict_entries.count {
                            const entry = self.current_dict_entries.get(di)
                            if (entry.kind == DICT_BINARY_OP and entry.op == bin.op) {
                                const fn_ptr = fb.emitLoadLocal(self.current_dict_params.get(di), I64, bin.span)
                                var call_args: List(int) = .{}
                                call_args.append(left)
                                call_args.append(right)
                                return fb.emitCallIndirect(fn_ptr, call_args, result_type, bin.span)
                            }
                        }
                    }
                }
            }
        }

        const op = tokenToBinaryOp(tok)
        return fb.emitBinary(op, left, right, result_type, bin.span)
    }

    /// Short-circuit and/or at IR level: defer right-side lowering until inside the branch.
    /// Go reference: ssagen/ssa.go:3398-3442 (OANDAND/OOROR expr path).
    /// Pattern: result_local + store + load (matches Zig compiler lower.zig:301-334).
    fn lowerShortCircuit(bin: Binary) int {
        const fb = self.builder.func() orelse return null_node
        const left = self.lowerExprNode(bin.left)
        if (left == null_node) { return null_node }

        const is_and = (bin.op == Token.land or bin.op == Token.kw_and)

        const result_local = fb.addLocalWithSize("__sc_result", BOOL, false, 8)
        const eval_right_block = fb.newBlock("sc.eval_right")
        const short_circuit_block = fb.newBlock("sc.short")
        const merge_block = fb.newBlock("sc.merge")

        if (is_and) {
            // and: left true → eval right; left false → short circuit (result = false)
            fb.emitBranch(left, eval_right_block, short_circuit_block, bin.span)
        } else {
            // or: left true → short circuit (result = true); left false → eval right
            fb.emitBranch(left, short_circuit_block, eval_right_block, bin.span)
        }

        // Short circuit block: result = false (for and) or true (for or)
        fb.setBlock(short_circuit_block)
        const short_val = fb.emitConstBool(!is_and, bin.span)
        fb.emitStoreLocal(result_local, short_val, bin.span)
        fb.emitJump(merge_block, bin.span)

        // Eval right block: lower right operand HERE (deferred, after branch)
        fb.setBlock(eval_right_block)
        const right = self.lowerExprNode(bin.right)
        if (right != null_node) {
            fb.emitStoreLocal(result_local, right, bin.span)
        }
        fb.emitJump(merge_block, bin.span)

        // Merge: load result
        fb.setBlock(merge_block)
        return fb.emitLoadLocal(result_local, BOOL, bin.span)
    }

    /// String concatenation: decompose strings, call string_concat runtime
    fn lowerStringConcat(bin: Binary) int {
        const fb = self.builder.func() orelse return null_node
        const left = self.lowerExprNode(bin.left)
        const right = self.lowerExprNode(bin.right)
        if (left == null_node or right == null_node) { return null_node }

        // Decompose left string into ptr/len
        const left_local = fb.addLocalWithSize("__str_l", STRING, false, 16)
        fb.emitStoreLocal(left_local, left, bin.span)
        const left_ptr = fb.emitFieldLocal(left_local, 0, 0, I64, bin.span)
        const left_len = fb.emitFieldLocal(left_local, 1, 8, I64, bin.span)

        // Decompose right string into ptr/len
        const right_local = fb.addLocalWithSize("__str_r", STRING, false, 16)
        fb.emitStoreLocal(right_local, right, bin.span)
        const right_ptr = fb.emitFieldLocal(right_local, 0, 0, I64, bin.span)
        const right_len = fb.emitFieldLocal(right_local, 1, 8, I64, bin.span)

        // Call string_concat(left_ptr, left_len, right_ptr, right_len) → new_ptr (I64)
        // Zig reference: lower.zig lines 4893-4900 — returns I64, wraps with string_header
        var args: List(int) = .{}
        args.append(left_ptr)
        args.append(left_len)
        args.append(right_ptr)
        args.append(right_len)
        const new_ptr = fb.emitCall("string_concat", args, false, I64, bin.span)

        // Compute new_len = left_len + right_len
        const new_len = fb.emitBinary(BinaryOp.add, left_len, right_len, I64, bin.span)

        // Create string_header(new_ptr, new_len) — produces string_make in SSA
        return fb.emit(Node.init(Data.string_header(StringHeader { ptr: new_ptr, len: new_len }), STRING, bin.span))
    }

    /// String comparison: decompose strings, call string_eq runtime
    fn lowerStringCompare(bin: Binary) int {
        const fb = self.builder.func() orelse return null_node
        const left = self.lowerExprNode(bin.left)
        const right = self.lowerExprNode(bin.right)
        if (left == null_node or right == null_node) { return null_node }

        // Decompose left string
        const left_local = fb.addLocalWithSize("__str_l", STRING, false, 16)
        fb.emitStoreLocal(left_local, left, bin.span)
        const left_ptr = fb.emitFieldLocal(left_local, 0, 0, I64, bin.span)
        const left_len = fb.emitFieldLocal(left_local, 1, 8, I64, bin.span)

        // Decompose right string
        const right_local = fb.addLocalWithSize("__str_r", STRING, false, 16)
        fb.emitStoreLocal(right_local, right, bin.span)
        const right_ptr = fb.emitFieldLocal(right_local, 0, 0, I64, bin.span)
        const right_len = fb.emitFieldLocal(right_local, 1, 8, I64, bin.span)

        // Call string_eq(left_ptr, left_len, right_ptr, right_len)
        var args: List(int) = .{}
        args.append(left_ptr)
        args.append(left_len)
        args.append(right_ptr)
        args.append(right_len)
        const eq_result = fb.emitCall("string_eq", args, false, BOOL, bin.span)

        // For != invert the result
        if (bin.op == Token.neq) {
            return fb.emitUnary(UnaryOp.@"not", eq_result, BOOL, bin.span)
        }
        return eq_result
    }

    fn lowerUnary(un: Unary, idx: int) int {
        const fb = self.builder.func() orelse return null_node
        const operand = self.lowerExprNode(un.operand)
        if (operand == null_node) { return null_node }

        const result_type = self.inferExprType(idx)
        const op = tokenToUnaryOp(un.op)
        return fb.emitUnary(op, operand, result_type, un.span)
    }

    // ========================================================================
    // Field access / Index / Struct init
    // ========================================================================

    fn lowerFieldAccess(fa: FieldAccessExpr, idx: int) int {
        const fb = self.builder.func() orelse return null_node
        const base_type = self.inferExprType(fa.base)
        const type_info = self.types.get(base_type)

        // String .len
        if (base_type == STRING and fa.field == "len") {
            const base = self.lowerExprNode(fa.base)
            if (base == null_node) { return null_node }
            const tmp = fb.addLocalWithSize("__str", STRING, false, 16)
            fb.emitStoreLocal(tmp, base, fa.span)
            return fb.emitFieldLocal(tmp, 1, 8, I64, fa.span)
        }

        // String .ptr
        if (base_type == STRING and fa.field == "ptr") {
            const base = self.lowerExprNode(fa.base)
            if (base == null_node) { return null_node }
            const tmp = fb.addLocalWithSize("__str", STRING, false, 16)
            fb.emitStoreLocal(tmp, base, fa.span)
            return fb.emitFieldLocal(tmp, 0, 0, I64, fa.span)
        }

        // Slice .len
        if (type_info.tag == TAG_SLICE and fa.field == "len") {
            const base = self.lowerExprNode(fa.base)
            if (base == null_node) { return null_node }
            return fb.emitSliceLen(base, fa.span)
        }

        // Slice .ptr
        if (type_info.tag == TAG_SLICE and fa.field == "ptr") {
            const base = self.lowerExprNode(fa.base)
            if (base == null_node) { return null_node }
            var elem_type = I64
            switch (type_info) { Type.slice |s| => { elem_type = s.elem }, else => {} }
            const ptr_type = self.types.makePointer(elem_type)
            return fb.emitSlicePtr(base, ptr_type, fa.span)
        }

        // Slice .cap
        if (type_info.tag == TAG_SLICE and fa.field == "cap") {
            const base = self.lowerExprNode(fa.base)
            if (base == null_node) { return null_node }
            return fb.emitSliceCap(base, fa.span)
        }

        // Array .len (compile-time constant)
        if (type_info.tag == TAG_ARRAY and fa.field == "len") {
            var length = 0
            switch (type_info) { Type.array |a| => { length = a.length }, else => {} }
            return fb.emitConstInt(length, I64, fa.span)
        }

        // Struct field access
        if (type_info.tag == TAG_STRUCT) {
            return self.lowerStructFieldAccess(fa, base_type)
        }

        // Pointer to struct — auto-deref
        if (type_info.tag == TAG_POINTER) {
            const pointee_type = switch (type_info) { Type.pointer |p| => p.elem, else => VOID }
            const pointee_info = self.types.get(pointee_type)
            if (pointee_info.tag == TAG_STRUCT) {
                return self.lowerPtrStructFieldAccess(fa, pointee_type)
            }
        }

        // Union: .tag pseudo-field, payload extraction, or variant tag
        // Zig reference: lower.zig lines 5368-5403
        if (type_info.tag == TAG_UNION) {
            // .tag pseudo-field returns the tag value (offset 0)
            if (fa.field == "tag") {
                // Try to access from local if base is an ident
                if (self.extractIdentName(fa.base)) |base_name| {
                    if (fb.lookupLocal(base_name)) |local_idx| {
                        return fb.emitFieldLocal(local_idx, 0, 0, I64, fa.span)
                    }
                }
                const base = self.lowerExprNode(fa.base)
                if (base == null_node) { return null_node }
                // Store to temp, extract tag at offset 0
                const union_size = self.types.sizeOf(base_type)
                const tmp = fb.addLocalWithSize("__union_tag", base_type, false, union_size)
                fb.emitStoreLocal(tmp, base, fa.span)
                return fb.emitFieldLocal(tmp, 0, 0, I64, fa.span)
            }
            // Union variant field access: payload extraction or unit variant construction
            // Zig reference: lower.zig lines 5553-5573
            switch (type_info) {
                Type.union_type |ut| => {
                    for i in 0..ut.variant_count {
                        const v = ut.getVariant(i)
                        if (v.name == fa.field) {
                            if (v.payload_type != VOID and v.payload_type > 0) {
                                // Payload extraction: load from union at offset 8
                                if (self.extractIdentName(fa.base)) |vbase_name| {
                                    if (fb.lookupLocal(vbase_name)) |vlocal_idx| {
                                        return fb.emitFieldLocal(vlocal_idx, 1, 8, v.payload_type, fa.span)
                                    }
                                }
                                const vbase = self.lowerExprNode(fa.base)
                                if (vbase == null_node) { return null_node }
                                return fb.emitFieldValue(vbase, 1, 8, v.payload_type, fa.span)
                            }
                            // Unit variant: create temp local with tag stored
                            const usize = self.types.sizeOf(base_type)
                            if (usize > 8) {
                                const utmp = fb.addLocalWithSize("__union_tmp", base_type, false, usize)
                                const utag = fb.emitConstInt(i, I64, fa.span)
                                fb.emitStoreLocalField(utmp, 0, 0, utag, fa.span)
                                return fb.emitLoadLocal(utmp, base_type, fa.span)
                            }
                            return fb.emitConstInt(i, base_type, fa.span)
                        }
                    }
                },
                else => {},
            }
        }

        // Enum variant constant (Color.Red → integer value)
        if (type_info.tag == TAG_ENUM) {
            const variant_val = self.findEnumVariant(base_type, fa.field)
            if (variant_val >= 0) {
                return fb.emitConstInt(variant_val, base_type, fa.span)
            }
        }

        // List .count (common pattern)
        if (type_info.tag == TAG_LIST and fa.field == "count") {
            const base = self.lowerExprNode(fa.base)
            if (base == null_node) { return null_node }
            // List.count is at offset 8 (items=0, count=8)
            const tmp = fb.addLocalWithSize("__list", base_type, false, 24)
            fb.emitStoreLocal(tmp, base, fa.span)
            return fb.emitFieldLocal(tmp, 1, 8, I64, fa.span)
        }

        // Optional .? unwrap
        if (type_info.tag == TAG_OPTIONAL and fa.field == "?") {
            const base = self.lowerExprNode(fa.base)
            if (base == null_node) { return null_node }
            const elem_type = switch (type_info) { Type.optional |opt| => opt.elem, else => VOID }
            if (self.isPtrLikeOptional(base_type)) {
                // Pointer-like: unwrap is identity
                return base
            }
            // Compound optional: extract payload from field 1, offset 8
            const opt_local = fb.addLocalWithSize("__opt_unwrap", base_type, false, self.types.sizeOf(base_type))
            fb.emitStoreLocal(opt_local, base, fa.span)
            return fb.emitFieldLocal(opt_local, 1, 8, elem_type, fa.span)
        }

        // Tuple field access (e.g. tuple.0, tuple.1)
        if (type_info.tag == TAG_TUPLE) {
            // Parse numeric field name
            var field_idx = -1
            if (fa.field.len > 0 and fa.field[0] >= 48 and fa.field[0] <= 57) {
                field_idx = parseIntLit(fa.field)
            }
            if (field_idx >= 0) {
                const base = self.lowerExprNode(fa.base)
                if (base == null_node) { return null_node }
                var elem_type = VOID
                var offset = 0
                switch (type_info) { Type.tuple |t| => {
                    if (field_idx < t.elem_count) {
                        elem_type = t.getElemType(field_idx)
                        // Compute offset: sum sizes of preceding elements
                        for fi in 0..field_idx {
                            offset = offset + self.types.sizeOf(t.getElemType(fi))
                        }
                    }
                }, else => {} }
                const tmp = fb.addLocalWithSize("__tuple", base_type, false, self.types.sizeOf(base_type))
                fb.emitStoreLocal(tmp, base, fa.span)
                return fb.emitFieldLocal(tmp, field_idx, offset, elem_type, fa.span)
            }
        }

        // Fallback: try checker's type for the overall expression
        const result_type = self.inferExprType(idx)
        if (result_type != VOID) {
            const field_idx = self.findStructFieldIdx(base_type, fa.field)
            if (field_idx >= 0) {
                if (self.getStructField(base_type, field_idx)) |field| {
                    const base = self.lowerExprNode(fa.base)
                    if (base == null_node) { return null_node }
                    return fb.emitFieldValue(base, field_idx, field.offset, field.type_idx, fa.span)
                }
            }
        }

        return null_node
    }

    /// Struct field access — checks for local ident base optimization.
    fn lowerStructFieldAccess(fa: FieldAccessExpr, struct_type: int) int {
        const fb = self.builder.func() orelse return null_node
        const field_idx = self.findStructFieldIdx(struct_type, fa.field)
        if (field_idx < 0) { return null_node }
        if (self.getStructField(struct_type, field_idx)) |field| {
            if (self.extractIdentName(fa.base)) |base_name| {
                if (fb.lookupLocal(base_name)) |local_idx| {
                    return fb.emitFieldLocal(local_idx, field_idx, field.offset, field.type_idx, fa.span)
                }
            }

            // Expression base — use emitFieldValue
            const base = self.lowerExprNode(fa.base)
            if (base == null_node) { return null_node }
            return fb.emitFieldValue(base, field_idx, field.offset, field.type_idx, fa.span)
        }
        return null_node
    }

    /// Pointer-to-struct field access — auto-deref then access field.
    fn lowerPtrStructFieldAccess(fa: FieldAccessExpr, pointee_type: int) int {
        const fb = self.builder.func() orelse return null_node
        const field_idx = self.findStructFieldIdx(pointee_type, fa.field)
        if (field_idx < 0) { return null_node }
        if (self.getStructField(pointee_type, field_idx)) |field| {
            if (self.extractIdentName(fa.base)) |base_name| {
                if (fb.lookupLocal(base_name)) |local_idx| {
                    return fb.emitPtrField(local_idx, field_idx, field.offset, field.type_idx, fa.span)
                }
            }

            // Expression base — Zig reference: emitFieldValue (lower.zig line 5248)
            const base = self.lowerExprNode(fa.base)
            if (base == null_node) { return null_node }
            return fb.emitFieldValue(base, field_idx, field.offset, field.type_idx, fa.span)
        }
        return null_node
    }

    fn lowerIndex(ie: IndexExpr, idx: int) int {
        const fb = self.builder.func() orelse return null_node
        const base_type = self.inferExprType(ie.base)
        const type_info = self.types.get(base_type)

        // Get element type and size
        var elem_type = I64
        if (type_info.tag == TAG_ARRAY) {
            switch (type_info) { Type.array |a| => { elem_type = a.elem }, else => {} }
        } else if (type_info.tag == TAG_SLICE) {
            switch (type_info) { Type.slice |s| => { elem_type = s.elem }, else => {} }
        } else if (base_type == STRING) {
            // String indexing via charAt
            const base = self.lowerExprNode(ie.base)
            const index = self.lowerExprNode(ie.idx)
            if (base == null_node or index == null_node) { return null_node }
            var args: List(int) = .{}
            args.append(base)
            args.append(index)
            return fb.emitCall("charAt", args, false, I64, ie.span)
        }
        const elem_size = self.types.sizeOf(elem_type)

        // Lower index expression
        const index = self.lowerExprNode(ie.idx)
        if (index == null_node) { return null_node }

        // Bounds check (debug mode only)
        if (!self.release_mode) {
            if (type_info.tag == TAG_ARRAY) {
                var arr_len = 0
                switch (type_info) { Type.array |a| => { arr_len = a.length }, else => {} }
                const len_node = fb.emitConstInt(arr_len, I64, ie.span)
                self.emitBoundsCheck(index, len_node, ie.span)
            } else if (type_info.tag == TAG_SLICE) {
                // Need to get the slice value to extract length
                if (self.extractIdentName(ie.base)) |sl_name| {
                    if (fb.lookupLocal(sl_name)) |sl_local| {
                        const sl_val = fb.emitLoadLocal(sl_local, base_type, ie.span)
                        const len_node = fb.emitSliceLen(sl_val, ie.span)
                        self.emitBoundsCheck(index, len_node, ie.span)
                    }
                }
            }
        }

        if (self.extractIdentName(ie.base)) |base_name| {
            if (fb.lookupLocal(base_name)) |local_idx| {
                return fb.emitIndexLocal(local_idx, index, elem_size, elem_type, ie.span)
            }
        }

        // Expression base
        const base = self.lowerExprNode(ie.base)
        if (base == null_node) { return null_node }
        return fb.emitIndexValue(base, index, elem_size, elem_type, ie.span)
    }

    fn lowerStructInit(si: StructInitExpr, idx: int) int {
        const fb = self.builder.func() orelse return null_node
        // Get struct type from checker or by name lookup
        var struct_type = self.inferExprType(idx)
        if (struct_type == VOID or struct_type == invalid_type) {
            const looked_up = self.types.lookupByName(si.type_name)
            if (looked_up >= 0) { struct_type = looked_up }
        }
        if (struct_type == VOID or struct_type == invalid_type) { return null_node }

        const size = self.types.sizeOf(struct_type)
        const tmp = fb.addLocalWithSize("__struct_init", struct_type, false, size)

        // Store each field init
        for i in 0..si.fields.count {
            const field_init_idx = si.fields.get(i)
            var fi_name = ""
            var fi_value = null_node
            var found = false
            switch (self.tree.getNode(field_init_idx)) { Node.expr |e| => switch (e) {
                Expr.field_init_node |fi| => { fi_name = fi.name; fi_value = fi.value; found = true },
                else => {},
            }, else => {} }

            if (found) {
                const field_idx = self.findStructFieldIdx(struct_type, fi_name)
                if (field_idx >= 0) {
                    if (self.getStructField(struct_type, field_idx)) |field| {
                        const val = self.lowerExprNode(fi_value)
                        if (val != null_node) {
                            fb.emitStoreLocalField(tmp, field_idx, field.offset, val, si.span)
                        }
                    }
                }
            }
        }

        // Return address of the initialized struct
        return fb.emitAddrLocal(tmp, struct_type, si.span)
    }

    // Recursively resolve address of nested struct fields (e.g. &obj.field.inner)
    // Zig reference: lower.zig:3271-3326
    fn resolveStructFieldAddr(node_idx: int) int {
        const fb = self.builder.func() orelse return null_node
        // Check if node is an ident — base case
        if (self.extractIdentName(node_idx)) |name| {
            if (fb.lookupLocal(name)) |local_idx| {
                const local_type = fb.locals.get(local_idx).type_idx
                const ptr_type = self.types.makePointer(local_type)
                return fb.emitAddrLocal(local_idx, ptr_type, Span { start: 0, end: 0 })
            }
            if (self.builder.lookupGlobal(name)) |g| {
                const ptr_type = self.types.makePointer(g.global.type_idx)
                return fb.emitAddrGlobal(g.idx, name, ptr_type, Span { start: 0, end: 0 })
            }
            return null_node
        }

        // Check if node is a field_access
        var fa_opt: ?FieldAccessExpr = null
        switch (self.tree.getNode(node_idx)) { Node.expr |e| => switch (e) {
            Expr.field_access |fa| => { fa_opt = fa },
            else => {},
        }, else => {} }

        if (fa_opt) |fa| {
            const base_type_idx = self.inferExprType(fa.base)
            const base_type = self.types.get(base_type_idx)

            // Get struct type (direct or through pointer)
            var struct_type_idx = VOID
            var is_ptr = false
            if (base_type.tag == TAG_STRUCT) {
                struct_type_idx = base_type_idx
            } else if (base_type.tag == TAG_POINTER) {
                is_ptr = true
                const elem = switch (base_type) { Type.pointer |p| => p.elem, else => VOID }
                const elem_info = self.types.get(elem)
                if (elem_info.tag == TAG_STRUCT) {
                    struct_type_idx = elem
                }
            }
            if (struct_type_idx == VOID) { return null_node }

            // Get base address: pointer → load value, struct → recurse
            const base_addr = if (is_ptr) {
                self.lowerExprNode(fa.base)
            } else {
                self.resolveStructFieldAddr(fa.base)
            }
            if (base_addr == null_node) { return null_node }

            // Find field and emit offset
            const field_idx = self.findStructFieldIdx(struct_type_idx, fa.field)
            if (field_idx >= 0) {
                if (self.getStructField(struct_type_idx, field_idx)) |field| {
                    const field_offset = field.offset
                    if (field_offset == 0) { return base_addr }
                    const field_ptr_type = self.types.makePointer(field.type_idx)
                    return fb.emitAddrOffset(base_addr, field_offset, field_ptr_type, fa.span)
                }
            }
            return null_node
        }

        return null_node
    }

    fn lowerAddrOf(ao: AddrOf, idx: int) int {
        const fb = self.builder.func() orelse return null_node
        const operand_type = self.inferExprType(ao.operand)
        const ptr_type = self.types.makePointer(operand_type)

        // Check if operand is an ident — direct addr of local
        if (self.extractIdentName(ao.operand)) |op_name| {
            if (fb.lookupLocal(op_name)) |local_idx| {
                return fb.emitAddrLocal(local_idx, ptr_type, ao.span)
            }
        }

        // Check if operand is a field_access — use resolveStructFieldAddr
        var is_field_access = false
        switch (self.tree.getNode(ao.operand)) { Node.expr |e| => switch (e) {
            Expr.field_access => { is_field_access = true },
            else => {},
        }, else => {} }
        if (is_field_access) {
            const result = self.resolveStructFieldAddr(ao.operand)
            if (result != null_node) { return result }
        }

        // For non-ident operands, lower and store to temp
        const val = self.lowerExprNode(ao.operand)
        if (val == null_node) { return null_node }
        const size = self.types.sizeOf(operand_type)
        const tmp = fb.addLocalWithSize("__addr_tmp", operand_type, false, size)
        fb.emitStoreLocal(tmp, val, ao.span)
        return fb.emitAddrLocal(tmp, ptr_type, ao.span)
    }

    fn lowerDeref(dr: Deref, idx: int) int {
        const fb = self.builder.func() orelse return null_node
        const ptr_type = self.inferExprType(dr.operand)
        const ptr_info = self.types.get(ptr_type)

        // Get element type from pointer
        var elem_type = I64
        if (ptr_info.tag == TAG_POINTER) {
            switch (ptr_info) { Type.pointer |p| => { elem_type = p.elem }, else => {} }
        }

        // Check if operand is a local ident
        var op_name = ""
        var is_ident = false
        switch (self.tree.getNode(dr.operand)) { Node.expr |e| => switch (e) {
            Expr.ident |id| => { op_name = id.name; is_ident = true },
            else => {},
        }, else => {} }

        if (is_ident) {
            if (fb.lookupLocal(op_name)) |local_idx| {
                return fb.emitPtrLoad(local_idx, elem_type, dr.span)
            }
        }

        // Expression operand
        const ptr = self.lowerExprNode(dr.operand)
        if (ptr == null_node) { return null_node }
        return fb.emitPtrLoadValue(ptr, elem_type, dr.span)
    }

    // ========================================================================
    // Slice and array expressions
    // ========================================================================

    fn lowerSliceExpr(se: SliceExpr, idx: int) int {
        const fb = self.builder.func() orelse return null_node
        const base_type = self.inferExprType(se.base)
        const type_info = self.types.get(base_type)

        // String slicing
        if (base_type == STRING) {
            return self.lowerStringSlice(se)
        }

        // Get element type
        var elem_type = I64
        if (type_info.tag == TAG_ARRAY) {
            switch (type_info) { Type.array |a| => { elem_type = a.elem }, else => {} }
        } else if (type_info.tag == TAG_SLICE) {
            switch (type_info) { Type.slice |s| => { elem_type = s.elem }, else => {} }
        }
        const elem_size = self.types.sizeOf(elem_type)
        const slice_type = self.types.makeSlice(elem_type)

        // Lower start/end
        var start = null_node
        if (se.start != null_node) {
            start = self.lowerExprNode(se.start)
        }
        var end = null_node
        if (se.end != null_node) {
            end = self.lowerExprNode(se.end)
        }

        // Default end to array length
        if (end == null_node and type_info.tag == TAG_ARRAY) {
            var length = 0
            switch (type_info) { Type.array |a| => { length = a.length }, else => {} }
            end = fb.emitConstInt(length, I64, se.span)
        }
        if (end == null_node) { return null_node }

        // Default start to 0
        if (start == null_node) {
            start = fb.emitConstInt(0, I64, se.span)
        }

        // Slice bounds checks (debug mode only)
        if (!self.release_mode) {
            // Get the source length for checking
            var source_len = null_node
            if (type_info.tag == TAG_ARRAY) {
                var arr_len = 0
                switch (type_info) { Type.array |a| => { arr_len = a.length }, else => {} }
                source_len = fb.emitConstInt(arr_len, I64, se.span)
            } else if (type_info.tag == TAG_SLICE) {
                if (self.extractIdentName(se.base)) |sl_name| {
                    if (fb.lookupLocal(sl_name)) |sl_local| {
                        const sl_val = fb.emitLoadLocal(sl_local, base_type, se.span)
                        source_len = fb.emitSliceLen(sl_val, se.span)
                    }
                }
            }
            if (source_len != null_node) {
                // end <= length (slice end can equal length)
                self.emitSliceBoundsCheck(end, source_len, se.span)
                // start <= end
                self.emitSliceBoundsCheck(start, end, se.span)
            }
        }

        if (self.extractIdentName(se.base)) |base_name| {
            if (fb.lookupLocal(base_name)) |local_idx| {
                return fb.emitSliceLocal(local_idx, start, end, elem_size, slice_type, se.span)
            }
        }

        const base = self.lowerExprNode(se.base)
        if (base == null_node) { return null_node }
        return fb.emitSliceValue(base, start, end, elem_size, slice_type, se.span)
    }

    /// String slicing: zero-copy substring (new ptr, new len).
    fn lowerStringSlice(se: SliceExpr) int {
        const fb = self.builder.func() orelse return null_node
        const base = self.lowerExprNode(se.base)
        if (base == null_node) { return null_node }

        // Store base string to temp for field access
        const base_local = fb.addLocalWithSize("__str_base", STRING, false, 16)
        fb.emitStoreLocal(base_local, base, se.span)
        const str_ptr = fb.emitFieldLocal(base_local, 0, 0, I64, se.span)
        const str_len = fb.emitFieldLocal(base_local, 1, 8, I64, se.span)

        // Start value
        var start_val = fb.emitConstInt(0, I64, se.span)
        if (se.start != null_node) {
            start_val = self.lowerExprNode(se.start)
        }

        // End value (default to string length)
        var end_val = str_len
        if (se.end != null_node) {
            end_val = self.lowerExprNode(se.end)
        }

        // new_ptr = str_ptr + start
        const new_ptr = fb.emitBinary(BinaryOp.add, str_ptr, start_val, I64, se.span)
        // new_len = end - start
        const new_len = fb.emitBinary(BinaryOp.sub, end_val, start_val, I64, se.span)

        // Construct result string compound
        const result_local = fb.addLocalWithSize("__str_slice", STRING, false, 16)
        fb.emitStoreLocalField(result_local, 0, 0, new_ptr, se.span)
        fb.emitStoreLocalField(result_local, 1, 8, new_len, se.span)
        return fb.emitLoadLocal(result_local, STRING, se.span)
    }

    fn lowerArrayLiteral(al: ArrayLiteral, idx: int) int {
        const fb = self.builder.func() orelse return null_node
        if (al.elements.count == 0) { return null_node }

        const first_elem_type = self.inferExprType(al.elements.get(0))
        const elem_size = self.types.sizeOf(first_elem_type)
        const array_type = self.types.makeArray(first_elem_type, al.elements.count)
        const array_size = self.types.sizeOf(array_type)

        const local_idx = fb.addLocalWithSize("__arr", array_type, false, array_size)
        for i in 0..al.elements.count {
            const elem_idx = al.elements.get(i)
            const elem = self.lowerExprNode(elem_idx)
            if (elem != null_node) {
                const idx_const = fb.emitConstInt(i, I64, al.span)
                fb.emitStoreIndexLocal(local_idx, idx_const, elem, elem_size, al.span)
            }
        }
        return fb.emitAddrLocal(local_idx, array_type, al.span)
    }

    // ========================================================================
    // Complex expression lowering
    // ========================================================================

    fn lowerCall(c: Call, idx: int) int {
        const fb = self.builder.func() orelse return null_node
        // Dispatch call types following lower.zig:6545-6965

        // 0. Distinct type constructor: RawPtr(expr) — zero-cost, just lower the argument
        // Zig reference: lower.zig line 8046-8053
        if (self.extractIdentName(c.callee)) |ident_name| {
            const type_idx = self.types.lookupByName(ident_name)
            if (type_idx >= 0) {
                const type_info = self.types.get(type_idx)
                if (type_info.tag == TAG_DISTINCT and c.args.count == 1) {
                    return self.lowerExprNode(c.args.get(0))
                }
            }
        }

        // 1. Method call: callee is field_access (Type.method or value.method)
        var fa: FieldAccessExpr = undefined
        var is_field_access = false
        switch (self.tree.getNode(c.callee)) { Node.expr |e| => switch (e) {
            Expr.field_access |f| => { fa = f; is_field_access = true },
            else => {},
        }, else => {} }

        if (is_field_access) {
            const base_type_idx = self.inferExprType(fa.base)
            const base_type = self.types.get(base_type_idx)

            // Resolve type name for method lookup
            var type_name = switch (base_type) {
                Type.struct_type |st| => st.name,
                Type.enum_type |et| => et.name,
                Type.pointer |p| => switch (self.types.get(p.elem)) {
                    Type.struct_type |st| => st.name,
                    Type.enum_type |et| => et.name,
                    else => "",
                },
                else => "",
            }
            if (type_name == "" and base_type_idx == STRING) { type_name = "string" }

            // Fallback: if base type not resolved from expr_types, try resolving base ident
            // as a type name directly. This handles cross-file static method calls like
            // Node.init(...) where the checker may not have stored the base type in expr_types.
            // Zig reference: lower.zig lines 8266-8289
            if (type_name == "") {
                if (self.extractIdentName(fa.base)) |base_ident| {
                    const resolved_type = self.types.lookupByName(base_ident)
                    if (resolved_type >= 0) {
                        const resolved_info = self.types.get(resolved_type)
                        if (resolved_info.tag == TAG_STRUCT) {
                            type_name = switch (resolved_info) { Type.struct_type |st| => st.name, else => "" }
                        } else if (resolved_info.tag == TAG_ENUM) {
                            type_name = switch (resolved_info) { Type.enum_type |et| => et.name, else => "" }
                        } else if (resolved_info.tag == TAG_UNION) {
                            return self.lowerUnionConstructor(c, fa, resolved_type)
                        }
                    }
                }
            }

            // Try method lookup
            if (type_name != "") {
                const method_idx = self.types.lookupMethod(type_name, fa.field)
                if (method_idx >= 0) {
                    const method_info = self.types.getMethodInfo(method_idx)
                    return self.lowerMethodCall(c, fa, method_info)
                }
            }

            // Union variant constructor: Result.Ok(42)
            if (base_type.tag == TAG_UNION) {
                return self.lowerUnionConstructor(c, fa, base_type_idx)
            }
        }

        // 2. Generic function call: max(i64)(3, 5) — callee is a call expr
        switch (self.tree.getNode(c.callee)) { Node.expr |e| => switch (e) {
            Expr.call |ic| => { return self.lowerGenericCall(c, ic) },
            else => {},
        }, else => {} }

        // 3. Named builtins: len, print, println, append, __string_make
        const callee_name_opt = self.extractIdentName(c.callee)
        const is_ident_callee = callee_name_opt != null
        if (callee_name_opt) |callee_name| {
            if (callee_name == "len") { return self.lowerBuiltinLen(c) }
            if (callee_name == "print") { return self.lowerBuiltinPrint(c, false, 1) }
            if (callee_name == "println") { return self.lowerBuiltinPrint(c, true, 1) }
            if (callee_name == "eprint") { return self.lowerBuiltinPrint(c, false, 2) }
            if (callee_name == "eprintln") { return self.lowerBuiltinPrint(c, true, 2) }
            if (callee_name == "__string_make") { return self.lowerBuiltinStringMake(c) }
            if (callee_name == "append") { return self.lowerBuiltinAppend(c) }
        }

        // 4. Regular function call — process args with ABI decomposition
        var args: List(int) = .{}

        // Get function type for parameter checking
        const func_type_idx = self.inferExprType(c.callee)
        const func_type_info = self.types.get(func_type_idx)
        const param_count = switch (func_type_info) { Type.func |ft| => ft.param_count, else => 0 }

        for i in 0..c.args.count {
            const arg_idx = c.args.get(i)

            // Determine parameter type for ABI decomposition
            var param_is_pointer = false
            var param_is_compound = false  // slice or string
            var param_type_idx = VOID
            if (func_type_info.tag == TAG_FUNC and i < param_count) {
                switch (func_type_info) { Type.func |ft| => {
                    const param = ft.getParam(i)
                    param_type_idx = param.type_idx
                    const pt = self.types.get(param_type_idx)
                    param_is_pointer = (pt.tag == TAG_POINTER)
                    param_is_compound = (pt.tag == TAG_SLICE) or (param_type_idx == STRING)
                }, else => {} }
            }

            // Lower the argument
            var arg_node = self.lowerExprNode(arg_idx)
            if (arg_node == null_node) { continue }

            // @safe auto-ref: struct value → *Struct param
            if (self.chk.safe_mode and param_is_pointer and param_type_idx != VOID) {
                arg_node = self.maybeAutoRef(arg_node, arg_idx, param_type_idx, c.span)
            }

            // T → ?T wrapping for compound optional params
            if (param_type_idx != VOID) {
                arg_node = self.maybeWrapOptional(arg_node, arg_idx, param_type_idx, c.span)
            }

            // Decompose compound types at call boundary
            if (param_is_compound) {
                const ptr_val = fb.emitSlicePtr(arg_node, I64, c.span)
                const len_val = fb.emitSliceLen(arg_node, c.span)
                args.append(ptr_val)
                args.append(len_val)
            } else if (self.isLargeCompound(param_type_idx)) {
                self.decomposeCompoundArg(&args, arg_node, param_type_idx, c.span)
            } else {
                // Fallback: if param type unknown (VOID), check arg type
                // Zig ref: lower.zig:8440 — decomposes large struct/union args at call site
                if (param_type_idx == VOID) {
                    const arg_type_idx = self.inferExprType(arg_idx)
                    if (self.isLargeCompound(arg_type_idx)) {
                        self.decomposeCompoundArg(&args, arg_node, arg_type_idx, c.span)
                    } else {
                        args.append(arg_node)
                    }
                } else {
                    args.append(arg_node)
                }
            }
        }

        const return_type = switch (func_type_info) { Type.func |ft| => ft.return_type, else => VOID }

        var func_name = ""
        if (callee_name_opt) |cn| { func_name = cn }

        // Check if indirect call (function pointer / closure)
        if (!is_ident_callee) {
            // Closure call: load table_idx, use closure_call
            const closure_ptr = self.lowerExprNode(c.callee)
            const table_idx = fb.emitPtrLoadValue(closure_ptr, I64, c.span)
            return fb.emitClosureCall(table_idx, closure_ptr, args, return_type, c.span)
        }

        // Check if ident is a local (function pointer variable → indirect call)
        if (fb.lookupLocal(func_name)) |_| {
            const closure_ptr = self.lowerExprNode(c.callee)
            const table_idx = fb.emitPtrLoadValue(closure_ptr, I64, c.span)
            return fb.emitClosureCall(table_idx, closure_ptr, args, return_type, c.span)
        }

        // Module qualification: resolve to defining module's qualified name
        const resolved_name = self.resolveCallName(func_name)

        // SRET: caller allocates temp, passes address as hidden first arg
        if (self.needsSret(return_type)) {
            return self.emitSretCall(resolved_name, args, return_type, c.span)
        }

        return fb.emitCall(resolved_name, args, false, return_type, c.span)
    }

    // ========================================================================
    // Method call lowering
    // ========================================================================

    fn lowerMethodCall(call: Call, fa: FieldAccessExpr, method_info: MethodInfo) int {
        const fb = self.builder.func() orelse return null_node
        // Queue generic impl method for deferred lowering
        if (self.lookupGenericInst(method_info.func_name)) |inst| {
            self.ensureGenericFnQueued(inst)
        }

        var args: List(int) = .{}

        // Static methods: no receiver
        const receiver_offset = if (method_info.is_static) { 0 } else { 1 }

        if (!method_info.is_static) {
            const base_type_idx = self.inferExprType(fa.base)
            const base_type = self.types.get(base_type_idx)

            // Prepare receiver
            var receiver_val = null_node
            if (method_info.receiver_is_ptr) {
                // Method expects *Self — take address if base is value
                if (base_type.tag == TAG_POINTER) {
                    receiver_val = self.lowerExprNode(fa.base)
                } else {
                    // Try to take address of local
                    if (self.extractIdentName(fa.base)) |base_name| {
                        if (fb.lookupLocal(base_name)) |local_idx| {
                            const ptr_type = self.types.makePointer(base_type_idx)
                            receiver_val = fb.emitAddrLocal(local_idx, ptr_type, fa.span)
                        } else if (self.builder.lookupGlobal(base_name)) |g| {
                            const ptr_type = self.types.makePointer(base_type_idx)
                            receiver_val = fb.emitAddrGlobal(g.idx, base_name, ptr_type, fa.span)
                        } else {
                            receiver_val = self.lowerExprNode(fa.base)
                        }
                    } else {
                        // Field access base (e.g. b.local_map.set()) — take address of
                        // the struct field directly. Zig reference: lower.zig line 8929.
                        // Without this, the field value is loaded (copied) and mutations
                        // to the copy are lost (double-pointer chain mutation bug).
                        var is_fa = false
                        switch (self.tree.getNode(fa.base)) { Node.expr |be| => switch (be) {
                            Expr.field_access => { is_fa = true },
                            else => {},
                        }, else => {} }
                        if (is_fa) {
                            const addr = self.resolveStructFieldAddr(fa.base)
                            if (addr != null_node) {
                                receiver_val = addr
                            } else {
                                receiver_val = self.lowerExprNode(fa.base)
                            }
                        } else {
                            // Non-lvalue expression — spill to temp local
                            const val = self.lowerExprNode(fa.base)
                            const ptr_type = self.types.makePointer(base_type_idx)
                            const tmp_local = fb.addLocalWithSize("__method_recv", base_type_idx, true, self.types.sizeOf(base_type_idx))
                            fb.emitStoreLocal(tmp_local, val, fa.span)
                            receiver_val = fb.emitAddrLocal(tmp_local, ptr_type, fa.span)
                        }
                    }
                }
            } else {
                // Method expects Self (value) — deref if base is pointer
                if (base_type.tag == TAG_POINTER) {
                    const ptr_val = self.lowerExprNode(fa.base)
                    receiver_val = fb.emitPtrLoadValue(ptr_val, base_type_idx, fa.span)
                } else {
                    receiver_val = self.lowerExprNode(fa.base)
                }
            }

            if (receiver_val == null_node) { return null_node }
            args.append(receiver_val)
        }

        // Get param types for ABI decomposition
        const ft_info = self.types.get(method_info.func_type)
        const m_param_count = switch (ft_info) { Type.func |ft| => ft.param_count, else => 0 }

        for i in 0..call.args.count {
            const arg_idx = call.args.get(i)

            var param_is_pointer = false
            var param_is_compound = false
            var param_type_idx = VOID
            const param_i = i + receiver_offset
            if (ft_info.tag == TAG_FUNC and param_i < m_param_count) {
                switch (ft_info) { Type.func |ft| => {
                    const param = ft.getParam(param_i)
                    param_type_idx = param.type_idx
                    const pt = self.types.get(param_type_idx)
                    param_is_pointer = (pt.tag == TAG_POINTER)
                    param_is_compound = (pt.tag == TAG_SLICE) or (param_type_idx == STRING)
                }, else => {} }
            }

            var arg_node = self.lowerExprNode(arg_idx)
            if (arg_node == null_node) { continue }

            // @safe auto-ref
            if (self.chk.safe_mode and param_is_pointer and param_type_idx != VOID) {
                arg_node = self.maybeAutoRef(arg_node, arg_idx, param_type_idx, call.span)
            }

            // Decompose compound args
            if (param_is_compound) {
                const ptr_val = fb.emitSlicePtr(arg_node, I64, call.span)
                const len_val = fb.emitSliceLen(arg_node, call.span)
                args.append(ptr_val)
                args.append(len_val)
            } else if (self.isLargeCompound(param_type_idx)) {
                self.decomposeCompoundArg(&args, arg_node, param_type_idx, call.span)
            } else {
                if (param_type_idx == VOID) {
                    const arg_type_idx = self.inferExprType(arg_idx)
                    if (self.isLargeCompound(arg_type_idx)) {
                        self.decomposeCompoundArg(&args, arg_node, arg_type_idx, call.span)
                    } else {
                        args.append(arg_node)
                    }
                } else {
                    args.append(arg_node)
                }
            }
        }

        const return_type = switch (ft_info) { Type.func |ft| => ft.return_type, else => VOID }

        // Resolve the method's qualified name via its defining module
        // Extract type name from base for fallback resolution
        const base_type_idx = self.inferExprType(fa.base)
        const base_info = self.types.get(base_type_idx)
        var m_type_name = switch (base_info) {
            Type.struct_type |st| => st.name,
            Type.enum_type |et| => et.name,
            Type.pointer |p| => switch (self.types.get(p.elem)) {
                Type.struct_type |st| => st.name,
                Type.enum_type |et| => et.name,
                else => "",
            },
            else => "",
        }
        if (m_type_name == "" and base_type_idx == STRING) { m_type_name = "string" }
        // Go LinkFuncName: qualify method call target (skip for generic instances).
        // Generic instances use bare name (TypeIndex makes it unique).
        // Zig reference: lower.zig line 9510-9513.
        const resolved_method = if (self.lookupGenericInst(method_info.func_name) != null) {
            method_info.func_name
        } else {
            self.resolveMethodName(m_type_name, method_info.func_name, method_info.source_tree)
        }

        // Dict dispatch: if inside a dict-stenciled body and receiver is a type param,
        // emit indirect call through the dictionary fn-ptr param.
        if (self.has_dict_context) {
            const recv_type = self.inferExprType(fa.base)
            if (self.chk.hasTypeSubstitution()) {
                for si in 0..self.chk.type_sub_vals.count {
                    const sub_type = self.chk.type_sub_vals.get(si)
                    // Check if receiver is T or *T
                    var is_match = (sub_type == recv_type)
                    if (!is_match and self.types.isPointer(recv_type)) {
                        is_match = (sub_type == self.types.pointerElem(recv_type))
                    }
                    if (is_match) {
                        for di in 0..self.current_dict_entries.count {
                            const entry = self.current_dict_entries.get(di)
                            if (entry.kind == DICT_METHOD_CALL and entry.method_name == fa.field) {
                                const fn_ptr = fb.emitLoadLocal(self.current_dict_params.get(di), I64, call.span)
                                if (self.needsSret(return_type)) {
                                    const ret_size = self.types.sizeOf(return_type)
                                    const sret_local = fb.addLocalWithSize("__sret_tmp", return_type, false, ret_size)
                                    const sret_addr = fb.emitAddrLocal(sret_local, I64, call.span)
                                    var sret_args: List(int) = .{}
                                    sret_args.append(sret_addr)
                                    for ai in 0..args.count {
                                        sret_args.append(args.get(ai))
                                    }
                                    fb.emitCallIndirect(fn_ptr, sret_args, VOID, call.span)
                                    return fb.emitLoadLocal(sret_local, return_type, call.span)
                                }
                                return fb.emitCallIndirect(fn_ptr, args, return_type, call.span)
                            }
                        }
                    }
                }
            }
        }

        // SRET for method calls returning large types
        if (self.needsSret(return_type)) {
            return self.emitSretCall(resolved_method, args, return_type, call.span)
        }

        return fb.emitCall(resolved_method, args, false, return_type, call.span)
    }

    // ========================================================================
    // Union variant constructor
    // ========================================================================

    fn lowerUnionConstructor(call: Call, fa: FieldAccessExpr, union_type_idx: int) int {
        const fb = self.builder.func() orelse return null_node
        const union_info = self.types.get(union_type_idx)
        if (union_info.tag != TAG_UNION) { return null_node }

        // Find variant index by name
        var variant_idx = -1
        switch (union_info) {
            Type.union_type |ut| => {
                for i in 0..ut.variant_count {
                    const v = ut.getVariant(i)
                    if (v.name == fa.field) {
                        variant_idx = i
                        break
                    }
                }
            },
            else => {},
        }
        if (variant_idx < 0) { return null_node }

        const union_size = self.types.sizeOf(union_type_idx)
        if (union_size > 8) {
            // Multi-word union: create temp local, store tag+payload
            const tmp = fb.addLocalWithSize("__union_tmp", union_type_idx, false, union_size)
            const tag_val = fb.emitConstInt(variant_idx, I64, fa.span)
            fb.emitStoreLocalField(tmp, 0, 0, tag_val, fa.span)
            if (call.args.count > 0) {
                const payload_val = self.lowerExprNode(call.args.get(0))
                if (payload_val != null_node) {
                    fb.emitStoreLocalField(tmp, 1, 8, payload_val, fa.span)
                }
            }
            return fb.emitLoadLocal(tmp, union_type_idx, fa.span)
        }

        // Single-word union
        var payload = null_node
        if (call.args.count > 0) {
            payload = self.lowerExprNode(call.args.get(0))
        }
        return fb.emitUnionInit(variant_idx, payload, union_type_idx, fa.span)
    }

    // ========================================================================
    // Generic function call
    // ========================================================================

    fn lowerGenericCall(call: Call, inner_call: Call) int {
        const fb = self.builder.func() orelse return null_node
        // The checker already resolved the generic instantiation and stored it
        // in generic_instantiations keyed by the inner callee node index.
        // We look up by the inner_call callee to find the concrete name.
        var concrete_name = ""

        // Iterate generic_inst_by_name to find a match
        // The checker stores inst info with the concrete_name already built.
        // We need to find it via the callee. Try the checker's expr_types to match.
        var gen_name = ""
        switch (self.tree.getNode(inner_call.callee)) { Node.expr |e| => switch (e) {
            Expr.ident |id| => { gen_name = id.name },
            else => {},
        }, else => {} }

        if (gen_name == "") { return null_node }

        // Build the concrete key: "funcName(typeIdx1;typeIdx2)"
        var key = gen_name ++ "("
        for i in 0..inner_call.args.count {
            const arg_node_idx = inner_call.args.get(i)
            const resolved = self.resolveTypeNode(arg_node_idx)
            if (i > 0) { key = key ++ ";" }
            key = key ++ intToString(resolved)
        }
        key = key ++ ")"
        concrete_name = key

        // Queue for lowering
        if (self.lookupGenericInst(concrete_name)) |inst| {
            self.ensureGenericFnQueued(inst)
        }

        // Lower value arguments
        var gen_args: List(int) = .{}

        // Get concrete function type for param checking
        const concrete_func_type = self.types.lookupByName(concrete_name)
        const cfunc_info_raw = self.types.get(if (concrete_func_type >= 0) { concrete_func_type } else { VOID })
        const c_param_count = switch (cfunc_info_raw) { Type.func |ft| => ft.param_count, else => 0 }

        for i in 0..call.args.count {
            const arg_idx = call.args.get(i)
            var arg_node = self.lowerExprNode(arg_idx)
            if (arg_node == null_node) { continue }

            // Decompose large compound args
            if (cfunc_info_raw.tag == TAG_FUNC and i < c_param_count) {
                var param_type_idx = VOID
                switch (cfunc_info_raw) { Type.func |ft| => {
                    const param = ft.getParam(i)
                    param_type_idx = param.type_idx
                }, else => {} }
                if (self.isLargeCompound(param_type_idx)) {
                    self.decomposeCompoundArg(&gen_args, arg_node, param_type_idx, call.span)
                    continue
                }
            }
            gen_args.append(arg_node)
        }

        const ret_type = switch (cfunc_info_raw) { Type.func |ft| => ft.return_type, else => VOID }

        // SRET for generic function calls
        if (self.needsSret(ret_type)) {
            return self.emitSretCall(concrete_name, gen_args, ret_type, call.span)
        }

        return fb.emitCall(concrete_name, gen_args, false, ret_type, call.span)
    }

    // ========================================================================
    // Call helper: SRET
    // ========================================================================

    fn emitSretCall(func_name: string, args: List(int), return_type: int, span: Span) int {
        const fb = self.builder.func() orelse return null_node
        const ret_size = self.types.sizeOf(return_type)
        const sret_local = fb.addLocalWithSize("__sret_tmp", return_type, false, ret_size)
        const sret_addr = fb.emitAddrLocal(sret_local, I64, span)
        var sret_args: List(int) = .{}
        sret_args.append(sret_addr)
        for i in 0..args.count {
            sret_args.append(args.get(i))
        }
        fb.emitCall(func_name, sret_args, false, VOID, span)
        return fb.emitLoadLocal(sret_local, return_type, span)
    }

    // ========================================================================
    // Call helpers: auto-ref, optional wrapping, compound decomposition
    // ========================================================================

    /// @safe auto-ref: when passing a struct value to a *Struct param, take address.
    fn maybeAutoRef(arg_node: int, arg_idx: int, param_type_idx: int, span: Span) int {
        const fb = self.builder.func() orelse return null_node
        const param_info = self.types.get(param_type_idx)
        if (param_info.tag != TAG_POINTER) { return arg_node }

        const elem_type = switch (param_info) { Type.pointer |p| => p.elem, else => VOID }

        const arg_type = self.inferExprType(arg_idx)
        const arg_info = self.types.get(arg_type)
        if (arg_info.tag != TAG_STRUCT) { return arg_node }
        if (!self.types.isAssignable(arg_type, elem_type)) { return arg_node }

        const ptr_type = self.types.makePointer(arg_type)

        // Try to take address of original lvalue
        var id_name = ""
        var is_ident = false
        switch (self.tree.getNode(arg_idx)) { Node.expr |e| => switch (e) {
            Expr.ident |id| => { id_name = id.name; is_ident = true },
            else => {},
        }, else => {} }

        if (is_ident) {
            if (fb.lookupLocal(id_name)) |local_idx| {
                return fb.emitAddrLocal(local_idx, ptr_type, span)
            }
            if (self.builder.lookupGlobal(id_name)) |g| {
                return fb.emitAddrGlobal(g.idx, id_name, ptr_type, span)
            }
        }

        // Non-lvalue → temp copy
        const tmp = fb.addLocalWithSize("__safe_ref", arg_type, true, self.types.sizeOf(arg_type))
        fb.emitStoreLocal(tmp, arg_node, span)
        return fb.emitAddrLocal(tmp, ptr_type, span)
    }

    /// T → ?T wrapping for compound optional params.
    fn maybeWrapOptional(arg_node: int, arg_idx: int, param_type_idx: int, span: Span) int {
        const fb = self.builder.func() orelse return null_node
        const param_info = self.types.get(param_type_idx)
        if (param_info.tag != TAG_OPTIONAL) { return arg_node }
        if (self.isPtrLikeOptional(param_type_idx)) { return arg_node }

        const arg_type = self.inferExprType(arg_idx)
        const arg_info = self.types.get(arg_type)
        if (arg_info.tag == TAG_OPTIONAL) { return arg_node }  // already optional

        const opt_size = self.types.sizeOf(param_type_idx)
        const tmp = fb.addLocalWithSize("__opt_arg", param_type_idx, false, opt_size)
        const tag_one = fb.emitConstInt(1, I64, span)
        fb.emitStoreLocalField(tmp, 0, 0, tag_one, span)
        fb.emitStoreLocalField(tmp, 1, 8, arg_node, span)
        return fb.emitLoadLocal(tmp, param_type_idx, span)
    }

    /// Check if a type is a large compound (struct/union/tuple > 8 bytes).
    fn isLargeCompound(type_idx: int) bool {
        if (type_idx == VOID) { return false }
        const info = self.types.get(type_idx)
        const size = self.types.sizeOf(type_idx)
        if ((info.tag == TAG_STRUCT or info.tag == TAG_UNION or info.tag == TAG_TUPLE) and size > 8) {
            return true
        }
        if (info.tag == TAG_OPTIONAL and !self.isPtrLikeOptional(type_idx) and size > 8) {
            return true
        }
        return false
    }

    /// Decompose a large compound value into per-slot i64 values.
    fn decomposeCompoundArg(args: *List(int), arg_node: int, type_idx: int, span: Span) void {
        const fb = self.builder.func() orelse return null_node
        const size = self.types.sizeOf(type_idx)
        const num_slots = (size + 7) / 8
        for slot in 0..num_slots {
            const offset = slot * 8
            const field = fb.emitFieldValue(arg_node, slot, offset, I64, span)
            args.append(field)
        }
    }

    /// Get the return type from a Type that is known to be a function type.
    // ========================================================================
    // Builtin: len
    // ========================================================================

    fn lowerBuiltinLen(call: Call) int {
        const fb = self.builder.func() orelse return null_node
        if (call.args.count != 1) { return null_node }
        const arg_idx = call.args.get(0)

        // Check if arg is a string literal — compile-time length
        switch (self.tree.getNode(arg_idx)) { Node.expr |e| => switch (e) {
            Expr.literal |l| => {
                if (l.kind == LiteralKind.@"string") {
                    return fb.emitConstInt(@lenOf(l.value), I64, call.span)
                }
            },
            else => {},
        }, else => {} }

        // Check if arg is an ident — optimize with field access
        if (self.extractIdentName(arg_idx)) |id_name| {
            if (fb.lookupLocal(id_name)) |local_idx| {
                const local = fb.locals.get(local_idx)
                const local_type = self.types.get(local.type_idx)
                if (local.type_idx == STRING) {
                    return fb.emitFieldLocal(local_idx, 1, 8, I64, call.span)
                }
                if (local_type.tag == TAG_SLICE) {
                    return fb.emitFieldLocal(local_idx, 1, 8, I64, call.span)
                }
                if (local_type.tag == TAG_ARRAY) {
                    var arr_len = 0
                    switch (local_type) { Type.array |a| => { arr_len = a.length }, else => {} }
                    return fb.emitConstInt(arr_len, I64, call.span)
                }
            }
        }

        // General case: lower expression and extract len
        const arg_type = self.inferExprType(arg_idx)
        if (arg_type == STRING) {
            const str_val = self.lowerExprNode(arg_idx)
            return fb.emitSliceLen(str_val, call.span)
        }
        const arg_info = self.types.get(arg_type)
        if (arg_info.tag == TAG_SLICE) {
            const slice_val = self.lowerExprNode(arg_idx)
            return fb.emitSliceLen(slice_val, call.span)
        }
        if (arg_info.tag == TAG_ARRAY) {
            var arr_len = 0
            switch (arg_info) { Type.array |a| => { arr_len = a.length }, else => {} }
            return fb.emitConstInt(arr_len, I64, call.span)
        }
        return null_node
    }

    // ========================================================================
    // Builtin: __string_make
    // ========================================================================

    fn lowerBuiltinStringMake(call: Call) int {
        const fb = self.builder.func() orelse return null_node
        if (call.args.count != 2) { return null_node }
        const ptr_val = self.lowerExprNode(call.args.get(0))
        const len_val = self.lowerExprNode(call.args.get(1))
        if (ptr_val == null_node or len_val == null_node) { return null_node }

        // Construct string compound: store ptr+len
        const tmp = fb.addLocalWithSize("__str_make", STRING, false, 16)
        fb.emitStoreLocalField(tmp, 0, 0, ptr_val, call.span)
        fb.emitStoreLocalField(tmp, 1, 8, len_val, call.span)
        return fb.emitLoadLocal(tmp, STRING, call.span)
    }

    // ========================================================================
    // Builtin: print / println / eprint / eprintln
    // ========================================================================

    fn lowerBuiltinPrint(call: Call, is_println: bool, fd: int) int {
        const fb = self.builder.func() orelse return null_node
        if (call.args.count != 1) { return null_node }
        const arg_type = self.inferExprType(call.args.get(0))
        const type_info = self.types.get(arg_type)
        const is_integer = (type_info.tag == TAG_ENUM or
            arg_type == I8 or arg_type == I16 or arg_type == I32 or arg_type == I64 or
            arg_type == INT or arg_type == U8 or arg_type == U16 or arg_type == U32 or arg_type == U64 or
            arg_type == UNTYPED_INT)

        if (is_integer) {
            const int_val = self.lowerExprNode(call.args.get(0))
            var print_args: List(int) = .{}
            print_args.append(int_val)
            const fn_name = if (fd == 2) { "eprint_int" } else { "print_int" }
            fb.emitCall(fn_name, print_args, false, VOID, call.span)
        } else {
            const str_val = self.lowerExprNode(call.args.get(0))
            const ptr_val = fb.emitSlicePtr(str_val, I64, call.span)
            const len_val = fb.emitSliceLen(str_val, call.span)
            const fd_val = fb.emitConstInt(fd, I64, call.span)
            var write_args: List(int) = .{}
            write_args.append(fd_val)
            write_args.append(ptr_val)
            write_args.append(len_val)
            fb.emitCall("write", write_args, false, I64, call.span)
        }

        if (is_println) {
            const nl_idx = fb.addStringLiteral("\n")
            const nl_str = fb.emitConstSlice(nl_idx, call.span)
            const nl_ptr = fb.emitSlicePtr(nl_str, I64, call.span)
            const nl_len = fb.emitConstInt(1, I64, call.span)
            const fd_val = fb.emitConstInt(fd, I64, call.span)
            var nl_args: List(int) = .{}
            nl_args.append(fd_val)
            nl_args.append(nl_ptr)
            nl_args.append(nl_len)
            fb.emitCall("write", nl_args, false, I64, call.span)
        }
        return null_node
    }

    // ========================================================================
    // Builtin: append — Go's slice growth algorithm
    // ========================================================================

    fn lowerBuiltinAppend(call: Call) int {
        const fb = self.builder.func() orelse return null_node
        if (call.args.count != 2) { return null_node }

        // Infer element type from slice
        const slice_type_idx = self.inferExprType(call.args.get(0))
        const slice_type = self.types.get(slice_type_idx)
        var elem_type_idx = I64
        if (slice_type.tag == TAG_SLICE) {
            switch (slice_type) { Type.slice |s| => { elem_type_idx = s.elem }, else => {} }
        } else if (slice_type.tag == TAG_ARRAY) {
            switch (slice_type) { Type.array |a| => { elem_type_idx = a.elem }, else => {} }
        } else { return null_node }

        const elem_size = self.types.sizeOf(elem_type_idx)
        const result_type = self.types.makeSlice(elem_type_idx)

        // Get ptr, len, cap from source
        var old_ptr = null_node
        var old_len = null_node
        var old_cap = null_node

        var arg_name = ""
        var is_arg_ident = false
        switch (self.tree.getNode(call.args.get(0))) { Node.expr |e| => switch (e) {
            Expr.ident |id| => { arg_name = id.name; is_arg_ident = true },
            else => {},
        }, else => {} }

        if (slice_type.tag == TAG_ARRAY) {
            if (is_arg_ident) {
                if (fb.lookupLocal(arg_name)) |local_idx| {
                    const ptr_type = self.types.makePointer(elem_type_idx)
                    old_ptr = fb.emitAddrLocal(local_idx, ptr_type, call.span)
                    var arr_len = 0
                    switch (slice_type) { Type.array |a| => { arr_len = a.length }, else => {} }
                    old_len = fb.emitConstInt(arr_len, I64, call.span)
                    old_cap = old_len
                }
            }
        } else if (slice_type.tag == TAG_SLICE) {
            if (is_arg_ident) {
                if (fb.lookupLocal(arg_name)) |local_idx| {
                    old_ptr = fb.emitFieldLocal(local_idx, 0, 0, I64, call.span)
                    old_len = fb.emitFieldLocal(local_idx, 1, 8, I64, call.span)
                    old_cap = fb.emitFieldLocal(local_idx, 2, 16, I64, call.span)
                }
            }
        }

        if (old_ptr == null_node or old_len == null_node or old_cap == null_node) {
            return null_node
        }

        // new_len = old_len + 1
        const one = fb.emitConstInt(1, I64, call.span)
        const new_len = fb.emitBinary(BinaryOp.add, old_len, one, I64, call.span)
        const elem_size_val = fb.emitConstInt(elem_size, I64, call.span)

        // if new_len <= old_cap: fast path, else: grow
        const cond = fb.emitBinary(BinaryOp.le, new_len, old_cap, BOOL, call.span)

        // Result locals for ptr and cap (used across blocks)
        const result_ptr_local = fb.addLocalWithSize("__append_ptr", I64, true, 8)
        const result_cap_local = fb.addLocalWithSize("__append_cap", I64, true, 8)

        const then_block = fb.newBlock("append.fast")
        const else_block = fb.newBlock("append.grow")
        const merge_block = fb.newBlock("append.merge")

        fb.emitBranch(cond, then_block, else_block, call.span)

        // Fast path: no allocation
        fb.setBlock(then_block)
        fb.emitStoreLocal(result_ptr_local, old_ptr, call.span)
        fb.emitStoreLocal(result_cap_local, old_cap, call.span)
        fb.emitJump(merge_block, call.span)

        // Slow path: grow
        fb.setBlock(else_block)
        var cap_args: List(int) = .{}
        cap_args.append(new_len)
        cap_args.append(old_cap)
        const new_cap_grow = fb.emitCall("nextslicecap", cap_args, false, I64, call.span)
        var grow_args: List(int) = .{}
        grow_args.append(old_ptr)
        grow_args.append(old_len)
        grow_args.append(new_cap_grow)
        grow_args.append(elem_size_val)
        const new_ptr_grow = fb.emitCall("growslice", grow_args, false, I64, call.span)
        fb.emitStoreLocal(result_ptr_local, new_ptr_grow, call.span)
        fb.emitStoreLocal(result_cap_local, new_cap_grow, call.span)
        fb.emitJump(merge_block, call.span)

        // Merge: read results, store element
        fb.setBlock(merge_block)
        const new_ptr = fb.emitLoadLocal(result_ptr_local, I64, call.span)
        const new_cap = fb.emitLoadLocal(result_cap_local, I64, call.span)

        // Store element at s[oldLen]
        const elem_val = self.lowerExprNode(call.args.get(1))
        const offset = fb.emitBinary(BinaryOp.mul, old_len, elem_size_val, I64, call.span)
        const dest_ptr = fb.emitBinary(BinaryOp.add, new_ptr, offset, I64, call.span)
        fb.emitPtrStoreValue(dest_ptr, elem_val, call.span)

        // Return slice{new_ptr, new_len, new_cap}
        const result_local = fb.addLocalWithSize("__append_result", result_type, false, 24)
        fb.emitStoreLocalField(result_local, 0, 0, new_ptr, call.span)
        fb.emitStoreLocalField(result_local, 1, 8, new_len, call.span)
        fb.emitStoreLocalField(result_local, 2, 16, new_cap, call.span)
        return fb.emitLoadLocal(result_local, result_type, call.span)
    }

    // ========================================================================
    // If expression
    // ========================================================================

    fn lowerIfExpr(ie: IfExpr, idx: int) int {
        const fb = self.builder.func() orelse return null_node
        // Optional capture: if (opt) |val| { ... } else { ... }
        if (ie.capture != "") {
            return self.lowerIfOptionalExpr(ie, idx)
        }

        // Simple if expression: emitSelect
        const cond = self.lowerExprNode(ie.condition)
        if (cond == null_node) { return null_node }

        const then_val = self.lowerExprNode(ie.then_branch)
        const else_val = if (ie.else_branch != null_node) {
            self.lowerExprNode(ie.else_branch)
        } else { null_node }

        if (then_val == null_node) { return null_node }
        if (else_val == null_node) { return null_node }

        const result_type = self.inferExprType(idx)
        return fb.emitSelect(cond, then_val, else_val, result_type, ie.span)
    }

    /// If-optional expression: if (opt) |val| then else fallback
    fn lowerIfOptionalExpr(ie: IfExpr, idx: int) int {
        const fb = self.builder.func() orelse return null_node
        const cond_type = self.inferExprType(ie.condition)
        const is_ptr_like = self.isPtrLikeOptional(cond_type)
        const result_type = self.inferExprType(idx)

        // Lower condition
        const opt_val = self.lowerExprNode(ie.condition)
        if (opt_val == null_node) { return null_node }

        // Check if it's non-null
        var check = null_node
        if (is_ptr_like) {
            // Pointer-like: compare != 0
            const zero = fb.emitConstInt(0, I64, ie.span)
            check = fb.emitBinary(BinaryOp.ne, opt_val, zero, BOOL, ie.span)
        } else {
            // Compound optional: check tag at field 0
            const opt_local = fb.addLocalWithSize("__opt_cond", cond_type, false, self.types.sizeOf(cond_type))
            fb.emitStoreLocal(opt_local, opt_val, ie.span)
            const tag = fb.emitFieldLocal(opt_local, 0, 0, I64, ie.span)
            const one = fb.emitConstInt(1, I64, ie.span)
            check = fb.emitBinary(BinaryOp.eq, tag, one, BOOL, ie.span)
        }

        // Result local for block-based lowering
        const result_local = fb.addLocalWithSize("__if_result", result_type, true, self.types.sizeOf(result_type))

        const then_block = fb.newBlock("if.opt.then")
        const else_block = fb.newBlock("if.opt.else")
        const merge_block = fb.newBlock("if.opt.end")

        fb.emitBranch(check, then_block, else_block, ie.span)

        // Then block: bind capture to payload
        fb.setBlock(then_block)
        const scope_depth = fb.markScopeEntry()

        // Extract payload
        var payload_type = VOID
        if (is_ptr_like) {
            payload_type = cond_type  // For ptr-like, the value IS the payload
            // Get element type from optional
            switch (self.types.get(cond_type)) { Type.optional |o| => { payload_type = o.elem }, else => {} }
        } else {
            switch (self.types.get(cond_type)) { Type.optional |o| => { payload_type = o.elem }, else => {} }
        }

        const cap_size = self.types.sizeOf(payload_type)
        const cap_local = fb.addLocalWithSize(ie.capture, payload_type, ie.capture_is_ptr, cap_size)
        if (is_ptr_like) {
            fb.emitStoreLocal(cap_local, opt_val, ie.span)
        } else {
            // Compound optional payload is at offset 8
            const opt_local2 = fb.addLocalWithSize("__opt_for_cap", cond_type, false, self.types.sizeOf(cond_type))
            fb.emitStoreLocal(opt_local2, opt_val, ie.span)
            const payload = fb.emitFieldLocal(opt_local2, 1, 8, payload_type, ie.span)
            fb.emitStoreLocal(cap_local, payload, ie.span)
        }

        const then_val = self.lowerExprNode(ie.then_branch)
        if (then_val != null_node and fb.needsTerminator()) {
            fb.emitStoreLocal(result_local, then_val, ie.span)
            fb.emitJump(merge_block, ie.span)
        } else if (fb.needsTerminator()) {
            fb.emitJump(merge_block, ie.span)
        }
        fb.restoreScope(scope_depth)

        // Else block
        fb.setBlock(else_block)
        if (ie.else_branch != null_node) {
            const else_val = self.lowerExprNode(ie.else_branch)
            if (else_val != null_node and fb.needsTerminator()) {
                fb.emitStoreLocal(result_local, else_val, ie.span)
            }
        }
        if (fb.needsTerminator()) {
            fb.emitJump(merge_block, ie.span)
        }

        fb.setBlock(merge_block)
        return fb.emitLoadLocal(result_local, result_type, ie.span)
    }

    // ========================================================================
    // String interpolation
    // ========================================================================

    fn lowerStringInterp(si: StringInterpExpr, idx: int) int {
        const fb = self.builder.func() orelse return null_node
        // Each segment is either a text literal or an expression.
        // Text → addStringLiteral → emitConstSlice
        // Expr → if int, int_to_string + string_header; if bool, select; if string, use directly
        // Chain all segments inline with string_concat.
        // Reference: Zig compiler lower.zig lowerStringInterp (lines 2903-2993)

        var result = null_node
        for i in 0..si.segments.count {
            const seg_idx = si.segments.get(i)
            const seg_node = self.tree.getNode(seg_idx)

            var seg_val = null_node
            // Check if it's a string literal (text segment)
            var is_text_segment = false
            switch (seg_node) { Node.expr |e| => switch (e) {
                Expr.literal |l| => {
                    if (l.kind == LiteralKind.@"string") {
                        const parsed = parseStringLiteral(l.value)
                        if (parsed.len > 0) {
                            const str_idx = fb.addStringLiteral(parsed)
                            seg_val = fb.emitConstSlice(str_idx, si.span)
                        }
                        is_text_segment = true
                    }
                },
                else => {},
            }, else => {} }

            if (!is_text_segment) {
                // Expression segment
                const seg_type = self.inferExprType(seg_idx)
                const seg_info = self.types.get(seg_type)
                const is_int = (seg_type == I64 or seg_type == INT or seg_type == I32 or
                    seg_type == I16 or seg_type == I8 or seg_type == U8 or
                    seg_type == U16 or seg_type == U32 or seg_type == U64 or
                    seg_info.tag == TAG_ENUM)

                if (is_int) {
                    const int_val = self.lowerExprNode(seg_idx)
                    // Allocate buffer for conversion (matches Zig compiler)
                    const buf_size = 24
                    const buf_type = self.types.makeArray(U8, buf_size)
                    const buf_local = fb.addLocalWithSize("__interp_buf", buf_type, true, buf_size)
                    const buf_addr = fb.emitAddrLocal(buf_local, I64, si.span)
                    var conv_args: List(int) = .{}
                    conv_args.append(int_val)
                    conv_args.append(buf_addr)
                    // int_to_string returns I64 (length), NOT a string
                    const str_len = fb.emitCall("int_to_string", conv_args, false, I64, si.span)
                    // String starts at buf_addr + 21 - str_len (right-aligned in buffer)
                    const twenty_one = fb.emitConstInt(21, I64, si.span)
                    const str_offset = fb.emitBinary(BinaryOp.sub, twenty_one, str_len, I64, si.span)
                    const str_ptr = fb.emitBinary(BinaryOp.add, buf_addr, str_offset, I64, si.span)
                    // Store ptr+len into a string local
                    const str_local = fb.addLocalWithSize("__its_str", STRING, false, 16)
                    fb.emitStoreLocalField(str_local, 0, 0, str_ptr, si.span)
                    fb.emitStoreLocalField(str_local, 1, 8, str_len, si.span)
                    seg_val = fb.emitLoadLocal(str_local, STRING, si.span)
                } else if (seg_type == BOOL) {
                    // Bool: select between "true" and "false" literals (matches Zig compiler)
                    const bool_val = self.lowerExprNode(seg_idx)
                    const true_idx = fb.addStringLiteral("true")
                    const true_str = fb.emitConstSlice(true_idx, si.span)
                    const false_idx = fb.addStringLiteral("false")
                    const false_str = fb.emitConstSlice(false_idx, si.span)
                    const true_ptr = fb.emitSlicePtr(true_str, I64, si.span)
                    const true_len = fb.emitConstInt(4, I64, si.span)
                    const false_ptr = fb.emitSlicePtr(false_str, I64, si.span)
                    const false_len = fb.emitConstInt(5, I64, si.span)
                    const sel_ptr = fb.emitSelect(bool_val, true_ptr, false_ptr, I64, si.span)
                    const sel_len = fb.emitSelect(bool_val, true_len, false_len, I64, si.span)
                    // Store ptr+len into a string local
                    const bool_local = fb.addLocalWithSize("__bts_str", STRING, false, 16)
                    fb.emitStoreLocalField(bool_local, 0, 0, sel_ptr, si.span)
                    fb.emitStoreLocalField(bool_local, 1, 8, sel_len, si.span)
                    seg_val = fb.emitLoadLocal(bool_local, STRING, si.span)
                } else {
                    seg_val = self.lowerExprNode(seg_idx)
                }
            }

            if (seg_val == null_node) { continue }

            if (result == null_node) {
                result = seg_val
            } else {
                // Decompose result into ptr/len
                const left_local = fb.addLocalWithSize("__interp_l", STRING, false, 16)
                fb.emitStoreLocal(left_local, result, si.span)
                const left_ptr = fb.emitFieldLocal(left_local, 0, 0, I64, si.span)
                const left_len = fb.emitFieldLocal(left_local, 1, 8, I64, si.span)

                // Decompose seg_val into ptr/len
                const right_local = fb.addLocalWithSize("__interp_r", STRING, false, 16)
                fb.emitStoreLocal(right_local, seg_val, si.span)
                const right_ptr = fb.emitFieldLocal(right_local, 0, 0, I64, si.span)
                const right_len = fb.emitFieldLocal(right_local, 1, 8, I64, si.span)

                // string_concat returns I64 (new pointer), NOT a string
                var concat_args: List(int) = .{}
                concat_args.append(left_ptr)
                concat_args.append(left_len)
                concat_args.append(right_ptr)
                concat_args.append(right_len)
                const new_ptr = fb.emitCall("string_concat", concat_args, false, I64, si.span)

                // Compute new_len = left_len + right_len
                const new_len = fb.emitBinary(BinaryOp.add, left_len, right_len, I64, si.span)

                // Store ptr+len into a string local
                const cat_local = fb.addLocalWithSize("__cat_str", STRING, false, 16)
                fb.emitStoreLocalField(cat_local, 0, 0, new_ptr, si.span)
                fb.emitStoreLocalField(cat_local, 1, 8, new_len, si.span)
                result = fb.emitLoadLocal(cat_local, STRING, si.span)
            }
        }
        if (result == null_node) {
            const empty_idx = fb.addStringLiteral("")
            return fb.emitConstSlice(empty_idx, si.span)
        }
        return result
    }

    // ========================================================================
    // Builtin call (@sizeOf, @intCast, @assert, etc.)
    // ========================================================================

    fn lowerBuiltinCall(bc: BuiltinCallExpr, idx: int) int {
        const fb = self.builder.func() orelse return null_node
        const kind = bc.kind

        // Identity/passthrough builtins
        if (kind == BuiltinKind.@"as" or kind == BuiltinKind.int_from_enum or
            kind == BuiltinKind.enum_from_int or kind == BuiltinKind.int_from_bool or
            kind == BuiltinKind.align_cast or kind == BuiltinKind.const_cast or
            kind == BuiltinKind.type_of or kind == BuiltinKind.compile_error) {
            if (bc.args.count > 0) {
                return self.lowerExprNode(bc.args.get(0))
            }
            return null_node
        }

        // Const emit builtins
        if (kind == BuiltinKind.size_of) {
            const type_arg = self.resolveTypeNode(bc.type_arg)
            const size = self.types.sizeOf(type_arg)
            return fb.emitConstInt(size, I64, bc.span)
        }
        if (kind == BuiltinKind.align_of) {
            // Alignment is typically 8 for most types on 64-bit
            const type_arg = self.resolveTypeNode(bc.type_arg)
            const size = self.types.sizeOf(type_arg)
            const align = if (size >= 8) { 8 } else if (size >= 4) { 4 } else if (size >= 2) { 2 } else { 1 }
            return fb.emitConstInt(align, I64, bc.span)
        }
        if (kind == BuiltinKind.enum_len) {
            const type_arg = self.resolveTypeNode(bc.type_arg)
            const info = self.types.get(type_arg)
            const count = switch (info) { Type.enum_type |e| => e.variant_count, else => 0 }
            return fb.emitConstInt(count, I64, bc.span)
        }
        if (kind == BuiltinKind.offset_of) {
            // @offsetOf(Type, "field") — compile-time offset
            if (bc.args.count >= 1) {
                const type_arg = self.resolveTypeNode(bc.type_arg)
                // Get field name from first arg (should be a string literal)
                var field_name = ""
                switch (self.tree.getNode(bc.args.get(0))) { Node.expr |e| => switch (e) {
                    Expr.literal |l| => { if (l.kind == LiteralKind.@"string") { field_name = l.value } },
                    Expr.ident |id| => { field_name = id.name },
                    else => {},
                }, else => {} }
                const field_idx = self.findStructFieldIdx(type_arg, field_name)
                if (field_idx >= 0) {
                    if (self.getStructField(type_arg, field_idx)) |field| {
                        return fb.emitConstInt(field.offset, I64, bc.span)
                    }
                }
            }
            return fb.emitConstInt(0, I64, bc.span)
        }

        // Cast/convert builtins
        if (kind == BuiltinKind.int_cast or kind == BuiltinKind.truncate) {
            if (bc.args.count > 0) {
                const operand = self.lowerExprNode(bc.args.get(0))
                if (operand == null_node) { return null_node }
                const target_type = self.resolveTypeNode(bc.type_arg)
                return fb.emitIntCast(operand, target_type, bc.span)
            }
            return null_node
        }
        if (kind == BuiltinKind.float_cast) {
            if (bc.args.count > 0) {
                const operand = self.lowerExprNode(bc.args.get(0))
                if (operand == null_node) { return null_node }
                const target_type = self.resolveTypeNode(bc.type_arg)
                return fb.emitConvert(operand, self.inferExprType(bc.args.get(0)), target_type, bc.span)
            }
            return null_node
        }
        if (kind == BuiltinKind.float_from_int) {
            if (bc.args.count > 0) {
                const operand = self.lowerExprNode(bc.args.get(0))
                if (operand == null_node) { return null_node }
                const target_type = self.resolveTypeNode(bc.type_arg)
                return fb.emitConvert(operand, I64, target_type, bc.span)
            }
            return null_node
        }
        if (kind == BuiltinKind.int_from_float) {
            if (bc.args.count > 0) {
                const operand = self.lowerExprNode(bc.args.get(0))
                if (operand == null_node) { return null_node }
                const target_type = self.resolveTypeNode(bc.type_arg)
                return fb.emitConvert(operand, self.inferExprType(bc.args.get(0)), target_type, bc.span)
            }
            return null_node
        }
        if (kind == BuiltinKind.ptr_cast) {
            if (bc.args.count > 0) {
                const operand = self.lowerExprNode(bc.args.get(0))
                if (operand == null_node) { return null_node }
                const target_type = self.resolveTypeNode(bc.type_arg)
                return fb.emitPtrCast(operand, target_type, bc.span)
            }
            return null_node
        }
        if (kind == BuiltinKind.int_to_ptr) {
            if (bc.args.count > 0) {
                const operand = self.lowerExprNode(bc.args.get(0))
                if (operand == null_node) { return null_node }
                const target_type = self.resolveTypeNode(bc.type_arg)
                return fb.emitIntToPtr(operand, target_type, bc.span)
            }
            return null_node
        }
        if (kind == BuiltinKind.ptr_to_int) {
            if (bc.args.count > 0) {
                const operand = self.lowerExprNode(bc.args.get(0))
                if (operand == null_node) { return null_node }
                const target_type = self.resolveTypeNode(bc.type_arg)
                return fb.emitPtrToInt(operand, target_type, bc.span)
            }
            return null_node
        }
        if (kind == BuiltinKind.bit_cast) {
            if (bc.args.count > 0) {
                return self.lowerExprNode(bc.args.get(0))  // identity at IR level
            }
            return null_node
        }

        // Math intrinsics (unary)
        if (kind == BuiltinKind.abs or kind == BuiltinKind.ceil or kind == BuiltinKind.floor or
            kind == BuiltinKind.trunc or kind == BuiltinKind.round or kind == BuiltinKind.sqrt) {
            if (bc.args.count > 0) {
                const operand = self.lowerExprNode(bc.args.get(0))
                if (operand == null_node) { return null_node }
                const result_type = self.inferExprType(idx)
                const op = if (kind == BuiltinKind.abs) { UnaryOp.abs }
                    else if (kind == BuiltinKind.ceil) { UnaryOp.ceil }
                    else if (kind == BuiltinKind.floor) { UnaryOp.floor }
                    else if (kind == BuiltinKind.trunc) { UnaryOp.trunc_float }
                    else if (kind == BuiltinKind.round) { UnaryOp.nearest }
                    else { UnaryOp.sqrt }
                return fb.emitUnary(op, operand, result_type, bc.span)
            }
            return null_node
        }

        // Math intrinsics (binary)
        if (kind == BuiltinKind.fmin or kind == BuiltinKind.fmax) {
            if (bc.args.count >= 2) {
                const left = self.lowerExprNode(bc.args.get(0))
                const right = self.lowerExprNode(bc.args.get(1))
                if (left == null_node or right == null_node) { return null_node }
                const result_type = self.inferExprType(idx)
                const op = if (kind == BuiltinKind.fmin) { BinaryOp.fmin } else { BinaryOp.fmax }
                return fb.emitBinary(op, left, right, result_type, bc.span)
            }
            return null_node
        }

        // @min / @max — store to locals before branch (br_table pattern)
        if (kind == BuiltinKind.min or kind == BuiltinKind.max) {
            if (bc.args.count >= 2) {
                const left = self.lowerExprNode(bc.args.get(0))
                const right = self.lowerExprNode(bc.args.get(1))
                if (left == null_node or right == null_node) { return null_node }
                const result_type = self.inferExprType(idx)
                // Store to locals first (br_table pattern)
                const left_local = fb.addLocalWithSize("__min_l", result_type, false, 8)
                const right_local = fb.addLocalWithSize("__min_r", result_type, false, 8)
                fb.emitStoreLocal(left_local, left, bc.span)
                fb.emitStoreLocal(right_local, right, bc.span)
                const left_v = fb.emitLoadLocal(left_local, result_type, bc.span)
                const right_v = fb.emitLoadLocal(right_local, result_type, bc.span)
                const cmp_op = if (kind == BuiltinKind.min) { BinaryOp.lt } else { BinaryOp.gt }
                const cond = fb.emitBinary(cmp_op, left_v, right_v, BOOL, bc.span)
                const l2 = fb.emitLoadLocal(left_local, result_type, bc.span)
                const r2 = fb.emitLoadLocal(right_local, result_type, bc.span)
                return fb.emitSelect(cond, l2, r2, result_type, bc.span)
            }
            return null_node
        }

        // Bit manipulation
        if (kind == BuiltinKind.ctz or kind == BuiltinKind.clz or kind == BuiltinKind.pop_count) {
            if (bc.args.count > 0) {
                const operand = self.lowerExprNode(bc.args.get(0))
                if (operand == null_node) { return null_node }
                const result_type = self.inferExprType(idx)
                const op = if (kind == BuiltinKind.ctz) { UnaryOp.ctz }
                    else if (kind == BuiltinKind.clz) { UnaryOp.clz }
                    else { UnaryOp.popcnt }
                return fb.emitUnary(op, operand, result_type, bc.span)
            }
            return null_node
        }

        // Memory/string builtins
        if (kind == BuiltinKind.@"string") {
            // @string(ptr, len) → string compound
            if (bc.args.count >= 2) {
                const ptr_val = self.lowerExprNode(bc.args.get(0))
                const len_val = self.lowerExprNode(bc.args.get(1))
                if (ptr_val == null_node or len_val == null_node) { return null_node }
                const tmp = fb.addLocalWithSize("__str_hdr", STRING, false, 16)
                fb.emitStoreLocalField(tmp, 0, 0, ptr_val, bc.span)
                fb.emitStoreLocalField(tmp, 1, 8, len_val, bc.span)
                return fb.emitLoadLocal(tmp, STRING, bc.span)
            }
            return null_node
        }
        if (kind == BuiltinKind.ptr_of) {
            if (bc.args.count > 0) {
                const val = self.lowerExprNode(bc.args.get(0))
                if (val == null_node) { return null_node }
                return fb.emitSlicePtr(val, I64, bc.span)
            }
            return null_node
        }
        if (kind == BuiltinKind.len_of) {
            if (bc.args.count > 0) {
                const val = self.lowerExprNode(bc.args.get(0))
                if (val == null_node) { return null_node }
                return fb.emitSliceLen(val, bc.span)
            }
            return null_node
        }

        // ARC management
        if (kind == BuiltinKind.arc_retain) {
            // Wasm uses bump allocator, no ARC — return arg directly (matches Zig line 10635)
            if (bc.args.count > 0) {
                return self.lowerExprNode(bc.args.get(0))
            }
            return null_node
        }
        if (kind == BuiltinKind.arc_release) {
            // Wasm uses bump allocator, no ARC — no-op (matches Zig line 10645)
            return null_node
        }

        // Atomics
        if (kind == BuiltinKind.atomic_load) {
            if (bc.args.count > 0) {
                const ptr = self.lowerExprNode(bc.args.get(0))
                if (ptr == null_node) { return null_node }
                const result_type = self.inferExprType(idx)
                return fb.emitUnary(UnaryOp.atomic_load, ptr, result_type, bc.span)
            }
            return null_node
        }
        if (kind == BuiltinKind.atomic_store) {
            if (bc.args.count >= 2) {
                const ptr = self.lowerExprNode(bc.args.get(0))
                const val = self.lowerExprNode(bc.args.get(1))
                if (ptr == null_node or val == null_node) { return null_node }
                return fb.emitBinary(BinaryOp.atomic_store, ptr, val, VOID, bc.span)
            }
            return null_node
        }
        if (kind == BuiltinKind.atomic_add) {
            if (bc.args.count >= 2) {
                const ptr = self.lowerExprNode(bc.args.get(0))
                const val = self.lowerExprNode(bc.args.get(1))
                if (ptr == null_node or val == null_node) { return null_node }
                return fb.emitBinary(BinaryOp.atomic_add, ptr, val, I64, bc.span)
            }
            return null_node
        }
        if (kind == BuiltinKind.atomic_exchange) {
            if (bc.args.count >= 2) {
                const ptr = self.lowerExprNode(bc.args.get(0))
                const val = self.lowerExprNode(bc.args.get(1))
                if (ptr == null_node or val == null_node) { return null_node }
                return fb.emitBinary(BinaryOp.atomic_exchange, ptr, val, I64, bc.span)
            }
            return null_node
        }
        if (kind == BuiltinKind.atomic_cas) {
            if (bc.args.count >= 3) {
                // CAS: ptr, expected, desired → old value
                const ptr = self.lowerExprNode(bc.args.get(0))
                const expected = self.lowerExprNode(bc.args.get(1))
                const desired = self.lowerExprNode(bc.args.get(2))
                if (ptr == null_node or expected == null_node or desired == null_node) { return null_node }
                // Use a call-based CAS
                var cas_args: List(int) = .{}
                cas_args.append(ptr)
                cas_args.append(expected)
                cas_args.append(desired)
                return fb.emitCall("__atomic_cas", cas_args, false, I64, bc.span)
            }
            return null_node
        }

        // Target info builtins
        if (kind == BuiltinKind.target or kind == BuiltinKind.target_os or kind == BuiltinKind.target_arch) {
            const target_str = if (kind == BuiltinKind.target_os) { "macos" }
                else if (kind == BuiltinKind.target_arch) { "aarch64" }
                else { "aarch64-macos" }
            const str_idx = fb.addStringLiteral(target_str)
            return fb.emitConstSlice(str_idx, bc.span)
        }

        // @assert — branch, test context → error EU return, else trap
        if (kind == BuiltinKind.assert) {
            if (bc.args.count > 0) {
                const cond = self.lowerExprNode(bc.args.get(0))
                if (cond == null_node) { return null_node }

                const ok_block = fb.newBlock("assert.ok")
                const fail_block = fb.newBlock("assert.fail")

                fb.emitBranch(cond, ok_block, fail_block, bc.span)

                fb.setBlock(fail_block)
                if (self.test_mode) {
                    // In test mode, return error union with tag=1
                    self.emitTestAssertFail(bc.span)
                } else {
                    // Write message to stderr and trap
                    self.emitAssertPanic("assertion failed", bc.span)
                }

                fb.setBlock(ok_block)
            }
            return null_node
        }

        // @assertEq — compare, then handle failure
        if (kind == BuiltinKind.assert_eq) {
            if (bc.args.count >= 2) {
                const left = self.lowerExprNode(bc.args.get(0))
                const right = self.lowerExprNode(bc.args.get(1))
                if (left == null_node or right == null_node) { return null_node }

                // Compare: use string_eq for strings, == for others
                const left_type = self.inferExprType(bc.args.get(0))
                var cond = null_node
                if (left_type == STRING) {
                    const left_local = fb.addLocalWithSize("__aeq_l", STRING, false, 16)
                    fb.emitStoreLocal(left_local, left, bc.span)
                    const lp = fb.emitFieldLocal(left_local, 0, 0, I64, bc.span)
                    const ll = fb.emitFieldLocal(left_local, 1, 8, I64, bc.span)
                    const right_local = fb.addLocalWithSize("__aeq_r", STRING, false, 16)
                    fb.emitStoreLocal(right_local, right, bc.span)
                    const rp = fb.emitFieldLocal(right_local, 0, 0, I64, bc.span)
                    const rl = fb.emitFieldLocal(right_local, 1, 8, I64, bc.span)
                    var eq_args: List(int) = .{}
                    eq_args.append(lp)
                    eq_args.append(ll)
                    eq_args.append(rp)
                    eq_args.append(rl)
                    cond = fb.emitCall("string_eq", eq_args, false, BOOL, bc.span)
                } else {
                    cond = fb.emitBinary(BinaryOp.eq, left, right, BOOL, bc.span)
                }

                const ok_block = fb.newBlock("asserteq.ok")
                const fail_block = fb.newBlock("asserteq.fail")

                fb.emitBranch(cond, ok_block, fail_block, bc.span)

                fb.setBlock(fail_block)
                if (self.test_mode) {
                    self.emitTestAssertFail(bc.span)
                } else {
                    self.emitAssertPanic("assertion failed: not equal", bc.span)
                }

                fb.setBlock(ok_block)
            }
            return null_node
        }

        // @panic — write message + trap
        if (kind == BuiltinKind.panic) {
            if (bc.args.count > 0) {
                const msg = self.lowerExprNode(bc.args.get(0))
                if (msg != null_node) {
                    const ptr = fb.emitSlicePtr(msg, I64, bc.span)
                    const len = fb.emitSliceLen(msg, bc.span)
                    const fd = fb.emitConstInt(2, I64, bc.span)
                    var write_args: List(int) = .{}
                    write_args.append(fd)
                    write_args.append(ptr)
                    write_args.append(len)
                    fb.emitCall("write", write_args, false, I64, bc.span)
                }
            }
            var exit_args: List(int) = .{}
            exit_args.append(fb.emitConstInt(2, I64, bc.span))
            fb.emitCall("exit", exit_args, false, VOID, bc.span)
            fb.emitTrap(bc.span)
            // Dead block after trap
            const dead = fb.newBlock("panic.dead")
            fb.setBlock(dead)
            return null_node
        }

        // @trap
        if (kind == BuiltinKind.trap) {
            fb.emitTrap(bc.span)
            const dead = fb.newBlock("trap.dead")
            fb.setBlock(dead)
            return null_node
        }

        // @has_field — comptime check
        if (kind == BuiltinKind.has_field) {
            if (bc.args.count >= 1) {
                const type_arg = self.resolveTypeNode(bc.type_arg)
                var field_name = ""
                switch (self.tree.getNode(bc.args.get(0))) { Node.expr |e| => switch (e) {
                    Expr.literal |l| => { if (l.kind == LiteralKind.@"string") { field_name = l.value } },
                    else => {},
                }, else => {} }
                const field_idx = self.findStructFieldIdx(type_arg, field_name)
                const val = if (field_idx >= 0) { 1 } else { 0 }
                return fb.emitConstInt(val, BOOL, bc.span)
            }
            return fb.emitConstBool(false, bc.span)
        }

        // @tag_name — enum tag to string, if-chain over variants
        if (kind == BuiltinKind.tag_name) {
            return self.lowerTagName(bc)
        }

        // @error_name — error set variant to string
        if (kind == BuiltinKind.error_name) {
            return self.lowerErrorName(bc)
        }

        // @embed_file — compile-time file read
        if (kind == BuiltinKind.embed_file) {
            if (bc.args.count > 0) {
                // Extract path from string literal argument
                var raw_path = ""
                var found_path = false
                switch (self.tree.getNode(bc.args.get(0))) { Node.expr |e| => switch (e) {
                    Expr.literal |lit| => {
                        if (lit.kind == LiteralKind.@"string") {
                            raw_path = lit.value
                            found_path = true
                        }
                    },
                    else => {},
                }, else => {} }

                if (found_path) {
                    // Strip quotes
                    var rel_path = raw_path
                    if (raw_path.len >= 2 and raw_path[0] == 34 and raw_path[raw_path.len - 1] == 34) {
                        rel_path = substring(raw_path, 1, raw_path.len - 1)
                    }
                    // Read file content
                    const content = readFile(rel_path) catch {
                        const str_idx = fb.addStringLiteral("")
                        return fb.emitConstSlice(str_idx, bc.span)
                    }
                    const str_idx = fb.addStringLiteral(content)
                    return fb.emitConstSlice(str_idx, bc.span)
                }
            }
            const empty_idx = fb.addStringLiteral("")
            return fb.emitConstSlice(empty_idx, bc.span)
        }

        // @type_name, @enum_name, @type_info — comptime
        if (kind == BuiltinKind.type_name) {
            const type_arg = self.resolveTypeNode(bc.type_arg)
            const name = self.types.typeName(type_arg)
            const str_idx = fb.addStringLiteral(name)
            return fb.emitConstSlice(str_idx, bc.span)
        }
        if (kind == BuiltinKind.enum_name) {
            return self.lowerTagName(bc)  // Same as @tag_name
        }

        return null_node
    }

    /// Emit test assert failure: return error union with tag=1
    fn emitTestAssertFail(span: Span) void {
        const fb = self.builder.func() orelse return null_node
        const eu_type = self.types.makeErrorUnion(VOID)
        const eu_size = self.types.sizeOf(eu_type)
        const tmp = fb.addLocalWithSize("__test_fail", eu_type, false, eu_size)
        const one = fb.emitConstInt(1, I64, span)
        fb.emitStoreLocalField(tmp, 0, 0, one, span)
        const err_idx = fb.emitConstInt(1, I64, span)
        fb.emitStoreLocalField(tmp, 1, 8, err_idx, span)
        const ret_ptr = fb.emitAddrLocal(tmp, I64, span)
        self.emitCleanups(0)
        fb.emitRet(ret_ptr, span)
    }

    /// Emit panic for assert failure: write message to stderr + exit + trap
    fn emitAssertPanic(msg: string, span: Span) void {
        const fb = self.builder.func() orelse return null_node
        const str_idx = fb.addStringLiteral(msg)
        const str_val = fb.emitConstSlice(str_idx, span)
        const ptr = fb.emitSlicePtr(str_val, I64, span)
        const len = fb.emitSliceLen(str_val, span)
        const fd = fb.emitConstInt(2, I64, span)
        var args: List(int) = .{}
        args.append(fd)
        args.append(ptr)
        args.append(len)
        fb.emitCall("write", args, false, I64, span)

        // Newline
        const nl_idx = fb.addStringLiteral("\n")
        const nl_val = fb.emitConstSlice(nl_idx, span)
        const nl_ptr = fb.emitSlicePtr(nl_val, I64, span)
        const nl_len = fb.emitConstInt(1, I64, span)
        var nl_args: List(int) = .{}
        nl_args.append(fd)
        nl_args.append(nl_ptr)
        nl_args.append(nl_len)
        fb.emitCall("write", nl_args, false, I64, span)

        var exit_args: List(int) = .{}
        exit_args.append(fb.emitConstInt(2, I64, span))
        fb.emitCall("exit", exit_args, false, VOID, span)
        fb.emitTrap(span)
    }

    /// @tag_name: enum value → string name via if-chain
    fn lowerTagName(bc: BuiltinCallExpr) int {
        const fb = self.builder.func() orelse return null_node
        if (bc.args.count == 0) { return null_node }
        const val = self.lowerExprNode(bc.args.get(0))
        if (val == null_node) { return null_node }

        const enum_type = self.inferExprType(bc.args.get(0))
        const enum_info = self.types.get(enum_type)
        if (enum_info.tag != TAG_ENUM) { return null_node }

        // Store to local for re-use across branches
        const val_local = fb.addLocalWithSize("__tag_val", I64, false, 8)
        fb.emitStoreLocal(val_local, val, bc.span)

        const result_local = fb.addLocalWithSize("__tag_name", STRING, true, 16)
        const merge_block = fb.newBlock("tagname.end")

        switch (enum_info) {
            Type.enum_type |et| => {
                for i in 0..et.variant_count {
                    const v = et.getVariant(i)
                    const case_block = fb.newBlock("tagname.case")
                    const next_block = fb.newBlock("tagname.next")

                    const cur = fb.emitLoadLocal(val_local, I64, bc.span)
                    const variant_val = fb.emitConstInt(v.value, I64, bc.span)
                    const cond = fb.emitBinary(BinaryOp.eq, cur, variant_val, BOOL, bc.span)
                    fb.emitBranch(cond, case_block, next_block, bc.span)

                    fb.setBlock(case_block)
                    const str_idx = fb.addStringLiteral(v.name)
                    const str_val = fb.emitConstSlice(str_idx, bc.span)
                    fb.emitStoreLocal(result_local, str_val, bc.span)
                    fb.emitJump(merge_block, bc.span)

                    fb.setBlock(next_block)
                }
            },
            else => {},
        }

        // Default: empty string
        const empty_idx = fb.addStringLiteral("")
        const empty_val = fb.emitConstSlice(empty_idx, bc.span)
        fb.emitStoreLocal(result_local, empty_val, bc.span)
        fb.emitJump(merge_block, bc.span)

        fb.setBlock(merge_block)
        return fb.emitLoadLocal(result_local, STRING, bc.span)
    }

    /// @error_name: error value → string name
    /// Note: Map iteration not yet available in Cot — use runtime call instead
    fn lowerErrorName(bc: BuiltinCallExpr) int {
        const fb = self.builder.func() orelse return null_node
        if (bc.args.count == 0) { return null_node }
        const val = self.lowerExprNode(bc.args.get(0))
        if (val == null_node) { return null_node }

        // Call runtime error_name function
        var args: List(int) = .{}
        args.append(val)
        return fb.emitCall("error_name", args, false, STRING, bc.span)
    }

    // ========================================================================
    // Switch expression
    // ========================================================================

    fn lowerSwitchExpr(se: SwitchExpr, idx: int) int {
        // Dispatch to the right implementation
        const subject_type = self.inferExprType(se.subject)
        const result_type = self.inferExprType(idx)
        const subject_info = self.types.get(subject_type)

        // Union switch
        if (subject_info.tag == TAG_UNION) {
            return self.lowerUnionSwitch(se, idx)
        }

        // Void result → statement form
        if (result_type == VOID) {
            self.lowerSwitchStatement(se)
            return null_node
        }

        // Select arms with calls must use block-based lowering (branches, not selects).
        // Select-based lowering eagerly evaluates ALL arm bodies — wrong for side effects.
        if (self.switchArmsHaveCalls(se)) {
            return self.lowerSwitchValueBlocks(se, idx)
        }
        // Compound optionals can't use select (16-byte values)
        const result_info = self.types.get(result_type)
        if (result_info.tag == TAG_OPTIONAL and !self.isPtrLikeOptional(result_type)) {
            return self.lowerSwitchValueBlocks(se, idx)
        }
        return self.lowerSwitchAsSelect(se, result_type)
    }

    /// Conservative check: do any switch arms potentially have side effects?
    fn switchArmsHaveCalls(se: SwitchExpr) bool {
        for i in 0..se.cases.count {
            const case_idx = se.cases.get(i)
            if (self.exprMayHaveSideEffects(case_idx)) { return true }
        }
        if (se.else_body != null_node) {
            if (self.exprMayHaveSideEffects(se.else_body)) { return true }
        }
        return false
    }

    /// Returns true for calls, blocks, and other non-pure expressions.
    fn exprMayHaveSideEffects(idx: int) bool {
        if (idx == null_node) { return false }
        switch (self.tree.getNode(idx)) {
            Node.expr |e| => {
                return switch (e) {
                    Expr.call |_| => true,
                    Expr.builtin_call |_| => true,
                    Expr.block_expr |_| => true,
                    Expr.switch_case_node |sc| => self.exprMayHaveSideEffects(sc.body),
                    else => false,
                }
            },
            else => { return true },  // Statement bodies may have side effects
        }
    }

    /// Switch as select — optimized path for simple expression switches.
    /// Builds nested emitSelect chains instead of block-based branching.
    /// Ref: lower.zig:6853-6917
    fn lowerSwitchAsSelect(se: SwitchExpr, result_type: int) int {
        const fb = self.builder.func() orelse return null_node
        // Set current enum type for .variant shorthand resolution
        const old_switch_enum = self.current_switch_enum_type
        const sel_subject_type = self.inferExprType(se.subject)
        if (self.types.get(sel_subject_type).tag == TAG_ENUM) {
            self.current_switch_enum_type = sel_subject_type
        }
        const subject = self.lowerExprNode(se.subject)

        // String switch: pre-extract ptr/len
        const is_string_switch = (sel_subject_type == STRING)
        var subject_ptr = null_node
        var subject_len = null_node
        if (is_string_switch) {
            const ptr_type = self.types.makePointer(U8)
            subject_ptr = fb.emitSlicePtr(subject, ptr_type, se.span)
            subject_len = fb.emitSliceLen(subject, se.span)
        }

        // Start with else arm as initial result
        var result = null_node
        if (se.else_body != null_node) {
            result = self.lowerExprNode(se.else_body)
        }
        if (result == null_node) {
            result = fb.emitConstInt(0, result_type, se.span)
        }

        // Build nested selects in reverse case order
        var i = se.cases.count
        while (i > 0) {
            i = i - 1
            const case_idx = se.cases.get(i)
            var sc: SwitchCaseNode = undefined
            var found = false
            switch (self.tree.getNode(case_idx)) { Node.expr |e| => switch (e) {
                Expr.switch_case_node |c| => { sc = c; found = true },
                else => {},
            }, else => {} }
            if (!found) { continue }

            var case_cond = null_node

            if (sc.is_range and sc.patterns.count >= 2) {
                // Range pattern in expression form
                const range_start = self.lowerExprNode(sc.patterns.get(0))
                const range_end = self.lowerExprNode(sc.patterns.get(1))
                const ge_cond = fb.emitBinary(BinaryOp.ge, subject, range_start, BOOL, se.span)
                const le_cond = fb.emitBinary(BinaryOp.le, subject, range_end, BOOL, se.span)
                case_cond = fb.emitBinary(BinaryOp.@"and", ge_cond, le_cond, BOOL, se.span)
            } else {
                for p in 0..sc.patterns.count {
                    const pat_idx = sc.patterns.get(p)
                    const pattern_val = self.lowerExprNode(pat_idx)
                    if (pattern_val == null_node) { continue }
                    var pattern_cond = null_node
                    if (is_string_switch) {
                        const ptr_type = self.types.makePointer(U8)
                        const p_ptr = fb.emitSlicePtr(pattern_val, ptr_type, se.span)
                        const p_len = fb.emitSliceLen(pattern_val, se.span)
                        var eq_args: List(int) = .{}
                        eq_args.append(subject_ptr)
                        eq_args.append(subject_len)
                        eq_args.append(p_ptr)
                        eq_args.append(p_len)
                        const eq_result = fb.emitCall("string_eq", eq_args, false, I64, se.span)
                        const zero = fb.emitConstInt(0, I64, se.span)
                        pattern_cond = fb.emitBinary(BinaryOp.ne, eq_result, zero, BOOL, se.span)
                    } else {
                        pattern_cond = fb.emitBinary(BinaryOp.eq, subject, pattern_val, BOOL, se.span)
                    }
                    if (case_cond == null_node) {
                        case_cond = pattern_cond
                    } else {
                        case_cond = fb.emitBinary(BinaryOp.@"or", case_cond, pattern_cond, BOOL, se.span)
                    }
                }
            }

            // Guard in expression form
            if (sc.guard != null_node and case_cond != null_node) {
                const guard_cond = self.lowerExprNode(sc.guard)
                case_cond = fb.emitBinary(BinaryOp.@"and", case_cond, guard_cond, BOOL, se.span)
            }

            const case_val = self.lowerExprNode(sc.body)
            // noreturn arms return null_node — skip select
            if (case_val == null_node) { continue }
            if (case_cond != null_node) {
                result = fb.emitSelect(case_cond, case_val, result, result_type, se.span)
            }
        }

        self.current_switch_enum_type = old_switch_enum
        return result
    }

    /// Switch statement (void result) — if-chain over cases
    fn lowerSwitchStatement(se: SwitchExpr) void {
        const fb = self.builder.func() orelse return null_node
        const subject = self.lowerExprNode(se.subject)
        if (subject == null_node) { return }

        // Store subject to local for re-use
        const subject_type = self.inferExprType(se.subject)
        const subject_local = fb.addLocalWithSize("__switch_subj", subject_type, false, self.types.sizeOf(subject_type))
        fb.emitStoreLocal(subject_local, subject, se.span)

        const merge_block = fb.newBlock("switch.end")

        for i in 0..se.cases.count {
            const case_idx = se.cases.get(i)
            var sc: SwitchCaseNode = undefined
            var found = false
            switch (self.tree.getNode(case_idx)) { Node.expr |e| => switch (e) {
                Expr.switch_case_node |c| => { sc = c; found = true },
                else => {},
            }, else => {} }
            if (!found) { continue }

            const case_block = fb.newBlock("switch.case")
            // Match Zig compiler: last case reuses merge_block (or else_block) instead of creating extra block
            var next_block = merge_block
            if (i + 1 < se.cases.count) {
                next_block = fb.newBlock("switch.next")
            } else if (se.else_body != null_node) {
                next_block = fb.newBlock("switch.else")
            }

            // Build condition: OR of all pattern matches
            var case_cond = null_node
            for p in 0..sc.patterns.count {
                const pat_idx = sc.patterns.get(p)
                const pat_val = self.lowerExprNode(pat_idx)
                if (pat_val == null_node) { continue }
                const subj = fb.emitLoadLocal(subject_local, subject_type, se.span)
                var match_cond = null_node

                if (subject_type == STRING) {
                    // String comparison
                    match_cond = self.emitStringEqual(subj, pat_val, se.span)
                } else {
                    match_cond = fb.emitBinary(BinaryOp.eq, subj, pat_val, BOOL, se.span)
                }

                if (case_cond == null_node) {
                    case_cond = match_cond
                } else {
                    case_cond = fb.emitBinary(BinaryOp.@"or", case_cond, match_cond, BOOL, se.span)
                }
            }

            // Guard
            if (sc.guard != null_node and case_cond != null_node) {
                const guard_cond = self.lowerExprNode(sc.guard)
                if (guard_cond != null_node) {
                    case_cond = fb.emitBinary(BinaryOp.@"and", case_cond, guard_cond, BOOL, se.span)
                }
            }

            if (case_cond != null_node) {
                fb.emitBranch(case_cond, case_block, next_block, se.span)
            } else {
                fb.emitJump(next_block, se.span)
            }

            fb.setBlock(case_block)
            if (sc.body != null_node) {
                self.lowerBlockNode(sc.body)
            }
            if (fb.needsTerminator()) {
                fb.emitJump(merge_block, se.span)
            }

            fb.setBlock(next_block)
        }

        // Else body
        if (se.else_body != null_node) {
            self.lowerBlockNode(se.else_body)
        }
        if (fb.needsTerminator()) {
            fb.emitJump(merge_block, se.span)
        }

        fb.setBlock(merge_block)
    }

    /// Union switch: extract tag, match variants, bind payloads
    fn lowerUnionSwitch(se: SwitchExpr, idx: int) int {
        const fb = self.builder.func() orelse return null_node
        // WasmGC path: use ref.test for dispatch
        if (self.gc_mode) {
            return self.lowerUnionSwitchGC(se, idx)
        }

        const subject = self.lowerExprNode(se.subject)
        if (subject == null_node) { return null_node }

        const subject_type = self.inferExprType(se.subject)
        const result_type = self.inferExprType(idx)
        const union_size = self.types.sizeOf(subject_type)

        // Store subject for multi-access
        const subject_local = fb.addLocalWithSize("__union_subj", subject_type, false, union_size)
        fb.emitStoreLocal(subject_local, subject, se.span)

        // Extract tag at offset 0
        const tag = fb.emitFieldLocal(subject_local, 0, 0, I64, se.span)
        const tag_local = fb.addLocalWithSize("__union_tag", I64, false, 8)
        fb.emitStoreLocal(tag_local, tag, se.span)

        var result_local = null_local
        if (result_type != VOID) {
            result_local = fb.addLocalWithSize("__switch_result", result_type, true, self.types.sizeOf(result_type))
        }

        const merge_block = fb.newBlock("switch.end")

        for i in 0..se.cases.count {
            const case_idx = se.cases.get(i)
            var sc: SwitchCaseNode = undefined
            var found = false
            switch (self.tree.getNode(case_idx)) { Node.expr |e| => switch (e) {
                Expr.switch_case_node |c| => { sc = c; found = true },
                else => {},
            }, else => {} }
            if (!found) { continue }

            const case_block = fb.newBlock("union.case")
            // Match Zig compiler: last case reuses merge_block (or else_block) instead of creating extra block
            var next_block = merge_block
            if (i + 1 < se.cases.count) {
                next_block = fb.newBlock("union.next")
            } else if (se.else_body != null_node) {
                next_block = fb.newBlock("union.else")
            }

            // Match on tag value — find variant index from pattern
            var case_cond = null_node
            for p in 0..sc.patterns.count {
                // Pattern is typically an ident or field_access — resolve to variant index
                const pat_idx = sc.patterns.get(p)
                const variant_idx = self.resolveUnionVariantIndex(subject_type, pat_idx)
                if (variant_idx >= 0) {
                    const cur_tag = fb.emitLoadLocal(tag_local, I64, se.span)
                    const expected = fb.emitConstInt(variant_idx, I64, se.span)
                    const match_cond = fb.emitBinary(BinaryOp.eq, cur_tag, expected, BOOL, se.span)
                    if (case_cond == null_node) {
                        case_cond = match_cond
                    } else {
                        case_cond = fb.emitBinary(BinaryOp.@"or", case_cond, match_cond, BOOL, se.span)
                    }
                }
            }

            if (case_cond != null_node) {
                fb.emitBranch(case_cond, case_block, next_block, se.span)
            } else {
                fb.emitJump(next_block, se.span)
            }

            fb.setBlock(case_block)
            const scope_depth = fb.markScopeEntry()

            // Capture handling: bind payload
            if (sc.capture != "") {
                // Payload starts at offset 8
                const payload_type = self.resolveUnionPayloadType(subject_type, sc.patterns)
                const cap_size = self.types.sizeOf(payload_type)
                const cap_local = fb.addLocalWithSize(sc.capture, payload_type, false, cap_size)
                // Load payload from subject_local at offset 8
                const payload = fb.emitFieldLocal(subject_local, 1, 8, payload_type, se.span)
                fb.emitStoreLocal(cap_local, payload, se.span)
            }

            if (sc.body != null_node) {
                if (result_type != VOID) {
                    const body_val = self.lowerExprNode(sc.body)
                    if (body_val != null_node and result_local != null_local) {
                        fb.emitStoreLocal(result_local, body_val, se.span)
                    }
                } else {
                    self.lowerBlockNode(sc.body)
                }
            }

            fb.restoreScope(scope_depth)
            if (fb.needsTerminator()) {
                fb.emitJump(merge_block, se.span)
            }

            fb.setBlock(next_block)
        }

        // Else body
        if (se.else_body != null_node) {
            if (result_type != VOID) {
                const else_val = self.lowerExprNode(se.else_body)
                if (else_val != null_node and result_local != null_local) {
                    fb.emitStoreLocal(result_local, else_val, se.span)
                }
            } else {
                self.lowerBlockNode(se.else_body)
            }
        }
        if (fb.needsTerminator()) {
            fb.emitJump(merge_block, se.span)
        }

        fb.setBlock(merge_block)
        if (result_type != VOID and result_local != null_local) {
            return fb.emitLoadLocal(result_local, result_type, se.span)
        }
        return null_node
    }

    /// WasmGC union switch: use ref.test for dispatch, ref.cast + struct.get for capture.
    fn lowerUnionSwitchGC(se: SwitchExpr, idx: int) int {
        const fb = self.builder.func() orelse return null_node
        const subject_ref = self.lowerExprNode(se.subject)
        if (subject_ref == null_node) { return null_node }

        const subject_type = self.inferExprType(se.subject)
        const result_type = self.inferExprType(idx)

        var result_local = null_local
        if (result_type != VOID) {
            result_local = fb.addLocalWithSize("__switch_result", result_type, true, self.types.sizeOf(result_type))
        }

        const merge_block = fb.newBlock("switch.end")

        // Get union type info
        const ut_info = self.types.get(subject_type)

        for i in 0..se.cases.count {
            const case_idx = se.cases.get(i)
            var sc: SwitchCaseNode = undefined
            var found = false
            switch (self.tree.getNode(case_idx)) { Node.expr |e| => switch (e) {
                Expr.switch_case_node |c| => { sc = c; found = true },
                else => {},
            }, else => {} }
            if (!found) { continue }

            const case_block = fb.newBlock("union.gc.case")
            // Match Zig compiler: last case reuses merge_block (or else_block) instead of creating extra block
            var next_block = merge_block
            if (i + 1 < se.cases.count) {
                next_block = fb.newBlock("union.gc.next")
            } else if (se.else_body != null_node) {
                next_block = fb.newBlock("union.gc.else")
            }

            // Match using ref.test for each pattern
            var case_cond = null_node
            for p in 0..sc.patterns.count {
                const pat_idx = sc.patterns.get(p)
                const variant_idx = self.resolveUnionVariantIndex(subject_type, pat_idx)
                if (variant_idx >= 0) {
                    switch (ut_info) { Type.union_type |ut| => {
                        const v = ut.getVariant(variant_idx)
                        const variant_name = "__union_" ++ ut.name ++ "_" ++ v.name
                        const test_val = fb.emitGcRefTest(subject_ref, variant_name, se.span)
                        if (case_cond == null_node) {
                            case_cond = test_val
                        } else {
                            case_cond = fb.emitBinary(BinaryOp.@"or", case_cond, test_val, BOOL, se.span)
                        }
                    }, else => {} }
                }
            }

            if (case_cond != null_node) {
                fb.emitBranch(case_cond, case_block, next_block, se.span)
            } else {
                fb.emitJump(next_block, se.span)
            }

            fb.setBlock(case_block)
            const scope_depth = fb.markScopeEntry()

            // Capture handling: ref.cast + struct.get
            if (sc.capture != "") {
                const payload_type = self.resolveUnionPayloadType(subject_type, sc.patterns)
                const cap_size = self.types.sizeOf(payload_type)
                const cap_local = fb.addLocalWithSize(sc.capture, payload_type, false, cap_size)

                // Get variant name for cast
                const first_vidx = self.resolveUnionVariantIndex(subject_type, sc.patterns.get(0))
                if (first_vidx >= 0) {
                    switch (ut_info) { Type.union_type |ut| => {
                        const v = ut.getVariant(first_vidx)
                        if (v.payload_type != VOID) {
                            const variant_name = "__union_" ++ ut.name ++ "_" ++ v.name
                            const casted = fb.emitGcRefCast(subject_ref, variant_name, subject_type, se.span)
                            const payload_val = fb.emitGcStructGet(casted, variant_name, 0, payload_type, se.span)
                            fb.emitStoreLocal(cap_local, payload_val, se.span)
                        }
                    }, else => {} }
                }
            }

            if (sc.body != null_node) {
                if (result_type != VOID) {
                    const body_val = self.lowerExprNode(sc.body)
                    if (body_val != null_node and result_local != null_local) {
                        fb.emitStoreLocal(result_local, body_val, se.span)
                    }
                } else {
                    self.lowerBlockNode(sc.body)
                }
            }

            fb.restoreScope(scope_depth)
            if (fb.needsTerminator()) {
                fb.emitJump(merge_block, se.span)
            }

            fb.setBlock(next_block)
        }

        // Else body
        if (se.else_body != null_node) {
            if (result_type != VOID) {
                const else_val = self.lowerExprNode(se.else_body)
                if (else_val != null_node and result_local != null_local) {
                    fb.emitStoreLocal(result_local, else_val, se.span)
                }
            } else {
                self.lowerBlockNode(se.else_body)
            }
        }
        if (fb.needsTerminator()) {
            fb.emitJump(merge_block, se.span)
        }

        fb.setBlock(merge_block)
        if (result_type != VOID and result_local != null_local) {
            return fb.emitLoadLocal(result_local, result_type, se.span)
        }
        return null_node
    }

    /// Block-based switch for expressions with side effects
    fn lowerSwitchValueBlocks(se: SwitchExpr, idx: int) int {
        const fb = self.builder.func() orelse return null_node
        const subject = self.lowerExprNode(se.subject)
        if (subject == null_node) { return null_node }

        const subject_type = self.inferExprType(se.subject)
        const result_type = self.inferExprType(idx)

        const subject_local = fb.addLocalWithSize("__switch_subj", subject_type, false, self.types.sizeOf(subject_type))
        fb.emitStoreLocal(subject_local, subject, se.span)

        const result_local = fb.addLocalWithSize("__switch_result", result_type, true, self.types.sizeOf(result_type))
        const merge_block = fb.newBlock("switch.end")

        for i in 0..se.cases.count {
            const case_idx = se.cases.get(i)
            var sc: SwitchCaseNode = undefined
            var found = false
            switch (self.tree.getNode(case_idx)) { Node.expr |e| => switch (e) {
                Expr.switch_case_node |c| => { sc = c; found = true },
                else => {},
            }, else => {} }
            if (!found) { continue }

            const case_block = fb.newBlock("switch.case")
            // Match Zig compiler: last case reuses merge_block (or else_block) instead of creating extra block
            var next_block = merge_block
            if (i + 1 < se.cases.count) {
                next_block = fb.newBlock("switch.next")
            } else if (se.else_body != null_node) {
                next_block = fb.newBlock("switch.else")
            }

            var case_cond = null_node
            for p in 0..sc.patterns.count {
                const pat_idx = sc.patterns.get(p)
                const pat_val = self.lowerExprNode(pat_idx)
                if (pat_val == null_node) { continue }
                const subj = fb.emitLoadLocal(subject_local, subject_type, se.span)
                var match_cond = null_node
                if (subject_type == STRING) {
                    match_cond = self.emitStringEqual(subj, pat_val, se.span)
                } else {
                    match_cond = fb.emitBinary(BinaryOp.eq, subj, pat_val, BOOL, se.span)
                }
                if (case_cond == null_node) {
                    case_cond = match_cond
                } else {
                    case_cond = fb.emitBinary(BinaryOp.@"or", case_cond, match_cond, BOOL, se.span)
                }
            }

            if (case_cond != null_node) {
                fb.emitBranch(case_cond, case_block, next_block, se.span)
            } else {
                fb.emitJump(next_block, se.span)
            }

            fb.setBlock(case_block)
            if (sc.body != null_node) {
                const val = self.lowerExprNode(sc.body)
                if (val != null_node) {
                    fb.emitStoreLocal(result_local, val, se.span)
                }
            }
            if (fb.needsTerminator()) {
                fb.emitJump(merge_block, se.span)
            }

            fb.setBlock(next_block)
        }

        // Else
        if (se.else_body != null_node) {
            const else_val = self.lowerExprNode(se.else_body)
            if (else_val != null_node) {
                fb.emitStoreLocal(result_local, else_val, se.span)
            }
        }
        if (fb.needsTerminator()) {
            fb.emitJump(merge_block, se.span)
        }

        fb.setBlock(merge_block)
        return fb.emitLoadLocal(result_local, result_type, se.span)
    }

    // ========================================================================
    // New expression (heap allocation)
    // ========================================================================

    fn lowerNewExpr(ne: NewExpr, idx: int) int {
        const fb = self.builder.func() orelse return null_node
        // Resolve struct type
        var struct_type_idx = self.inferExprType(idx)
        if (struct_type_idx == VOID or struct_type_idx == invalid_type) {
            const looked_up = self.types.lookupByName(ne.type_name)
            if (looked_up >= 0) { struct_type_idx = looked_up }
        }
        if (struct_type_idx == VOID or struct_type_idx == invalid_type) { return null_node }

        // Get the actual struct type (unwrap pointer if needed)
        var payload_type = struct_type_idx
        const type_info = self.types.get(struct_type_idx)
        if (type_info.tag == TAG_POINTER) {
            switch (type_info) { Type.pointer |p| => { payload_type = p.elem }, else => {} }
        }

        const payload_size = self.types.sizeOf(payload_type)
        const header_size = 32  // ARC_HEADER_SIZE with magic guard
        const total_size = header_size + payload_size

        // ARC Phase 4: Queue synthetic deinit for structs with ARC fields but no user deinit
        const metadata_name = ne.type_name
        const payload_info = self.types.get(payload_type)
        if (payload_info.tag == TAG_STRUCT) {
            var has_arc_fields = false
            switch (payload_info) {
                Type.struct_type |st| => {
                    for fi in 0..st.field_count {
                        const field = st.getField(fi)
                        if (self.types.couldBeARC(field.type_idx)) {
                            has_arc_fields = true
                            break
                        }
                    }
                },
                else => {},
            }
            if (has_arc_fields and self.types.lookupMethod(metadata_name, "deinit") < 0) {
                var already_queued = false
                for qi in 0..self.pending_auto_deinits.count {
                    if (self.pending_auto_deinits.get(qi) == metadata_name) {
                        already_queued = true
                        break
                    }
                }
                if (!already_queued) {
                    self.pending_auto_deinits.append(metadata_name)
                }
            }
        }

        // Emit type metadata + alloc
        const qualified_metadata = self.qualifyTypeName(metadata_name)
        const metadata = fb.emitTypeMetadata(qualified_metadata, ne.span)
        const size_val = fb.emitConstInt(total_size, I64, ne.span)
        var alloc_args: List(int) = .{}
        alloc_args.append(metadata)
        alloc_args.append(size_val)
        const ptr = fb.emitCall("alloc", alloc_args, false, I64, ne.span)

        // Store in temp local for multi-access
        const ptr_local = fb.addLocalWithSize("__new_ptr", I64, false, 8)
        fb.emitStoreLocal(ptr_local, ptr, ne.span)

        // Initialize fields
        for i in 0..ne.fields.count {
            const field_init_idx = ne.fields.get(i)
            var fi_name = ""
            var fi_value = null_node
            var fi_found = false
            switch (self.tree.getNode(field_init_idx)) { Node.expr |e| => switch (e) {
                Expr.field_init_node |fi| => { fi_name = fi.name; fi_value = fi.value; fi_found = true },
                else => {},
            }, else => {} }

            if (fi_found) {
                const field_idx = self.findStructFieldIdx(payload_type, fi_name)
                if (field_idx >= 0) {
                    if (self.getStructField(payload_type, field_idx)) |field| {
                        const val = self.lowerExprNode(fi_value)
                        if (val != null_node) {
                            const base_ptr = fb.emitLoadLocal(ptr_local, I64, ne.span)
                            const offset_val = fb.emitConstInt(field.offset, I64, ne.span)
                            const field_addr = fb.emitBinary(BinaryOp.add, base_ptr, offset_val, I64, ne.span)

                            // String/slice decomposition
                            if (field.type_idx == STRING or self.types.get(field.type_idx).tag == TAG_SLICE) {
                                const ptr_part = fb.emitSlicePtr(val, I64, ne.span)
                                fb.emitPtrStoreValue(field_addr, ptr_part, ne.span)
                                const len_part = fb.emitSliceLen(val, ne.span)
                                const len_addr = fb.emitBinary(BinaryOp.add, field_addr, fb.emitConstInt(8, I64, ne.span), I64, ne.span)
                                fb.emitPtrStoreValue(len_addr, len_part, ne.span)
                            } else {
                                fb.emitPtrStoreValue(field_addr, val, ne.span)
                            }
                        }
                    }
                }
            }
        }

        // Constructor sugar: call init() after allocation
        if (ne.is_constructor and ne.constructor_args.count > 0) {
            const init_name = ne.type_name ++ "_init"
            var init_args: List(int) = .{}
            const self_ptr = fb.emitLoadLocal(ptr_local, I64, ne.span)
            init_args.append(self_ptr)
            for i in 0..ne.constructor_args.count {
                const arg = self.lowerExprNode(ne.constructor_args.get(i))
                if (arg != null_node) { init_args.append(arg) }
            }
            fb.emitCall(init_name, init_args, false, VOID, ne.span)
        }

        return fb.emitLoadLocal(ptr_local, struct_type_idx, ne.span)
    }

    // ========================================================================
    // Tuple literal
    // ========================================================================

    fn lowerTupleLiteral(tl: TupleLiteral, idx: int) int {
        const fb = self.builder.func() orelse return null_node
        if (tl.elements.count == 0) { return null_node }

        const tuple_type = self.inferExprType(idx)
        const tuple_size = self.types.sizeOf(tuple_type)
        const tmp = fb.addLocalWithSize("__tuple", tuple_type, false, tuple_size)

        var offset = 0
        for i in 0..tl.elements.count {
            const elem_idx = tl.elements.get(i)
            const elem = self.lowerExprNode(elem_idx)
            if (elem != null_node) {
                fb.emitStoreLocalField(tmp, i, offset, elem, tl.span)
            }
            const elem_type = self.inferExprType(elem_idx)
            offset = offset + self.types.sizeOf(elem_type)
        }

        return fb.emitAddrLocal(tmp, tuple_type, tl.span)
    }

    // ========================================================================
    // Struct init as expression (returns value, not stored to local)
    // ========================================================================

    fn lowerStructInitExpr(si: StructInitExpr, node_idx: int) int {
        const fb = self.builder.func() orelse return null_node
        // Resolve struct type — prefer expr_types (per-file scoped) over global name_map
        var struct_type_idx = self.inferExprType(node_idx)
        if (struct_type_idx == VOID or struct_type_idx == invalid_type) {
            if (si.type_name.len > 0) {
                const looked_up = self.types.lookupByName(si.type_name)
                if (looked_up >= 0) { struct_type_idx = looked_up }
            }
        }
        if (struct_type_idx == VOID or struct_type_idx == invalid_type) { return null_node }

        const type_info = self.types.get(struct_type_idx)
        if (type_info.tag != TAG_STRUCT) { return null_node }

        const size = self.types.sizeOf(struct_type_idx)
        const temp_idx = fb.addLocalWithSize("__struct_tmp", struct_type_idx, true, size)

        // Store each explicitly provided field
        switch (type_info) { Type.struct_type |st| => {
            for fi in 0..si.fields.count {
                const field_init_idx = si.fields.get(fi)
                var fi_name = ""
                var fi_value = null_node
                var found = false
                switch (self.tree.getNode(field_init_idx)) { Node.expr |e| => switch (e) {
                    Expr.field_init_node |fnode| => { fi_name = fnode.name; fi_value = fnode.value; found = true },
                    else => {},
                }, else => {} }

                if (found) {
                    for j in 0..st.field_count {
                        const field = st.getField(j)
                        if (field.name == fi_name) {
                            const value_node = self.lowerExprNode(fi_value)
                            const field_type_info = self.types.get(field.type_idx)
                            const is_string_field = (field.type_idx == STRING or field_type_info.tag == TAG_SLICE)
                            if (is_string_field) {
                                const ptr_type = self.types.makePointer(U8)
                                const ptr_ir = fb.emitSlicePtr(value_node, ptr_type, si.span)
                                const len_ir = fb.emitSliceLen(value_node, si.span)
                                fb.emitStoreLocalField(temp_idx, j, field.offset, ptr_ir, si.span)
                                fb.emitStoreLocalField(temp_idx, j + 1, field.offset + 8, len_ir, si.span)
                            } else if (field_type_info.tag == TAG_OPTIONAL and !self.isPtrLikeOptional(field.type_idx)) {
                                self.storeCompoundOptField(temp_idx, j, field.offset, value_node, fi_value, si.span)
                            } else {
                                fb.emitStoreLocalField(temp_idx, j, field.offset, value_node, si.span)
                            }
                            break
                        }
                    }
                }
            }

            // Emit default values for omitted fields
            for di in 0..st.field_count {
                const field = st.getField(di)
                if (field.default_value == null_node) { continue }
                var provided = false
                for fi in 0..si.fields.count {
                    const field_init_idx = si.fields.get(fi)
                    switch (self.tree.getNode(field_init_idx)) { Node.expr |e| => switch (e) {
                        Expr.field_init_node |fnode| => { if (fnode.name == field.name) { provided = true } },
                        else => {},
                    }, else => {} }
                }
                if (provided) { continue }
                const value_node = self.lowerExprNode(field.default_value)
                const field_type_info = self.types.get(field.type_idx)
                const is_string_field = (field.type_idx == STRING or field_type_info.tag == TAG_SLICE)
                if (is_string_field) {
                    const ptr_type = self.types.makePointer(U8)
                    const ptr_ir = fb.emitSlicePtr(value_node, ptr_type, si.span)
                    const len_ir = fb.emitSliceLen(value_node, si.span)
                    fb.emitStoreLocalField(temp_idx, di, field.offset, ptr_ir, si.span)
                    fb.emitStoreLocalField(temp_idx, di + 1, field.offset + 8, len_ir, si.span)
                } else if (field_type_info.tag == TAG_OPTIONAL and !self.isPtrLikeOptional(field.type_idx)) {
                    self.storeCompoundOptField(temp_idx, di, field.offset, value_node, field.default_value, si.span)
                } else {
                    fb.emitStoreLocalField(temp_idx, di, field.offset, value_node, si.span)
                }
            }
        }, else => {} }

        return fb.emitLoadLocal(temp_idx, struct_type_idx, si.span)
    }

    // ========================================================================
    // Array/String/Slice/Union init helpers (store into pre-allocated local)
    // ========================================================================

    fn lowerArrayInit(local_idx: int, value_idx: int, span: Span) void {
        const fb = self.builder.func() orelse return null_node
        switch (self.tree.getNode(value_idx)) { Node.expr |e| => switch (e) {
            Expr.array_literal |al| => {
                if (al.elements.count == 0) { return }
                const local = fb.locals.get(local_idx)
                var elem_type = self.inferExprType(al.elements.get(0))
                const local_info = self.types.get(local.type_idx)
                if (local_info.tag == TAG_ARRAY) {
                    switch (local_info) { Type.array |a| => { elem_type = a.elem }, else => {} }
                }
                const elem_size = self.types.sizeOf(elem_type)
                for i in 0..al.elements.count {
                    const elem_idx = al.elements.get(i)
                    const elem_node = self.lowerExprNode(elem_idx)
                    const idx_node = fb.emitConstInt(i, I64, span)
                    fb.emitStoreIndexLocal(local_idx, idx_node, elem_node, elem_size, span)
                }
            },
            else => {
                const val = self.lowerExprNode(value_idx)
                if (val != null_node) { fb.emitStoreLocal(local_idx, val, span) }
            },
        }, else => {} }
    }

    fn lowerStringInit(local_idx: int, value_idx: int, span: Span) void {
        const fb = self.builder.func() orelse return null_node
        const str_node = self.lowerExprNode(value_idx)
        if (str_node == null_node) { return }
        const ptr_type = self.types.makePointer(U8)
        const ptr_val = fb.emitSlicePtr(str_node, ptr_type, span)
        const len_val = fb.emitSliceLen(str_node, span)
        fb.emitStoreLocalField(local_idx, 0, 0, ptr_val, span)
        fb.emitStoreLocalField(local_idx, 1, 8, len_val, span)
    }

    fn lowerSliceInit(local_idx: int, value_idx: int, slice_type: int, span: Span) void {
        const fb = self.builder.func() orelse return null_node
        const slice_node = self.lowerExprNode(value_idx)
        if (slice_node == null_node) { return }
        const slice_info = self.types.get(slice_type)
        var elem_type = U8
        switch (slice_info) { Type.slice |s| => { elem_type = s.elem }, else => {} }
        const ptr_type = self.types.makePointer(elem_type)
        const ptr_val = fb.emitSlicePtr(slice_node, ptr_type, span)
        const len_val = fb.emitSliceLen(slice_node, span)
        const cap_val = fb.emitSliceCap(slice_node, span)
        fb.emitStoreLocalField(local_idx, 0, 0, ptr_val, span)
        fb.emitStoreLocalField(local_idx, 1, 8, len_val, span)
        fb.emitStoreLocalField(local_idx, 2, 16, cap_val, span)
    }

    fn lowerTupleInit(local_idx: int, value_idx: int, span: Span) void {
        const fb = self.builder.func() orelse return null_node
        switch (self.tree.getNode(value_idx)) { Node.expr |e| => switch (e) {
            Expr.tuple_literal |tl| => {
                const tuple_type_idx = self.inferExprType(value_idx)
                for i in 0..tl.elements.count {
                    const elem_idx = tl.elements.get(i)
                    const value_ir = self.lowerExprNode(elem_idx)
                    const offset = self.types.tupleElementOffset(tuple_type_idx, i)
                    fb.emitStoreLocalField(local_idx, i, offset, value_ir, span)
                }
            },
            else => {},
        }, else => {} }
    }

    fn lowerUnionInit(local_idx: int, value_idx: int, type_idx: int, span: Span) void {
        const fb = self.builder.func() orelse return null_node
        const type_info = self.types.get(type_idx)
        if (type_info.tag != TAG_UNION) { return }

        // WasmGC path: union variants are GC struct subtypes
        if (self.gc_mode) {
            self.lowerUnionInitGC(local_idx, value_idx, type_idx, span)
            return
        }

        // Linear memory path: tag + payload
        switch (self.tree.getNode(value_idx)) { Node.expr |e| => switch (e) {
            Expr.call |call| => {
                // Payload variant: Result.Ok(42) → store tag + payload
                switch (self.tree.getNode(call.callee)) { Node.expr |ce| => switch (ce) {
                    Expr.field_access |fa| => {
                        switch (type_info) { Type.union_type |ut| => {
                            for i in 0..ut.variant_count {
                                const v = ut.getVariant(i)
                                if (v.name == fa.field) {
                                    const tag_val = fb.emitConstInt(i, I64, span)
                                    fb.emitStoreLocalField(local_idx, 0, 0, tag_val, span)
                                    if (call.args.count > 0) {
                                        const payload_val = self.lowerExprNode(call.args.get(0))
                                        fb.emitStoreLocalField(local_idx, 1, 8, payload_val, span)
                                    }
                                    return
                                }
                            }
                        }, else => {} }
                    },
                    else => {},
                }, else => {} }
            },
            Expr.field_access |fa| => {
                // Simple variant (no payload): Result.Err → store tag only
                switch (type_info) { Type.union_type |ut| => {
                    for i in 0..ut.variant_count {
                        const v = ut.getVariant(i)
                        if (v.name == fa.field) {
                            const tag_val = fb.emitConstInt(i, I64, span)
                            fb.emitStoreLocalField(local_idx, 0, 0, tag_val, span)
                            return
                        }
                    }
                }, else => {} }
            },
            else => {
                const val = self.lowerExprNode(value_idx)
                if (val != null_node) { fb.emitStoreLocal(local_idx, val, span) }
            },
        }, else => {} }
    }

    /// WasmGC union init: emit gc_struct_new for the variant subtype.
    fn lowerUnionInitGC(local_idx: int, value_idx: int, type_idx: int, span: Span) void {
        const fb = self.builder.func() orelse return null_node
        const type_info = self.types.get(type_idx)
        switch (type_info) { Type.union_type |ut| => {
            switch (self.tree.getNode(value_idx)) { Node.expr |e| => switch (e) {
                Expr.call |call| => {
                    // Payload variant call: Shape.circle(c)
                    switch (self.tree.getNode(call.callee)) { Node.expr |ce| => switch (ce) {
                        Expr.field_access |fa| => {
                            for i in 0..ut.variant_count {
                                const v = ut.getVariant(i)
                                if (v.name == fa.field) {
                                    const variant_name = "__union_" ++ ut.name ++ "_" ++ v.name
                                    if (call.args.count > 0 and v.payload_type != VOID) {
                                        const payload_val = self.lowerExprNode(call.args.get(0))
                                        var field_values: List(int) = .{}
                                        field_values.append(payload_val)
                                        const ref = fb.emitGcStructNew(variant_name, field_values, type_idx, span)
                                        fb.emitStoreLocal(local_idx, ref, span)
                                    } else {
                                        var empty_fields: List(int) = .{}
                                        const ref = fb.emitGcStructNew(variant_name, empty_fields, type_idx, span)
                                        fb.emitStoreLocal(local_idx, ref, span)
                                    }
                                    return
                                }
                            }
                        },
                        else => {},
                    }, else => {} }
                },
                Expr.field_access |fa| => {
                    // Unit variant: State.Running
                    for i in 0..ut.variant_count {
                        const v = ut.getVariant(i)
                        if (v.name == fa.field) {
                            const variant_name = "__union_" ++ ut.name ++ "_" ++ v.name
                            var empty_fields: List(int) = .{}
                            const ref = fb.emitGcStructNew(variant_name, empty_fields, type_idx, span)
                            fb.emitStoreLocal(local_idx, ref, span)
                            return
                        }
                    }
                },
                else => {
                    const val = self.lowerExprNode(value_idx)
                    if (val != null_node) { fb.emitStoreLocal(local_idx, val, span) }
                },
            }, else => {} }
        }, else => {} }
    }

    // ========================================================================
    // Array/Slice concat operators
    // ========================================================================

    /// Array concat: [N]T ++ [M]T → [N+M]T — element-by-element copy to temp local
    fn lowerArrayConcat(left: int, right: int, left_type_idx: int, right_type_idx: int, span: Span) int {
        const fb = self.builder.func() orelse return null_node
        const left_info = self.types.get(left_type_idx)
        const right_info = self.types.get(right_type_idx)
        if (left_info.tag != TAG_ARRAY or right_info.tag != TAG_ARRAY) { return null_node }

        var elem_type = I64
        var left_len = 0
        var right_len = 0
        switch (left_info) { Type.array |a| => { elem_type = a.elem; left_len = a.length }, else => {} }
        switch (right_info) { Type.array |a| => { right_len = a.length }, else => {} }

        const elem_size = self.types.sizeOf(elem_type)
        const result_len = left_len + right_len
        const result_type = self.types.makeArray(elem_type, result_len)
        const result_size = self.types.sizeOf(result_type)
        const temp_name = "__cat_" ++ intToString(fb.locals.count)
        const local_idx = fb.addLocalWithSize(temp_name, result_type, false, result_size)

        // Copy left array elements
        for i in 0..left_len {
            const idx_node = fb.emitConstInt(i, I64, span)
            const src_elem = fb.emitIndexValue(left, idx_node, elem_size, elem_type, span)
            fb.emitStoreIndexLocal(local_idx, idx_node, src_elem, elem_size, span)
        }
        // Copy right array elements at offset left_len
        for j in 0..right_len {
            const src_idx = fb.emitConstInt(j, I64, span)
            const dst_idx = fb.emitConstInt(left_len + j, I64, span)
            const src_elem = fb.emitIndexValue(right, src_idx, elem_size, elem_type, span)
            fb.emitStoreIndexLocal(local_idx, dst_idx, src_elem, elem_size, span)
        }
        return fb.emitAddrLocal(local_idx, result_type, span)
    }

    /// Slice concat: []T ++ []T → []T — via string_concat runtime (alloc + memcpy)
    fn lowerSliceConcat(left: int, right: int, slice_type_idx: int, span: Span) int {
        const fb = self.builder.func() orelse return null_node
        const slice_info = self.types.get(slice_type_idx)
        var elem_type = U8
        switch (slice_info) { Type.slice |s| => { elem_type = s.elem }, else => {} }
        const elem_size = self.types.sizeOf(elem_type)
        const ptr_type = self.types.makePointer(elem_type)

        // Extract ptr and len from both slices
        const ptr1 = fb.emitSlicePtr(left, ptr_type, span)
        const len1 = fb.emitSliceLen(left, span)
        const ptr2 = fb.emitSlicePtr(right, ptr_type, span)
        const len2 = fb.emitSliceLen(right, span)

        // Convert to byte lengths for string_concat
        const elem_size_node = fb.emitConstInt(elem_size, I64, span)
        const byte_len1 = fb.emitBinary(BinaryOp.mul, len1, elem_size_node, I64, span)
        const byte_len2 = fb.emitBinary(BinaryOp.mul, len2, elem_size_node, I64, span)

        // Alloc + copy via string_concat(ptr1, byte_len1, ptr2, byte_len2)
        var args: List(int) = .{}
        args.append(ptr1)
        args.append(byte_len1)
        args.append(ptr2)
        args.append(byte_len2)
        const new_ptr = fb.emitCall("string_concat", args, false, I64, span)
        const new_len = fb.emitBinary(BinaryOp.add, len1, len2, I64, span)

        // Return slice_header(ptr, len, cap=len)
        return fb.emit(Node.init(Data.slice_header(SliceHeader { ptr: new_ptr, len: new_len, cap: new_len }), slice_type_idx, span))
    }

    // ========================================================================
    // Compound orelse: ?T orelse default → branch on tag
    // ========================================================================

    fn lowerCompoundOrelse(left: int, bin: Binary, left_type_idx: int, result_type: int) int {
        const fb = self.builder.func() orelse return null_node
        const opt_size = self.types.sizeOf(left_type_idx)
        const opt_local = fb.addLocalWithSize("__orelse_opt", left_type_idx, false, opt_size)
        fb.emitStoreLocal(opt_local, left, bin.span)
        const tag = fb.emitFieldLocal(opt_local, 0, 0, I64, bin.span)
        const zero_tag = fb.emitConstInt(0, I64, bin.span)
        const is_non_null = fb.emitBinary(BinaryOp.ne, tag, zero_tag, BOOL, bin.span)

        const result_size = self.types.sizeOf(result_type)
        const result_local = fb.addLocalWithSize("__orelse_result", result_type, false, result_size)
        const then_block = fb.newBlock("orelse.nonnull")
        const else_block = fb.newBlock("orelse.null")
        const merge_block = fb.newBlock("orelse.end")
        fb.emitBranch(is_non_null, then_block, else_block, bin.span)

        // Non-null path: extract payload
        fb.setBlock(then_block)
        var payload_type = result_type
        switch (self.types.get(left_type_idx)) { Type.optional |opt| => { payload_type = opt.elem }, else => {} }
        const payload = fb.emitFieldLocal(opt_local, 1, 8, payload_type, bin.span)
        fb.emitStoreLocal(result_local, payload, bin.span)
        fb.emitJump(merge_block, bin.span)

        // Null path: lower fallback expression
        fb.setBlock(else_block)
        const fallback = self.lowerExprNode(bin.right)
        if (fallback != null_node) {
            fb.emitStoreLocal(result_local, fallback, bin.span)
        }
        fb.emitJump(merge_block, bin.span)

        // Merge: load result
        fb.setBlock(merge_block)
        return fb.emitLoadLocal(result_local, result_type, bin.span)
    }

    // ========================================================================
    // Labeled loop lookup
    // ========================================================================

    fn findLabeledLoop(target_label: string) ?LoopContext {
        var i = self.loop_stack.count - 1
        while (i >= 0) {
            const ctx = self.loop_stack.get(i)
            if (ctx.label == target_label) { return ctx }
            i = i - 1
        }
        return null
    }

    // ========================================================================
    // Error handling helpers
    // ========================================================================

    /// Resolve error pattern to const int or lower as expression.
    /// Used in switch arms for error matching.
    fn resolveErrorPatternOrLower(pattern_idx: int, span: Span) int {
        const fb = self.builder.func() orelse return null_node
        switch (self.tree.getNode(pattern_idx)) { Node.expr |e| => switch (e) {
            Expr.error_literal |el| => {
                const error_idx = self.getGlobalErrorIndex(el.error_name)
                return fb.emitConstInt(error_idx, I64, span)
            },
            else => {},
        }, else => {} }
        return self.lowerExprNode(pattern_idx)
    }

    /// Check if any switch case has a capture variable.
    fn hasCapture(se: SwitchExpr) bool {
        for i in 0..se.cases.count {
            const case_idx = se.cases.get(i)
            switch (self.tree.getNode(case_idx)) { Node.expr |e| => switch (e) {
                Expr.switch_case_node |sc| => {
                    if (sc.capture.len > 0) { return true }
                },
                else => {},
            }, else => {} }
        }
        return false
    }

    /// Store a compound value (string/slice) into a local via field decomposition.
    /// Used in catch blocks where the caught value needs compound storage.
    fn storeCatchCompound(local_idx: int, val: int, span: Span) void {
        const fb = self.builder.func() orelse return null_node
        const ptr_type = self.types.makePointer(U8)
        const ptr_val = fb.emitSlicePtr(val, ptr_type, span)
        const len_val = fb.emitSliceLen(val, span)
        fb.emitStoreLocalField(local_idx, 0, 0, ptr_val, span)
        fb.emitStoreLocalField(local_idx, 1, 8, len_val, span)
    }

    // ========================================================================
    // Function value creation (closure/function pointer)
    // ========================================================================

    fn createFuncValue(func_name: string, type_idx: int, span: Span) int {
        const fb = self.builder.func() orelse return null_node
        const HEAP_HEADER_SIZE = 16
        const payload_size = 8  // one i64 for table_idx
        const total_size = HEAP_HEADER_SIZE + payload_size

        // Allocate closure struct: alloc(0, total_size)
        const metadata_node = fb.emitConstInt(0, I64, span)
        const size_node = fb.emitConstInt(total_size, I64, span)
        var alloc_args: List(int) = .{}
        alloc_args.append(metadata_node)
        alloc_args.append(size_node)
        const alloc_result = fb.emitCall("alloc", alloc_args, false, I64, span)

        // Store result in temp
        const temp_name = "__closure_ptr_" ++ intToString(self.temp_counter)
        self.temp_counter = self.temp_counter + 1
        const temp_idx = fb.addLocalWithSize(temp_name, I64, true, 8)
        fb.emitStoreLocal(temp_idx, alloc_result, span)
        const ptr_node = fb.emitLoadLocal(temp_idx, I64, span)

        // Store func address at offset 0
        const table_idx_node = fb.emitFuncAddr(func_name, type_idx, span)
        fb.emitPtrStoreValue(ptr_node, table_idx_node, span)

        return fb.emitLoadLocal(temp_idx, I64, span)
    }

    // ========================================================================
    // Closure support
    // ========================================================================

    fn lowerClosureExpr(ce: ClosureExpr) int {
        const fb = self.builder.func() orelse return null_node
        // Detect captured variables from parent scope
        var captures: List(CaptureInfo) = .{}
        self.detectCaptures(ce.body, fb, captures)

        // Generate unique name
        const closure_name = "__closure_" ++ intToString(self.closure_counter)
        self.closure_counter = self.closure_counter + 1

        // Save parent function builder state
        const saved_builder_func = self.builder.current_func_ptr

        // Create closure body function
        var return_type = VOID
        if (ce.return_type != null_node) { return_type = self.resolveTypeNode(ce.return_type) }
        self.builder.startFunc(closure_name, VOID, return_type, ce.span)
        if (self.builder.func()) |closure_fb| {
            self.clearPerFunctionState()

            // Add declared params
            for pi in 0..ce.params.count {
                const param_idx = ce.params.get(pi)
                const p_node = self.tree.getNode(param_idx)
                var pname = ""
                var ptype_expr = null_node
                switch (p_node) { Node.expr |e| => switch (e) {
                    Expr.field_def |fd| => { pname = fd.name; ptype_expr = fd.type_expr },
                    else => {},
                }, else => {} }
                const param_type = self.resolveTypeNode(ptype_expr)
                closure_fb.addParam(pname, param_type, self.types.sizeOf(param_type))
            }

            // At function start: read captures from CTXT global
            if (captures.count > 0) {
                const ctxt_ptr = closure_fb.emitWasmGlobalRead(1, I64, ce.span)
                for i in 0..captures.count {
                    const cap = captures.get(i)
                    const offset = (i + 1) * 8
                    const cap_addr = closure_fb.emitAddrOffset(ctxt_ptr, offset, I64, ce.span)
                    const cap_val = closure_fb.emitPtrLoadValue(cap_addr, cap.type_idx, ce.span)
                    const local_idx = closure_fb.addLocalWithSize(cap.name, cap.type_idx, true, 8)
                    closure_fb.emitStoreLocal(local_idx, cap_val, ce.span)
                }
            }

            // Lower body
            if (ce.body != null_node) {
                self.lowerBlockNode(ce.body)
                if (return_type == VOID and closure_fb.needsTerminator()) {
                    self.emitCleanups(0)
                    closure_fb.emitRet(null_node, ce.span)
                }
            }
        }
        self.builder.endFunc()

        // Restore parent function builder
        self.builder.current_func_ptr = saved_builder_func

        // Now in parent function: allocate closure struct [table_idx][cap0][cap1]...
        const num_captures = captures.count
        const payload_size = (1 + num_captures) * 8
        const total_size = 16 + payload_size  // 16 = heap header

        const metadata_node = fb.emitConstInt(0, I64, ce.span)
        const size_node = fb.emitConstInt(total_size, I64, ce.span)
        var alloc_args: List(int) = .{}
        alloc_args.append(metadata_node)
        alloc_args.append(size_node)
        const alloc_result = fb.emitCall("alloc", alloc_args, false, I64, ce.span)

        const temp_idx = fb.addLocalWithSize("__closure_ptr", I64, true, 8)
        fb.emitStoreLocal(temp_idx, alloc_result, ce.span)
        const ptr_node = fb.emitLoadLocal(temp_idx, I64, ce.span)

        // Store table_idx at offset 0
        const func_type = self.inferExprType(0)  // approximate; will be resolved at call site
        const table_idx_node = fb.emitFuncAddr(closure_name, func_type, ce.span)
        fb.emitPtrStoreValue(ptr_node, table_idx_node, ce.span)

        // Store each capture at offset 8, 16, ...
        for i in 0..captures.count {
            const cap = captures.get(i)
            const offset = (i + 1) * 8
            const reload_ptr = fb.emitLoadLocal(temp_idx, I64, ce.span)
            const cap_addr = fb.emitAddrOffset(reload_ptr, offset, I64, ce.span)
            const cap_val = fb.emitLoadLocal(cap.local_idx, cap.type_idx, ce.span)
            fb.emitPtrStoreValue(cap_addr, cap_val, ce.span)
        }

        return fb.emitLoadLocal(temp_idx, I64, ce.span)
    }

    /// Walk AST body to detect captured variables (idents referencing parent's locals).
    fn detectCaptures(body_idx: int, parent_fb: *FuncBuilder, captures: List(CaptureInfo)) void {
        const fb = self.builder.func() orelse return null_node
        if (body_idx == null_node) { return }
        const node = self.tree.getNode(body_idx)
        switch (node) {
            Node.expr |expr| => switch (expr) {
                Expr.ident |id| => {
                    if (parent_fb.lookupLocal(id.name)) |local_idx| {
                        // Don't add duplicates
                        for i in 0..captures.count {
                            if (captures.get(i).name == id.name) { return }
                        }
                        var cap_type = I64
                        if (local_idx < parent_fb.locals.count) {
                            cap_type = parent_fb.locals.get(local_idx).type_idx
                        }
                        captures.append(CaptureInfo { name: id.name, local_idx: local_idx, type_idx: cap_type })
                    }
                },
                Expr.binary |bin| => {
                    self.detectCaptures(bin.left, parent_fb, captures)
                    self.detectCaptures(bin.right, parent_fb, captures)
                },
                Expr.unary |un| => { self.detectCaptures(un.operand, parent_fb, captures) },
                Expr.call |c| => {
                    self.detectCaptures(c.callee, parent_fb, captures)
                    for i in 0..c.args.count {
                        self.detectCaptures(c.args.get(i), parent_fb, captures)
                    }
                },
                Expr.paren |p| => { self.detectCaptures(p.inner, parent_fb, captures) },
                Expr.if_expr |ie| => {
                    self.detectCaptures(ie.condition, parent_fb, captures)
                    self.detectCaptures(ie.then_branch, parent_fb, captures)
                    if (ie.else_branch != null_node) { self.detectCaptures(ie.else_branch, parent_fb, captures) }
                },
                Expr.index_expr |ix| => {
                    self.detectCaptures(ix.base, parent_fb, captures)
                    self.detectCaptures(ix.idx, parent_fb, captures)
                },
                Expr.field_access |fa| => {
                    self.detectCaptures(fa.base, parent_fb, captures)
                },
                Expr.block_expr |b| => {
                    for i in 0..b.stmts.count {
                        self.detectCaptures(b.stmts.get(i), parent_fb, captures)
                    }
                    if (b.result_expr != null_node) { self.detectCaptures(b.result_expr, parent_fb, captures) }
                },
                Expr.spawn_expr |se| => { self.detectCaptures(se.body, parent_fb, captures) },
                Expr.select_expr |se| => {
                    for i in 0..se.cases.count {
                        const sc = self.tree.getSelectCase(se.cases.get(i))
                        self.detectCaptures(sc.channel, parent_fb, captures)
                        if (sc.send_value != null_node) { self.detectCaptures(sc.send_value, parent_fb, captures) }
                        self.detectCaptures(sc.body, parent_fb, captures)
                    }
                    if (se.default_body != null_node) { self.detectCaptures(se.default_body, parent_fb, captures) }
                },
                Expr.catch_expr |ce| => {
                    self.detectCaptures(ce.operand, parent_fb, captures)
                    if (ce.fallback != null_node) { self.detectCaptures(ce.fallback, parent_fb, captures) }
                },
                Expr.orelse_expr |oe| => {
                    self.detectCaptures(oe.operand, parent_fb, captures)
                    if (oe.fallback != null_node) { self.detectCaptures(oe.fallback, parent_fb, captures) }
                },
                else => {},
            },
            Node.stmt |stmt| => switch (stmt) {
                Stmt.expr_stmt |es| => { self.detectCaptures(es.expr, parent_fb, captures) },
                Stmt.return_stmt |rs| => {
                    if (rs.value != null_node) { self.detectCaptures(rs.value, parent_fb, captures) }
                },
                Stmt.var_stmt |vs| => {
                    if (vs.value != null_node) { self.detectCaptures(vs.value, parent_fb, captures) }
                },
                Stmt.assign_stmt |as_stmt| => {
                    self.detectCaptures(as_stmt.target, parent_fb, captures)
                    self.detectCaptures(as_stmt.value, parent_fb, captures)
                },
                Stmt.if_stmt |is| => {
                    self.detectCaptures(is.condition, parent_fb, captures)
                    self.detectCaptures(is.then_branch, parent_fb, captures)
                    if (is.else_branch != null_node) { self.detectCaptures(is.else_branch, parent_fb, captures) }
                },
                Stmt.while_stmt |ws| => {
                    self.detectCaptures(ws.condition, parent_fb, captures)
                    self.detectCaptures(ws.body, parent_fb, captures)
                },
                Stmt.for_stmt |fs| => {
                    if (fs.iterable != null_node) { self.detectCaptures(fs.iterable, parent_fb, captures) }
                    self.detectCaptures(fs.body, parent_fb, captures)
                },
                Stmt.block_stmt |bs| => {
                    for i in 0..bs.stmts.count {
                        self.detectCaptures(bs.stmts.get(i), parent_fb, captures)
                    }
                },
                else => {},
            },
            else => {},
        }
    }

    // ========================================================================
    // Spawn / Select
    // ========================================================================

    /// Lower spawn { body } — fire-and-forget concurrent dispatch.
    /// Copied from lower.zig:6002-6106
    fn lowerSpawnExpr(se: SpawnExpr) int {
        const fb = self.builder.func() orelse return null_node
        // Detect captured variables from parent scope
        var captures: List(CaptureInfo) = .{}
        self.detectCaptures(se.body, fb, captures)

        // Generate unique name
        const spawn_bare = "__spawn_" ++ intToString(self.spawn_counter)
        self.spawn_counter = self.spawn_counter + 1
        const spawn_name = self.qualifyName(spawn_bare)

        // Save parent function builder state
        const saved_builder_func = self.builder.current_func_ptr

        // Create spawn body function: (env_ptr: i64) -> void
        self.builder.startFunc(spawn_name, VOID, VOID, se.span)
        if (self.builder.func()) |spawn_fb| {
            self.clearPerFunctionState()

            // Add env_ptr parameter
            const env_param_idx = spawn_fb.addParam("__env_ptr", I64, 8)

            // Load captures from env_ptr
            if (captures.count > 0) {
                const env_ptr = spawn_fb.emitLoadLocal(env_param_idx, I64, se.span)
                for i in 0..captures.count {
                    const cap = captures.get(i)
                    const offset = i * 8
                    const cap_addr = spawn_fb.emitAddrOffset(env_ptr, offset, I64, se.span)
                    const cap_val = spawn_fb.emitPtrLoadValue(cap_addr, cap.type_idx, se.span)
                    const local_idx = spawn_fb.addLocalWithSize(cap.name, cap.type_idx, true, 8)
                    spawn_fb.emitStoreLocal(local_idx, cap_val, se.span)
                }
            }

            // Lower body block
            if (se.body != null_node) {
                self.lowerBlockNode(se.body)
                if (spawn_fb.needsTerminator()) {
                    self.emitCleanups(0)
                    spawn_fb.emitRet(null_node, se.span)
                }
            }
        }
        self.builder.endFunc()

        // Restore parent function builder
        self.builder.current_func_ptr = saved_builder_func

        // In parent function: allocate env struct and fill captures, then call sched_spawn
        if (captures.count > 0) {
            // Allocate env struct
            const metadata_node = fb.emitConstInt(0, I64, se.span)
            const size_node = fb.emitConstInt(captures.count * 8, I64, se.span)
            var alloc_args: List(int) = .{}
            alloc_args.append(metadata_node)
            alloc_args.append(size_node)
            const alloc_result = fb.emitCall("alloc", alloc_args, false, I64, se.span)

            const temp_name = "__spawn_env_" ++ intToString(self.temp_counter)
            self.temp_counter = self.temp_counter + 1
            const temp_idx = fb.addLocalWithSize(temp_name, I64, true, 8)
            fb.emitStoreLocal(temp_idx, alloc_result, se.span)

            // Fill captures
            for i in 0..captures.count {
                const cap = captures.get(i)
                const offset = i * 8
                const reload_ptr = fb.emitLoadLocal(temp_idx, I64, se.span)
                const cap_addr = fb.emitAddrOffset(reload_ptr, offset, I64, se.span)
                const cap_val = fb.emitLoadLocal(cap.local_idx, cap.type_idx, se.span)
                fb.emitPtrStoreValue(cap_addr, cap_val, se.span)
            }

            // Get func addr and env ptr, call sched_spawn
            const fn_ptr = fb.emitFuncAddr(spawn_name, I64, se.span)
            const env_ptr = fb.emitLoadLocal(temp_idx, I64, se.span)
            var spawn_args: List(int) = .{}
            spawn_args.append(fn_ptr)
            spawn_args.append(env_ptr)
            fb.emitCall("sched_spawn", spawn_args, false, VOID, se.span)
        } else {
            // No captures: env_ptr = 0 (null)
            const fn_ptr = fb.emitFuncAddr(spawn_name, I64, se.span)
            const env_null = fb.emitConstInt(0, I64, se.span)
            var spawn_args: List(int) = .{}
            spawn_args.append(fn_ptr)
            spawn_args.append(env_null)
            fb.emitCall("sched_spawn", spawn_args, false, VOID, se.span)
        }

        return null_node
    }

    /// Lower select expression: Go-style channel select.
    /// Copied from lower.zig:6112-6130
    fn lowerSelectExpr(se: SelectExpr) int {
        if (se.cases.count == 0) {
            // Empty select with just default
            if (se.default_body != null_node) {
                return self.lowerExprNode(se.default_body)
            }
            return null_node
        }

        // Simple path: 1 case + default
        if (se.cases.count == 1 and se.default_body != null_node) {
            const sc = self.tree.getSelectCase(se.cases.get(0))
            return self.lowerSelectSimple(sc, se.default_body, se.span)
        }

        // General N-case path
        return self.lowerSelectGeneral(se)
    }

    /// Lower simple select: 1 channel case + default → tryRecv/trySend + branch
    /// Copied from lower.zig:6133-6274
    fn lowerSelectSimple(sc: SelectCase, default_body: int, span: Span) int {
        const fb = self.builder.func() orelse return null_node
        if (sc.kind == SELECT_RECV) {
            // tmp = ch.tryRecv(); if (tmp != null) { body } else { default }
            const ch = self.lowerExprNode(sc.channel)
            if (ch == null_node) { return null_node }

            // Resolve tryRecv method via type registry (same as lowerMethodCall)
            // Zig reference: lower.zig:6600-6631
            const ch_type_idx = self.inferExprType(sc.channel)
            const ch_info = self.types.get(ch_type_idx)
            var method_name = "tryRecv"
            var opt_type = self.types.makeOptional(I64)
            // Find struct type name for method lookup
            var struct_name = ""
            if (ch_info.tag == TAG_POINTER) {
                switch (ch_info) { Type.pointer |p| => {
                    const pointee = self.types.get(p.elem)
                    if (pointee.tag == TAG_STRUCT) {
                        switch (pointee) { Type.struct_type |st| => { struct_name = st.name }, else => {} }
                    }
                }, else => {} }
            } else if (ch_info.tag == TAG_STRUCT) {
                switch (ch_info) { Type.struct_type |st| => { struct_name = st.name }, else => {} }
            }
            if (struct_name != "") {
                const m_idx = self.types.lookupMethod(struct_name, "tryRecv")
                if (m_idx >= 0) {
                    const m = self.types.getMethodInfo(m_idx)
                    // Qualify name (skip for generic instances)
                    method_name = if (self.lookupGenericInst(m.func_name) != null) {
                        m.func_name
                    } else {
                        self.resolveMethodName(struct_name, m.func_name, m.source_tree)
                    }
                    // Get return type from method signature
                    const func_info = self.types.get(m.func_type)
                    if (func_info.tag == TAG_FUNC) {
                        switch (func_info) { Type.func |ft| => {
                            opt_type = ft.return_type
                        }, else => {} }
                    }
                    // Queue generic instance if needed
                    if (self.lookupGenericInst(m.func_name)) |inst| {
                        self.ensureGenericFnQueued(inst)
                    }
                }
            }

            var args: List(int) = .{}
            args.append(ch)
            const result = fb.emitCall(method_name, args, false, opt_type, span)

            const temp_name = "__select_recv_" ++ intToString(self.temp_counter)
            self.temp_counter = self.temp_counter + 1
            const opt_size = self.types.sizeOf(opt_type)
            const temp_local = fb.addLocalWithSize(temp_name, opt_type, false, opt_size)
            fb.emitStoreLocal(temp_local, result, span)

            // Check if non-null: compound optional tag at field 0
            const is_compound = !self.isPtrLikeOptional(opt_type)
            var is_non_null = null_node
            if (is_compound) {
                const tag = fb.emitFieldLocal(temp_local, 0, 0, I64, span)
                const zero = fb.emitConstInt(0, I64, span)
                is_non_null = fb.emitBinary(BinaryOp.ne, tag, zero, BOOL, span)
            } else {
                const recv_val = fb.emitLoadLocal(temp_local, opt_type, span)
                const null_val = fb.emitConstNull(UNTYPED_NULL, span)
                is_non_null = fb.emitBinary(BinaryOp.ne, recv_val, null_val, BOOL, span)
            }

            const then_block = fb.newBlock("select.recv")
            const else_block = fb.newBlock("select.default")
            const merge_block = fb.newBlock("select.end")
            fb.emitBranch(is_non_null, then_block, else_block, span)

            // Then block: bind capture, execute body
            fb.setBlock(then_block)
            if (sc.capture.len > 0) {
                var unwrapped = null_node
                if (is_compound) {
                    unwrapped = fb.emitFieldLocal(temp_local, 1, 8, I64, span)
                } else {
                    const loaded = fb.emitLoadLocal(temp_local, opt_type, span)
                    unwrapped = fb.emitUnary(UnaryOp.optional_unwrap, loaded, I64, span)
                }
                const capture_local = fb.addLocalWithSize(sc.capture, I64, false, 8)
                fb.emitStoreLocal(capture_local, unwrapped, span)
            }
            self.lowerExprNode(sc.body)
            if (fb.needsTerminator()) { fb.emitJump(merge_block, span) }

            // Else block: default body
            fb.setBlock(else_block)
            self.lowerExprNode(default_body)
            if (fb.needsTerminator()) { fb.emitJump(merge_block, span) }

            fb.setBlock(merge_block)
            return null_node
        } else {
            // Send case: lower the full ch.trySend(val) call
            const send_result = self.lowerExprNode(sc.channel)
            if (send_result == null_node) { return null_node }

            const then_block = fb.newBlock("select.send")
            const else_block = fb.newBlock("select.default")
            const merge_block = fb.newBlock("select.end")
            fb.emitBranch(send_result, then_block, else_block, span)

            fb.setBlock(then_block)
            self.lowerExprNode(sc.body)
            if (fb.needsTerminator()) { fb.emitJump(merge_block, span) }

            fb.setBlock(else_block)
            self.lowerExprNode(default_body)
            if (fb.needsTerminator()) { fb.emitJump(merge_block, span) }

            fb.setBlock(merge_block)
            return null_node
        }
    }

    /// Lower general N-case select: builds cases array, calls sched_select runtime.
    /// Copied from lower.zig:6277-6397
    fn lowerSelectGeneral(se: SelectExpr) int {
        const fb = self.builder.func() orelse return null_node
        const num_cases = se.cases.count

        // Allocate cases array: each entry 24 bytes (channel_ptr, kind, value_ptr)
        const cases_size = num_cases * 24
        const meta_node = fb.emitConstInt(0, I64, se.span)
        const size_node = fb.emitConstInt(cases_size, I64, se.span)
        var alloc_args: List(int) = .{}
        alloc_args.append(meta_node)
        alloc_args.append(size_node)
        const cases_ptr = fb.emitCall("alloc", alloc_args, false, I64, se.span)

        const cases_temp = "__select_cases_" ++ intToString(self.temp_counter)
        self.temp_counter = self.temp_counter + 1
        const cases_local = fb.addLocalWithSize(cases_temp, I64, true, 8)
        fb.emitStoreLocal(cases_local, cases_ptr, se.span)

        // Fill cases array
        for i in 0..num_cases {
            const sc = self.tree.getSelectCase(se.cases.get(i))
            const base_offset = i * 24
            const cases_reload = fb.emitLoadLocal(cases_local, I64, se.span)

            // Offset 0: channel pointer
            const ch = self.lowerExprNode(sc.channel)
            const ch_addr = fb.emitAddrOffset(cases_reload, base_offset, I64, se.span)
            fb.emitPtrStoreValue(ch_addr, ch, se.span)

            // Offset 8: kind (0=recv, 1=send)
            const kind_val = if (sc.kind == SELECT_RECV) { 0 } else { 1 }
            const kind_node = fb.emitConstInt(kind_val, I64, se.span)
            const kind_addr = fb.emitAddrOffset(cases_reload, base_offset + 8, I64, se.span)
            fb.emitPtrStoreValue(kind_addr, kind_node, se.span)

            // Offset 16: value_ptr (for send) or 0 (for recv)
            if (sc.kind == SELECT_SEND and sc.send_value != null_node) {
                const send_val = self.lowerExprNode(sc.send_value)
                const val_addr = fb.emitAddrOffset(cases_reload, base_offset + 16, I64, se.span)
                fb.emitPtrStoreValue(val_addr, send_val, se.span)
            } else {
                const zero = fb.emitConstInt(0, I64, se.span)
                const val_addr = fb.emitAddrOffset(cases_reload, base_offset + 16, I64, se.span)
                fb.emitPtrStoreValue(val_addr, zero, se.span)
            }
        }

        // Call sched_select(cases_ptr, num_cases, block)
        const cases_final = fb.emitLoadLocal(cases_local, I64, se.span)
        const n_cases = fb.emitConstInt(num_cases, I64, se.span)
        const block_flag = if (se.default_body != null_node) { fb.emitConstInt(0, I64, se.span) } else { fb.emitConstInt(1, I64, se.span) }
        var select_args: List(int) = .{}
        select_args.append(cases_final)
        select_args.append(n_cases)
        select_args.append(block_flag)
        const selected_idx = fb.emitCall("sched_select", select_args, false, I64, se.span)

        const result_temp = "__select_result_" ++ intToString(self.temp_counter)
        self.temp_counter = self.temp_counter + 1
        const result_local = fb.addLocalWithSize(result_temp, I64, true, 8)
        fb.emitStoreLocal(result_local, selected_idx, se.span)

        // Dispatch: switch on returned index (-1 = default, 0..N-1 = case index)
        const merge_block = fb.newBlock("select.end")

        // If has default, check for -1 first
        if (se.default_body != null_node) {
            const default_block = fb.newBlock("select.default")
            const dispatch_block = fb.newBlock("select.dispatch")
            const result_val = fb.emitLoadLocal(result_local, I64, se.span)
            const neg_one = fb.emitConstInt(-1, I64, se.span)
            const is_default = fb.emitBinary(BinaryOp.eq, result_val, neg_one, BOOL, se.span)
            fb.emitBranch(is_default, default_block, dispatch_block, se.span)

            fb.setBlock(default_block)
            self.lowerExprNode(se.default_body)
            if (fb.needsTerminator()) { fb.emitJump(merge_block, se.span) }

            fb.setBlock(dispatch_block)
        }

        // Dispatch cases: chain of if-else comparisons
        for i in 0..num_cases {
            const case_block = fb.newBlock("select.case")
            const next_block = if (i + 1 < num_cases) { fb.newBlock("select.next") } else { merge_block }

            const result_val = fb.emitLoadLocal(result_local, I64, se.span)
            const case_idx = fb.emitConstInt(i, I64, se.span)
            const is_match = fb.emitBinary(BinaryOp.eq, result_val, case_idx, BOOL, se.span)
            fb.emitBranch(is_match, case_block, next_block, se.span)

            fb.setBlock(case_block)
            // For recv with capture, read value from cases array at offset 16
            const sc = self.tree.getSelectCase(se.cases.get(i))
            if (sc.kind == SELECT_RECV and sc.capture.len > 0) {
                const recv_offset = i * 24 + 16
                const cases_reload = fb.emitLoadLocal(cases_local, I64, se.span)
                const recv_addr = fb.emitAddrOffset(cases_reload, recv_offset, I64, se.span)
                const recv_val = fb.emitPtrLoadValue(recv_addr, I64, se.span)
                const capture_local = fb.addLocalWithSize(sc.capture, I64, true, 8)
                fb.emitStoreLocal(capture_local, recv_val, se.span)
            }
            self.lowerExprNode(sc.body)
            if (fb.needsTerminator()) { fb.emitJump(merge_block, se.span) }

            if (i + 1 < num_cases) {
                fb.setBlock(next_block)
            }
        }

        // Free cases array
        fb.setBlock(merge_block)
        const cases_to_free = fb.emitLoadLocal(cases_local, I64, se.span)
        var dealloc_args: List(int) = .{}
        dealloc_args.append(cases_to_free)
        fb.emitCall("dealloc", dealloc_args, false, VOID, se.span)

        return null_node
    }

    // ========================================================================
    // Async/Await
    // ========================================================================

    /// Count await expressions in an AST subtree.
    /// Copied from lower.zig:1090-1145
    fn countAwaitPoints(idx: int) int {
        if (idx == null_node) { return 0 }
        var count = 0
        const node = self.tree.getNode(idx)
        switch (node) {
            Node.expr |expr| => switch (expr) {
                Expr.await_expr |_| => { count = count + 1 },
                Expr.binary |b| => {
                    count = count + self.countAwaitPoints(b.left)
                    count = count + self.countAwaitPoints(b.right)
                },
                Expr.unary |u| => { count = count + self.countAwaitPoints(u.operand) },
                Expr.call |c| => {
                    count = count + self.countAwaitPoints(c.callee)
                    for i in 0..c.args.count {
                        count = count + self.countAwaitPoints(c.args.get(i))
                    }
                },
                Expr.if_expr |ie| => {
                    count = count + self.countAwaitPoints(ie.condition)
                    count = count + self.countAwaitPoints(ie.then_branch)
                    if (ie.else_branch != null_node) { count = count + self.countAwaitPoints(ie.else_branch) }
                },
                Expr.block_expr |be| => {
                    for i in 0..be.stmts.count {
                        count = count + self.countAwaitPoints(be.stmts.get(i))
                    }
                    if (be.result_expr != null_node) { count = count + self.countAwaitPoints(be.result_expr) }
                },
                Expr.paren |p| => { count = count + self.countAwaitPoints(p.inner) },
                Expr.try_expr |t| => { count = count + self.countAwaitPoints(t.operand) },
                else => {},
            },
            Node.stmt |stmt| => switch (stmt) {
                Stmt.expr_stmt |es| => { count = count + self.countAwaitPoints(es.expr) },
                Stmt.return_stmt |rs| => {
                    if (rs.value != null_node) { count = count + self.countAwaitPoints(rs.value) }
                },
                Stmt.var_stmt |vs| => {
                    if (vs.value != null_node) { count = count + self.countAwaitPoints(vs.value) }
                },
                Stmt.assign_stmt |as_stmt| => { count = count + self.countAwaitPoints(as_stmt.value) },
                Stmt.if_stmt |is_stmt| => {
                    count = count + self.countAwaitPoints(is_stmt.condition)
                    count = count + self.countAwaitPoints(is_stmt.then_branch)
                    if (is_stmt.else_branch != null_node) { count = count + self.countAwaitPoints(is_stmt.else_branch) }
                },
                Stmt.while_stmt |ws| => {
                    count = count + self.countAwaitPoints(ws.condition)
                    count = count + self.countAwaitPoints(ws.body)
                },
                Stmt.block_stmt |bs| => {
                    for i in 0..bs.stmts.count {
                        count = count + self.countAwaitPoints(bs.stmts.get(i))
                    }
                },
                Stmt.defer_stmt |ds| => { count = count + self.countAwaitPoints(ds.expr) },
                else => {},
            },
            else => {},
        }
        return count
    }

    /// Lower await expression — extract result from Future.
    /// Native: eager evaluation — result already stored in future[8].
    /// Copied from lower.zig:10222-10299
    fn lowerAwaitExpr(ae: AwaitExpr, idx: int) int {
        const fb = self.builder.func() orelse return null_node
        // Get the future type from the operand
        const operand_type = self.inferExprType(ae.operand)
        const ot = self.types.get(operand_type)
        if (ot.tag != TAG_FUTURE) {
            return self.lowerExprNode(ae.operand)
        }
        const result_type = switch (ot) { Type.future |ft| => ft.result_type, else => I64 }

        // Lower the future operand (gives us the state/fiber pointer)
        const future_ptr = self.lowerExprNode(ae.operand)

        // Check if compound result
        const result_size = self.types.sizeOf(result_type)
        const is_compound = result_size > 8

        // Native (eager): result is already at future[8]
        if (is_compound) {
            const num_words = (result_size + 7) / 8
            const result_local = fb.addLocalWithSize("__await_result", result_type, false, result_size)
            for w in 0..num_words {
                const src_offset = 8 + w * 8
                const src_addr = fb.emitAddrOffset(future_ptr, src_offset, I64, ae.span)
                const word = fb.emitPtrLoadValue(src_addr, I64, ae.span)
                fb.emitStoreLocalField(result_local, w, w * 8, word, ae.span)
            }
            return fb.emitAddrLocal(result_local, I64, ae.span)
        }
        const result_addr = fb.emitAddrOffset(future_ptr, 8, I64, ae.span)
        return fb.emitPtrLoadValue(result_addr, result_type, ae.span)
    }

    /// Lower async function declaration — native fiber pattern (eager execution).
    /// Emits: body function (fn_name_body) + constructor (fn_name) returning Future pointer.
    /// Copied from lower.zig:963-1087
    fn lowerAsyncFiber(fn_decl: FnDecl) void {
        const inner_return_type = if (fn_decl.return_type != null_node) {
            self.resolveTypeNode(fn_decl.return_type)
        } else { VOID }

        // --- Emit body function (fn_name_body) ---
        const fiber_link_name = self.qualifyName(fn_decl.name)
        const body_name = fiber_link_name ++ "_body"
        self.builder.startFunc(body_name, VOID, inner_return_type, fn_decl.span)
        if (self.builder.func()) |body_fb| {
            self.clearPerFunctionState()

            for i in 0..fn_decl.params.count {
                const param_idx = fn_decl.params.get(i)
                self.addParamFromNode(param_idx)
            }

            if (fn_decl.body != null_node) {
                self.lowerBlockNode(fn_decl.body)
                if (inner_return_type == VOID and body_fb.needsTerminator()) {
                    self.emitCleanups(0)
                    body_fb.emitRet(null_node, fn_decl.span)
                }
            }
        }
        self.builder.endFunc()

        // --- Emit constructor (fn_name) — calls body eagerly, stores result in future ---
        self.builder.startFunc(fiber_link_name, VOID, I64, fn_decl.span)
        if (self.builder.func()) |fb| {
            self.clearPerFunctionState()

            // Add params matching declared signature
            for i in 0..fn_decl.params.count {
                const param_idx = fn_decl.params.get(i)
                self.addParamFromNode(param_idx)
            }

            // Compute future size: state(8) + result
            var result_size = 0
            if (inner_return_type != VOID) { result_size = self.types.sizeOf(inner_return_type) }
            const future_size = 8 + result_size

            // Allocate future struct
            const metadata = fb.emitConstInt(0, I64, fn_decl.span)
            const size_val = fb.emitConstInt(future_size, I64, fn_decl.span)
            var alloc_args: List(int) = .{}
            alloc_args.append(metadata)
            alloc_args.append(size_val)
            const future_ptr = fb.emitCall("alloc", alloc_args, false, I64, fn_decl.span)
            const future_local = fb.addLocalWithSize("__future", I64, false, 8)
            fb.emitStoreLocal(future_local, future_ptr, fn_decl.span)

            // Call body function with same args — eager evaluation
            var body_args: List(int) = .{}
            for i in 0..fn_decl.params.count {
                const param_idx = fn_decl.params.get(i)
                var pname = ""
                switch (self.tree.getNode(param_idx)) { Node.expr |e| => switch (e) {
                    Expr.field_def |fd| => { pname = fd.name },
                    else => {},
                }, else => {} }
                if (pname.len > 0) {
                    if (fb.lookupLocal(pname)) |local_idx| {
                        const param_type = fb.locals.get(local_idx).type_idx
                        const pi = self.types.get(param_type)
                        if (param_type == STRING or pi.tag == TAG_SLICE) {
                            const val = fb.emitLoadLocal(local_idx, param_type, fn_decl.span)
                            body_args.append(fb.emitSlicePtr(val, I64, fn_decl.span))
                            body_args.append(fb.emitSliceLen(val, fn_decl.span))
                        } else {
                            body_args.append(fb.emitLoadLocal(local_idx, I64, fn_decl.span))
                        }
                    }
                }
            }
            const result = fb.emitCall(body_name, body_args, false, inner_return_type, fn_decl.span)

            // Store result at future[8]
            if (inner_return_type != VOID) {
                const fp = fb.emitLoadLocal(future_local, I64, fn_decl.span)
                const result_addr = fb.emitAddrOffset(fp, 8, I64, fn_decl.span)
                fb.emitPtrStoreValue(result_addr, result, fn_decl.span)
            }

            // Set state = 1 (DONE) at future[0]
            const fp2 = fb.emitLoadLocal(future_local, I64, fn_decl.span)
            const one = fb.emitConstInt(1, I64, fn_decl.span)
            fb.emitPtrStoreValue(fp2, one, fn_decl.span)

            // Return future pointer
            const ret_val = fb.emitLoadLocal(future_local, I64, fn_decl.span)
            fb.emitRet(ret_val, fn_decl.span)
        }
        self.builder.endFunc()
    }

    // ========================================================================
    // Shape Stenciling / Dict Helpers
    // ========================================================================

    /// Generate a dict helper name for a type-dependent operation.
    /// Format: __cot_dict_{type_name}_{op_name}
    /// Copied from lower.zig:8360-8372
    fn dictHelperName(concrete_type: int, entry: DictEntry) string {
        const type_name = self.types.typeName(concrete_type)
        if (entry.kind == DICT_BINARY_OP) {
            return "__cot_dict_" ++ type_name ++ "_" ++ dictOpName(entry.op)
        }
        return "__cot_dict_" ++ type_name ++ "_" ++ entry.method_name
    }

    /// Generate a binary op helper function.
    /// Emits: __cot_dict_{type}_{op}(a: T, b: T) -> T or bool
    /// Copied from lower.zig:8411-8443
    fn generateBinaryOpHelper(name: string, concrete_type: int, op: int) void {
        const fb = self.builder.func() orelse return null_node
        // Comparison ops return bool, arithmetic returns T
        // op is a Token value; convert to BinaryOp for IR emission
        const bop = tokenToBinaryOp(op)
        const return_type = switch (bop) {
            BinaryOp.eq, BinaryOp.ne, BinaryOp.lt, BinaryOp.gt, BinaryOp.le, BinaryOp.ge => BOOL,
            else => concrete_type,
        }
        const sz = self.types.sizeOf(concrete_type)
        const span = Span { start: 0, end: 0 }
        self.builder.startFunc(name, VOID, return_type, span)
        if (self.builder.func()) |fb| {
            const param_a = fb.addParam("a", concrete_type, sz)
            const param_b = fb.addParam("b", concrete_type, sz)
            const a_val = fb.emitLoadLocal(param_a, concrete_type, span)
            const b_val = fb.emitLoadLocal(param_b, concrete_type, span)
            const result = fb.emitBinary(bop, a_val, b_val, return_type, span)
            fb.emitRet(result, span)
        }
        self.builder.endFunc()
    }

    /// Generate a method call helper function.
    /// Emits: __cot_dict_{type}_{method}(args...) -> R { return concrete_method(args...) }
    /// Copied from lower.zig:8447-8500
    fn generateMethodCallHelper(name: string, concrete_type: int, method_name: string) void {
        const fb = self.builder.func() orelse return null_node
        const type_name = self.types.typeName(concrete_type)
        const mi_idx = self.types.lookupMethod(type_name, method_name)
        if (mi_idx < 0) { return }
        const mi = self.types.getMethodInfo(mi_idx)
        const func_info = self.types.get(mi.func_type)
        var return_type = VOID
        switch (func_info) {
            Type.func |f| => { return_type = f.return_type },
            else => {},
        }
        const uses_sret = self.needsSret(return_type)
        const ir_return_type = if (uses_sret) { VOID } else { return_type }

        const span = Span { start: 0, end: 0 }
        self.builder.startFunc(name, VOID, ir_return_type, span)
        if (self.builder.func()) |fb| {
            if (uses_sret) { fb.sret_return_type = return_type }

            // SRET hidden first param
            if (uses_sret) { fb.addParam("__sret", I64, 8) }

            // Add params and build forward call args
            var call_args: List(int) = .{}
            if (uses_sret) {
                if (fb.lookupLocal("__sret")) |sret_idx| {
                    call_args.append(fb.emitLoadLocal(sret_idx, I64, span))
                }
            }

            const ff = switch (func_info) { Type.func |f| => f, else => FuncType { param_count: 0, params: 0, return_type: VOID } }
            for i in 0..ff.param_count {
                const p = ff.getParam(i)
                const local = fb.addParam(p.name, p.type_idx, self.types.sizeOf(p.type_idx))
                call_args.append(fb.emitLoadLocal(local, p.type_idx, span))
            }

            // Resolve concrete method name
            const concrete_method = self.resolveMethodName(type_name, mi.func_name, mi.source_tree)

            if (uses_sret) {
                fb.emitCall(concrete_method, call_args, false, VOID, span)
                fb.emitRet(null_node, span)
            } else {
                const result = fb.emitCall(concrete_method, call_args, false, return_type, span)
                fb.emitRet(result, span)
            }
        }
        self.builder.endFunc()
    }

    /// Check if a type matches one of the type parameter concrete types.
    /// Returns the index or -1.
    /// Copied from lower.zig:7864-7869
    fn typeParamIndex(type_param_types: List(int), ty: int) int {
        for i in 0..type_param_types.count {
            if (type_param_types.get(i) == ty) { return i }
        }
        return -1
    }

    /// Analyze a generic function body for stencilability.
    /// Returns STENCIL_SHAPE_ONLY, STENCIL_DICT, or STENCIL_NOT_STENCILABLE.
    /// Copied from lower.zig:7825-7860
    fn analyzeStencilability(body_node: int, type_param_types: List(int)) int {
        if (type_param_types.count == 0) { return STENCIL_NOT_STENCILABLE }

        var collector: List(DictEntry) = .{}
        const ok = self.collectNodeDictEntries(body_node, type_param_types, &collector)
        if (!ok) { return STENCIL_NOT_STENCILABLE }
        if (collector.count == 0) {
            self.stencil_dict_entries.count = 0
            return STENCIL_SHAPE_ONLY
        }

        // Deduplicate and store in stencil_dict_entries
        self.stencil_dict_entries.count = 0
        for i in 0..collector.count {
            const entry = collector.get(i)
            var found = false
            for j in 0..self.stencil_dict_entries.count {
                const existing = self.stencil_dict_entries.get(j)
                if (existing.kind == entry.kind and existing.op == entry.op
                    and existing.type_param_idx == entry.type_param_idx
                    and existing.method_name == entry.method_name) {
                    found = true
                }
            }
            if (!found) { self.stencil_dict_entries.append(entry) }
        }
        return STENCIL_DICT
    }

    /// Recursive AST walk: collect DictEntry for Tier 2 ops.
    /// Returns false if Tier 3 (not stencilable) found.
    /// Copied from lower.zig:7877-8043
    fn collectNodeDictEntries(node_idx: int, tpt: List(int), collector: *List(DictEntry)) bool {
        if (node_idx == null_node) { return true }
        const node = self.tree.getNode(node_idx)
        var result = true
        switch (node) {
            Node.expr |expr| => { result = self.collectExprDictEntries(expr, node_idx, tpt, collector) },
            Node.stmt |stmt| => { result = self.collectStmtDictEntries(stmt, tpt, collector) },
            Node.decl |_| => {},
        }
        return result
    }

    /// Collect dict entries from an expression.
    /// Copied from lower.zig:7887-8043
    fn collectExprDictEntries(expr: Expr, node_idx: int, tpt: List(int), collector: *List(DictEntry)) bool {
        // Use tag string to dispatch — avoids return-in-switch-arm limitation
        const tag1 = exprTagStr1(expr)
        const tag = if (@lenOf(tag1) > 0) { tag1 } else { exprTagStr2(expr) }

        if (tag == "binary") {
            var bin_left = 0
            var bin_right = 0
            var bin_op = 0
            switch (expr) { Expr.binary |bin| => { bin_left = bin.left; bin_right = bin.right; bin_op = bin.op }, else => {} }
            const left_type = self.chk.expr_types.getOrNull(bin_left) orelse -1
            const right_type = self.chk.expr_types.getOrNull(bin_right) orelse -1
            const left_pi = self.typeParamIndex(tpt, left_type)
            const right_pi = self.typeParamIndex(tpt, right_type)
            if (left_pi >= 0 or right_pi >= 0) {
                const bop = @enumFromInt(bin_op) as BinaryOp
                const is_dict_op = bop.isComparison() or bop.isArithmetic()
                if (!is_dict_op) { return false }
                const pi = if (left_pi >= 0) { left_pi } else { right_pi }
                collector.append(DictEntry { kind: DICT_BINARY_OP, op: bin_op, method_name: "", type_param_idx: pi })
            }
            if (!self.collectNodeDictEntries(bin_left, tpt, collector)) { return false }
            return self.collectNodeDictEntries(bin_right, tpt, collector)
        }

        if (tag == "call") {
            var callee_n = 0
            var call_args: List(int) = .{}
            switch (expr) { Expr.call |c| => { callee_n = c.callee; call_args = c.args }, else => {} }
            // Check method calls on T-typed receiver
            const callee_node = self.tree.getNode(callee_n)
            switch (callee_node) { Node.expr |ce| => switch (ce) {
                Expr.field_access |fa| => {
                    const recv_type = self.chk.expr_types.getOrNull(fa.base) orelse -1
                    var pi = self.typeParamIndex(tpt, recv_type)
                    if (pi < 0 and recv_type >= 0 and self.types.isPointer(recv_type)) {
                        pi = self.typeParamIndex(tpt, self.types.pointerElem(recv_type))
                    }
                    if (pi >= 0) {
                        collector.append(DictEntry { kind: DICT_METHOD_CALL, op: 0, method_name: fa.field, type_param_idx: pi })
                    }
                },
                else => {},
            }, else => {} }
            if (!self.collectNodeDictEntries(callee_n, tpt, collector)) { return false }
            for i in 0..call_args.count {
                if (!self.collectNodeDictEntries(call_args.get(i), tpt, collector)) { return false }
            }
            return true
        }

        if (tag == "if_expr") {
            var cond = 0
            var then_br = 0
            var else_br = null_node
            switch (expr) { Expr.if_expr |ie| => { cond = ie.condition; then_br = ie.then_branch; else_br = ie.else_branch }, else => {} }
            if (!self.collectNodeDictEntries(cond, tpt, collector)) { return false }
            if (!self.collectNodeDictEntries(then_br, tpt, collector)) { return false }
            return self.collectNodeDictEntries(else_br, tpt, collector)
        }

        if (tag == "block_expr") {
            var stmts: List(int) = .{}
            var result_n = null_node
            switch (expr) { Expr.block_expr |be| => { stmts = be.stmts; result_n = be.result_expr }, else => {} }
            for i in 0..stmts.count {
                if (!self.collectNodeDictEntries(stmts.get(i), tpt, collector)) { return false }
            }
            return self.collectNodeDictEntries(result_n, tpt, collector)
        }

        if (tag == "unary") {
            var operand = 0
            switch (expr) { Expr.unary |u| => { operand = u.operand }, else => {} }
            return self.collectNodeDictEntries(operand, tpt, collector)
        }

        if (tag == "paren") {
            var inner = 0
            switch (expr) { Expr.paren |p| => { inner = p.inner }, else => {} }
            return self.collectNodeDictEntries(inner, tpt, collector)
        }

        if (tag == "field_access") {
            var base = 0
            switch (expr) { Expr.field_access |fa| => { base = fa.base }, else => {} }
            return self.collectNodeDictEntries(base, tpt, collector)
        }

        if (tag == "index_expr") {
            var base = 0
            var idx = 0
            switch (expr) { Expr.index_expr |ix| => { base = ix.base; idx = ix.idx }, else => {} }
            if (!self.collectNodeDictEntries(base, tpt, collector)) { return false }
            return self.collectNodeDictEntries(idx, tpt, collector)
        }

        if (tag == "try_expr") {
            var operand = 0
            switch (expr) { Expr.try_expr |te| => { operand = te.operand }, else => {} }
            return self.collectNodeDictEntries(operand, tpt, collector)
        }

        if (tag == "catch_expr") {
            var operand = 0
            var fallback = null_node
            switch (expr) { Expr.catch_expr |ce| => { operand = ce.operand; fallback = ce.fallback }, else => {} }
            if (!self.collectNodeDictEntries(operand, tpt, collector)) { return false }
            return self.collectNodeDictEntries(fallback, tpt, collector)
        }

        if (tag == "orelse_expr") {
            var operand = 0
            var fallback = null_node
            switch (expr) { Expr.orelse_expr |oe| => { operand = oe.operand; fallback = oe.fallback }, else => {} }
            if (!self.collectNodeDictEntries(operand, tpt, collector)) { return false }
            if (fallback != null_node) {
                if (!self.collectNodeDictEntries(fallback, tpt, collector)) { return false }
            }
            return true
        }

        if (tag == "addr_of") {
            var operand = 0
            switch (expr) { Expr.addr_of |ao| => { operand = ao.operand }, else => {} }
            return self.collectNodeDictEntries(operand, tpt, collector)
        }

        if (tag == "deref") {
            var operand = 0
            switch (expr) { Expr.deref |d| => { operand = d.operand }, else => {} }
            return self.collectNodeDictEntries(operand, tpt, collector)
        }

        // Tier 3: closures, async, spawn, select → not stencilable
        if (tag == "closure_expr" or tag == "spawn_expr" or tag == "select_expr" or tag == "await_expr") {
            return false
        }

        // Safe leaf nodes (ident, literal, etc.)
        return true
    }

    /// Collect dict entries from a statement.
    /// Copied from lower.zig:8046-8105
    fn collectStmtDictEntries(stmt: Stmt, tpt: List(int), collector: *List(DictEntry)) bool {
        const tag = stmtTagStr(stmt)

        if (tag == "expr_stmt") {
            var expr_node = 0
            switch (stmt) { Stmt.expr_stmt |es| => { expr_node = es.expr }, else => {} }
            return self.collectNodeDictEntries(expr_node, tpt, collector)
        }

        if (tag == "return_stmt") {
            var value = 0
            switch (stmt) { Stmt.return_stmt |rs| => { value = rs.value }, else => {} }
            if (value != null_node) { return self.collectNodeDictEntries(value, tpt, collector) }
            return true
        }

        if (tag == "var_stmt") {
            var value = 0
            switch (stmt) { Stmt.var_stmt |vs| => { value = vs.value }, else => {} }
            if (value != null_node) { return self.collectNodeDictEntries(value, tpt, collector) }
            return true
        }

        if (tag == "assign_stmt") {
            var target = 0
            var value = 0
            switch (stmt) { Stmt.assign_stmt |as_stmt| => { target = as_stmt.target; value = as_stmt.value }, else => {} }
            return self.collectNodeDictEntries(target, tpt, collector)
                and self.collectNodeDictEntries(value, tpt, collector)
        }

        if (tag == "if_stmt") {
            var condition = 0
            var then_branch = 0
            var else_branch = 0
            switch (stmt) { Stmt.if_stmt |is_stmt| => { condition = is_stmt.condition; then_branch = is_stmt.then_branch; else_branch = is_stmt.else_branch }, else => {} }
            if (!self.collectNodeDictEntries(condition, tpt, collector)) { return false }
            if (!self.collectNodeDictEntries(then_branch, tpt, collector)) { return false }
            if (else_branch != null_node) {
                if (!self.collectNodeDictEntries(else_branch, tpt, collector)) { return false }
            }
            return true
        }

        if (tag == "while_stmt") {
            var condition = 0
            var body = 0
            switch (stmt) { Stmt.while_stmt |ws| => { condition = ws.condition; body = ws.body }, else => {} }
            return self.collectNodeDictEntries(condition, tpt, collector)
                and self.collectNodeDictEntries(body, tpt, collector)
        }

        if (tag == "for_stmt") {
            var iterable = 0
            var body = 0
            switch (stmt) { Stmt.for_stmt |fs| => { iterable = fs.iterable; body = fs.body }, else => {} }
            if (iterable != null_node) {
                if (!self.collectNodeDictEntries(iterable, tpt, collector)) { return false }
            }
            return self.collectNodeDictEntries(body, tpt, collector)
        }

        if (tag == "block_stmt") {
            var ok = true
            switch (stmt) { Stmt.block_stmt |bs| => {
                for i in 0..bs.stmts.count {
                    if (!self.collectNodeDictEntries(bs.stmts.get(i), tpt, collector)) { ok = false }
                }
            }, else => {} }
            return ok
        }

        if (tag == "defer_stmt") {
            var expr_node = 0
            switch (stmt) { Stmt.defer_stmt |ds| => { expr_node = ds.expr }, else => {} }
            return self.collectNodeDictEntries(expr_node, tpt, collector)
        }

        // All other statement types: safe
        return true
    }

    /// Generate all dict helpers for a generic instance.
    /// Copied from lower.zig:8395-8408
    fn generateDictHelpers(type_args: List(int), dict_entries: List(DictEntry)) void {
        for i in 0..dict_entries.count {
            const entry = dict_entries.get(i)
            var concrete_type = 0
            if (entry.type_param_idx < type_args.count) {
                concrete_type = type_args.get(entry.type_param_idx)
            }
            const helper_name = self.dictHelperName(concrete_type, entry)
            // Dedup
            if (self.generated_dict_helpers.contains(helper_name)) { continue }
            self.generated_dict_helpers.set(helper_name, 1)

            if (entry.kind == DICT_BINARY_OP) {
                self.generateBinaryOpHelper(helper_name, concrete_type, entry.op)
            } else {
                self.generateMethodCallHelper(helper_name, concrete_type, entry.method_name)
            }
        }
    }

    /// Build the dict_arg_names mapping for a concrete generic instance.
    /// Maps concrete_name → comma-separated helper function names.
    /// Copied from lower.zig:8349-8356
    fn buildDictArgNames(inst: *GenericInstInfo, dict_entries: List(DictEntry)) void {
        // Parse type args from inst.type_args_str
        var type_args: List(int) = .{}
        const tas = inst.type_args_str
        var start = 0
        for ci in 0..tas.len {
            if (tas[ci] == 59) {  // ';'
                type_args.append(Lowerer.parseIntSubstr(tas, start, ci))
                start = ci + 1
            }
        }
        if (start < tas.len) {
            type_args.append(Lowerer.parseIntSubstr(tas, start, tas.len))
        }

        // Build comma-separated helper names
        var result = ""
        for i in 0..dict_entries.count {
            const entry = dict_entries.get(i)
            var concrete_type = 0
            if (entry.type_param_idx < type_args.count) {
                concrete_type = type_args.get(entry.type_param_idx)
            }
            const helper_name = self.dictHelperName(concrete_type, entry)
            if (i > 0) { result = result ++ "," }
            result = result ++ helper_name
        }
        self.dict_arg_names.set(inst.concrete_name, result)
    }

    /// Parse type args string into a list of ints.
    /// Parse paired semicolon-separated type_args_str and param_names_str,
    /// pushing type substitutions into the checker.
    /// type_args_str: "5;17", param_names_str: "K;V" → pushTypeSub("K", 5), pushTypeSub("V", 17)
    fn parseAndPushTypeSubs(type_args_str: string, param_names_str: string) void {
        // Parse type arg values
        var args: List(int) = .{}
        var start = 0
        for ci in 0..type_args_str.len {
            if (type_args_str[ci] == 59) {
                args.append(Lowerer.parseIntSubstr(type_args_str, start, ci))
                start = ci + 1
            }
        }
        if (start < type_args_str.len) {
            args.append(Lowerer.parseIntSubstr(type_args_str, start, type_args_str.len))
        }

        // Parse param names and push substitutions
        var arg_idx = 0
        var nstart = 0
        for ci in 0..param_names_str.len {
            if (param_names_str[ci] == 59) {
                if (arg_idx < args.count) {
                    const name = substring(param_names_str, nstart, ci)
                    self.chk.pushTypeSub(name, args.get(arg_idx))
                }
                arg_idx = arg_idx + 1
                nstart = ci + 1
            }
        }
        if (nstart < param_names_str.len and arg_idx < args.count) {
            const name = substring(param_names_str, nstart, param_names_str.len)
            self.chk.pushTypeSub(name, args.get(arg_idx))
        }
    }

    fn parseTypeArgsStr(type_args_str: string) List(int) {
        var result: List(int) = .{}
        var start = 0
        for ci in 0..type_args_str.len {
            if (type_args_str[ci] == 59) {  // ';'
                result.append(Lowerer.parseIntSubstr(type_args_str, start, ci))
                start = ci + 1
            }
        }
        if (start < type_args_str.len) {
            result.append(Lowerer.parseIntSubstr(type_args_str, start, type_args_str.len))
        }
        return result
    }

    // ========================================================================
    // Error handling
    // ========================================================================

    fn lowerTryExpr(te: TryExpr, idx: int) int {
        const fb = self.builder.func() orelse return null_node
        // Lower the error-union-returning expression
        const eu_val = self.lowerExprNode(te.operand)
        if (eu_val == null_node) { return null_node }

        const eu_type = self.inferExprType(te.operand)
        const eu_size = self.types.sizeOf(eu_type)

        // Store to local for field access
        const eu_local = fb.addLocalWithSize("__try_eu", eu_type, false, eu_size)
        fb.emitStoreLocal(eu_local, eu_val, te.span)

        // Check tag at offset 0
        const tag = fb.emitFieldLocal(eu_local, 0, 0, I64, te.span)
        const zero = fb.emitConstInt(0, I64, te.span)
        const is_ok = fb.emitBinary(BinaryOp.eq, tag, zero, BOOL, te.span)

        const ok_block = fb.newBlock("try.ok")
        const err_block = fb.newBlock("try.err")

        fb.emitBranch(is_ok, ok_block, err_block, te.span)

        // Error block: propagate error — copy EU and return pointer to it
        fb.setBlock(err_block)
        // Create copy of error union in our frame
        const err_copy = fb.addLocalWithSize("__try_err", eu_type, false, eu_size)
        const tag_val = fb.emitFieldLocal(eu_local, 0, 0, I64, te.span)
        fb.emitStoreLocalField(err_copy, 0, 0, tag_val, te.span)
        const payload_val = fb.emitFieldLocal(eu_local, 1, 8, I64, te.span)
        fb.emitStoreLocalField(err_copy, 1, 8, payload_val, te.span)
        const err_ptr = fb.emitAddrLocal(err_copy, I64, te.span)
        self.emitCleanupsErrorPath(0)
        fb.emitRet(err_ptr, te.span)

        // OK block: extract payload from offset 8
        fb.setBlock(ok_block)
        const result_type = self.inferExprType(idx)
        const payload = fb.emitFieldLocal(eu_local, 1, 8, result_type, te.span)
        return payload
    }

    fn lowerCatchExpr(ce: CatchExpr, idx: int) int {
        const fb = self.builder.func() orelse return null_node

        // Get the error union type from the operand
        // Zig ref: lower.zig lines 11315-11380
        const eu_type = self.inferExprType(ce.operand)
        const eu_info = self.types.get(eu_type)
        if (eu_info.tag != TAG_ERROR_UNION) {
            return self.lowerExprNode(ce.operand)
        }
        const elem_type = switch (eu_info) { Type.error_union |eu| => eu.elem, else => VOID }
        const is_compound = elem_type == STRING

        // Call returns a POINTER to the error union
        const eu_ptr = self.lowerExprNode(ce.operand)
        if (eu_ptr == null_node) { return null_node }

        // Read tag at [ptr + 0] — dereference the pointer
        const tag_val = fb.emitPtrLoadValue(eu_ptr, I64, ce.span)
        const zero = fb.emitConstInt(0, I64, ce.span)
        const is_ok = fb.emitBinary(BinaryOp.eq, tag_val, zero, BOOL, ce.span)

        const result_type = self.inferExprType(idx)
        const result_size = self.types.sizeOf(result_type)
        const result_local = fb.addLocalWithSize("__catch_result", result_type, true, result_size)

        const ok_block = fb.newBlock("catch.ok")
        const err_block = fb.newBlock("catch.err")
        const merge_block = fb.newBlock("catch.end")

        fb.emitBranch(is_ok, ok_block, err_block, ce.span)

        // OK block: read success payload from [ptr + 8]
        fb.setBlock(ok_block)
        if (is_compound) {
            // Compound (string): read ptr at [eu_ptr+8], len at [eu_ptr+16]
            const ptr_addr = fb.emitAddrOffset(eu_ptr, 8, I64, ce.span)
            const ptr_val = fb.emitPtrLoadValue(ptr_addr, I64, ce.span)
            const len_addr = fb.emitAddrOffset(eu_ptr, 16, I64, ce.span)
            const len_val = fb.emitPtrLoadValue(len_addr, I64, ce.span)
            fb.emitStoreLocalField(result_local, 0, 0, ptr_val, ce.span)
            fb.emitStoreLocalField(result_local, 1, 8, len_val, ce.span)
        } else {
            const payload_addr = fb.emitAddrOffset(eu_ptr, 8, I64, ce.span)
            const payload = fb.emitPtrLoadValue(payload_addr, result_type, ce.span)
            fb.emitStoreLocal(result_local, payload, ce.span)
        }
        fb.emitJump(merge_block, ce.span)

        // Error block: optional capture binding + fallback
        fb.setBlock(err_block)
        const scope_depth = fb.markScopeEntry()

        if (ce.capture != "") {
            // Bind capture to error tag value
            const cap_local = fb.addLocalWithSize(ce.capture, I64, false, 8)
            fb.emitStoreLocal(cap_local, tag_val, ce.span)
        }

        if (ce.fallback != null_node) {
            const fallback_val = self.lowerExprNode(ce.fallback)
            if (fallback_val != null_node) {
                fb.emitStoreLocal(result_local, fallback_val, ce.span)
            }
        }

        fb.restoreScope(scope_depth)

        // CRITICAL: use fb.needsTerminator() not fallback_is_noreturn
        if (fb.needsTerminator()) {
            fb.emitJump(merge_block, ce.span)
        }

        fb.setBlock(merge_block)
        return fb.emitLoadLocal(result_local, result_type, ce.span)
    }

    fn lowerOrElseExpr(oe: OrElseExpr, idx: int) int {
        const fb = self.builder.func() orelse return null_node
        const operand = self.lowerExprNode(oe.operand)
        if (operand == null_node) { return null_node }

        const operand_type_idx = self.inferExprType(oe.operand)
        const elem_type = self.inferExprType(idx)
        const is_compound = !self.isPtrLikeOptional(operand_type_idx)

        if (is_compound) {
            // Compound optional: [tag:i64][payload:i64]
            const opt_size = self.types.sizeOf(operand_type_idx)
            const opt_local = fb.addLocalWithSize("__orelse_opt", operand_type_idx, false, opt_size)
            fb.emitStoreLocal(opt_local, operand, oe.span)

            const tag = fb.emitFieldLocal(opt_local, 0, 0, I64, oe.span)
            const zero = fb.emitConstInt(0, I64, oe.span)
            const is_non_null = fb.emitBinary(BinaryOp.ne, tag, zero, BOOL, oe.span)

            const result_size = self.types.sizeOf(elem_type)
            const result_local = fb.addLocalWithSize("__orelse_result", elem_type, false, result_size)
            const then_block = fb.newBlock("orelse.nonnull")
            const else_block = fb.newBlock("orelse.null")
            const merge_block = fb.newBlock("orelse.end")
            fb.emitBranch(is_non_null, then_block, else_block, oe.span)

            // Non-null: extract payload
            fb.setBlock(then_block)
            const payload = fb.emitFieldLocal(opt_local, 1, 8, elem_type, oe.span)
            fb.emitStoreLocal(result_local, payload, oe.span)
            fb.emitJump(merge_block, oe.span)

            // Null: lower fallback
            fb.setBlock(else_block)
            switch (oe.fallback_kind) {
                ORELSE_EXPR => {
                    const fallback = self.lowerExprNode(oe.fallback)
                    if (fallback != null_node) {
                        fb.emitStoreLocal(result_local, fallback, oe.span)
                    }
                },
                ORELSE_RETURN_VOID => {
                    self.lowerReturn(ReturnStmt { .value = null_node, .span = oe.span })
                },
                ORELSE_RETURN_VAL => {
                    self.lowerReturn(ReturnStmt { .value = oe.fallback, .span = oe.span })
                },
                ORELSE_BREAK_VAL => {
                    self.lowerBreak("", null_node)
                },
                ORELSE_CONTINUE_VAL => {
                    self.lowerContinue("")
                },
                else => {},
            }

            if (fb.needsTerminator()) {
                fb.emitJump(merge_block, oe.span)
            }

            fb.setBlock(merge_block)
            return fb.emitLoadLocal(result_local, elem_type, oe.span)
        }

        // Pointer-like optional: null=0 sentinel
        if (oe.fallback_kind == ORELSE_EXPR) {
            // Simple case: emitSelect
            const null_val = fb.emitConstNull(UNTYPED_NULL, oe.span)
            const condition = fb.emitBinary(BinaryOp.ne, operand, null_val, BOOL, oe.span)
            const unwrapped = fb.emitUnary(UnaryOp.optional_unwrap, operand, elem_type, oe.span)
            const fallback = self.lowerExprNode(oe.fallback)
            return fb.emitSelect(condition, unwrapped, fallback, elem_type, oe.span)
        }

        // Pointer-like with non-expr fallback: needs 3-block pattern
        const null_val = fb.emitConstNull(UNTYPED_NULL, oe.span)
        const is_non_null = fb.emitBinary(BinaryOp.ne, operand, null_val, BOOL, oe.span)

        const then_block = fb.newBlock("orelse.nonnull")
        const else_block = fb.newBlock("orelse.null")
        const merge_block = fb.newBlock("orelse.end")
        fb.emitBranch(is_non_null, then_block, else_block, oe.span)

        fb.setBlock(then_block)
        const unwrapped = fb.emitUnary(UnaryOp.optional_unwrap, operand, elem_type, oe.span)
        const result_local = fb.addLocalWithSize("__orelse_result", elem_type, false, 8)
        fb.emitStoreLocal(result_local, unwrapped, oe.span)
        fb.emitJump(merge_block, oe.span)

        fb.setBlock(else_block)
        switch (oe.fallback_kind) {
            ORELSE_RETURN_VOID => {
                self.lowerReturn(ReturnStmt { .value = null_node, .span = oe.span })
            },
            ORELSE_RETURN_VAL => {
                self.lowerReturn(ReturnStmt { .value = oe.fallback, .span = oe.span })
            },
            ORELSE_BREAK_VAL => {
                self.lowerBreak("", null_node)
            },
            ORELSE_CONTINUE_VAL => {
                self.lowerContinue("")
            },
            else => {},
        }

        if (fb.needsTerminator()) {
            fb.emitJump(merge_block, oe.span)
        }

        fb.setBlock(merge_block)
        return fb.emitLoadLocal(result_local, elem_type, oe.span)
    }

    fn lowerErrorLiteral(el: ErrorLiteralExpr, idx: int) int {
        const fb = self.builder.func() orelse return null_node
        const err_idx = self.getGlobalErrorIndex(el.error_name)

        // Create error union: [tag=1][error_idx]
        const ret_type = self.inferExprType(idx)
        var eu_size = 16
        var eu_type = ret_type
        if (ret_type != VOID) {
            eu_size = self.types.sizeOf(ret_type)
        } else {
            eu_type = self.types.makeErrorUnion(VOID)
        }
        const tmp = fb.addLocalWithSize("__err_lit", eu_type, false, eu_size)
        const one = fb.emitConstInt(1, I64, el.span)
        fb.emitStoreLocalField(tmp, 0, 0, one, el.span)
        const idx_val = fb.emitConstInt(err_idx, I64, el.span)
        fb.emitStoreLocalField(tmp, 1, 8, idx_val, el.span)
        return fb.emitAddrLocal(tmp, I64, el.span)
    }

    /// Get or assign a unique global error index for an error name.
    fn getGlobalErrorIndex(name: string) int {
        if (self.global_error_table.contains(name)) {
            return self.global_error_table.get(name)
        }
        self.next_error_idx = self.next_error_idx + 1
        self.global_error_table.set(name, self.next_error_idx)
        return self.next_error_idx
    }

    // ========================================================================
    // Emit helpers
    // ========================================================================

    /// Emit cleanup stack entries that are errdefer only.
    fn emitCleanupsErrorPath(target_depth: int) void {
        var i = self.cleanup_stack.count - 1
        while (i >= target_depth) {
            const entry = self.cleanup_stack.get(i)
            if (entry.kind == CLEANUP_ERRDEFER) {
                self.lowerExprNode(entry.value)
            }
            i = i - 1
        }
    }

    /// Helper: emit string comparison.
    fn emitStringEqual(left: int, right: int, span: Span) int {
        const fb = self.builder.func() orelse return null_node
        const left_local = fb.addLocalWithSize("__seq_l", STRING, false, 16)
        fb.emitStoreLocal(left_local, left, span)
        const lp = fb.emitFieldLocal(left_local, 0, 0, I64, span)
        const ll = fb.emitFieldLocal(left_local, 1, 8, I64, span)

        const right_local = fb.addLocalWithSize("__seq_r", STRING, false, 16)
        fb.emitStoreLocal(right_local, right, span)
        const rp = fb.emitFieldLocal(right_local, 0, 0, I64, span)
        const rl = fb.emitFieldLocal(right_local, 1, 8, I64, span)

        var args: List(int) = .{}
        args.append(lp)
        args.append(ll)
        args.append(rp)
        args.append(rl)
        return fb.emitCall("string_eq", args, false, BOOL, span)
    }

    /// Resolve a union variant index from a pattern AST node.
    fn resolveUnionVariantIndex(union_type_idx: int, pat_idx: int) int {
        // Pattern is typically an ident or field_access — resolve to variant name
        var variant_name = ""
        switch (self.tree.getNode(pat_idx)) { Node.expr |e| => switch (e) {
            Expr.ident |id| => { variant_name = id.name },
            Expr.field_access |fa| => { variant_name = fa.field },
            else => {},
        }, else => {} }
        if (variant_name == "") { return -1 }

        const info = self.types.get(union_type_idx)
        if (info.tag != TAG_UNION) { return -1 }
        switch (info) {
            Type.union_type |ut| => {
                for i in 0..ut.variant_count {
                    const v = ut.getVariant(i)
                    if (v.name == variant_name) { return i }
                }
            },
            else => {},
        }
        return -1
    }

    /// Resolve the payload type of a union variant matched by patterns.
    fn resolveUnionPayloadType(union_type_idx: int, patterns: List(int)) int {
        if (patterns.count == 0) { return I64 }
        const pat_idx = patterns.get(0)
        var variant_name = ""
        switch (self.tree.getNode(pat_idx)) { Node.expr |e| => switch (e) {
            Expr.ident |id| => { variant_name = id.name },
            Expr.field_access |fa| => { variant_name = fa.field },
            else => {},
        }, else => {} }
        if (variant_name == "") { return I64 }

        const info = self.types.get(union_type_idx)
        if (info.tag != TAG_UNION) { return I64 }
        switch (info) {
            Type.union_type |ut| => {
                for i in 0..ut.variant_count {
                    const v = ut.getVariant(i)
                    if (v.name == variant_name) { return v.payload_type }
                }
            },
            else => {},
        }
        return I64
    }

    /// Ensure a generic function instance is queued for lowering.
    fn ensureGenericFnQueued(inst: *GenericInstInfo) void {
        if (@ptrToInt(inst) == 0 or @ptrToInt(inst) < 4096) { return }
        if (self.lowered_generics.contains(inst.concrete_name)) { return }
        self.lowered_generics.set(inst.concrete_name, 1)
        // Will be processed in lowerQueuedGenericFunctions
    }

    fn lowerBlockExpr(be: BlockExpr) int {
        const fb = self.builder.func() orelse return null_node
        // Labeled block: label: { ... break :label value ... }
        if (be.label != "") {
            return self.lowerLabeledBlockExpr(be)
        }
        // Regular block: lower contents, return result
        const scope_depth = fb.markScopeEntry()
        for i in 0..be.stmts.count {
            const stmt_idx = be.stmts.get(i)
            const maybe_stmt = asStmt(self.tree.getNode(stmt_idx))
            if (maybe_stmt) |s| {
                if (self.lowerStmt(s)) {
                    fb.restoreScope(scope_depth)
                    return null_node
                }
            }
        }
        var result = null_node
        if (be.result_expr != null_node) {
            result = self.lowerExprNode(be.result_expr)
        }
        fb.restoreScope(scope_depth)
        return result
    }

    fn lowerLabeledBlockExpr(be: BlockExpr) int {
        const fb = self.builder.func() orelse return null_node
        // Infer result type — default to I64
        var result_type = I64
        if (be.result_expr != null_node) {
            result_type = self.inferExprType(be.result_expr)
        }
        const result_size = self.types.sizeOf(result_type)

        const result_local = fb.addLocalWithSize("__block_result", result_type, false, result_size)
        const exit_block = fb.newBlock("block.exit")

        // Push labeled block context
        self.labeled_block_stack.append(LabeledBlockCtx {
            .label = be.label,
            .exit_block = exit_block,
            .result_local = result_local,
            .result_type = result_type,
            .cleanup_depth = self.cleanup_stack.count,
        })

        const scope_depth = fb.markScopeEntry()
        for i in 0..be.stmts.count {
            const stmt_idx = be.stmts.get(i)
            const maybe_stmt = asStmt(self.tree.getNode(stmt_idx))
            if (maybe_stmt) |s| {
                self.lowerStmt(s)
            }
        }

        // If block has a trailing expression (implicit result), store it
        if (be.result_expr != null_node) {
            const expr_val = self.lowerExprNode(be.result_expr)
            if (expr_val != null_node) {
                fb.emitStoreLocal(result_local, expr_val, be.span)
            }
        }

        if (fb.needsTerminator()) {
            fb.emitJump(exit_block, be.span)
        }

        fb.restoreScope(scope_depth)
        self.labeled_block_stack.pop()

        fb.setBlock(exit_block)
        return fb.emitLoadLocal(result_local, result_type, be.span)
    }

    // ========================================================================
    // Generic function queue
    // ========================================================================

    fn lowerQueuedGenericFunctions() void {
        var made_progress = true
        var iter_count = 0
        var total_lowered = 0
        while (made_progress) {
            made_progress = false
            iter_count += 1
            var pending: List(string) = .{}
            const all_keys = self.chk.generic_inst_by_name.keys()
            for i in 0..all_keys.count {
                const key = all_keys.get(i)
                if (!self.lowered_generics.contains(key)) { continue }
                if (self.builder.hasFunc(key)) { continue }
                pending.append(key)
            }
            if (iter_count > 100) { return }  // Safety: prevent infinite loops
            // Process collected snapshot (safe — no iterator active)
            for i in 0..pending.count {
                const name = pending.get(i)
                if (self.builder.hasFunc(name)) { continue }
                self.lowerGenericFnInstance(name)
                if (!self.builder.hasFunc(name)) {
                    // Function lowering failed silently (e.g., shape alias, missing body).
                    // Mark as lowered to prevent infinite re-processing.
                    self.builder.startFunc(name, VOID, VOID, Span.zero())
                    if (self.builder.func()) |fb| {
                        fb.emitRet(null_node, Span.zero())
                    }
                    self.builder.endFunc()
                }
                total_lowered += 1
                made_progress = true
            }
        }
    }

    /// Lower one concrete generic function as a top-level function.
    fn lowerGenericFnInstance(concrete_name: string) void {
        // Look up the GenericInstInfo
        if (self.lookupGenericInst(concrete_name)) |inst| {
            self.lowerGenericFnInstanceInner(inst, concrete_name)
        }
    }

    fn lowerGenericFnInstanceInner(inst: *GenericInstInfo, concrete_name: string) void {
        // Swap to the defining file's AST for cross-file generic resolution
        const saved_tree = self.tree
        self.tree = inst.getAst()

        // Get the fn_decl node from the defining file's AST
        const fn_node = self.tree.getNode(inst.generic_node)
        var fn_d: FnDecl = undefined
        var found = false
        switch (fn_node) { Node.decl |d| => switch (d) {
            Decl.fn_decl |f| => { fn_d = f; found = true },
            else => {},
        }, else => {} }
        if (!found) {
            self.tree = saved_tree
            return
        }

        // Set up type substitution in checker from type_args_str + type_param_names
        // Both are semicolon-separated: "5;17" and "K;V"
        const saved_sub_count = self.chk.type_sub_keys.count
        const type_args = inst.type_args_str
        const param_names = inst.type_param_names
        self.parseAndPushTypeSubs(type_args, param_names)

        // Shape stenciling DISABLED — selfcot's Wasm linker doesn't support
        // shape aliases yet. Every generic instance is lowered fully.
        // TODO: Re-enable when func_indices resolves aliases at link time.

        // Go pattern: use expr_types preserved from Phase 2 instead of re-checking.
        // This eliminates checkFnDeclBody during lowering, avoiding stack overflow.
        const saved_expr_types = self.chk.expr_types
        const saved_chk_ast = self.chk.ast
        self.chk.ast = self.tree  // swap checker AST to defining file
        if (inst.expr_types_ptr != 0) {
            // Use Phase 2 expr_types directly — no re-checking needed
            self.chk.expr_types = @intToPtr(*Map(int, int), inst.expr_types_ptr).*
        } else {
            // Fallback: fresh expr_types with re-check (for impl method generics).
            // Zig/Go pattern: use a temporary ErrorReporter for the defining file's
            // source to prevent corrupt byte offset → source text mapping.
            // The defining file's AST is in self.tree (swapped above).
            var fresh_types: Map(int, int) = .{}
            self.chk.expr_types = fresh_types
            const saved_err = self.chk.err
            var temp_err = ErrorReporter.init()
            self.chk.err = &temp_err
            self.chk.checkFnDeclBody(inst.generic_node, concrete_name)
            self.chk.err = saved_err
        }

        // Lower the concrete function body
        const return_type = self.resolveTypeNode(fn_d.return_type)
        const uses_sret = self.needsSret(return_type)
        var wasm_return_type = return_type
        if (uses_sret) { wasm_return_type = VOID }
        self.builder.startFunc(concrete_name, VOID, wasm_return_type, fn_d.span)
        if (self.builder.func()) |fb| {
            if (uses_sret) { fb.sret_return_type = return_type }
            self.clearPerFunctionState()

            if (uses_sret) {
                fb.addParam("__sret", I64, 8)
            }

            // Dict-stenciled functions disabled (shape stenciling off)

            // Add params
            for pi in 0..fn_d.params.count {
                const param_idx = fn_d.params.get(pi)
                const p_node = self.tree.getNode(param_idx)
                var pname = ""
                var ptype_expr = null_node
                switch (p_node) { Node.expr |e| => switch (e) {
                    Expr.field_def |fd| => { pname = fd.name; ptype_expr = fd.type_expr },
                    else => {},
                }, else => {} }
                var param_type = self.resolveTypeNode(ptype_expr)
                // Skip safeWrapType for substituted type parameters.
                // Mirror checker isSubstitutedTypeParam: check both Expr.ident
                // and Expr.type_expr with TYPE_NAMED kind (Zig ref: lower.zig:9179-9182).
                const is_substituted = self.chk.isSubstitutedTypeParam(ptype_expr)
                if (!is_substituted) { param_type = self.chk.safeWrapType(param_type) }
                fb.addParam(pname, param_type, self.types.sizeOf(param_type))
            }

            if (fn_d.body != null_node) {
                self.lowerBlockNode(fn_d.body)
                if (return_type == VOID and fb.needsTerminator()) {
                    self.emitCleanups(0)
                    fb.emitRet(null_node, fn_d.span)
                } else if (fb.needsTerminator()) {
                    const rti = self.types.get(return_type)
                    if (rti.tag == TAG_ERROR_UNION) {
                        const eu_elem = switch (rti) { Type.error_union |eu| => eu.elem, else => VOID }
                        if (eu_elem == VOID) {
                            self.emitCleanups(0)
                            self.emitErrorVoidSuccessReturn(return_type, fn_d.span)
                        }
                    }
                }
            }
        }
        // Clear dict context
        self.has_dict_context = false
        self.current_dict_entries.count = 0
        self.current_dict_params.count = 0
        self.builder.endFunc()

        // Restore type substitution, checker AST, expr_types, and tree
        self.chk.type_sub_keys.count = saved_sub_count
        self.chk.type_sub_vals.count = saved_sub_count
        self.chk.expr_types = saved_expr_types
        self.chk.ast = saved_chk_ast
        self.tree = saved_tree
    }

    /// Parse an integer from a substring of s[start..end].
    static fn parseIntSubstr(s: string, start: int, end: int) int {
        var result = 0
        for i in start..end {
            const c = s[i]
            if (c >= 48 and c <= 57) {
                result = result * 10 + (c - 48)
            }
        }
        return result
    }

    // ========================================================================
    // AST query helpers
    // ========================================================================

    /// Extract ident name from a node, if it's an ident expression.
    fn extractIdentName(node_idx: int) ?string {
        switch (self.tree.getNode(node_idx)) {
            Node.expr |e| => switch (e) {
                Expr.ident |id| => { return id.name },
                else => {},
            },
            else => {},
        }
        return null
    }

    /// Look up a generic instantiation by concrete name.
    fn lookupGenericInst(name: string) ?*GenericInstInfo {
        if (!self.chk.generic_inst_by_name.contains(name)) { return null }
        return self.chk.generic_inst_by_name.get(name)
    }

    /// Execute a deferred cleanup expression (defer/errdefer body).
    /// Zig reference: lower.zig:2117-2124
    fn lowerDeferredNode(node_idx: int) void {
        switch (self.tree.getNode(node_idx)) {
            Node.stmt |stmt| => {
                self.lowerStmt(stmt)
            },
            Node.expr => {
                self.lowerExprNode(node_idx)
            },
            else => {},
        }
    }

    /// Check if a binary operator is division or modulo.
    /// Used to route div/mod to special handlers (zero-check injection).
    /// Zig reference: lower.zig:4573-4578
    fn isDivOp(op: int) bool {
        return op == Token.quo or op == Token.rem
    }

    /// Find a labeled block by name in the labeled_block_stack.
    /// Zig reference: lower.zig:4108-4116
    fn findLabeledBlock(target_label: string) ?LabeledBlockCtx {
        var i = self.labeled_block_stack.count
        while (i > 0) {
            i = i - 1
            const blk_ctx = self.labeled_block_stack.get(i)
            if (blk_ctx.label == target_label) {
                return blk_ctx
            }
        }
        return null
    }

    /// Resolve a type argument node into a TypeIndex.
    /// Handles type keywords as idents, type substitution, and complex type_expr nodes.
    /// Zig reference: lower.zig:10092-10120
    fn resolveTypeArgNode(idx: int) int {
        if (self.extractIdentName(idx)) |name| {
            // Check type substitution first (active during generic instantiation)
            if (self.chk.hasTypeSubstitution()) {
                const sub = self.chk.lookupTypeSub(name)
                if (sub >= 0) { return sub }
            }
            // Check type keywords
            if (name == "void") { return VOID }
            if (name == "bool") { return BOOL }
            if (name == "i8") { return I8 }
            if (name == "i16") { return I16 }
            if (name == "i32") { return I32 }
            if (name == "i64") { return I64 }
            if (name == "int") { return I64 }
            if (name == "u8") { return U8 }
            if (name == "u16") { return U16 }
            if (name == "u32") { return U32 }
            if (name == "u64") { return U64 }
            if (name == "f32") { return F32 }
            if (name == "f64") { return F64 }
            if (name == "string") { return STRING }
            // Named type lookup
            const named = self.types.lookupByName(name)
            if (named >= 0) { return named }
            return VOID
        }
        // Fall through to standard type_expr resolution
        return self.resolveTypeNode(idx)
    }

    /// Construct a mangled generic type name and look it up.
    /// E.g. List(i64) → "List(42)" where 42 is the TypeIndex for i64.
    /// Zig reference: lower.zig:10075-10088
    fn resolveGenericTypeName(base_name: string, type_args: List(int)) int {
        var buf = base_name ++ "("
        for i in 0..type_args.count {
            if (i > 0) { buf = buf ++ ";" }
            const arg_type = self.resolveTypeArgNode(type_args.get(i))
            buf = buf ++ intToString(arg_type)
        }
        buf = buf ++ ")"
        const result = self.types.lookupByName(buf)
        if (result >= 0) { return result }
        return VOID
    }

    // ========================================================================
    // Type query helpers
    // ========================================================================

    /// Find a struct field index by name. Returns -1 if not found.
    fn findStructFieldIdx(struct_type_idx: int, field_name: string) int {
        const info = self.types.get(struct_type_idx)
        if (info.tag != TAG_STRUCT) { return -1 }
        switch (info) {
            Type.struct_type |st| => {
                for i in 0..st.field_count {
                    const field = st.getField(i)
                    if (field.name == field_name) { return i }
                }
            },
            else => {},
        }
        return -1
    }

    /// Get a struct field by index. Caller must ensure type is struct and index is valid.
    fn getStructField(struct_type_idx: int, field_idx: int) ?*StructField {
        switch (self.types.get(struct_type_idx)) {
            Type.struct_type |st| => { return st.getField(field_idx) },
            else => {},
        }
        return null
    }

    /// Find an enum variant's value by name. Returns -1 if not found.
    fn findEnumVariant(enum_type_idx: int, variant_name: string) int {
        const info = self.types.get(enum_type_idx)
        if (info.tag != TAG_ENUM) { return -1 }
        switch (info) {
            Type.enum_type |e| => {
                for i in 0..e.variant_count {
                    const v = e.getVariant(i)
                    if (v.name == variant_name) { return v.value }
                }
            },
            else => {},
        }
        return -1
    }

    /// Infer the result type of a binary expression.
    /// Comparisons always produce BOOL, others inherit left operand's type.
    fn inferBinaryType(tok: int, left: int, right: int) int {
        // Comparison operators → BOOL
        if (tok == Token.eql or tok == Token.neq or
            tok == Token.lss or tok == Token.leq or
            tok == Token.gtr or tok == Token.geq) {
            return BOOL
        }
        // Logical operators → BOOL
        if (tok == Token.land or tok == Token.lor or
            tok == Token.kw_and or tok == Token.kw_or) {
            return BOOL
        }
        // All other ops inherit left operand's type
        return self.inferExprType(left)
    }

    // ========================================================================
    // Comptime evaluation
    // ========================================================================

    /// Look up a comptime value by name — checks function-local vars first, then globals.
    /// Returns -1 if not found.
    fn lookupComptimeValue(name: string) int {
        if (self.comptime_value_vars.contains(name)) {
            return self.comptime_value_vars.get(name)
        }
        if (self.global_comptime_values.contains(name)) {
            return self.global_comptime_values.get(name)
        }
        return -1
    }

    /// Emit a comptime value as IR nodes.
    /// For the self-hosted compiler, comptime values are stored as ints.
    /// Kind encoding: 0=int, 1=float (as bits), 2=string index, 3=bool.
    /// Ref: lower.zig:8723-8737
    fn emitComptimeValue(val: int, span: Span) int {
        const fb = self.builder.func() orelse return null_node
        // Simple case: treat as integer constant
        return fb.emitConstInt(val, I64, span)
    }

    /// Evaluate a float literal expression at compile time.
    /// Handles: literal, paren, negation, binary arithmetic (+,-,*,/).
    /// Ref: lower.zig:1142-1168
    fn evalFloatLiteral(idx: int) ?float {
        if (idx == null_node) { return null }
        switch (self.tree.getNode(idx)) { Node.expr |e| => {
            return switch (e) {
                Expr.literal |l| => {
                    if (l.kind == LiteralKind.@"float") {
                        return parseFloatLit(l.value)
                    }
                    if (l.kind == LiteralKind.@"int") {
                        return @floatFromInt(f64, parseIntLit(l.value))
                    }
                    return null
                },
                Expr.paren |p| => self.evalFloatLiteral(p.inner),
                Expr.unary |un| => {
                    if (un.op == Token.sub as int) {
                        if (self.evalFloatLiteral(un.operand)) |v| {
                            return -v
                        }
                    }
                    return null
                },
                Expr.binary |bin| => {
                    const l = self.evalFloatLiteral(bin.left)
                    const r = self.evalFloatLiteral(bin.right)
                    if (l == null or r == null) { return null }
                    if (bin.op == Token.add) { return l.? + r.? }
                    if (bin.op == Token.sub) { return l.? - r.? }
                    if (bin.op == Token.mul) { return l.? * r.? }
                    if (bin.op == Token.quo) { return l.? / r.? }
                    return null
                },
                else => null,
            }
        }, else => { return null } }
    }

    /// Extract string literal value from a node, stripping surrounding quotes.
    fn getStringLiteral(idx: int) ?string {
        if (idx == null_node) { return null }
        switch (self.tree.getNode(idx)) { Node.expr |e| => switch (e) {
            Expr.literal |l| => {
                if (l.kind != LiteralKind.@"string") { return null }
                const v = l.value
                if (@lenOf(v) >= 2 and charAt(v, 0) == 34 and charAt(v, @lenOf(v) - 1) == 34) {
                    return @string(@ptrOf(v) + 1, @lenOf(v) - 2)
                }
                return v
            },
            else => { return null },
        }, else => { return null } }
    }

    // ========================================================================
    // Helper functions
    // ========================================================================

    /// Clear per-function state at function entry.
    fn clearPerFunctionState() void {
        var empty_cleanup: List(CleanupEntry) = .{}
        self.cleanup_stack = empty_cleanup
        var empty_comptime: Map(string, int) = .{}
        self.comptime_value_vars = empty_comptime
        var empty_weak: Map(int, int) = .{}
        self.weak_locals = empty_weak
    }

    /// Emit a bounds check: if index >= length, print Go-style panic message and exit.
    /// Go: runtime/panic.go goPanicIndex — "index out of range [N] with length M"
    /// Zig: Sema.zig:26482 — addSafetyCheck pattern.
    /// Ref: lower.zig:8800-8803
    fn emitBoundsCheck(index_node: int, length_node: int, span: Span) void {
        const fb = self.builder.func() orelse return null_node
        // index < length (strict — for element access)
        const in_bounds = fb.emitBinary(BinaryOp.lt, index_node, length_node, BOOL, span)
        self.emitBoundsCheckImpl(in_bounds, index_node, length_node, span)
    }

    /// Emit a slice bounds check: if index > length, panic.
    /// Slice end index CAN equal length (exclusive upper bound).
    /// Ref: lower.zig:8808-8811
    fn emitSliceBoundsCheck(index_node: int, length_node: int, span: Span) void {
        const fb = self.builder.func() orelse return null_node
        // index <= length (non-strict — for slice bounds)
        const in_bounds = fb.emitBinary(BinaryOp.le, index_node, length_node, BOOL, span)
        self.emitBoundsCheckImpl(in_bounds, index_node, length_node, span)
    }

    /// Ref: lower.zig:8813-8863
    fn emitBoundsCheckImpl(in_bounds: int, index_node: int, length_node: int, span: Span) void {
        const fb = self.builder.func() orelse return null_node
        const ok_block = fb.newBlock("bounds.ok")
        const fail_block = fb.newBlock("bounds.fail")
        fb.emitBranch(in_bounds, ok_block, fail_block, span)
        fb.setBlock(fail_block)

        const fd = fb.emitConstInt(2, I64, span)  // stderr

        // "panic: index out of range ["
        const prefix_idx = fb.addStringLiteral("panic: index out of range [")
        const prefix_val = fb.emitConstSlice(prefix_idx, span)
        var prefix_args: List(int) = .{}
        prefix_args.append(fd)
        prefix_args.append(prefix_val)
        fb.emitCall("write", prefix_args, true, I64, span)

        // Print the index value
        var idx_args: List(int) = .{}
        idx_args.append(index_node)
        fb.emitCall("eprint_int", idx_args, false, VOID, span)

        // "] with length "
        const mid_idx = fb.addStringLiteral("] with length ")
        const mid_val = fb.emitConstSlice(mid_idx, span)
        var mid_args: List(int) = .{}
        mid_args.append(fd)
        mid_args.append(mid_val)
        fb.emitCall("write", mid_args, true, I64, span)

        // Print the length value
        var len_args: List(int) = .{}
        len_args.append(length_node)
        fb.emitCall("eprint_int", len_args, false, VOID, span)

        // Newline
        const nl_idx = fb.addStringLiteral("\n")
        const nl_val = fb.emitConstSlice(nl_idx, span)
        var nl_args: List(int) = .{}
        nl_args.append(fd)
        nl_args.append(nl_val)
        fb.emitCall("write", nl_args, true, I64, span)

        // Exit with code 2
        const exit_code = fb.emitConstInt(2, I64, span)
        var exit_args: List(int) = .{}
        exit_args.append(exit_code)
        fb.emitCall("exit", exit_args, false, VOID, span)

        fb.emitTrap(span)
        fb.setBlock(ok_block)
    }

    /// Check if any active cleanup is a defer, errdefer, or scope_destroy.
    /// Reference: lower.zig:1982-1987
    fn hasDeferCleanups() bool {
        for i in 0..self.cleanup_stack.count {
            const cleanup = self.cleanup_stack.get(i)
            if (cleanup.kind == CLEANUP_DEFER or cleanup.kind == CLEANUP_ERRDEFER or cleanup.kind == CLEANUP_SCOPE_DESTROY) {
                return true
            }
        }
        return false
    }

    /// Check if a base expression (ident, field access, index, deref) has
    /// an associated cleanup in the cleanup stack.
    /// Reference: lower.zig:2101-2114
    fn baseHasCleanup(base_idx: int) bool {
        const node = self.tree.getNode(base_idx)
        switch (node) { Node.expr |e| => switch (e) {
            Expr.ident |id| => {
                if (self.builder.func()) |fb| {
                    if (fb.lookupLocal(id.name)) |local_idx| {
                        // Check if any cleanup targets this local
                        for j in 0..self.cleanup_stack.count {
                            const cleanup = self.cleanup_stack.get(j)
                            if (cleanup.local_idx == local_idx) { return true }
                        }
                    }
                }
                return false
            },
            Expr.field_access |fa| => { return self.baseHasCleanup(fa.base) },
            Expr.index_expr |ix| => { return self.baseHasCleanup(ix.base) },
            Expr.deref |d| => { return self.baseHasCleanup(d.operand) },
            else => { return false },
        }, else => { return false } }
    }

    /// Register scope_destroy cleanup for structs with deinit() method.
    /// Called after lowering struct init to auto-call deinit at scope exit.
    /// Reference: lower.zig:1995-2028
    fn maybeRegisterScopeDestroy(local_idx: int, type_idx: int) void {
        const type_info = self.types.get(type_idx)
        if (type_info.tag != TAG_STRUCT) { return }
        const struct_name = switch (type_info) { Type.struct_type |st| => st.name, else => "" }
        if (struct_name == "") { return }

        // Check if this struct has a deinit() method
        const method_idx = self.types.lookupMethod(struct_name, "deinit")
        if (method_idx >= 0) {
            const method_info = self.types.getMethodInfo(method_idx)
            // Queue generic function for lowering if needed
            if (self.lookupGenericInst(method_info.func_name)) |inst| {
                self.ensureGenericFnQueued(inst)
            }
            // Qualify deinit method name for cross-module consistency
            const qualified_deinit = if (self.lookupGenericInst(method_info.func_name) != null) {
                method_info.func_name
            } else {
                self.resolveMethodName(struct_name, method_info.func_name, method_info.source_tree)
            }
            self.cleanup_stack.append(CleanupEntry {
                kind: CLEANUP_SCOPE_DESTROY,
                value: null_node,
                type_idx: type_idx,
                local_idx: local_idx,
                func_name: qualified_deinit,
            })
        } else {
            // ARC Phase 4: Check for auto-generated deinit
            for i in 0..self.pending_auto_deinits.count {
                const auto_name = self.pending_auto_deinits.get(i)
                if (auto_name == struct_name) {
                    const qualified_type = self.qualifyTypeName(struct_name)
                    const deinit_name = "${qualified_type}_deinit"
                    self.cleanup_stack.append(CleanupEntry {
                        kind: CLEANUP_SCOPE_DESTROY,
                        value: null_node,
                        type_idx: type_idx,
                        local_idx: local_idx,
                        func_name: deinit_name,
                    })
                    return
                }
            }
        }
    }

    /// Emit pending cleanups down to the given depth (defer + ARC release).
    fn emitCleanups(target_depth: int) void {
        self.emitCleanupsImpl(target_depth, false, true)
    }

    /// Emit cleanups on error path — runs both defer and errdefer.
    fn emitCleanupsErrorPathFull(target_depth: int) void {
        self.emitCleanupsImpl(target_depth, true, true)
    }

    /// Emit cleanups without popping (for break/continue).
    fn emitCleanupsNoPop(target_depth: int) void {
        self.emitCleanupsImpl(target_depth, false, false)
    }

    fn emitCleanupsImpl(target_depth: int, is_error_path: bool, pop: bool) void {
        if (self.builder.func()) |fb| {
            // Process in reverse order (LIFO)
            var i = self.cleanup_stack.count
            while (i > target_depth) {
                i = i - 1
                const cleanup = self.cleanup_stack.get(i)

                switch (cleanup.kind) {
                    CLEANUP_RELEASE => {
                        // ARC release — reload current value (may have been reassigned)
                        var value = cleanup.value
                        if (cleanup.local_idx >= 0) {
                            value = fb.emitLoadLocal(cleanup.local_idx, cleanup.type_idx, Span.zero())
                        }
                        var args: List(int) = .{}
                        args.append(value)
                        fb.emitCall("release", args, false, VOID, Span.zero())
                    },
                    CLEANUP_DEFER => {
                        self.lowerExprNode(cleanup.value)
                    },
                    CLEANUP_ERRDEFER => {
                        // errdefer only fires on error exit paths
                        if (is_error_path) {
                            self.lowerExprNode(cleanup.value)
                        }
                    },
                    CLEANUP_SCOPE_DESTROY => {
                        if (cleanup.local_idx >= 0 and cleanup.func_name != "") {
                            const ptr_type = self.types.makePointer(cleanup.type_idx)
                            const self_addr = fb.emitAddrLocal(cleanup.local_idx, ptr_type, Span.zero())
                            var args: List(int) = .{}
                            args.append(self_addr)
                            fb.emitCall(cleanup.func_name, args, false, VOID, Span.zero())
                        }
                    },
                    else => {},
                }
            }

            // Pop the cleanups we just emitted
            if (pop) {
                self.cleanup_stack.count = target_depth
            }
        }
    }

    /// Emit ARC field releases for destructor functions.
    /// Ref: lower.zig:2011-2019
    fn emitFieldReleases(type_name: string, span: Span) void {
        const fb = self.builder.func() orelse return null_node
        // Look up struct type by name
        const type_idx = self.types.lookupByName(type_name)
        if (type_idx < 0) { return }
        const type_info = self.types.get(type_idx)
        if (type_info.tag != TAG_STRUCT) { return }
        switch (type_info) {
            Type.struct_type |st| => {
                const ptr_type = self.types.makePointer(type_idx)
                for i in 0..st.field_count {
                    const field = st.getField(i)
                    if (self.types.couldBeARC(field.type_idx)) {
                        const self_local: int = 0  // first param (self)
                        const self_ptr = fb.emitLoadLocal(self_local, ptr_type, span)
                        const field_val = fb.emitFieldValue(self_ptr, i, field.offset, field.type_idx, span)
                        var release_args: List(int) = .{}
                        release_args.append(field_val)
                        fb.emitCall("release", release_args, false, VOID, span)
                    }
                }
            },
            else => {},
        }
    }

    /// Generate synthetic deinit functions for structs with ARC fields but no user deinit.
    /// Reference: Swift auto-generated memberwise destroy.
    /// Ref: lower.zig:1991-2026
    fn emitPendingAutoDeinits() void {
        const fb = self.builder.func() orelse return null_node
        for i in 0..self.pending_auto_deinits.count {
            const type_name = self.pending_auto_deinits.get(i)
            const struct_type_idx = self.types.lookupByName(type_name)
            if (struct_type_idx < 0) { continue }
            const type_info = self.types.get(struct_type_idx)
            if (type_info.tag != TAG_STRUCT) { continue }

            const qualified_type = self.qualifyTypeName(type_name)
            const deinit_name = qualified_type ++ "_deinit"
            // Skip if already emitted (multi-file dedup)
            if (self.builder.hasFunc(deinit_name)) { continue }

            const ptr_type = self.types.makePointer(struct_type_idx)
            self.builder.startFunc(deinit_name, VOID, VOID, Span.zero())
            if (self.builder.func()) |fb| {
                self.clearPerFunctionState()
                fb.is_destructor = true
                fb.addParam("self", ptr_type, 8)
                self.emitFieldReleases(type_name, Span.zero())
                fb.emitRet(null_node, Span.zero())
            }
            self.builder.endFunc()
        }
    }

    /// SRET: returns true if the type needs struct return (> 8 bytes).
    fn needsSret(type_idx: int) bool {
        const info = self.types.get(type_idx)
        if (info.tag == TAG_STRUCT or info.tag == TAG_TUPLE or info.tag == TAG_UNION) {
            // WasmGC: struct types are GC refs (single value), no SRET needed
            if (self.gc_mode and info.tag == TAG_STRUCT) { return false }
            if (self.types.sizeOf(type_idx) > 8) {
                return true
            }
        }
        if (info.tag == TAG_OPTIONAL) {
            if (!self.isPtrLikeOptional(type_idx)) {
                return true
            }
        }
        return false
    }

    /// Returns true if the optional wraps a pointer (single-value null=0 sentinel).
    fn isPtrLikeOptional(type_idx: int) bool {
        const info = self.types.get(type_idx)
        if (info.tag != TAG_OPTIONAL) { return false }
        // Extract elem type from optional
        switch (info) {
            Type.optional |opt| => {
                const elem_tag = self.types.get(opt.elem).tag
                if (elem_tag == TAG_POINTER) { return true }
                // WasmGC: struct and union types are GC refs, so ?T is (ref null $T)
                if (self.gc_mode and (elem_tag == TAG_STRUCT or elem_tag == TAG_UNION)) { return true }
                return false
            },
            else => { return false },
        }
    }

    /// Returns true if the optional wraps a GC ref type (struct/union in WasmGC mode).
    fn isGcRefOptional(type_idx: int) bool {
        if (!self.gc_mode) { return false }
        const info = self.types.get(type_idx)
        if (info.tag != TAG_OPTIONAL) { return false }
        switch (info) {
            Type.optional |opt| => {
                const elem_tag = self.types.get(opt.elem).tag
                return elem_tag == TAG_STRUCT or elem_tag == TAG_UNION
            },
            else => { return false },
        }
    }

    // ========================================================================
    // Compound optional store helpers
    // ========================================================================

    /// Store a value into a compound optional result local, wrapping T → ?T as needed.
    /// Used by switch/if expressions that produce compound optional results.
    /// Ref: lower.zig:306-341
    fn storeCompoundOptArm(result_local: int, val: int, body_idx: int, span: Span) void {
        const fb = self.builder.func() orelse return null_node
        // Check if arm value is a null literal
        var is_null = false
        switch (self.tree.getNode(body_idx)) { Node.expr |e| => switch (e) {
            Expr.literal |l| => { if (l.kind == LiteralKind.null_lit) { is_null = true } },
            else => {},
        }, else => {} }

        if (is_null) {
            // null → tag=0
            const tag_zero = fb.emitConstInt(0, I64, span)
            fb.emitStoreLocalField(result_local, 0, 0, tag_zero, span)
        } else {
            const arm_type = self.inferExprType(body_idx)
            const arm_info = self.types.get(arm_type)
            if (arm_info.tag == TAG_OPTIONAL and !self.isPtrLikeOptional(arm_type)) {
                // Already compound optional → compound copy
                fb.emitStoreLocal(result_local, val, span)
            } else {
                // Plain T → wrap as tag=1, payload=value
                const tag_one = fb.emitConstInt(1, I64, span)
                fb.emitStoreLocalField(result_local, 0, 0, tag_one, span)
                const arm_size = self.types.sizeOf(arm_type)
                if (arm_size > 8) {
                    // Large T — copy word by word into payload area
                    const val_tmp = fb.addLocalWithSize("__opt_arm_tmp", arm_type, false, arm_size)
                    fb.emitStoreLocal(val_tmp, val, span)
                    const num_words = (arm_size + 7) / 8
                    for i in 0..num_words {
                        const off = i * 8
                        const word = fb.emitFieldLocal(val_tmp, i, off, I64, span)
                        fb.emitStoreLocalField(result_local, 1 + i, 8 + off, word, span)
                    }
                } else {
                    fb.emitStoreLocalField(result_local, 1, 8, val, span)
                }
            }
        }
    }

    /// Store compound optional via pointer base (for struct field assign through pointer).
    /// Ref: lower.zig:344-382
    fn storeCompoundOptFieldPtr(ptr: int, field_idx: int, field_offset: int, val: int, ast_idx: int, span: Span) void {
        const fb = self.builder.func() orelse return null_node
        var is_null = false
        switch (self.tree.getNode(ast_idx)) { Node.expr |e| => switch (e) {
            Expr.literal |l| => { if (l.kind == LiteralKind.null_lit) { is_null = true } },
            else => {},
        }, else => {} }

        if (is_null) {
            const tag_zero = fb.emitConstInt(0, I64, span)
            fb.emitStoreFieldValue(ptr, field_idx, field_offset, tag_zero, span)
        } else {
            const arm_type = self.inferExprType(ast_idx)
            const arm_info = self.types.get(arm_type)
            if (arm_info.tag == TAG_OPTIONAL and !self.isPtrLikeOptional(arm_type)) {
                // Already compound optional — copy all words
                const arm_size = self.types.sizeOf(arm_type)
                const num_words = arm_size / 8
                const tmp = fb.addLocalWithSize("__opt_fap_tmp", arm_type, false, arm_size)
                fb.emitStoreLocal(tmp, val, span)
                for i in 0..num_words {
                    const offset = i * 8
                    const field = fb.emitFieldLocal(tmp, i, offset, I64, span)
                    fb.emitStoreFieldValue(ptr, field_idx + i, field_offset + offset, field, span)
                }
            } else {
                const tag_one = fb.emitConstInt(1, I64, span)
                fb.emitStoreFieldValue(ptr, field_idx, field_offset, tag_one, span)
                const arm_size = self.types.sizeOf(arm_type)
                if (arm_size > 8) {
                    const val_tmp = fb.addLocalWithSize("__opt_fap_val", arm_type, false, arm_size)
                    fb.emitStoreLocal(val_tmp, val, span)
                    const num_words = (arm_size + 7) / 8
                    for i in 0..num_words {
                        const off = i * 8
                        const word = fb.emitFieldLocal(val_tmp, i, off, I64, span)
                        fb.emitStoreFieldValue(ptr, field_idx + 1 + i, field_offset + 8 + off, word, span)
                    }
                } else {
                    fb.emitStoreFieldValue(ptr, field_idx + 1, field_offset + 8, val, span)
                }
            }
        }
    }

    /// Store a value into a compound optional struct field, wrapping T → ?T as needed.
    /// Handles struct init fields and default values.
    /// Ref: lower.zig:386-426
    fn storeCompoundOptField(local_idx: int, field_idx: int, field_offset: int, val: int, ast_idx: int, span: Span) void {
        const fb = self.builder.func() orelse return null_node
        var is_null = false
        switch (self.tree.getNode(ast_idx)) { Node.expr |e| => switch (e) {
            Expr.literal |l| => { if (l.kind == LiteralKind.null_lit) { is_null = true } },
            else => {},
        }, else => {} }

        if (is_null) {
            const tag_zero = fb.emitConstInt(0, I64, span)
            fb.emitStoreLocalField(local_idx, field_idx, field_offset, tag_zero, span)
        } else {
            const arm_type = self.inferExprType(ast_idx)
            const arm_info = self.types.get(arm_type)
            if (arm_info.tag == TAG_OPTIONAL and !self.isPtrLikeOptional(arm_type)) {
                // Already compound optional — copy all words
                const arm_size = self.types.sizeOf(arm_type)
                const num_words = arm_size / 8
                const tmp = fb.addLocalWithSize("__opt_field_tmp", arm_type, false, arm_size)
                fb.emitStoreLocal(tmp, val, span)
                for i in 0..num_words {
                    const offset = i * 8
                    const field = fb.emitFieldLocal(tmp, i, offset, I64, span)
                    fb.emitStoreLocalField(local_idx, field_idx + i, field_offset + offset, field, span)
                }
            } else {
                // Plain T → wrap as tag=1, payload=value
                const tag_one = fb.emitConstInt(1, I64, span)
                fb.emitStoreLocalField(local_idx, field_idx, field_offset, tag_one, span)
                const arm_size = self.types.sizeOf(arm_type)
                if (arm_size > 8) {
                    const val_tmp = fb.addLocalWithSize("__opt_fld_val", arm_type, false, arm_size)
                    fb.emitStoreLocal(val_tmp, val, span)
                    const num_words = (arm_size + 7) / 8
                    for i in 0..num_words {
                        const off = i * 8
                        const word = fb.emitFieldLocal(val_tmp, i, off, I64, span)
                        fb.emitStoreLocalField(local_idx, field_idx + 1 + i, field_offset + 8 + off, word, span)
                    }
                } else {
                    fb.emitStoreLocalField(local_idx, field_idx + 1, field_offset + 8, val, span)
                }
            }
        }
    }

    /// Resolve a type expression AST node to a type index.
    fn resolveTypeNode(idx: int) int {
        if (idx == null_node) { return VOID }
        if (self.chk.expr_types.contains(idx)) {
            return self.chk.expr_types.get(idx)
        }
        // Fallback: only resolve type_expr nodes (not idents/literals/etc.)
        // Zig lower.zig:10061-10063: if not a type_expr, return VOID
        // NOTE: Self-hosted AST stores inner types as idents (not nested type_exprs),
        // so compound kinds use chk.resolveTypeExpr (handles both idents and type_exprs).
        var kind = -1
        var d1 = null_node
        var d2 = null_node
        switch (self.tree.getNode(idx)) { Node.expr |e| => switch (e) {
            Expr.type_expr |te| => { kind = te.kind; d1 = te.data1; d2 = te.data2 },
            // In @safe mode, the parser creates self params with Expr.ident type (not type_expr).
            // Resolve by NAME directly — avoids AST mismatch between lowerer and checker.
            Expr.ident |id| => {
                if (self.chk.hasTypeSubstitution()) {
                    const sub = self.chk.lookupTypeSub(id.name)
                    if (sub >= 0) { return sub }
                }
                const tid = self.types.lookupByName(id.name)
                if (tid >= 0) { return tid }
                return VOID
            },
            // Generic type instances: Map(K, V), List(T), etc.
            // Delegate to checker's resolveTypeExpr which handles generic_instance.
            Expr.generic_instance |_gi| => {
                return self.chk.resolveTypeExpr(idx)
            },
            // Tuple types: (T1, T2, ...) — parser stores as Expr.tuple_type, not type_expr.
            // Must be handled here since resolveTypeNode only matches type_expr by default.
            Expr.tuple_type |_tt| => {
                return self.chk.resolveTupleType(idx)
            },
            else => {},
        }, else => {} }
        if (kind < 0) { return VOID }
        // Resolve type_expr by kind (Zig lower.zig:10066-10136)
        if (kind == TYPE_NAMED) {
            // For TYPE_NAMED, d1 is an ident node. Check type substitution directly
            // before falling through to checker (which may use wrong AST for cross-file generics).
            if (self.chk.hasTypeSubstitution()) {
                var n = ""
                switch (self.tree.getNode(d1)) { Node.expr |e| => switch (e) {
                    Expr.ident |id| => { n = id.name },
                    else => {},
                }, else => {} }
                if (@lenOf(n) > 0) {
                    const sub = self.chk.lookupTypeSub(n)
                    if (sub >= 0) { return sub }
                }
            }
            return self.chk.resolveTypeExpr(d1)
        }
        if (kind == TYPE_POINTER) {
            return self.types.makePointer(self.chk.resolveTypeExpr(d1))
        }
        if (kind == TYPE_OPTIONAL) {
            return self.types.makeOptional(self.chk.resolveTypeExpr(d1))
        }
        if (kind == TYPE_ERROR_UNION) {
            return self.types.makeErrorUnion(self.chk.resolveTypeExpr(d1))
        }
        if (kind == TYPE_SLICE) {
            return self.types.makeSlice(self.chk.resolveTypeExpr(d1))
        }
        if (kind == TYPE_ARRAY) {
            return self.chk.resolveArrayType(d1, d2)
        }
        if (kind == TYPE_FUNCTION) {
            return self.chk.resolveTypeExprNode(idx)
        }
        if (kind == TYPE_TUPLE) {
            return self.chk.resolveTupleType(idx)
        }
        return VOID
    }

    /// Infer the type of an expression from the checker's type map.
    fn inferExprType(idx: int) int {
        if (self.chk.expr_types.contains(idx)) {
            return self.chk.expr_types.get(idx)
        }
        return VOID
    }

    /// Add a parameter from a param AST node.
    fn addParamFromNode(param_idx: int) void {
        const fb = self.builder.func() orelse return null_node
        // Param nodes are stored as expression nodes containing field defs
        var fd_name = ""
        var fd_type_expr = null_node
        var found = false
        switch (self.tree.getNode(param_idx)) { Node.expr |e| => switch (e) { Expr.field_def |fd| => { fd_name = fd.name; fd_type_expr = fd.type_expr; found = true }, else => {} }, else => {} }
        if (found) {
            var param_type = self.resolveTypeNode(fd_type_expr)
            // Zig lower.zig:793 — safeWrapType converts struct self to *Struct in @safe mode
            param_type = self.chk.safeWrapType(param_type)
            const size = self.types.sizeOf(param_type)
            fb.addParam(fd_name, param_type, size)
        }
    }
}

// ============================================================================
// Free helper functions
// ============================================================================

/// Functions that must keep bare names (entry points, compiler-generated, runtime).
fn shouldSkipQualification(name: string) bool {
    if (name == "main") { return true }
    if (startsWith(name, "__cot_init")) { return true }
    if (startsWith(name, "__test_")) { return true }
    if (startsWith(name, "__bench_")) { return true }
    return false
}

/// Sanitize a name for use as an identifier (replace non-alphanum with underscore).
fn sanitizeName(prefix: string, name: string) string {
    // Replace spaces with underscores. Other non-alphanumeric chars are rare
    // in test/bench names and get handled by the backend's mangling.
    var result = prefix
    var seg_start = 0
    for i in 0..name.len {
        if (name[i] == 32) {  // space
            // Append segment before space, then underscore
            if (i > seg_start) {
                result = result ++ @string(@ptrOf(name) + seg_start, i - seg_start)
            }
            result = result ++ "_"
            seg_start = i + 1
        }
    }
    // Append remaining segment
    if (seg_start < name.len) {
        result = result ++ @string(@ptrOf(name) + seg_start, name.len - seg_start)
    }
    return result
}

/// Check if a string ends with a suffix.
fn strEndsWith(s: string, suffix: string) bool {
    return endsWith(s, suffix)
}

/// Parse an integer literal string to int.
/// Supports decimal, hex (0x), octal (0o), binary (0b) prefixes.
/// Ref: lower.zig parseIntLiteral pattern
fn parseIntLit(s: string) int {
    var result = 0
    var negative = false
    var i = 0
    if (@lenOf(s) > 0) {
        const first = charAt(s, 0)
        if (first == 45) {  // '-'
            negative = true
            i = 1
        }
    }
    // Check for prefix: 0x, 0o, 0b
    if (i + 1 < @lenOf(s) and charAt(s, i) == 48) {  // '0'
        const prefix = charAt(s, i + 1)
        if (prefix == 120 or prefix == 88) {  // 'x' or 'X'
            i = i + 2
            while (i < @lenOf(s)) {
                const c = charAt(s, i)
                if (c >= 48 and c <= 57) { result = result * 16 + (c - 48) }
                else if (c >= 97 and c <= 102) { result = result * 16 + (c - 97 + 10) }  // a-f
                else if (c >= 65 and c <= 70) { result = result * 16 + (c - 65 + 10) }  // A-F
                else if (c != 95) { break }  // skip '_'
                i = i + 1
            }
            if (negative) { result = -result }
            return result
        }
        if (prefix == 111 or prefix == 79) {  // 'o' or 'O'
            i = i + 2
            while (i < @lenOf(s)) {
                const c = charAt(s, i)
                if (c >= 48 and c <= 55) { result = result * 8 + (c - 48) }
                else if (c != 95) { break }
                i = i + 1
            }
            if (negative) { result = -result }
            return result
        }
        if (prefix == 98 or prefix == 66) {  // 'b' or 'B'
            i = i + 2
            while (i < @lenOf(s)) {
                const c = charAt(s, i)
                if (c == 48) { result = result * 2 }
                else if (c == 49) { result = result * 2 + 1 }
                else if (c != 95) { break }
                i = i + 1
            }
            if (negative) { result = -result }
            return result
        }
    }
    // Decimal
    while (i < @lenOf(s)) {
        const c = charAt(s, i)
        if (c >= 48 and c <= 57) {  // '0'-'9'
            result = result * 10 + (c - 48)
        } else if (c == 95) {  // '_' separator
            // skip
        } else {
            break
        }
        i = i + 1
    }
    if (negative) { result = -result }
    return result
}

/// Parse a float literal string to float.
/// Supports scientific notation (e.g., 1.5e3, 2E-4).
fn parseFloatLit(s: string) float {
    var result: float = 0.0
    var frac: float = 0.0
    var frac_div: float = 1.0
    var in_frac = false
    var negative = false
    var i = 0
    if (@lenOf(s) > 0) {
        const first = charAt(s, 0)
        if (first == 45) {
            negative = true
            i = 1
        }
    }
    while (i < @lenOf(s)) {
        const c = charAt(s, i)
        if (c == 46) {  // '.'
            in_frac = true
        } else if (c == 101 or c == 69) {  // 'e' or 'E' — scientific notation
            i = i + 1
            break
        } else if (c >= 48 and c <= 57) {
            const digit = c - 48
            const fdigit = @floatFromInt(f64, digit)
            if (in_frac) {
                frac_div = frac_div * 10.0
                frac = frac + fdigit / frac_div
            } else {
                result = result * 10.0 + fdigit
            }
        } else if (c == 95) {
            // skip
        } else {
            break
        }
        i = i + 1
    }
    result = result + frac

    // Parse exponent if present (after 'e'/'E')
    if (i < @lenOf(s)) {
        var exp_neg = false
        var exp = 0
        if (charAt(s, i) == 45) { exp_neg = true; i = i + 1 }
        else if (charAt(s, i) == 43) { i = i + 1 }
        while (i < @lenOf(s)) {
            const c = charAt(s, i)
            if (c >= 48 and c <= 57) { exp = exp * 10 + (c - 48) }
            else if (c != 95) { break }
            i = i + 1
        }
        var multiplier: float = 1.0
        for _ in 0..exp { multiplier = multiplier * 10.0 }
        if (exp_neg) { result = result / multiplier }
        else { result = result * multiplier }
    }

    if (negative) { result = -result }
    return result
}

/// Parse a character literal: 'x', '\n', '\xHH'.
/// Returns the character's integer value, or 0 on error.
/// Ref: lower.zig:9416-9432
fn parseCharLiteral(text: string) int {
    if (@lenOf(text) < 3 or charAt(text, 0) != 39 or charAt(text, @lenOf(text) - 1) != 39) { return 0 }
    // inner = text[1..len-1]
    const inner_len = @lenOf(text) - 2
    if (inner_len == 0) { return 0 }
    const first = charAt(text, 1)
    if (first != 92) { return first }  // not backslash
    if (inner_len < 2) { return 0 }
    const second = charAt(text, 2)
    if (second == 110) { return 10 }       // 'n' → newline
    if (second == 116) { return 9 }        // 't' → tab
    if (second == 114) { return 13 }       // 'r' → carriage return
    if (second == 92) { return 92 }        // '\\' → backslash
    if (second == 39) { return 39 }        // '\'' → single quote
    if (second == 34) { return 34 }        // '"' → double quote
    if (second == 48) { return 0 }         // '0' → null
    if (second == 120 and inner_len >= 4) {  // 'x' → hex
        return hexDigit(charAt(text, 3)) * 16 + hexDigit(charAt(text, 4))
    }
    return second
}

/// Parse a single hex digit character to its value (0-15).
fn hexDigit(c: int) int {
    if (c >= 48 and c <= 57) { return c - 48 }        // '0'-'9'
    if (c >= 97 and c <= 102) { return c - 97 + 10 }  // 'a'-'f'
    if (c >= 65 and c <= 70) { return c - 65 + 10 }   // 'A'-'F'
    return 0
}

/// Process escape sequences in a raw string (no surrounding quotes).
/// Returns a new string with escape sequences resolved.
/// Ref: lower.zig:9437-9469
fn unescapeString(text: string) string {
    var result = ""
    var i = 0
    var seg_start = 0
    while (i < @lenOf(text)) {
        if (charAt(text, i) == 92 and i + 1 < @lenOf(text)) {  // backslash
            // Append segment before escape
            if (i > seg_start) {
                result = result ++ @string(@ptrOf(text) + seg_start, i - seg_start)
            }
            const esc = charAt(text, i + 1)
            if (esc == 110) { result = result ++ "\n" }       // 'n'
            else if (esc == 116) { result = result ++ "\t" }  // 't'
            else if (esc == 114) { result = result ++ "\r" }  // 'r'
            else if (esc == 92) { result = result ++ "\\" }   // '\\'
            else if (esc == 34) { result = result ++ "\"" }   // '"'
            else if (esc == 39) { result = result ++ "'" }    // '\''
            else if (esc == 48) { result = result ++ "\0" }   // '0'
            else if (esc == 120 and i + 3 < @lenOf(text)) {   // 'x' hex
                // \xHH — skip hex escape (handled at codegen level)
                i = i + 4
                seg_start = i
                continue
            } else {
                // Unknown escape — keep the escaped char
                result = result ++ @string(@ptrOf(text) + i + 1, 1)
            }
            i = i + 2
            seg_start = i
        } else {
            i = i + 1
        }
    }
    // Append remaining segment
    if (seg_start < @lenOf(text)) {
        result = result ++ @string(@ptrOf(text) + seg_start, @lenOf(text) - seg_start)
    }
    return result
}

/// Strip surrounding quotes and unescape a string literal.
/// Ref: lower.zig:9472-9497
fn parseStringLiteral(text: string) string {
    if (@lenOf(text) < 2 or charAt(text, 0) != 34 or charAt(text, @lenOf(text) - 1) != 34) {
        return text
    }
    const inner = @string(@ptrOf(text) + 1, @lenOf(text) - 2)
    return unescapeString(inner)
}


/// Map token op code to IR BinaryOp.
fn tokenToBinaryOp(tok: int) BinaryOp {
    if (tok == Token.add or tok == Token.add_assign) { return BinaryOp.add }
    if (tok == Token.sub or tok == Token.sub_assign) { return BinaryOp.sub }
    if (tok == Token.mul or tok == Token.mul_assign) { return BinaryOp.mul }
    if (tok == Token.quo or tok == Token.quo_assign) { return BinaryOp.div }
    if (tok == Token.rem or tok == Token.rem_assign) { return BinaryOp.mod }
    if (tok == Token.eql) { return BinaryOp.eq }
    if (tok == Token.neq) { return BinaryOp.ne }
    if (tok == Token.lss) { return BinaryOp.lt }
    if (tok == Token.leq) { return BinaryOp.le }
    if (tok == Token.gtr) { return BinaryOp.gt }
    if (tok == Token.geq) { return BinaryOp.ge }
    if (tok == Token.land or tok == Token.kw_and) { return BinaryOp.@"and" }
    if (tok == Token.lor or tok == Token.kw_or) { return BinaryOp.@"or" }
    if (tok == Token.@"and" or tok == Token.and_assign) { return BinaryOp.bit_and }
    if (tok == Token.@"or" or tok == Token.or_assign) { return BinaryOp.bit_or }
    if (tok == Token.xor or tok == Token.xor_assign) { return BinaryOp.bit_xor }
    if (tok == Token.shl) { return BinaryOp.shl }
    if (tok == Token.shr) { return BinaryOp.shr }
    if (tok == Token.concat) { return BinaryOp.add }
    return BinaryOp.add
}

/// Map token op code to IR UnaryOp.
fn tokenToUnaryOp(tok: int) UnaryOp {
    if (tok == Token.sub) { return UnaryOp.neg }
    if (tok == Token.lnot or tok == Token.kw_not) { return UnaryOp.@"not" }
    if (tok == Token.@"not") { return UnaryOp.bit_not }
    if (tok == Token.question) { return UnaryOp.optional_unwrap }
    return UnaryOp.neg
}

/// Initialize Lowerer scalars and builder — step 1.
fn initLowererScalars(lower: *Lowerer) void {
    lower.temp_counter = 0
    lower.test_mode = false
    lower.fail_fast = false
    lower.bench_mode = false
    lower.current_test_name = ""
    lower.closure_counter = 0
    lower.current_switch_enum_type = invalid_type
    lower.next_error_idx = 0
    lower.release_mode = false
    lower.gc_mode = false
    lower.builder = Builder.init()
}

/// Initialize Lowerer lists — step 2.
fn initLowererLists(lower: *Lowerer) void {
    var ls: List(LoopContext) = .{}
    lower.loop_stack = ls
    var lbs: List(LabeledBlockCtx) = .{}
    lower.labeled_block_stack = lbs
    var cs: List(CleanupEntry) = .{}
    lower.cleanup_stack = cs
    var tn: List(string) = .{}
    lower.test_names = tn
    var tdn: List(string) = .{}
    lower.test_display_names = tdn
    var bn: List(string) = .{}
    lower.bench_names = bn
    var bdn: List(string) = .{}
    lower.bench_display_names = bdn
    var pgi: List(GlobalInit) = .{}
    lower.pending_global_inits = pgi
    var pad: List(string) = .{}
    lower.pending_auto_deinits = pad
}

/// Initialize Lowerer maps — step 3.
fn initLowererMaps(lower: *Lowerer) void {
    var cv: Map(string, int) = .{}
    lower.const_values = cv
    var fv: Map(string, int) = .{}
    lower.float_const_values = fv
    var ft: Map(string, int) = .{}
    lower.float_const_types = ft
    var lg: Map(string, int) = .{}
    lower.lowered_generics = lg
    var ge: Map(string, int) = .{}
    lower.global_error_table = ge
    var wl: Map(int, int) = .{}
    lower.weak_locals = wl
    var cvv: Map(string, int) = .{}
    lower.comptime_value_vars = cvv
    var gcv: Map(string, int) = .{}
    lower.global_comptime_values = gcv
    var tmm: Map(int, string) = .{}
    lower.tree_module_map = tmm
    lower.spawn_counter = 0
    var ss: Map(string, string) = .{}
    lower.shape_stencils = ss
    var sa: Map(string, string) = .{}
    lower.shape_aliases = sa
    var gdh: Map(string, int) = .{}
    lower.generated_dict_helpers = gdh
    var sac: Map(int, int) = .{}
    lower.shape_analysis_cache = sac
    var dan: Map(string, string) = .{}
    lower.dict_arg_names = dan
    var sde: List(DictEntry) = .{}
    lower.stencil_dict_entries = sde
    var cde: List(DictEntry) = .{}
    lower.current_dict_entries = cde
    var cdp: List(int) = .{}
    lower.current_dict_params = cdp
    lower.has_dict_context = false
}

