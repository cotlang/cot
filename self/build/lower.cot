// Tests
// ============================================================================

test "lowerer init" {
    // Minimal: just a Lowerer with direct field writes (no other large structs)
    var lower: Lowerer = undefined
    lower.temp_counter = 0
    lower.test_mode = false
    lower.fail_fast = false
    lower.bench_mode = false
    lower.builder = Builder.init()
    @assertEq(lower.temp_counter, 0)
    @assertEq(lower.builder.funcs.count, 0)
}

test "lowerer set modes" {
    var ast = Ast.init("test.cot")
    var types = TypeRegistry.init()
    var err = ErrorReporter.init()
    var chk = Checker.init(&ast, &types, &err)

    var lower: Lowerer = undefined
    lower.tree = &ast
    lower.types = &types
    lower.err = &err
    lower.chk = &chk
    initLowererScalars(&lower)
    initLowererLists(&lower)
    initLowererMaps(&lower)
    lower.setTestMode(true)
    @assert(lower.test_mode)
    lower.setFailFast(true)
    @assert(lower.fail_fast)
    lower.setBenchMode(true)
    @assert(lower.bench_mode)
}

test "lowerer empty lower produces empty IR" {
    var ast = Ast.init("test.cot")
    var types = TypeRegistry.init()
    var err = ErrorReporter.init()
    var chk = Checker.init(&ast, &types, &err)

    var lower: Lowerer = undefined
    lower.tree = &ast
    lower.types = &types
    lower.err = &err
    lower.chk = &chk
    initLowererScalars(&lower)
    initLowererLists(&lower)
    initLowererMaps(&lower)
    const result = lower.lower()
    @assertEq(result.funcs.count, 0)
    @assertEq(result.globals.count, 0)
}

test "sanitizeName" {
    const result = sanitizeName("test_", "hello")
    @assertEq(result, "test_hello")

    const result2 = sanitizeName("bench_", "my bench")
    @assertEq(result2, "bench_my_bench")
}

test "parseInt basic" {
    @assertEq(parseIntLit("0"), 0)
    @assertEq(parseIntLit("42"), 42)
    @assertEq(parseIntLit("100"), 100)
    @assertEq(parseIntLit("-5"), -5)
    @assertEq(parseIntLit("1_000"), 1000)
}

test "parseFloat basic" {
    const f1 = parseFloatLit("3.14")
    @assert(f1 > 3.13)
    @assert(f1 < 3.15)

    const f2 = parseFloatLit("0.5")
    @assert(f2 > 0.49)
    @assert(f2 < 0.51)

    const f3 = parseFloatLit("-2.0")
    @assert(f3 < -1.99)
    @assert(f3 > -2.01)
}

test "needsSret basic types" {
    var ast = Ast.init("test.cot")
    var types = TypeRegistry.init()
    var err = ErrorReporter.init()
    var chk = Checker.init(&ast, &types, &err)

    var lower: Lowerer = undefined
    lower.tree = &ast
    lower.types = &types
    lower.err = &err
    lower.chk = &chk
    initLowererScalars(&lower)
    initLowererLists(&lower)
    initLowererMaps(&lower)
    // Basic types don't need SRET
    @assert(!lower.needsSret(VOID))
    @assert(!lower.needsSret(I64))
    @assert(!lower.needsSret(BOOL))
    @assert(!lower.needsSret(F64))
}

test "clearPerFunctionState" {
    var ast = Ast.init("test.cot")
    var types = TypeRegistry.init()
    var err = ErrorReporter.init()
    var chk = Checker.init(&ast, &types, &err)

    var lower: Lowerer = undefined
    lower.tree = &ast
    lower.types = &types
    lower.err = &err
    lower.chk = &chk
    initLowererScalars(&lower)
    initLowererLists(&lower)
    initLowererMaps(&lower)
    lower.cleanup_stack.append(CleanupEntry {
        kind: CLEANUP_DEFER,
        value: 0,
        type_idx: VOID,
        local_idx: null_local,
        func_name: "",
    })
    @assertEq(lower.cleanup_stack.count, 1)
    lower.clearPerFunctionState()
    @assertEq(lower.cleanup_stack.count, 0)
}

test "tokenToBinaryOp arithmetic" {
    @assertEq(tokenToBinaryOp(Token.add as int), BinaryOp.add)
    @assertEq(tokenToBinaryOp(Token.sub as int), BinaryOp.sub)
    @assertEq(tokenToBinaryOp(Token.mul as int), BinaryOp.mul)
    @assertEq(tokenToBinaryOp(Token.quo as int), BinaryOp.div)
    @assertEq(tokenToBinaryOp(Token.rem as int), BinaryOp.mod)
}

test "tokenToBinaryOp comparison" {
    @assertEq(tokenToBinaryOp(Token.eql as int), BinaryOp.eq)
    @assertEq(tokenToBinaryOp(Token.neq as int), BinaryOp.ne)
    @assertEq(tokenToBinaryOp(Token.lss as int), BinaryOp.lt)
    @assertEq(tokenToBinaryOp(Token.leq as int), BinaryOp.le)
    @assertEq(tokenToBinaryOp(Token.gtr as int), BinaryOp.gt)
    @assertEq(tokenToBinaryOp(Token.geq as int), BinaryOp.ge)
}

test "tokenToBinaryOp logical and bitwise" {
    @assertEq(tokenToBinaryOp(Token.land as int), BinaryOp.@"and")
    @assertEq(tokenToBinaryOp(Token.lor as int), BinaryOp.@"or")
    @assertEq(tokenToBinaryOp(Token.kw_and as int), BinaryOp.@"and")
    @assertEq(tokenToBinaryOp(Token.kw_or as int), BinaryOp.@"or")
    @assertEq(tokenToBinaryOp(Token.shl as int), BinaryOp.shl)
    @assertEq(tokenToBinaryOp(Token.shr as int), BinaryOp.shr)
}

test "tokenToUnaryOp" {
    @assertEq(tokenToUnaryOp(Token.sub as int), UnaryOp.neg)
    @assertEq(tokenToUnaryOp(Token.lnot as int), UnaryOp.@"not")
    @assertEq(tokenToUnaryOp(Token.kw_not as int), UnaryOp.@"not")
    @assertEq(tokenToUnaryOp(Token.question as int), UnaryOp.optional_unwrap)
}

test "shouldSkipQualification" {
    @assert(shouldSkipQualification("main"))
    @assert(shouldSkipQualification("__cot_init_globals"))
    @assert(shouldSkipQualification("__test_foo"))
    @assert(shouldSkipQualification("__bench_bar"))
    @assert(!shouldSkipQualification("myFunc"))
    @assert(!shouldSkipQualification("main_helper"))
}

test "parseCharLiteral" {
    @assertEq(parseCharLiteral("'a'"), 97)
    @assertEq(parseCharLiteral("'\\n'"), 10)
    @assertEq(parseCharLiteral("'\\t'"), 9)
    @assertEq(parseCharLiteral("'\\0'"), 0)
    @assertEq(parseCharLiteral("''"), 0)
    @assertEq(parseCharLiteral("'\\\\'"), 92)
}

test "parseIntLit hex octal binary" {
    @assertEq(parseIntLit("0xFF"), 255)
    @assertEq(parseIntLit("0x10"), 16)
    @assertEq(parseIntLit("0o17"), 15)
    @assertEq(parseIntLit("0b1010"), 10)
    @assertEq(parseIntLit("42"), 42)
    @assertEq(parseIntLit("-10"), -10)
    @assertEq(parseIntLit("0b0"), 0)
    @assertEq(parseIntLit("0xA"), 10)
}

test "parseFloatLit scientific notation" {
    @assertEq(parseFloatLit("1.5"), 1.5)
    @assertEq(parseFloatLit("1e2"), 100.0)
    @assertEq(parseFloatLit("2.5e1"), 25.0)
    @assertEq(parseFloatLit("-3.0"), -3.0)
}

test "hexDigit" {
    @assertEq(hexDigit(48), 0)   // '0'
    @assertEq(hexDigit(57), 9)   // '9'
    @assertEq(hexDigit(97), 10)  // 'a'
    @assertEq(hexDigit(102), 15) // 'f'
    @assertEq(hexDigit(65), 10)  // 'A'
}

test "parseStringLiteral" {
    @assertEq(parseStringLiteral("\"hello\""), "hello")
    @assertEq(parseStringLiteral("\"\""), "")
    @assertEq(parseStringLiteral("not_quoted"), "not_quoted")
}

test "evalFloatLiteral" {
    var ast = Ast.init("test.cot")
    var types = TypeRegistry.init()
    var err = ErrorReporter.init()
    var chk = Checker.init(&ast, &types, &err)

    var lower: Lowerer = undefined
    lower.tree = &ast
    lower.types = &types
    lower.err = &err
    lower.chk = &chk
    initLowererScalars(&lower)
    initLowererLists(&lower)
    initLowererMaps(&lower)

    // Add a float literal node
    const span = Span.zero()
    const float_idx = ast.addExpr(Expr.literal(Literal { kind: LiteralKind.@"float" as int, value: "3.14", span: span }))
    if (lower.evalFloatLiteral(float_idx)) |v| {
        @assert(v > 3.13)
        @assert(v < 3.15)
    } else {
        @panic("expected float value")
    }

    // Add an int literal node (should be converted to float)
    const int_idx = ast.addExpr(Expr.literal(Literal { kind: LiteralKind.@"int" as int, value: "42", span: span }))
    if (lower.evalFloatLiteral(int_idx)) |v| {
        @assertEq(v, 42.0)
    } else {
        @panic("expected float from int")
    }

    // Null node returns null
    @assert(lower.evalFloatLiteral(null_node) == null)
}

test "lookupComptimeValue" {
    var ast = Ast.init("test.cot")
    var types = TypeRegistry.init()
    var err = ErrorReporter.init()
    var chk = Checker.init(&ast, &types, &err)

    var lower: Lowerer = undefined
    lower.tree = &ast
    lower.types = &types
    lower.err = &err
    lower.chk = &chk
    initLowererScalars(&lower)
    initLowererLists(&lower)
    initLowererMaps(&lower)

    // No values stored yet
    @assertEq(lower.lookupComptimeValue("x"), -1)

    // Store in local comptime vars
    lower.comptime_value_vars.set("x", 42)
    @assertEq(lower.lookupComptimeValue("x"), 42)

    // Store in global comptime values
    lower.global_comptime_values.set("y", 99)
    @assertEq(lower.lookupComptimeValue("y"), 99)

    // Local takes precedence
    lower.comptime_value_vars.set("z", 10)
    lower.global_comptime_values.set("z", 20)
    @assertEq(lower.lookupComptimeValue("z"), 10)
}

test "dictOpName" {
    @assertEq(dictOpName(Token.eql as int), "eq")
    @assertEq(dictOpName(Token.neq as int), "ne")
    @assertEq(dictOpName(Token.lss as int), "lt")
    @assertEq(dictOpName(Token.add as int), "add")
    @assertEq(dictOpName(Token.sub as int), "sub")
    @assertEq(dictOpName(Token.mul as int), "mul")
    @assertEq(dictOpName(Token.quo as int), "div")
    @assertEq(dictOpName(Token.rem as int), "mod")
}

test "DictEntry struct" {
    const entry = DictEntry {
        kind: DICT_BINARY_OP,
        op: Token.eql as int,
        method_name: "",
        type_param_idx: 0,
    }
    @assertEq(entry.kind, DICT_BINARY_OP)
    @assertEq(entry.type_param_idx, 0)

    const method_entry = DictEntry {
        kind: DICT_METHOD_CALL,
        op: 0,
        method_name: "toString",
        type_param_idx: 1,
    }
    @assertEq(method_entry.kind, DICT_METHOD_CALL)
    @assertEq(method_entry.method_name, "toString")
}

test "shape stencil maps init" {
    var ast = Ast.init("test.cot")
    var types = TypeRegistry.init()
    var err = ErrorReporter.init()
    var chk = Checker.init(&ast, &types, &err)

    var lower: Lowerer = undefined
    lower.tree = &ast
    lower.types = &types
    lower.err = &err
    lower.chk = &chk
    initLowererScalars(&lower)
    initLowererLists(&lower)
    initLowererMaps(&lower)

    // Stencil maps should be empty initially
    @assert(!lower.shape_stencils.contains("test"))
    @assert(!lower.shape_aliases.contains("test"))
    @assert(!lower.generated_dict_helpers.contains("test"))

    // Can register shape stencils
    lower.shape_stencils.set("List$s8in", "List__i64__push")
    @assert(lower.shape_stencils.contains("List$s8in"))

    // Can register aliases
    lower.shape_aliases.set("List__u64__push", "List__i64__push")
    @assert(lower.shape_aliases.contains("List__u64__push"))
}
