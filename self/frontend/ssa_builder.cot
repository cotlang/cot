    // === Phi insertion (Braun et al. 2013) ===

    fn insertPhis() void {
        var fwd_refs: List(int) = .{}
        for i in 0..self.func.blocks.count {
            const blk = self.func.getBlock(i)
            for j in 0..blk.values.count {
                const vid = blk.values.get(j)
                const v = self.func.getValue(vid)
                if (v.op == SsaOp.fwd_ref) {
                    fwd_refs.append(vid)
                    self.ensureDefvar(blk.id, v.aux_int, vid)
                }
            }
        }

        var phi_args: List(int) = .{}

        while (fwd_refs.count > 0) {
            const fwd = fwd_refs.pop()
            const fwd_v = self.func.getValue(fwd)
            const block_idx = fwd_v.block
            if (block_idx == null_block) { continue }
            const block = self.func.getBlock(block_idx)
            if (block_idx == self.func.entry or block.preds.count == 0) { continue }

            const local_idx = fwd_v.aux_int
            phi_args.clear()

            for k in 0..block.preds.count {
                const pred_edge = block.preds.get(k)
                const val = self.lookupVarOutgoing(pred_edge.block, local_idx, fwd_v.type_idx, &fwd_refs)
                phi_args.append(val)
            }

            var witness: int = null_value
            var need_phi = false
            for k in 0..phi_args.count {
                const a = phi_args.get(k)
                if (a == fwd) { continue }
                if (witness == null_value) {
                    witness = a
                } else if (a != witness) {
                    need_phi = true
                }
            }

            if (need_phi) {
                var fv = self.func.getValue(fwd)
                fv.op = SsaOp.phi
                for k in 0..phi_args.count {
                    fv.addArg(phi_args.get(k))
                }
                self.func.setValue(fwd, fv)
            } else if (witness != null_value) {
                var fv = self.func.getValue(fwd)
                fv.op = SsaOp.copy
                fv.addArg(witness)
                self.func.setValue(fwd, fv)
            }
        }

        self.reorderPhis()
    }

    fn reorderPhis() void {
        for i in 0..self.func.blocks.count {
            var blk = self.func.getBlock(i)
            var phis: List(int) = .{}
            var non_phis: List(int) = .{}

            for j in 0..blk.values.count {
                const vid = blk.values.get(j)
                const v = self.func.getValue(vid)
                if (v.op == SsaOp.phi) {
                    phis.append(vid)
                } else {
                    non_phis.append(vid)
                }
            }

            blk.values.clear()
            for j in 0..phis.count { blk.values.append(phis.get(j)) }
            for j in 0..non_phis.count { blk.values.append(non_phis.get(j)) }
            self.func.setBlock(i, blk)
        }
    }

    fn verify() void {
        for i in 0..self.func.blocks.count {
            const blk = self.func.getBlock(i)
            // Skip unreachable blocks (no predecessors, not entry) — they may have
            // unresolved fwd_refs that can never be resolved.
            if (blk.preds.count == 0 and i != self.func.entry) { continue }
            var seen_non_phi = false
            for j in 0..blk.values.count {
                const v = self.func.getValue(blk.values.get(j))
                if (v.op == SsaOp.phi) {
                    // phi must be at block start
                    if (seen_non_phi) {
                        @panic("verify: phi after non-phi in block ${i} of ${self.ir_func.name}")
                    }
                    // phi arg count must match pred count
                    if (v.argsLen() != blk.preds.count) {
                        @panic("verify: phi args=${v.argsLen()} != preds=${blk.preds.count} in block ${i} of ${self.ir_func.name}")
                    }
                } else {
                    seen_non_phi = true
                }
                // No unresolved forward refs
                if (v.op == SsaOp.fwd_ref) {
                    @panic("verify: unresolved fwd_ref in block ${i} of ${self.ir_func.name}")
                }
            }
            if (blk.kind == SsaBlockKind.ret) {
                if (blk.succs.count != 0) {
                    @panic("verify: ret block ${i} has ${blk.succs.count} succs in ${self.ir_func.name}")
                }
            }
            if (blk.kind == SsaBlockKind.if_) {
                if (blk.succs.count != 2) {
                    @panic("verify: if block ${i} has ${blk.succs.count} succs (want 2) in ${self.ir_func.name}")
                }
                if (blk.controls.count == 0) {
                    @panic("verify: if block ${i} has no controls in ${self.ir_func.name}")
                }
            }
        }
    }

    // === Defvar helpers (flat list) ===

    fn lookupDefvar(block_id: int, local_idx: int) int {
        // Search backwards for most recent entry matching block_id and local_idx
        var i = self.defvars.count
        while (i > 0) {
            i -= 1
            const entry = self.defvars.get(i)
            if (entry.block_id == block_id and entry.local_idx == local_idx) {
                return entry.value_idx
            }
        }
        return null_value
    }

    fn setDefvar(block_id: int, local_idx: int, value_idx: int) void {
        // Update existing or append new entry
        var i = self.defvars.count
        while (i > 0) {
            i -= 1
            var entry = self.defvars.get(i)
            if (entry.block_id == block_id and entry.local_idx == local_idx) {
                entry.value_idx = value_idx
                self.defvars.set(i, entry)
                return
            }
        }
        self.defvars.append(DefvarEntry { block_id: block_id, local_idx: local_idx, value_idx: value_idx })
    }

    fn ensureDefvar(block_id: int, local_idx: int, value_idx: int) void {
        if (self.lookupDefvar(block_id, local_idx) == null_value) {
            self.setDefvar(block_id, local_idx, value_idx)
        }
    }

    fn lookupVarOutgoing(block_idx: int, local_idx: int, type_idx: int, fwd_refs: *List(int)) int {
        var cur = block_idx
        while (true) {
            const blk = self.func.getBlock(cur)
            const result = self.lookupDefvar(blk.id, local_idx)
            if (result != null_value) {
                return result
            }
            if (blk.preds.count == 1) {
                cur = blk.preds.get(0).block
                continue
            }
            break
        }

        const cur_blk = self.func.getBlock(cur)
        const new_fwd = self.func.newValue(SsaOp.fwd_ref, type_idx, cur, self.cur_pos_line, self.cur_pos_col)
        var nf = self.func.getValue(new_fwd)
        nf.aux_int = local_idx
        self.func.setValue(new_fwd, nf)
        self.func.addValueToBlock(new_fwd, cur)

        self.setDefvar(cur_blk.id, local_idx, new_fwd)
        fwd_refs.append(new_fwd)

        return new_fwd
    }

    // === Shared emit helpers (reduce repetition) ===

    fn emitNewValueWithArg(op: SsaOp, type_idx: int, arg: int) int {
        const cur = self.cur_block
        const val = self.func.newValue(op, type_idx, cur, self.cur_pos_line, self.cur_pos_col)
        var v = self.func.getValue(val)
        v.addArg(arg)
        self.func.setValue(val, v)
        self.func.addValueToBlock(val, cur)
        return val
    }

    fn emitBinOp(op: SsaOp, type_idx: int, left: int, right: int) int {
        const cur = self.cur_block
        const val = self.func.newValue(op, type_idx, cur, self.cur_pos_line, self.cur_pos_col)
        var v = self.func.getValue(val)
        v.addArg2(left, right)
        self.func.setValue(val, v)
        self.func.addValueToBlock(val, cur)
        return val
    }

    fn emitSelect3(op: SsaOp, type_idx: int, a: int, b: int, c: int) int {
        const cur = self.cur_block
        const val = self.func.newValue(op, type_idx, cur, self.cur_pos_line, self.cur_pos_col)
        var v = self.func.getValue(val)
        v.addArg3(a, b, c)
        self.func.setValue(val, v)
        self.func.addValueToBlock(val, cur)
        return val
    }

    fn emitOffPtr(base: int, offset: int) int {
        const cur = self.cur_block
        const val = self.func.newValue(SsaOp.off_ptr, VOID, cur, self.cur_pos_line, self.cur_pos_col)
        var v = self.func.getValue(val)
        v.aux_int = offset
        v.addArg(base)
        self.func.setValue(val, v)
        self.func.addValueToBlock(val, cur)
        return val
    }

    fn emitStore(addr: int, value: int) int {
        const cur = self.cur_block
        const val = self.func.newValue(SsaOp.store, VOID, cur, self.cur_pos_line, self.cur_pos_col)
        var v = self.func.getValue(val)
        v.addArg2(addr, value)
        self.func.setValue(val, v)
        self.func.addValueToBlock(val, cur)
        return val
    }

    fn emitStoreOp(addr: int, value: int) int {
        const value_type_idx = self.func.getValue(value).type_idx
        const store_op = self.getStoreOp(value_type_idx)
        return self.emitStoreWithOp(store_op, addr, value)
    }

    fn emitStoreWithOp(op: SsaOp, addr: int, value: int) int {
        const cur = self.cur_block
        const val = self.func.newValue(op, VOID, cur, self.cur_pos_line, self.cur_pos_col)
        var v = self.func.getValue(val)
        v.addArg2(addr, value)
        self.func.setValue(val, v)
        self.func.addValueToBlock(val, cur)
        return val
    }

    fn emitMove(dst_addr: int, src: int, type_size: int, ir_node_idx: int) int {
        const cur = self.cur_block
        const val_v = self.func.getValue(src)
        const src_addr = if (val_v.op == SsaOp.load and val_v.argsLen() > 0) { val_v.args.get(0) } else { src }
        const move_val = self.func.newValue(SsaOp.move, VOID, cur, self.cur_pos_line, self.cur_pos_col)
        var mv = self.func.getValue(move_val)
        mv.addArg2(dst_addr, src_addr)
        var move_size = type_size
        if (move_size == 0) {
            move_size = self.type_reg.sizeOf(self.ir_func.getNode(ir_node_idx).type_idx)
        }
        mv.aux_int = move_size
        self.func.setValue(move_val, mv)
        self.func.addValueToBlock(move_val, cur)
        return move_val
    }

    fn emitStringSliceLoad(base_addr: int, type_idx: int) int {
        const cur = self.cur_block
        const ptr_load = self.emitNewValueWithArg(SsaOp.load, I64, base_addr)
        const len_addr = self.emitOffPtr(base_addr, 8)
        const len_load = self.emitNewValueWithArg(SsaOp.load, I64, len_addr)

        const make_op = if (type_idx == STRING) { SsaOp.string_make } else { SsaOp.slice_make }
        const make_val = self.func.newValue(make_op, type_idx, cur, self.cur_pos_line, self.cur_pos_col)
        var mv = self.func.getValue(make_val)
        mv.addArg2(ptr_load, len_load)
        self.func.setValue(make_val, mv)
        self.func.addValueToBlock(make_val, cur)
        return make_val
    }

    fn emitStringSliceStore(dest_addr: int, value: int) int {
        const val_v = self.func.getValue(value)
        var ptr_component: int = null_value
        var len_component: int = null_value

        if ((val_v.op == SsaOp.string_make or val_v.op == SsaOp.slice_make) and val_v.argsLen() >= 2) {
            ptr_component = val_v.args.get(0)
            len_component = val_v.args.get(1)
        } else {
            ptr_component = self.emitNewValueWithArg(SsaOp.slice_ptr, I64, value)
            len_component = self.emitNewValueWithArg(SsaOp.slice_len, I64, value)
        }

        self.emitStore(dest_addr, ptr_component)
        const len_addr = self.emitOffPtr(dest_addr, 8)
        const len_store = self.emitStore(len_addr, len_component)
        return len_store
    }
}

// ============================================================================
// Tests
// ============================================================================

fn makeTestFunc(name: string) Func {
    var params: List(Local) = .{}
    var locals: List(Local) = .{}
    var blocks: List(Block) = .{}
    blocks.append(Block.init(0))
    var nodes: List(Node) = .{}
    var string_literals: List(string) = .{}
    return Func {
        name: name,
        type_idx: 0,
        return_type: VOID,
        params: params,
        locals: locals,
        blocks: blocks,
        entry: 0,
        nodes: nodes,
        span: Span.zero(),
        frame_size: 0,
        string_literals: string_literals,
        is_destructor: false,
        is_export: false,
    }
}

test "SSABuilder init creates entry block" {
    var type_reg = TypeRegistry.init()
    var ir_func = makeTestFunc("test_fn")
    var globals: List(Global) = .{}
    var builder = SSABuilder.init(ir_func, globals, &type_reg)
    @assertEq(builder.func.name, "test_fn")
    @assert(builder.func.entry != null_block)
    @assert(builder.cur_block != null_block)
}

test "SSABuilder block transitions" {
    var type_reg = TypeRegistry.init()
    var ir_func = makeTestFunc("test_fn")
    var globals: List(Global) = .{}
    var builder = SSABuilder.init(ir_func, globals, &type_reg)

    // Entry block is current
    @assert(builder.cur_block != null_block)
    const entry = builder.cur_block

    // Create and start a new block
    const block2 = builder.func.newBlock(SsaBlockKind.plain)
    builder.startBlock(block2)
    @assertEq(builder.cur_block, block2)

    // End block
    const ended = builder.endBlock()
    @assertEq(ended, block2)
    @assertEq(builder.cur_block, null_block)
}

test "SSABuilder variable assign and lookup" {
    var type_reg = TypeRegistry.init()
    var ir_func = makeTestFunc("test_fn")
    var globals: List(Global) = .{}
    var builder = SSABuilder.init(ir_func, globals, &type_reg)

    // Emit a constant value
    const const_val = builder.emitConst(SsaOp.const_int, I64, 42)

    // Assign to variable
    builder.assign(0, const_val)

    // Lookup should return same value
    const looked_up = builder.variable(0, I64)
    @assertEq(const_val, looked_up)
}

test "SSABuilder emitConst and getLoadOp" {
    var type_reg = TypeRegistry.init()
    var ir_func = makeTestFunc("test_fn")
    var globals: List(Global) = .{}
    var builder = SSABuilder.init(ir_func, globals, &type_reg)

    // Test emitConst
    const c1 = builder.emitConst(SsaOp.const_int, I64, 100)
    const v1 = builder.func.getValue(c1)
    @assertEq(v1.aux_int, 100)
    @assertEq(v1.op == SsaOp.const_int, true)

    // Test getLoadOp
    @assertEq(builder.getLoadOp(I8) == SsaOp.load8s, true)
    @assertEq(builder.getLoadOp(U8) == SsaOp.load8, true)
    @assertEq(builder.getLoadOp(I32) == SsaOp.load32s, true)
    @assertEq(builder.getLoadOp(U32) == SsaOp.load32, true)
    @assertEq(builder.getLoadOp(I64) == SsaOp.load, true)

    // Test getStoreOp
    @assertEq(builder.getStoreOp(U8) == SsaOp.store8, true)
    @assertEq(builder.getStoreOp(I16) == SsaOp.store16, true)
    @assertEq(builder.getStoreOp(I32) == SsaOp.store32, true)
    @assertEq(builder.getStoreOp(I64) == SsaOp.store, true)
}

test "SSABuilder defvar helpers" {
    var type_reg = TypeRegistry.init()
    var ir_func = makeTestFunc("test_fn")
    var globals: List(Global) = .{}
    var builder = SSABuilder.init(ir_func, globals, &type_reg)

    // Initially no defvars
    @assertEq(builder.lookupDefvar(0, 0), null_value)

    // Set and lookup
    builder.setDefvar(0, 0, 42)
    @assertEq(builder.lookupDefvar(0, 0), 42)

    // Update existing
    builder.setDefvar(0, 0, 99)
    @assertEq(builder.lookupDefvar(0, 0), 99)

    // Different block
    builder.setDefvar(1, 0, 55)
    @assertEq(builder.lookupDefvar(1, 0), 55)
    @assertEq(builder.lookupDefvar(0, 0), 99)
}

test "SSABuilder fwd_ref on unknown variable" {
    var type_reg = TypeRegistry.init()
    var ir_func = makeTestFunc("test_fn")
    var globals: List(Global) = .{}
    var builder = SSABuilder.init(ir_func, globals, &type_reg)

    // Looking up an unknown variable should create a fwd_ref
    const val = builder.variable(99, I64)
    @assert(val != null_value)
    const v = builder.func.getValue(val)
    @assertEq(v.op == SsaOp.fwd_ref, true)
    @assertEq(v.aux_int, 99)  // stores the local_idx
}

test "SSABuilder helper predicates" {
    var type_reg = TypeRegistry.init()
    var ir_func = makeTestFunc("test_fn")
    var globals: List(Global) = .{}
    var builder = SSABuilder.init(ir_func, globals, &type_reg)

    // String is string_or_slice
    @assertEq(builder.isStringOrSlice(STRING), true)
    @assertEq(builder.isStringOrSlice(I64), false)

    // Not compound optional for basic types
    @assertEq(builder.isCompoundOptional(I64), false)
    @assertEq(builder.isCompoundOptional(BOOL), false)
}
