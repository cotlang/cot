/// SSA Pass Wrappers — uniquely-named entry points for all 6 Wasm SSA passes.
///
/// Needed because rewritegeneric and rewritedec both export `rewrite`,
/// and Cot doesn't support module-qualified calls.

import "std/map"
import "../../build/ssa"
import "../../optimize/rewrite"

/// Run the generic rewrite pass (ConstString → StringMake).
fn passRewriteGeneric(func: *SsaFunc, string_offsets: *Map(string, int)) void {
    rewrite(func, string_offsets)
}
