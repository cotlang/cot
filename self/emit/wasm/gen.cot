    fn emitFloatMemOp(v: *SsaValue) void {
        switch (v.op) {
            SsaOp.wasm_f64_load => {
                // Zig gen.zig:725-729
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.appendFrom(As.f64_load, constAddr(v.aux_int))
            },
            SsaOp.wasm_f64_store => {
                // Zig gen.zig:731-737
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.appendTo(As.f64_store, constAddr(v.aux_int))
            },
            SsaOp.wasm_f32_load => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.appendFrom(As.f32_load, constAddr(v.aux_int))
                // Convert f32 → i64 for storage in i64 local
                self.builder.append(As.i32_reinterpret_f32)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_f32_store => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                // Convert i64 → f32 for the store instruction
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.appendTo(As.f32_store, constAddr(v.aux_int))
            },
            else => {},
        }
    }

    fn emitBulkMemOp(v: *SsaValue) void {
        switch (v.op) {
            SsaOp.wasm_lowered_move => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.appendFrom(As.i32_const, constAddr(v.aux_int))
                self.builder.append(As.memory_copy)
            },
            SsaOp.wasm_lowered_zero => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.appendFrom(As.i32_const, constAddr(0))
                self.builder.appendFrom(As.i32_const, constAddr(v.aux_int))
                self.builder.append(As.memory_fill)
            },
            else => {},
        }
    }

    // ========================================================================
    // emitCallOp — Function calls
    // ========================================================================

    fn emitCallOp(v: *SsaValue) void {
        switch (v.op) {
            SsaOp.wasm_call => {
                for ai in 0..v.args.count {
                    const arg = v.args.get(ai)
                    self.getValue64(arg)
                    // Float args in f64 locals need reinterpret to i64 for Wasm call ABI
                    // Zig gen.zig:934-937
                    if (isFloatType(arg.type_idx)) {
                        self.builder.append(As.i64_reinterpret_f64)
                    }
                }
                const func_idx = self.resolveCallIndex(v)
                self.builder.appendTo(As.call, constAddr(func_idx))
            },
            SsaOp.wasm_return_call => {
                for ai in 0..v.args.count {
                    const arg = v.args.get(ai)
                    self.getValue64(arg)
                    if (isFloatType(arg.type_idx)) {
                        self.builder.append(As.i64_reinterpret_f64)
                    }
                }
                const rc_func_idx = self.resolveCallIndex(v)
                self.builder.appendTo(As.return_call, constAddr(rc_func_idx))
            },
            SsaOp.wasm_lowered_static_call => {
                for ai in 0..v.args.count {
                    const arg = v.args.get(ai)
                    self.getValue64(arg)
                    if (isFloatType(arg.type_idx)) {
                        self.builder.append(As.i64_reinterpret_f64)
                    }
                }
                const sc_func_idx = self.resolveCallIndex(v)
                self.builder.appendTo(As.call, constAddr(sc_func_idx))
            },
            SsaOp.wasm_lowered_closure_call => {
                // Set CTXT global from context pointer
                self.getValue64(v.args.get(1))
                self.builder.appendTo(As.global_set, constAddr(1))
                // Push function arguments (args[2..])
                for ai in 2..v.args.count {
                    const arg = v.args.get(ai)
                    self.getValue64(arg)
                    if (isFloatType(arg.type_idx)) {
                        self.builder.append(As.i64_reinterpret_f64)
                    }
                }
                // Push callee table index — must be i32 for call_indirect
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.appendTo(As.call_indirect, constAddr(v.aux_int))
            },
            SsaOp.wasm_lowered_inter_call => {
                // Push function arguments (skip arg[0])
                for ai in 1..v.args.count {
                    const arg = v.args.get(ai)
                    self.getValue64(arg)
                    if (isFloatType(arg.type_idx)) {
                        self.builder.append(As.i64_reinterpret_f64)
                    }
                }
                // Push callee (table index) — must be i32
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.appendTo(As.call_indirect, constAddr(v.aux_int))
            },
            SsaOp.wasm_call_indirect => {
                for ai in 0..v.args.count {
                    self.getValue64(v.args.get(ai))
                }
                self.builder.appendTo(As.call_indirect, constAddr(v.aux_int))
            },
            else => {},
        }
    }

    // ========================================================================
    // emitConvertOp — Type conversions
    // ========================================================================

    fn emitConvertOp(v: *SsaValue) void {
        switch (v.op) {
            // Type conversion — Zig gen.zig:1243-1288
            // Float locals are f64, no reinterpret needed for f64 values.
            SsaOp.convert => {
                const from_type = v.aux_int
                const to_type = v.type_idx
                self.getValue64(v.args.get(0))
                const from_is_float = (from_type == 10 or from_type == 11 or from_type == 14)
                const to_is_float = (to_type == 10 or to_type == 11 or to_type == 14)
                const from_is_32 = (from_type == 4)
                const to_is_32 = (to_type == 4)
                if (from_is_float and to_is_float) {
                    if (to_type == 10) {
                        // f64→f32 precision: demote then promote (round-trip loses precision)
                        self.builder.append(As.f32_demote_f64)
                        self.builder.append(As.f64_promote_f32)
                    }
                    // f32→f64 or same type: no-op (values are already f64 on stack)
                } else if (from_is_float and !to_is_float) {
                    // f64→int: saturating truncate
                    if (to_is_32) {
                        self.builder.append(As.i32_trunc_sat_f64_s)
                        self.builder.append(As.i64_extend_i32_s)
                    } else {
                        self.builder.append(As.i64_trunc_sat_f64_s)
                    }
                } else if (!from_is_float and to_is_float) {
                    // int→f64: convert signed integer to float
                    self.builder.append(As.f64_convert_i64_s)
                } else if (!from_is_32 and to_is_32) {
                    self.builder.append(As.i32_wrap_i64)
                    self.builder.append(As.i64_extend_i32_s)
                }
            },

            // Conversions (explicit Wasm ops)
            SsaOp.wasm_i32_wrap_i64 => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
            },
            SsaOp.wasm_i64_extend_i32_s => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i64_extend_i32_s)
            },
            SsaOp.wasm_i64_extend_i32_u => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i64_extend_i32_u)
            },
            // Truncation: f64→i64 (input is f64, output is i64)
            SsaOp.wasm_i64_trunc_f64_s => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i64_trunc_f64_s)
            },
            SsaOp.wasm_i64_trunc_f64_u => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i64_trunc_f64_u)
            },
            // Truncation: f32→i64 (f32 stored in i64 locals)
            SsaOp.wasm_i64_trunc_f32_s => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.i64_trunc_f32_s)
            },
            SsaOp.wasm_i64_trunc_f32_u => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.i64_trunc_f32_u)
            },
            // Truncation: f64→i32 (input is f64, output is i32)
            SsaOp.wasm_i32_trunc_f64_s => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_trunc_f64_s)
            },
            SsaOp.wasm_i32_trunc_f64_u => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_trunc_f64_u)
            },
            // Truncation: f32→i32 (f32 stored in i64 locals)
            SsaOp.wasm_i32_trunc_f32_s => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.i32_trunc_f32_s)
            },
            SsaOp.wasm_i32_trunc_f32_u => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.i32_trunc_f32_u)
            },
            // Conversion: i64→f64 (input is i64, output is f64)
            SsaOp.wasm_f64_convert_i64_s => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.f64_convert_i64_s)
            },
            SsaOp.wasm_f64_convert_i64_u => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.f64_convert_i64_u)
            },
            // Conversion: i32→f64 (input is i64-as-i32, output is f64)
            SsaOp.wasm_f64_convert_i32_s => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f64_convert_i32_s)
            },
            SsaOp.wasm_f64_convert_i32_u => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f64_convert_i32_u)
            },
            // Conversion: i64→f32 (f32 stored in i64 locals)
            SsaOp.wasm_f32_convert_i64_s => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.f32_convert_i64_s)
                self.builder.append(As.i32_reinterpret_f32)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_f32_convert_i64_u => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.f32_convert_i64_u)
                self.builder.append(As.i32_reinterpret_f32)
                self.builder.append(As.i64_extend_i32_u)
            },
            // Conversion: i32→f32 (f32 stored in i64 locals)
            SsaOp.wasm_f32_convert_i32_s => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_convert_i32_s)
                self.builder.append(As.i32_reinterpret_f32)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_f32_convert_i32_u => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_convert_i32_u)
                self.builder.append(As.i32_reinterpret_f32)
                self.builder.append(As.i64_extend_i32_u)
            },
            // Promotion: f32→f64 (f32 in i64 local → f64)
            SsaOp.wasm_f64_promote_f32 => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.f64_promote_f32)
            },
            // Demotion: f64→f32 (f64 → f32 in i64 local)
            SsaOp.wasm_f32_demote_f64 => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.f32_demote_f64)
                self.builder.append(As.i32_reinterpret_f32)
                self.builder.append(As.i64_extend_i32_u)
            },
            // Reinterpret ops — now emit actual instructions since locals are properly typed
            SsaOp.wasm_i64_reinterpret_f64 => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i64_reinterpret_f64)
            },
            SsaOp.wasm_f64_reinterpret_i64 => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.f64_reinterpret_i64)
            },
            // f32 reinterpret — f32 still in i64 locals, these are identity
            SsaOp.wasm_i32_reinterpret_f32 => {
                self.getValue64(v.args.get(0))
            },
            SsaOp.wasm_f32_reinterpret_i32 => {
                self.getValue64(v.args.get(0))
            },
            else => {},
        }
    }

    // ========================================================================
    // emitAddressOp — Address computation ops (split from emitMiscOp)
    // ========================================================================

    fn emitAddressOp(v: *SsaValue) void {
        switch (v.op) {
            SsaOp.local_addr => {
                self.builder.appendFrom(As.get, regAddr(Reg.sp))
                self.builder.append(As.i64_extend_i32_u)
                const byte_offset = v.aux_int * 8
                if (byte_offset != 0) {
                    self.builder.appendFrom(As.i64_const, constAddr(byte_offset))
                    self.builder.append(As.i64_add)
                }
            },
            SsaOp.global_addr => {
                const addr = GLOBAL_BASE + (v.aux_int * 8)
                self.builder.appendFrom(As.i64_const, constAddr(addr))
            },
            SsaOp.metadata_addr => {
                self.emitMetadataAddr(v)
            },
            SsaOp.addr => {
                self.emitFuncAddr(v)
            },
            SsaOp.off_ptr => {
                self.getValue64(v.args.get(0))
                if (v.aux_int != 0) {
                    self.builder.appendFrom(As.i64_const, constAddr(v.aux_int))
                    self.builder.append(As.i64_add)
                }
            },
            SsaOp.add_ptr => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_add)
            },
            SsaOp.sub_ptr => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_sub)
            },
            else => {},
        }
    }

    fn emitMetadataAddr(v: *SsaValue) void {
        const type_name = switch (v.aux) { SsaAux.str |s| => s, else => "" }
        if (@lenOf(type_name) > 0) {
            if (self.metadata_offsets) |offsets| {
                if (offsets.contains(type_name)) {
                    self.builder.appendFrom(As.i64_const, constAddr(offsets.get(type_name)))
                } else {
                    self.builder.appendFrom(As.i64_const, constAddr(0))
                }
            } else {
                self.builder.appendFrom(As.i64_const, constAddr(0))
            }
        } else {
            self.builder.appendFrom(As.i64_const, constAddr(0))
        }
    }

    fn emitFuncAddr(v: *SsaValue) void {
        const fn_name = switch (v.aux) { SsaAux.str |s| => s, else => "" }
        if (@ptrOf(fn_name) == 0 and @lenOf(fn_name) > 0) {
            println("[BUG] emitFuncAddr: null ptr with len=${@lenOf(fn_name)} val_id=${v.id} func=${self.ssa_func.name}")
            self.builder.appendFrom(As.i64_const, constAddr(0))
            return
        }
        if (@lenOf(fn_name) > 0) {
            if (self.func_table_indices) |fti| {
                if (fti.contains(fn_name)) {
                    self.builder.appendFrom(As.i64_const, constAddr(fti.get(fn_name)))
                } else if (self.func_indices) |fi| {
                    if (fi.contains(fn_name)) {
                        self.builder.appendFrom(As.i64_const, constAddr(fi.get(fn_name)))
                    } else {
                        self.builder.appendFrom(As.i64_const, constAddr(0))
                    }
                } else {
                    self.builder.appendFrom(As.i64_const, constAddr(0))
                }
            } else if (self.func_indices) |fi| {
                if (fi.contains(fn_name)) {
                    self.builder.appendFrom(As.i64_const, constAddr(fi.get(fn_name)))
                } else {
                    self.builder.appendFrom(As.i64_const, constAddr(0))
                }
            } else {
                self.builder.appendFrom(As.i64_const, constAddr(0))
            }
        } else {
            self.builder.appendFrom(As.i64_const, constAddr(0))
        }
    }

    // ========================================================================
    // emitGcOp — WasmGC struct operations (split from emitMiscOp)
    // ========================================================================

    fn emitGcOp(v: *SsaValue) void {
        switch (v.op) {
            SsaOp.wasm_gc_struct_new => {
                for ai in 0..v.args.count {
                    self.getValue64(v.args.get(ai))
                }
                const type_name = switch (v.aux) { SsaAux.str |s| => s, else => "" }
                var gc_type_idx = 0
                if (self.gc_struct_name_map) |m| {
                    if (m.contains(type_name)) { gc_type_idx = m.get(type_name) }
                }
                self.builder.appendFrom(As.gc_struct_new, constAddr(gc_type_idx))
            },
            SsaOp.wasm_gc_struct_get => {
                self.getValue64(v.args.get(0))
                const type_name2 = switch (v.aux) { SsaAux.str |s| => s, else => "" }
                var gc_type_idx2 = 0
                if (self.gc_struct_name_map) |m| {
                    if (m.contains(type_name2)) { gc_type_idx2 = m.get(type_name2) }
                }
                const gsg_idx = self.builder.appendFrom(As.gc_struct_get, constAddr(gc_type_idx2))
                var gsg_p = self.builder.get(gsg_idx)
                gsg_p.to = constAddr(v.aux_int)
                self.builder.set(gsg_idx, gsg_p)
            },
            SsaOp.wasm_gc_struct_set => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                const type_name3 = switch (v.aux) { SsaAux.str |s| => s, else => "" }
                var gc_type_idx3 = 0
                if (self.gc_struct_name_map) |m| {
                    if (m.contains(type_name3)) { gc_type_idx3 = m.get(type_name3) }
                }
                const gss_idx = self.builder.appendFrom(As.gc_struct_set, constAddr(gc_type_idx3))
                var gss_p = self.builder.get(gss_idx)
                gss_p.to = constAddr(v.aux_int)
                self.builder.set(gss_idx, gss_p)
            },
            else => {},
        }
    }

    // ========================================================================
    // emitGcArrayRefOp — WasmGC array, ref, and function reference operations
    // ========================================================================

    fn emitGcArrayRefOp(v: *SsaValue) void {
        const type_name = switch (v.aux) { SsaAux.str |s| => s, else => "" }

        // Resolve GC type index from name maps
        var gc_type_idx = 0
        if (self.gc_struct_name_map) |m| {
            if (m.contains(type_name)) { gc_type_idx = m.get(type_name) }
        }

        switch (v.op) {
            SsaOp.wasm_gc_array_new => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.appendFrom(As.gc_array_new, constAddr(gc_type_idx))
            },
            SsaOp.wasm_gc_array_new_default => {
                self.getValue64(v.args.get(0))
                self.builder.appendFrom(As.gc_array_new_default, constAddr(gc_type_idx))
            },
            SsaOp.wasm_gc_array_new_fixed => {
                for ai in 0..v.args.count { self.getValue64(v.args.get(ai)) }
                const pi = self.builder.appendFrom(As.gc_array_new_fixed, constAddr(gc_type_idx))
                var pp = self.builder.get(pi)
                pp.to = constAddr(v.aux_int)
                self.builder.set(pi, pp)
            },
            SsaOp.wasm_gc_array_new_data => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                const pi = self.builder.appendFrom(As.gc_array_new_data, constAddr(gc_type_idx))
                var pp = self.builder.get(pi)
                pp.to = constAddr(v.aux_int)
                self.builder.set(pi, pp)
            },
            SsaOp.wasm_gc_array_get => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.appendFrom(As.gc_array_get, constAddr(gc_type_idx))
            },
            SsaOp.wasm_gc_array_set => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.getValue64(v.args.get(2))
                self.builder.appendFrom(As.gc_array_set, constAddr(gc_type_idx))
            },
            SsaOp.wasm_gc_array_len => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.gc_array_len)
            },
            SsaOp.wasm_gc_array_copy => {
                for ai in 0..v.args.count { self.getValue64(v.args.get(ai)) }
                const pi = self.builder.appendFrom(As.gc_array_copy, constAddr(gc_type_idx))
                var pp = self.builder.get(pi)
                pp.to = constAddr(v.aux_int)
                self.builder.set(pi, pp)
            },
            SsaOp.wasm_gc_ref_test => {
                self.getValue64(v.args.get(0))
                self.builder.appendFrom(As.ref_test, constAddr(gc_type_idx))
            },
            SsaOp.wasm_gc_ref_cast => {
                self.getValue64(v.args.get(0))
                self.builder.appendFrom(As.ref_cast, constAddr(gc_type_idx))
            },
            SsaOp.wasm_gc_ref_null => {
                self.builder.appendFrom(As.ref_null, constAddr(gc_type_idx))
            },
            SsaOp.wasm_gc_ref_is_null => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.ref_is_null)
            },
            SsaOp.wasm_gc_ref_eq => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.ref_eq)
            },
            SsaOp.wasm_gc_ref_func => {
                self.builder.appendFrom(As.ref_func, constAddr(0))
            },
            SsaOp.wasm_gc_call_ref => {
                for ai in 0..v.args.count { self.getValue64(v.args.get(ai)) }
                self.builder.appendFrom(As.call_ref, constAddr(v.aux_int))
            },
            SsaOp.wasm_gc_return_call_ref => {
                for ai in 0..v.args.count { self.getValue64(v.args.get(ai)) }
                self.builder.appendFrom(As.return_call_ref, constAddr(v.aux_int))
            },
            SsaOp.wasm_gc_br_on_cast => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.@"unreachable")
            },
            else => {},
        }
    }

    // ========================================================================
    // emitMiscOp — Args, copy, phi, select, globals,
    //              bounds/nil checks, local get/set, drop, return, etc.
    // ========================================================================

    fn emitMiscOp(v: *SsaValue) void {
        switch (v.op) {
            SsaOp.local_addr, SsaOp.global_addr, SsaOp.metadata_addr, SsaOp.addr,
            SsaOp.off_ptr, SsaOp.add_ptr, SsaOp.sub_ptr => {
                self.emitAddressOp(v)
            },
            SsaOp.arg => {
                if (self.value_to_local.contains(v.id)) {
                    const local_idx = self.value_to_local.get(v.id)
                    self.builder.appendFrom(As.local_get, constAddr(local_idx))
                } else {
                    self.builder.appendFrom(As.local_get, constAddr(v.aux_int))
                }
            },

            // Copy — reinterpret if crossing float↔int boundary
            // Zig gen.zig:899-910
            SsaOp.copy => {
                const src = v.args.get(0)
                self.getValue64(src)
                if (isFloatType(src.type_idx) and !isFloatType(v.type_idx)) {
                    self.builder.append(As.i64_reinterpret_f64)
                }
                if (!isFloatType(src.type_idx) and isFloatType(v.type_idx)) {
                    self.builder.append(As.f64_reinterpret_i64)
                }
            },

            // Phi — load from local (populated by emitPhiMoves)
            SsaOp.phi => {
                if (self.value_to_local.contains(v.id)) {
                    const local_idx = self.value_to_local.get(v.id)
                    self.builder.appendFrom(As.local_get, constAddr(local_idx))
                }
            },

            // Conditional select (ternary)
            SsaOp.cond_select, SsaOp.wasm_select => {
                self.getValue64(v.args.get(1))
                self.getValue64(v.args.get(2))
                self.getValue32(v.args.get(0))
                self.builder.append(As.@"select")
            },

            // Wasm global get/set
            SsaOp.wasm_global_get => {
                self.builder.appendFrom(As.global_get, constAddr(v.aux_int))
            },
            SsaOp.wasm_global_set => {
                self.getValue64(v.args.get(0))
                self.builder.appendTo(As.global_set, constAddr(v.aux_int))
            },

            // ARC retain/release — native-only
            SsaOp.wasm_lowered_retain, SsaOp.wasm_lowered_release => {
                self.builder.append(As.@"unreachable")
            },

            // WasmGC struct operations
            SsaOp.wasm_gc_struct_new, SsaOp.wasm_gc_struct_get, SsaOp.wasm_gc_struct_set => {
                self.emitGcOp(v)
            },

            // WasmGC array/ref operations (infrastructure — codegen stubs)
            // WasmGC array/ref/func operations — emit real codegen
            SsaOp.wasm_gc_array_new, SsaOp.wasm_gc_array_new_default, SsaOp.wasm_gc_array_new_fixed,
            SsaOp.wasm_gc_array_new_data,
            SsaOp.wasm_gc_array_get, SsaOp.wasm_gc_array_set, SsaOp.wasm_gc_array_len, SsaOp.wasm_gc_array_copy,
            SsaOp.wasm_gc_ref_test, SsaOp.wasm_gc_ref_cast, SsaOp.wasm_gc_br_on_cast,
            SsaOp.wasm_gc_ref_null, SsaOp.wasm_gc_ref_is_null, SsaOp.wasm_gc_ref_eq,
            SsaOp.wasm_gc_ref_func, SsaOp.wasm_gc_call_ref, SsaOp.wasm_gc_return_call_ref => {
                self.emitGcArrayRefOp(v)
            },

            // Bounds check
            SsaOp.bounds_check => {
                if (v.args.count >= 2) {
                    self.getValue64(v.args.get(0))
                    self.getValue64(v.args.get(1))
                    self.builder.append(As.i64_ge_u)
                    self.builder.append(As.@"if")
                    self.builder.append(As.@"unreachable")
                    self.builder.append(As.end)
                }
            },

            // Nil check
            SsaOp.wasm_lowered_nil_check => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_eqz)
                self.builder.append(As.@"if")
                self.builder.append(As.@"unreachable")
                self.builder.append(As.end)
            },

            // Wasm local get/set (explicit ops)
            SsaOp.wasm_local_get => {
                self.builder.appendFrom(As.local_get, constAddr(v.aux_int))
            },
            SsaOp.wasm_local_set => {
                self.getValue64(v.args.get(0))
                self.builder.appendTo(As.local_set, constAddr(v.aux_int))
            },

            // Drop / Return / Unreachable / Nop / Select
            SsaOp.wasm_drop => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.drop)
            },
            SsaOp.wasm_return => {
                if (v.args.count > 0) {
                    self.getValue64(v.args.get(0))
                }
                self.builder.append(As.@"return")
            },
            SsaOp.wasm_unreachable => {
                self.builder.append(As.@"unreachable")
            },
            SsaOp.wasm_nop => {
                self.builder.append(As.nop)
            },

            // Const string (should be rewritten to string_make by rewritegeneric)
            SsaOp.const_string => {
                self.builder.appendFrom(As.i32_const, constAddr(v.aux_int))
            },

            // Memory / control flow no-ops
            SsaOp.init_mem, SsaOp.fwd_ref => {},

            else => {},
        }
    }

    // ========================================================================
    // Resolve function call index from name
    // Zig reference: gen.zig lines 943-954
    // ========================================================================

    fn resolveCallIndex(v: SsaValue) int {
        if (self.func_indices) |fi| {
            const name = switch (v.aux) { SsaAux.str |s| => s, else => "" }
            if (@lenOf(name) > 0 and fi.contains(name)) {
                return fi.get(name)
            }
            // Fallback to aux_int if name not in func_indices
        }
        return v.aux_int
    }

    // ========================================================================
    // generate — Generate Prog chain for the entire function
    // Zig reference: gen.zig lines 1146-1204
    // ========================================================================

    fn generate() Symbol {
        debug(.codegen, "wasm/gen: generating '${self.ssa_func.name}' (${self.ssa_func.blocks.count} blocks)")

        // Compute use counts (self-hosted SSA doesn't auto-track)
        self.computeUses()

        // Allocate locals for values (3-pass: i64, f64, GC ref)
        self.allocateLocals()

        // Compute frame size
        self.frame_size = self.computeFrameSize()

        // Emit TEXT marker at start (preprocess reads frame_size from it)
        const text_idx = self.builder.appendFrom(As.text, constAddr(self.frame_size))

        // Generate code for each block (Zig gen.zig:1346)
        for iter_i in 0..self.ssa_func.blocks.count {
            const bi = iter_i
            var next_bi = -1
            if (iter_i + 1 < self.ssa_func.blocks.count) {
                next_bi = iter_i + 1
            }
            const has_next = next_bi >= 0

            // Record first Prog of this block
            const first_prog_idx = self.builder.count

            // Generate values
            const blk = self.ssa_func.blocks.get(bi)
            for vi in 0..blk.values.count {
                const val = blk.values.get(vi)
                self.ssaGenValue(val)
            }

            // Record bstart (Zig gen.zig:1357-1365)
            if (self.builder.count > first_prog_idx) {
                self.bstart.set(bi, self.builder.count - 1)
            } else if (self.builder.count > 0) {
                self.bstart.set(bi, self.builder.count - 1)
            }

            // Emit phi moves before branches
            self.emitPhiMoves(bi)

            // Generate block control flow
            self.ssaGenBlock(bi, next_bi, has_next)
        }

        // Resolve branches: patch branch targets to prog indices
        for i in 0..self.branches.count {
            const branch = self.branches.get(i)
            if (self.bstart.contains(branch.target_block_id)) {
                const target_prog_idx = self.bstart.get(branch.target_block_id)
                var p = self.builder.get(branch.prog_idx)
                p.to = Addr.initBranch(target_prog_idx)
                self.builder.set(branch.prog_idx, p)
            }
        }

        // Build Symbol with the Prog chain
        var sym = Symbol.init(self.ssa_func.name)
        sym.is_func = true
        sym.frame_size = self.frame_size
        sym.param_count = self.param_count
        sym.float_local_count = self.float_local_count
        sym.gc_ref_locals = self.gc_ref_locals
        sym.text = self.builder.progs

        debug(.codegen, "wasm/gen: generated ${self.builder.count} instructions, ${self.branches.count} branches, frame_size=${self.frame_size}")

        return sym
    }

    // ========================================================================
    // ssaGenValue — Generate code for a single SSA value
    // Zig reference: gen.zig lines 1206-1273
    // ========================================================================

    fn ssaGenValue(v: *SsaValue) void {
        // Skip dead values (no uses and no side effects)
        if (v.uses == 0 and !hasSideEffects(v)) { return }

        // Skip compound type ops — no code generated
        // Zig gen.zig:1398 — skip string_make, slice_make, opt_make
        if (v.op == SsaOp.string_make or v.op == SsaOp.slice_make or v.op == SsaOp.opt_make) { return }

        // Skip rematerializable values (generate on demand)
        if (isRematerializable(v)) { return }

        // Skip comparisons — generated on-demand by getValue32
        if (isCmp(v)) { return }

        // Skip phi — locals populated by emitPhiMoves
        if (v.op == SsaOp.phi) { return }

        // Generate value on stack
        self.ssaGenValueOnStack(v)

        // return_call is a terminator — doesn't leave value on stack
        if (v.op == SsaOp.wasm_return_call) { return }

        // Store ops and bulk memory ops consume values and produce nothing — don't setReg
        if (v.op == SsaOp.wasm_i64_store or v.op == SsaOp.wasm_i64_store8 or
            v.op == SsaOp.wasm_i64_store16 or v.op == SsaOp.wasm_i64_store32 or
            v.op == SsaOp.wasm_i32_store or v.op == SsaOp.wasm_i32_store8 or
            v.op == SsaOp.wasm_i32_store16 or
            v.op == SsaOp.wasm_f64_store or v.op == SsaOp.wasm_f32_store or
            v.op == SsaOp.wasm_gc_struct_set or
            v.op == SsaOp.wasm_gc_array_set or v.op == SsaOp.wasm_gc_array_copy or
            v.op == SsaOp.wasm_lowered_move or v.op == SsaOp.wasm_lowered_zero) { return }

        // Nil check and bounds check produce no value — don't setReg
        if (v.op == SsaOp.wasm_lowered_nil_check or v.op == SsaOp.bounds_check) { return }

        // Retain/release are side-effect only — don't setReg
        if (v.op == SsaOp.wasm_lowered_retain or v.op == SsaOp.wasm_lowered_release) { return }

        // wasm_global_set, wasm_nop, wasm_drop, wasm_return — no value produced
        if (v.op == SsaOp.wasm_global_set or v.op == SsaOp.wasm_nop) { return }

        // init_mem, fwd_ref — no value produced
        if (v.op == SsaOp.init_mem or v.op == SsaOp.fwd_ref) { return }

        // Void/noreturn calls push nothing on the Wasm stack — skip setReg entirely.
        // Zig ref: gen.zig — exit() has type_idx == VOID; noreturn also produces nothing.
        const is_call = v.op == SsaOp.wasm_call or v.op == SsaOp.wasm_lowered_static_call
        if (is_call and (v.type_idx == VOID or v.type_idx == NORETURN)) { return }

        // Compound return handling: calls returning string push 2 values
        const is_compound_ret = is_call and v.type_idx == STRING
        if (is_compound_ret) {
            // Stack: [ptr, len] — store len first (top of stack), then ptr
            // Len local is pre-allocated in allocateLocals Pass 1.
            // Fallback: allocate on the fly (shouldn't happen if allocateLocals ran).
            if (self.compound_len_locals.contains(v.id)) {
                const len_local = self.compound_len_locals.get(v.id)
                self.builder.appendTo(As.local_set, constAddr(len_local))
            } else {
                const fallback_len = self.next_local
                self.next_local += 1
                self.compound_len_locals.set(v.id, fallback_len)
                self.builder.appendTo(As.local_set, constAddr(fallback_len))
            }
            if (v.uses > 0) {
                self.setReg(v)
            } else {
                // uses == 0: drop the ptr still on stack
                self.builder.append(As.drop)
            }
        } else if (v.uses > 0) {
            self.setReg(v)
        } else if (is_call and v.type_idx != VOID and v.type_idx != NORETURN) {
            // Side-effect call with discarded non-void return: drop
            self.builder.append(As.drop)
        } else if (v.op == SsaOp.wasm_gc_struct_new or
            v.op == SsaOp.wasm_gc_array_new or v.op == SsaOp.wasm_gc_array_new_default or
            v.op == SsaOp.wasm_gc_array_new_fixed or v.op == SsaOp.wasm_gc_array_new_data) {
            // GC alloc with uses=0: drop result
            self.builder.append(As.drop)
        }
    }

    // ========================================================================
    // allocateLocals — 2-pass: i64 (all values including floats), GC ref
    // All values stored as i64 — Go's all-i64 approach.
    // Zig reference: gen.zig lines 1277-1398
    // ========================================================================

    fn allocateLocals() void {
        // Count parameters
        for bi in 0..self.ssa_func.blocks.count {
            const blk = self.ssa_func.blocks.get(bi)
            for vi in 0..blk.values.count {
                const v = blk.values.get(vi)
                if (v.op == SsaOp.arg) {
                    const arg_idx = v.aux_int
                    self.value_to_local.set(v.id, arg_idx)
                    if (arg_idx + 1 > self.param_count) {
                        self.param_count = arg_idx + 1
                    }
                    // STRING args occupy two consecutive param locals
                    if (v.type_idx == STRING) {
                        self.compound_len_locals.set(v.id, arg_idx + 1)
                        if (arg_idx + 2 > self.param_count) {
                            self.param_count = arg_idx + 2
                        }
                    }
                }
            }
        }

        // PC_B is first declared local (index = param_count)
        self.next_local = self.param_count + 1

        // Pass 1: Allocate i64 locals (non-float values) — Zig gen.zig:1487-1523
        for bi in 0..self.ssa_func.blocks.count {
            const blk = self.ssa_func.blocks.get(bi)
            for vi in 0..blk.values.count {
                const v = blk.values.get(vi)
                if (v.op == SsaOp.arg) { continue }
                if (v.uses == 0 and !hasSideEffects(v)) { continue }
                if (isRematerializable(v)) { continue }
                if (isCmp(v)) { continue }
                if (v.op == SsaOp.slice_make or v.op == SsaOp.string_make or v.op == SsaOp.opt_make or
                    v.op == SsaOp.wasm_lowered_move or v.op == SsaOp.wasm_lowered_zero or
                    v.op == SsaOp.wasm_return_call) { continue }
                // Skip store ops — Zig gen.zig:1500-1503
                if (v.op == SsaOp.wasm_i64_store or v.op == SsaOp.wasm_i64_store8 or
                    v.op == SsaOp.wasm_i64_store16 or v.op == SsaOp.wasm_i64_store32 or
                    v.op == SsaOp.wasm_i32_store or v.op == SsaOp.wasm_i32_store8 or
                    v.op == SsaOp.wasm_i32_store16 or
                    v.op == SsaOp.wasm_f64_store or v.op == SsaOp.wasm_f32_store or
                    v.op == SsaOp.wasm_gc_struct_set or
                    v.op == SsaOp.wasm_gc_array_set or v.op == SsaOp.wasm_gc_array_copy) { continue }
                // Skip floats for pass 2 — Zig gen.zig:1504
                if (isFloatType(v.type_idx)) { continue }
                // Skip GC refs for pass 3 — Zig gen.zig:1505-1508
                if (v.op == SsaOp.wasm_gc_struct_new or
                    v.op == SsaOp.wasm_gc_array_new or v.op == SsaOp.wasm_gc_array_new_default or
                    v.op == SsaOp.wasm_gc_array_new_fixed or v.op == SsaOp.wasm_gc_array_new_data) { continue }

                const local_idx = self.next_local
                self.next_local += 1
                self.value_to_local.set(v.id, local_idx)

                // Pre-allocate compound len local for string-returning calls — Zig gen.zig:1517-1522
                const is_call_p1 = v.op == SsaOp.wasm_call or v.op == SsaOp.wasm_lowered_static_call
                if (is_call_p1 and v.type_idx == STRING) {
                    const len_local = self.next_local
                    self.next_local += 1
                    self.compound_len_locals.set(v.id, len_local)
                }
            }
        }

        // Pass 2: Allocate f64 locals (float values - contiguous at end) — Zig gen.zig:1526-1542
        var float_count = 0
        for bi in 0..self.ssa_func.blocks.count {
            const blk = self.ssa_func.blocks.get(bi)
            for vi in 0..blk.values.count {
                const v = blk.values.get(vi)
                if (v.op == SsaOp.arg) { continue }
                if (v.uses == 0 and !hasSideEffects(v)) { continue }
                if (isRematerializable(v)) { continue }
                if (isCmp(v)) { continue }
                if (!isFloatType(v.type_idx)) { continue }

                const local_idx = self.next_local
                self.next_local += 1
                float_count += 1
                self.value_to_local.set(v.id, local_idx)
            }
        }
        self.float_local_count = float_count

        // Pass 3: Allocate GC ref locals
        for bi in 0..self.ssa_func.blocks.count {
            const blk = self.ssa_func.blocks.get(bi)
            for vi in 0..blk.values.count {
                const v = blk.values.get(vi)
                if (v.op == SsaOp.arg) { continue }
                if (v.uses == 0) { continue }
                if (v.op != SsaOp.wasm_gc_struct_new and
                    v.op != SsaOp.wasm_gc_array_new and
                    v.op != SsaOp.wasm_gc_array_new_default and
                    v.op != SsaOp.wasm_gc_array_new_fixed and
                    v.op != SsaOp.wasm_gc_array_new_data) { continue }
                if (self.value_to_local.contains(v.id)) { continue }

                const local_idx = self.next_local
                self.next_local += 1
                const type_name = switch (v.aux) { SsaAux.str |s| => s, else => "" }
                var gc_idx = 0
                if (self.gc_struct_name_map) |m| {
                    if (m.contains(type_name)) { gc_idx = m.get(type_name) }
                }
                self.gc_ref_locals.append(gc_idx)
                self.value_to_local.set(v.id, local_idx)
            }
        }
    }

    // ========================================================================
    // computeFrameSize — from local_addr slots
    // ========================================================================

    fn computeFrameSize() int {
        var max_slot: int = -1
        for bi in 0..self.ssa_func.blocks.count {
            const blk = self.ssa_func.blocks.get(bi)
            for vi in 0..blk.values.count {
                const v = blk.values.get(vi)
                if (v.op == SsaOp.local_addr) {
                    if (v.aux_int > max_slot) {
                        max_slot = v.aux_int
                    }
                }
            }
        }
        if (max_slot < 0) { return 0 }
        const size = (max_slot + 1) * 8
        return ((size + 15) / 16) * 16
    }

    // ========================================================================
    // computeUses — Count SSA value uses (self-hosted doesn't auto-track)
    // ========================================================================

    fn computeUses() void {
        // Zero all uses first (Zig reference: deadcode.zig recomputeUses)
        // Without this, uses accumulate across passes, double-counting and
        // preventing dead loads from being identified (uses artificially > 0).
        var vi = 0
        while (vi < self.ssa_func.values.count) {
            self.ssa_func.values.get(vi).uses = 0
            vi += 1
        }

        // Count uses from block values and controls
        for bi in 0..self.ssa_func.blocks.count {
            const blk = self.ssa_func.blocks.get(bi)
            for vii in 0..blk.values.count {
                const val = blk.values.get(vii)
                for ai in 0..val.args.count {
                    val.args.get(ai).uses += 1
                }
            }
            for ci in 0..blk.controls.count {
                const ctrl_val = blk.controls.get(ci)
                ctrl_val.uses += 1
                // Also count uses from control value's args — control values
                // may not be in block.values (e.g. string_make used as return control
                // but removed from block.values by deadcode after copyelim).
                for cai in 0..ctrl_val.args.count {
                    ctrl_val.args.get(cai).uses += 1
                }
                // Transitively also count control args' args' uses (2 levels)
                for cai in 0..ctrl_val.args.count {
                    const ca_val = ctrl_val.args.get(cai)
                    for cai2 in 0..ca_val.args.count {
                        ca_val.args.get(cai2).uses += 1
                    }
                }
            }
        }
    }

    // ========================================================================
    // countParams — Count function parameters
    // ========================================================================

    fn countParams() int {
        var max_arg: int = 0
        var has_args = false
        for bi in 0..self.ssa_func.blocks.count {
            const blk = self.ssa_func.blocks.get(bi)
            for vi in 0..blk.values.count {
                const val = blk.values.get(vi)
                if (val.op == SsaOp.arg) {
                    has_args = true
                    if (val.aux_int + 1 > max_arg) {
                        max_arg = val.aux_int + 1
                    }
                }
            }
        }
        if (has_args) { return max_arg }
        return 0
    }
}

// ============================================================================
// Helper predicates (free functions, matching Zig gen.zig)
// ============================================================================

fn isRematerializable(v: *SsaValue) bool {
    return switch (v.op) {
        SsaOp.wasm_i64_const, SsaOp.wasm_i32_const, SsaOp.wasm_f64_const,
        SsaOp.const_int, SsaOp.const_32, SsaOp.const_64, SsaOp.const_float,
        SsaOp.const_bool, SsaOp.const_nil,
        SsaOp.local_addr, SsaOp.global_addr, SsaOp.metadata_addr => true,
        else => false,
    }
}

fn isCmp(v: *SsaValue) bool {
    return switch (v.op) {
        SsaOp.wasm_i64_eq, SsaOp.wasm_i64_ne, SsaOp.wasm_i64_lt_s, SsaOp.wasm_i64_le_s,
        SsaOp.wasm_i64_gt_s, SsaOp.wasm_i64_ge_s,
        SsaOp.wasm_i64_lt_u, SsaOp.wasm_i64_le_u, SsaOp.wasm_i64_gt_u, SsaOp.wasm_i64_ge_u,
        SsaOp.wasm_i64_eqz,
        SsaOp.wasm_f64_eq, SsaOp.wasm_f64_ne, SsaOp.wasm_f64_lt, SsaOp.wasm_f64_le,
        SsaOp.wasm_f64_gt, SsaOp.wasm_f64_ge => true,
        else => false,
    }
}

fn hasSideEffects(v: *SsaValue) bool {
    return switch (v.op) {
        SsaOp.wasm_i64_store, SsaOp.wasm_i32_store,
        SsaOp.wasm_i64_store8, SsaOp.wasm_i64_store16, SsaOp.wasm_i64_store32,
        SsaOp.wasm_i32_store8, SsaOp.wasm_i32_store16,
        SsaOp.wasm_f64_store, SsaOp.wasm_f32_store,
        SsaOp.wasm_return, SsaOp.wasm_drop,
        SsaOp.wasm_lowered_move, SsaOp.wasm_lowered_zero,
        SsaOp.wasm_lowered_static_call, SsaOp.wasm_lowered_closure_call, SsaOp.wasm_lowered_inter_call,
        SsaOp.wasm_call, SsaOp.wasm_call_indirect,
        SsaOp.wasm_lowered_retain, SsaOp.wasm_lowered_release,
        SsaOp.wasm_gc_struct_set,
        SsaOp.wasm_gc_array_set, SsaOp.wasm_gc_array_copy,
        SsaOp.wasm_gc_array_new, SsaOp.wasm_gc_array_new_default, SsaOp.wasm_gc_array_new_fixed,
        SsaOp.wasm_gc_array_new_data,
        SsaOp.wasm_unreachable => true,
        else => false,
    }
}

fn isFloatType(type_idx: int) bool {
    return type_idx == F64 or type_idx == F32 or type_idx == UNTYPED_FLOAT
}

// ============================================================================
// Public API
// ============================================================================

/// Generate a Symbol (Prog chain) for an SSA function.
fn genFunc(func: *SsaFunc) Symbol {
    var gen = GenState.init(func)
    return gen.generate()
}

/// Generate a Symbol with function index resolution.
fn genFuncWithIndices(func: *SsaFunc, func_indices: *Map(string, int)) Symbol {
    var gen = GenState.init(func)
    gen.setFuncIndices(func_indices)
    return gen.generate()
}

/// Generate a Symbol with full context (func indices, string offsets, table indices).
/// Zig reference: driver.zig generateFunc() call site.
fn generateFunc(func: *SsaFunc, func_indices: *Map(string, int), string_offsets: *Map(string, int), func_table_indices: *Map(string, int)) Symbol {
    var gen = GenState.init(func)
    gen.setFuncIndices(func_indices)
    gen.setStringOffsets(string_offsets)
    gen.setFuncTableIndices(func_table_indices)
    const sym = gen.generate()
    gen.free()
    return sym
}

// ============================================================================
// Tests
// ============================================================================

test "GenState basic constant" {
    var func = SsaFunc.init("answer")
    const blk = func.newBlock(SsaBlockKind.ret)

    const c = func.newValue(SsaOp.wasm_i64_const, 0, blk.idx, 0, 0)
    c.aux_int = 42
    c.uses = 1
    func.addValueToBlock(c, blk.idx)

    blk.setControl(c)

    const sym = genFunc(&func)
    @assertEq(sym.text.count > 0, true)
    @assertEq(sym.name, "answer")
}

test "GenState add two args" {
    var func = SsaFunc.init("add")
    const blk = func.newBlock(SsaBlockKind.ret)

    const a0 = func.newValue(SsaOp.arg, 0, blk.idx, 0, 0)
    a0.aux_int = 0
    a0.uses = 1
    func.addValueToBlock(a0, blk.idx)

    const a1 = func.newValue(SsaOp.arg, 0, blk.idx, 0, 0)
    a1.aux_int = 1
    a1.uses = 1
    func.addValueToBlock(a1, blk.idx)

    const add = func.newValue(SsaOp.wasm_i64_add, 0, blk.idx, 0, 0)
    add.uses = 1
    add.addArg(a0)
    add.addArg(a1)
    func.addValueToBlock(add, blk.idx)

    blk.setControl(add)

    const sym = genFunc(&func)
    @assertEq(sym.text.count > 0, true)
    @assertEq(sym.param_count, 2)
}

test "isRematerializable predicates" {
    var func = SsaFunc.init("test_pred")
    const blk = func.newBlock(SsaBlockKind.plain)

    const c = func.newValue(SsaOp.wasm_i64_const, 0, blk.idx, 0, 0)
    @assertEq(isRematerializable(c), true)

    const a = func.newValue(SsaOp.wasm_i64_add, 0, blk.idx, 0, 0)
    @assertEq(isRematerializable(a), false)
}

test "isCmp predicates" {
    var func = SsaFunc.init("test_cmp")
    const blk = func.newBlock(SsaBlockKind.plain)

    const cmp = func.newValue(SsaOp.wasm_i64_eq, 0, blk.idx, 0, 0)
    @assertEq(isCmp(cmp), true)

    const add = func.newValue(SsaOp.wasm_i64_add, 0, blk.idx, 0, 0)
    @assertEq(isCmp(add), false)
}

test "GenState computeFrameSize" {
    var func = SsaFunc.init("test_frame")
    const blk = func.newBlock(SsaBlockKind.plain)

    const a0 = func.newValue(SsaOp.local_addr, 0, blk.idx, 0, 0)
    a0.aux_int = 0
    func.addValueToBlock(a0, blk.idx)

    const a2 = func.newValue(SsaOp.local_addr, 0, blk.idx, 0, 0)
    a2.aux_int = 2
    func.addValueToBlock(a2, blk.idx)

    var gen = GenState.init(&func)
    @assertEq(gen.computeFrameSize(), 32)
}

test "GenState countParams" {
    var func = SsaFunc.init("test_params")
    const blk = func.newBlock(SsaBlockKind.plain)

    for i in 0..3 {
        const arg = func.newValue(SsaOp.arg, 0, blk.idx, 0, 0)
        arg.aux_int = i
        func.addValueToBlock(arg, blk.idx)
    }

    var gen = GenState.init(&func)
    @assertEq(gen.countParams(), 3)
}
