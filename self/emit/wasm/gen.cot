/// WasmGen — SSA to Wasm Prog chain generator.
///
/// Zig reference: compiler/codegen/wasm/gen.zig
/// Go reference: references/go/src/cmd/compile/internal/wasm/ssa.go
///
/// This generates Prog chains from SSA values and blocks.
/// Key functions matching Go:
/// - ssaGenValue: Generate code for a single SSA value
/// - ssaGenBlock: Generate code for block control flow (emits pseudo-jumps)
/// - getValue32/getValue64: Get value onto wasm stack
/// - setReg: Store value to register (local)
///
/// IMPORTANT: This emits PSEUDO-JUMPS (As.jmp) not real branches.
/// The preprocess pass later transforms these into the dispatch loop pattern.

import "std/list"
import "std/map"
import "std/string"
import "../../build/ssa"
import "../../check/types"
import "prog"
import "types"
import "../../debug"

// Memory layout constants
const GLOBAL_BASE: int = 0x20000  // 128KB, after stack and heap start

// ============================================================================
// Branch — records pseudo-jumps for later resolution
// Go reference: cmd/compile/internal/ssagen/ssa.go Branch struct
// ============================================================================

struct Branch {
    prog_idx: int,
    target_block_id: int,
}

// ============================================================================
// GenState — State for SSA code generation
// Go reference: cmd/compile/internal/ssagen/ssa.go State struct
// Zig reference: compiler/codegen/wasm/gen.zig GenState struct
// ============================================================================

struct GenState {
    ssa_func: *SsaFunc,
    builder: ProgBuilder,

    /// Value to local mapping (Go: regalloc assigns registers)
    value_to_local: Map(int, int),

    /// Next local index (set by allocateLocals after counting params)
    next_local: int,

    /// Number of function parameters
    param_count: int,

    /// Branch tracking (Go: s.Branches)
    branches: List(Branch),

    /// First Prog index of each block (Go: s.bstart)
    bstart: Map(int, int),

    /// OnWasmStack tracking (Go: s.OnWasmStackSkipped)
    on_wasm_stack_skipped: int,

    /// Frame size for locals
    frame_size: int,

    /// Number of f64 locals (always 0 — all values stored as i64)
    float_local_count: int,

    /// GC ref locals: each entry is a GC struct type index
    gc_ref_locals: List(int),

    /// Maps function names to Wasm function indices
    func_indices: ?*Map(string, int),

    /// Maps string literal content to memory offsets
    string_offsets: ?*Map(string, int),

    /// Maps type names to metadata memory offsets
    metadata_offsets: ?*Map(string, int),

    /// Maps function names to element table indices (for addr → call_indirect)
    func_table_indices: ?*Map(string, int),

    /// Maps GC struct type names to GC type indices
    gc_struct_name_map: ?*Map(string, int),

    /// Maps SSA value IDs to their compound "len" local index.
    /// For calls returning compound types (string, slice), the call pushes 2 values.
    /// The main local stores ptr, this stores len.
    compound_len_locals: Map(int, int),

    /// Free Maps/Lists NOT transferred to the returned Symbol.
    /// builder.progs and gc_ref_locals are aliased by the Symbol — do NOT free them here.
    fn free() void {
        self.value_to_local.free()
        self.branches.free()
        self.bstart.free()
        self.compound_len_locals.free()
    }

    static fn init(func: *SsaFunc) GenState {
        var value_to_local: Map(int, int) = .{}
        var branches: List(Branch) = .{}
        var bstart: Map(int, int) = .{}
        var gc_ref_locals: List(int) = .{}
        var compound_len_locals: Map(int, int) = .{}
        return GenState {
            ssa_func: func,
            builder: ProgBuilder.init(),
            value_to_local: value_to_local,
            next_local: 0,
            param_count: 0,
            branches: branches,
            bstart: bstart,
            on_wasm_stack_skipped: 0,
            frame_size: 0,
            float_local_count: 0,
            gc_ref_locals: gc_ref_locals,
            func_indices: null,
            string_offsets: null,
            metadata_offsets: null,
            func_table_indices: null,
            gc_struct_name_map: null,
            compound_len_locals: compound_len_locals,
        }
    }

    fn setFuncIndices(indices: *Map(string, int)) void {
        self.func_indices = indices
    }

    fn setStringOffsets(offsets: *Map(string, int)) void {
        self.string_offsets = offsets
    }

    fn setMetadataOffsets(offsets: *Map(string, int)) void {
        self.metadata_offsets = offsets
    }

    fn setFuncTableIndices(indices: *Map(string, int)) void {
        self.func_table_indices = indices
    }

    fn setGcStructNameMap(m: *Map(string, int)) void {
        self.gc_struct_name_map = m
    }

    // ========================================================================
    // Go's s.Br - emit pseudo-jump
    // Reference: cmd/compile/internal/ssagen/ssa.go lines 6711-6716
    // ========================================================================

    fn br(target_block_id: int) void {
        const p_idx = self.builder.appendTo(As.jmp, Addr.initBranch(-1))
        self.branches.append(Branch { prog_idx: p_idx, target_block_id: target_block_id })
    }

    // ========================================================================
    // Go's ssaGenBlock - control flow generation with PSEUDO-JUMPS
    // Reference: cmd/compile/internal/wasm/ssa.go lines 169-215
    // Zig reference: gen.zig lines 177-263
    // ========================================================================

    fn ssaGenBlock(bi: int, next_bi: int, has_next: bool) void {
        const blk = self.ssa_func.blocks.get(bi)

        if (blk.kind == SsaBlockKind.plain or blk.kind == SsaBlockKind.first or blk.kind == SsaBlockKind.defer_) {
            // Go: BlockPlain, BlockDefer (lines 171-174)
            // Zig ref: gen.zig lines 187-193
            if (blk.succs.count > 0) {
                const succ_edge = blk.succs.get(0)
                const succ_bi = succ_edge.block
                if (!has_next or next_bi != succ_bi) {
                    self.br(succ_bi)
                }
            }
        } else if (blk.kind == SsaBlockKind.if_) {
            // Go: BlockIf (lines 176-198)
            // Zig ref: gen.zig lines 197-224
            if (blk.succs.count < 2) { return }

            const succ0_bi = blk.succs.get(0).block  // true branch
            const succ1_bi = blk.succs.get(1).block  // false branch

            if (blk.controls.count > 0) {
                self.getValue32(blk.controls.get(0))
            }

            if (has_next and next_bi == succ0_bi) {
                // if false, jump to succ1 (Go: lines 178-184)
                self.builder.append(As.i32_eqz)
                self.builder.append(As.@"if")
                self.br(succ1_bi)
                self.builder.append(As.end)
            } else if (has_next and next_bi == succ1_bi) {
                // if true, jump to succ0 (Go: lines 185-190)
                self.builder.append(As.@"if")
                self.br(succ0_bi)
                self.builder.append(As.end)
            } else {
                // neither is next (Go: lines 191-197)
                self.builder.append(As.@"if")
                self.br(succ0_bi)
                self.builder.append(As.end)
                self.br(succ1_bi)
            }
        } else if (blk.kind == SsaBlockKind.ret) {
            // Go: BlockRet (lines 200-201)
            // Zig ref: gen.zig lines 228-252
            if (blk.controls.count > 0) {
                const ret_val = blk.controls.get(0)

                if (ret_val.op == SsaOp.string_make or ret_val.op == SsaOp.slice_make or ret_val.op == SsaOp.opt_make) {
                    // Compound return: push both components (ptr/tag, len/payload)
                    if (ret_val.args.count >= 2) {
                        self.getValue64(ret_val.args.get(0))
                        self.getValue64(ret_val.args.get(1))
                    }
                } else if (ret_val.type_idx == STRING and self.compound_len_locals.contains(ret_val.id)) {
                    // Compound return from call result — push ptr then len
                    self.getValue64(ret_val)
                    const len_local = self.compound_len_locals.get(ret_val.id)
                    self.builder.appendFrom(As.local_get, constAddr(len_local))
                } else {
                    // Non-compound scalar return
                    self.getValue64(ret_val)
                }
            }
            // Emit ARET pseudo-instruction, NOT real wasm return
            self.builder.append(As.aret)
        } else if (blk.kind == SsaBlockKind.exit) {
            // Go: BlockExit (lines 203-204) — nothing, handled by preprocess
        }

        // Go: Every block ends with ARESUMEPOINT (line 210)
        self.builder.append(As.resume_point)

        // Go: Check stack balance (lines 212-214)
        if (self.on_wasm_stack_skipped != 0) {
            self.on_wasm_stack_skipped = 0
        }
    }

    // ========================================================================
    // emitPhiMoves — store phi args to phi locals before branches
    // Zig reference: gen.zig lines 269-285
    // CRITICAL: Without this, phi nodes silently do nothing and
    // loops/if-else merges produce wrong values.
    // ========================================================================

    fn emitPhiMoves(block_idx: int) void {
        const blk = self.ssa_func.blocks.get(block_idx)
        for si in 0..blk.succs.count {
            const edge = blk.succs.get(si)
            const succ = self.ssa_func.blocks.get(edge.block)
            const pred_idx = edge.index
            for vi in 0..succ.values.count {
                const v = succ.values.get(vi)
                if (v.op != SsaOp.phi) { continue }
                if (pred_idx >= v.args.count) { continue }
                const arg_val = v.args.get(pred_idx)
                self.getValue64(arg_val)
                if (self.value_to_local.contains(v.id)) {
                    const local_idx = self.value_to_local.get(v.id)
                    // All locals are i64 — getValue64 already produces i64
                    self.builder.appendTo(As.local_set, constAddr(local_idx))
                }
            }
        }
    }

    // ========================================================================
    // Value access helpers
    // Go reference: cmd/compile/internal/wasm/ssa.go lines 474-533
    // Zig reference: gen.zig lines 294-346
    // ========================================================================

    /// Get 32-bit value onto wasm stack
    fn getValue32(v: *SsaValue) void {
        // Zig: check isRematerializable before local lookup
        if (!isRematerializable(v)) {
            if (self.value_to_local.contains(v.id)) {
                const local_idx = self.value_to_local.get(v.id)
                self.builder.appendFrom(As.local_get, constAddr(local_idx))
                self.builder.append(As.i32_wrap_i64)
                return
            }
        }
        self.ssaGenValueOnStack(v)
        if (!isCmp(v)) {
            self.builder.append(As.i32_wrap_i64)
        }
    }

    /// Get 64-bit value onto wasm stack
    fn getValue64(v: *SsaValue) void {
        // Check if rematerializable (constants)
        if (isRematerializable(v)) {
            self.ssaGenValueOnStack(v)
            return
        }
        // Get from local
        if (self.value_to_local.contains(v.id)) {
            const local_idx = self.value_to_local.get(v.id)
            self.builder.appendFrom(As.local_get, constAddr(local_idx))
            return
        }
        // Generate on stack (on-demand values like comparisons)
        self.ssaGenValueOnStack(v)
        if (isCmp(v)) {
            self.builder.append(As.i64_extend_i32_u)
        }
    }

    /// Store top of stack to local
    /// All locals are i64 — caller must ensure value on stack is i64.
    fn setReg(v: *SsaValue) void {
        if (self.value_to_local.contains(v.id)) {
            const local_idx = self.value_to_local.get(v.id)
            self.builder.appendTo(As.local_set, constAddr(local_idx))
        }
    }

    // ========================================================================
    // ssaGenValueOnStack — Generate value directly onto wasm stack
    // Go reference: cmd/compile/internal/wasm/ssa.go lines 313-461
    // Zig reference: gen.zig lines 350-1140
    // ========================================================================


    // ========================================================================
    // ssaGenValueOnStack — Dispatch to category-specific helpers
    // Go reference: cmd/compile/internal/wasm/ssa.go lines 313-461
    // Zig reference: gen.zig lines 350-1140
    // Split into helpers to avoid stack overflow from 191 switch arms.
    // ========================================================================

    fn ssaGenValueOnStack(v: *SsaValue) void {
        switch (v.op) {
            // Constants
            SsaOp.wasm_i64_const, SsaOp.const_int, SsaOp.const_64,
            SsaOp.wasm_i32_const, SsaOp.const_32,
            SsaOp.wasm_f64_const, SsaOp.const_float,
            SsaOp.const_bool, SsaOp.const_nil => { self.emitConstant(v) },

            // Compound type ops — Zig gen.zig:384, 391, 395, 406, 410
            SsaOp.string_make, SsaOp.slice_make, SsaOp.opt_make,
            SsaOp.string_ptr, SsaOp.slice_ptr,
            SsaOp.string_len, SsaOp.slice_len,
            SsaOp.opt_tag, SsaOp.opt_data => { self.emitCompoundOp(v) },

            // i64 arithmetic, bitwise, bit counting, comparisons, not, neg
            SsaOp.wasm_i64_add, SsaOp.wasm_i64_sub, SsaOp.wasm_i64_mul,
            SsaOp.wasm_i64_div_s, SsaOp.wasm_i64_div_u,
            SsaOp.wasm_i64_rem_s, SsaOp.wasm_i64_rem_u,
            SsaOp.wasm_i64_and, SsaOp.wasm_i64_or, SsaOp.wasm_i64_xor,
            SsaOp.wasm_i64_shl, SsaOp.wasm_i64_shr_s, SsaOp.wasm_i64_shr_u,
            SsaOp.wasm_i64_rotl, SsaOp.wasm_i64_rotr,
            SsaOp.wasm_i64_clz, SsaOp.wasm_i64_ctz, SsaOp.wasm_i64_popcnt,
            SsaOp.wasm_i64_eq, SsaOp.wasm_i64_ne,
            SsaOp.wasm_i64_lt_s, SsaOp.wasm_i64_le_s, SsaOp.wasm_i64_gt_s, SsaOp.wasm_i64_ge_s,
            SsaOp.wasm_i64_lt_u, SsaOp.wasm_i64_le_u, SsaOp.wasm_i64_gt_u, SsaOp.wasm_i64_ge_u,
            SsaOp.wasm_i64_eqz,
            SsaOp.@"not", SsaOp.neg => { self.emitI64Op(v) },

            // i32 arithmetic, bitwise, bit counting, comparisons (wrap-operate-extend)
            SsaOp.wasm_i32_and, SsaOp.wasm_i32_or, SsaOp.wasm_i32_xor,
            SsaOp.wasm_i32_shl, SsaOp.wasm_i32_shr_s, SsaOp.wasm_i32_shr_u,
            SsaOp.wasm_i32_rotl, SsaOp.wasm_i32_rotr,
            SsaOp.wasm_i32_add, SsaOp.wasm_i32_sub, SsaOp.wasm_i32_mul,
            SsaOp.wasm_i32_div_s, SsaOp.wasm_i32_div_u,
            SsaOp.wasm_i32_rem_s, SsaOp.wasm_i32_rem_u,
            SsaOp.wasm_i32_clz, SsaOp.wasm_i32_ctz, SsaOp.wasm_i32_popcnt,
            SsaOp.wasm_i32_eqz, SsaOp.wasm_i32_eq, SsaOp.wasm_i32_ne,
            SsaOp.wasm_i32_lt_s, SsaOp.wasm_i32_lt_u,
            SsaOp.wasm_i32_gt_s, SsaOp.wasm_i32_gt_u,
            SsaOp.wasm_i32_le_s, SsaOp.wasm_i32_le_u,
            SsaOp.wasm_i32_ge_s, SsaOp.wasm_i32_ge_u => { self.emitI32Op(v) },

            // Float ops (f64 and f32)
            SsaOp.wasm_f64_add, SsaOp.wasm_f64_sub, SsaOp.wasm_f64_mul, SsaOp.wasm_f64_div,
            SsaOp.wasm_f64_neg, SsaOp.wasm_f64_abs,
            SsaOp.wasm_f64_ceil, SsaOp.wasm_f64_floor, SsaOp.wasm_f64_trunc,
            SsaOp.wasm_f64_nearest, SsaOp.wasm_f64_sqrt,
            SsaOp.wasm_f64_min, SsaOp.wasm_f64_max, SsaOp.wasm_f64_copysign,
            SsaOp.wasm_f64_eq, SsaOp.wasm_f64_ne,
            SsaOp.wasm_f64_lt, SsaOp.wasm_f64_le, SsaOp.wasm_f64_gt, SsaOp.wasm_f64_ge,
            SsaOp.wasm_f32_add, SsaOp.wasm_f32_sub, SsaOp.wasm_f32_mul, SsaOp.wasm_f32_div,
            SsaOp.wasm_f32_neg, SsaOp.wasm_f32_abs,
            SsaOp.wasm_f32_ceil, SsaOp.wasm_f32_floor, SsaOp.wasm_f32_trunc,
            SsaOp.wasm_f32_nearest, SsaOp.wasm_f32_sqrt,
            SsaOp.wasm_f32_min, SsaOp.wasm_f32_max, SsaOp.wasm_f32_copysign,
            SsaOp.wasm_f32_eq, SsaOp.wasm_f32_ne,
            SsaOp.wasm_f32_lt, SsaOp.wasm_f32_gt,
            SsaOp.wasm_f32_le, SsaOp.wasm_f32_ge => { self.emitFloatOp(v) },

            // Memory loads/stores (i64)
            SsaOp.wasm_i64_load, SsaOp.wasm_i64_load8_s, SsaOp.wasm_i64_load8_u,
            SsaOp.wasm_i64_load16_s, SsaOp.wasm_i64_load16_u,
            SsaOp.wasm_i64_load32_s, SsaOp.wasm_i64_load32_u,
            SsaOp.wasm_i64_store, SsaOp.wasm_i64_store8, SsaOp.wasm_i64_store16, SsaOp.wasm_i64_store32 => { self.emitI64MemOp(v) },
            // Memory loads/stores (i32)
            SsaOp.wasm_i32_load, SsaOp.wasm_i32_store,
            SsaOp.wasm_i32_load8_s, SsaOp.wasm_i32_load8_u,
            SsaOp.wasm_i32_load16_s, SsaOp.wasm_i32_load16_u,
            SsaOp.wasm_i32_store8, SsaOp.wasm_i32_store16 => { self.emitI32MemOp(v) },
            // Memory loads/stores (float)
            SsaOp.wasm_f64_load, SsaOp.wasm_f64_store,
            SsaOp.wasm_f32_load, SsaOp.wasm_f32_store => { self.emitFloatMemOp(v) },
            // Bulk memory ops
            SsaOp.wasm_lowered_move, SsaOp.wasm_lowered_zero => { self.emitBulkMemOp(v) },

            // Function calls
            SsaOp.wasm_call, SsaOp.wasm_return_call,
            SsaOp.wasm_lowered_static_call, SsaOp.wasm_lowered_closure_call,
            SsaOp.wasm_lowered_inter_call, SsaOp.wasm_call_indirect => { self.emitCallOp(v) },

            // Conversions
            SsaOp.convert,
            SsaOp.wasm_i32_wrap_i64,
            SsaOp.wasm_i64_extend_i32_s, SsaOp.wasm_i64_extend_i32_u,
            SsaOp.wasm_i64_trunc_f64_s, SsaOp.wasm_i64_trunc_f64_u,
            SsaOp.wasm_i64_trunc_f32_s, SsaOp.wasm_i64_trunc_f32_u,
            SsaOp.wasm_i32_trunc_f64_s, SsaOp.wasm_i32_trunc_f64_u,
            SsaOp.wasm_i32_trunc_f32_s, SsaOp.wasm_i32_trunc_f32_u,
            SsaOp.wasm_f64_convert_i64_s, SsaOp.wasm_f64_convert_i64_u,
            SsaOp.wasm_f64_convert_i32_s, SsaOp.wasm_f64_convert_i32_u,
            SsaOp.wasm_f32_convert_i64_s, SsaOp.wasm_f32_convert_i64_u,
            SsaOp.wasm_f32_convert_i32_s, SsaOp.wasm_f32_convert_i32_u,
            SsaOp.wasm_f64_promote_f32, SsaOp.wasm_f32_demote_f64,
            SsaOp.wasm_i64_reinterpret_f64, SsaOp.wasm_f64_reinterpret_i64,
            SsaOp.wasm_i32_reinterpret_f32, SsaOp.wasm_f32_reinterpret_i32 => { self.emitConvertOp(v) },

            // Misc ops
            SsaOp.local_addr, SsaOp.global_addr, SsaOp.metadata_addr, SsaOp.addr,
            SsaOp.off_ptr, SsaOp.add_ptr, SsaOp.sub_ptr,
            SsaOp.arg, SsaOp.copy, SsaOp.phi,
            SsaOp.cond_select, SsaOp.wasm_select,
            SsaOp.wasm_global_get, SsaOp.wasm_global_set,
            SsaOp.bounds_check, SsaOp.wasm_lowered_nil_check,
            SsaOp.wasm_local_get, SsaOp.wasm_local_set,
            SsaOp.wasm_drop, SsaOp.wasm_return, SsaOp.wasm_unreachable, SsaOp.wasm_nop,
            SsaOp.wasm_gc_struct_new, SsaOp.wasm_gc_struct_get, SsaOp.wasm_gc_struct_set,
            SsaOp.wasm_gc_array_new, SsaOp.wasm_gc_array_new_default, SsaOp.wasm_gc_array_new_fixed,
            SsaOp.wasm_gc_array_new_data,
            SsaOp.wasm_gc_array_get, SsaOp.wasm_gc_array_set, SsaOp.wasm_gc_array_len, SsaOp.wasm_gc_array_copy,
            SsaOp.wasm_gc_ref_test, SsaOp.wasm_gc_ref_cast, SsaOp.wasm_gc_br_on_cast,
            SsaOp.wasm_gc_ref_null, SsaOp.wasm_gc_ref_is_null, SsaOp.wasm_gc_ref_eq,
            SsaOp.wasm_gc_ref_func, SsaOp.wasm_gc_call_ref, SsaOp.wasm_gc_return_call_ref,
            SsaOp.wasm_lowered_retain, SsaOp.wasm_lowered_release,
            SsaOp.const_string,
            SsaOp.init_mem, SsaOp.fwd_ref => { self.emitMiscOp(v) },

            // Unhandled ops silently ignored
            else => {},
        }
    }

    // ========================================================================
    // emitConstant — Constants
    // ========================================================================

    fn emitConstant(v: *SsaValue) void {
        switch (v.op) {
            SsaOp.wasm_i64_const, SsaOp.const_int, SsaOp.const_64 => {
                self.builder.appendFrom(As.i64_const, constAddr(v.aux_int))
            },
            SsaOp.wasm_i32_const, SsaOp.const_32 => {
                self.builder.appendFrom(As.i32_const, constAddr(v.aux_int))
            },
            SsaOp.wasm_f64_const, SsaOp.const_float => {
                // Float constants stay as f64 — float locals are f64
                // Zig gen.zig:366-369
                self.builder.appendFrom(As.f64_const, floatAddr(@bitCast(float, v.aux_int)))
            },
            SsaOp.const_bool => {
                if (v.aux_int != 0) {
                    self.builder.appendFrom(As.i64_const, constAddr(1))
                } else {
                    self.builder.appendFrom(As.i64_const, constAddr(0))
                }
            },
            SsaOp.const_nil => {
                self.builder.appendFrom(As.i64_const, constAddr(0))
            },
            else => {},
        }
    }

    // ========================================================================
    // emitCompoundOp — Compound type ops (string/slice make/ptr/len)
    // ========================================================================

    fn emitCompoundOp(v: *SsaValue) void {
        switch (v.op) {
            // Compound type ops - no code generated (decomposed when accessed)
            // Zig gen.zig:384 — string_make, slice_make, AND opt_make
            SsaOp.string_make, SsaOp.slice_make, SsaOp.opt_make => {
                // No code - these values are decomposed when accessed
            },

            // Extraction ops for compound types
            SsaOp.string_ptr, SsaOp.slice_ptr => {
                // Get ptr component: stored in arg's main local
                self.getValue64(v.args.get(0))
            },
            SsaOp.string_len, SsaOp.slice_len => {
                // Get len component: stored in arg's compound len local
                const arg_val = v.args.get(0)
                if (self.compound_len_locals.contains(arg_val.id)) {
                    const len_local = self.compound_len_locals.get(arg_val.id)
                    self.builder.appendFrom(As.local_get, constAddr(len_local))
                } else {
                    self.getValue64(arg_val)
                }
            },
            // Optional pointer extraction ops — same pattern as string/slice
            // Zig gen.zig:406-417
            SsaOp.opt_tag => {
                // Get tag component: stored in arg's main local
                self.getValue64(v.args.get(0))
            },
            SsaOp.opt_data => {
                // Get payload component: stored in arg's compound len local
                const arg_val = v.args.get(0)
                if (self.compound_len_locals.contains(arg_val.id)) {
                    const data_local = self.compound_len_locals.get(arg_val.id)
                    self.builder.appendFrom(As.local_get, constAddr(data_local))
                } else {
                    self.getValue64(arg_val)
                }
            },
            else => {},
        }
    }

    // ========================================================================
    // emitI64Op — i64 arithmetic, bitwise, comparisons, not, neg
    // ========================================================================

    fn emitI64Op(v: *SsaValue) void {
        switch (v.op) {
            // i64 arithmetic
            SsaOp.wasm_i64_add => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_add)
            },
            SsaOp.wasm_i64_sub => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_sub)
            },
            SsaOp.wasm_i64_mul => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_mul)
            },
            SsaOp.wasm_i64_div_s => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_div_s)
            },
            SsaOp.wasm_i64_div_u => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_div_u)
            },
            SsaOp.wasm_i64_rem_s => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_rem_s)
            },
            SsaOp.wasm_i64_rem_u => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_rem_u)
            },

            // i64 bitwise
            SsaOp.wasm_i64_and => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_and)
            },
            SsaOp.wasm_i64_or => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_or)
            },
            SsaOp.wasm_i64_xor => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_xor)
            },
            SsaOp.wasm_i64_shl => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_shl)
            },
            SsaOp.wasm_i64_shr_s => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_shr_s)
            },
            SsaOp.wasm_i64_shr_u => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_shr_u)
            },
            SsaOp.wasm_i64_rotl => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_rotl)
            },
            SsaOp.wasm_i64_rotr => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_rotr)
            },

            // i64 bit counting
            SsaOp.wasm_i64_clz => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i64_clz)
            },
            SsaOp.wasm_i64_ctz => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i64_ctz)
            },
            SsaOp.wasm_i64_popcnt => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i64_popcnt)
            },

            // Bitwise NOT — x XOR -1 (Wasm has no NOT)
            SsaOp.@"not" => {
                self.getValue64(v.args.get(0))
                self.builder.appendFrom(As.i64_const, constAddr(-1))
                self.builder.append(As.i64_xor)
            },

            // Integer negation — 0 - x (Wasm has no i64.neg)
            SsaOp.neg => {
                self.builder.appendFrom(As.i64_const, constAddr(0))
                self.getValue64(v.args.get(0))
                self.builder.append(As.i64_sub)
            },

            // i64 comparisons (produce i32)
            SsaOp.wasm_i64_eq => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_eq)
            },
            SsaOp.wasm_i64_ne => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_ne)
            },
            SsaOp.wasm_i64_lt_s => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_lt_s)
            },
            SsaOp.wasm_i64_le_s => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_le_s)
            },
            SsaOp.wasm_i64_gt_s => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_gt_s)
            },
            SsaOp.wasm_i64_ge_s => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_ge_s)
            },
            SsaOp.wasm_i64_lt_u => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_lt_u)
            },
            SsaOp.wasm_i64_le_u => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_le_u)
            },
            SsaOp.wasm_i64_gt_u => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_gt_u)
            },
            SsaOp.wasm_i64_ge_u => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.i64_ge_u)
            },
            SsaOp.wasm_i64_eqz => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i64_eqz)
            },
            else => {},
        }
    }

    // ========================================================================
    // emitI32Op — i32 arithmetic, bitwise, comparisons (wrap-operate-extend)
    // ========================================================================

    fn emitI32Op(v: *SsaValue) void {
        switch (v.op) {
            // i32 bitwise (wrap-operate-extend pattern from Zig gen.zig)
            SsaOp.wasm_i32_and => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_and)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_i32_or => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_or)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_i32_xor => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_xor)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_i32_shl => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_shl)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_i32_shr_s => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_shr_s)
                self.builder.append(As.i64_extend_i32_s)
            },
            SsaOp.wasm_i32_shr_u => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_shr_u)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_i32_rotl => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_rotl)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_i32_rotr => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_rotr)
                self.builder.append(As.i64_extend_i32_u)
            },

            // i32 arithmetic (wrap-operate-extend)
            SsaOp.wasm_i32_add => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_add)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_i32_sub => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_sub)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_i32_mul => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_mul)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_i32_div_s => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_div_s)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_i32_div_u => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_div_u)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_i32_rem_s => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_rem_s)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_i32_rem_u => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_rem_u)
                self.builder.append(As.i64_extend_i32_u)
            },

            // i32 bit counting (wrap-operate-extend)
            SsaOp.wasm_i32_clz => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_clz)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_i32_ctz => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_ctz)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_i32_popcnt => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_popcnt)
                self.builder.append(As.i64_extend_i32_u)
            },

            // i32 comparisons
            SsaOp.wasm_i32_eqz => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_eqz)
            },
            SsaOp.wasm_i32_eq => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_eq)
            },
            SsaOp.wasm_i32_ne => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_ne)
            },
            SsaOp.wasm_i32_lt_s => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_lt_s)
            },
            SsaOp.wasm_i32_lt_u => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_lt_u)
            },
            SsaOp.wasm_i32_gt_s => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_gt_s)
            },
            SsaOp.wasm_i32_gt_u => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_gt_u)
            },
            SsaOp.wasm_i32_le_s => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_le_s)
            },
            SsaOp.wasm_i32_le_u => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_le_u)
            },
            SsaOp.wasm_i32_ge_s => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_ge_s)
            },
            SsaOp.wasm_i32_ge_u => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.i32_ge_u)
            },
            else => {},
        }
    }

    // ========================================================================
    // emitFloatOp — f64 and f32 arithmetic, unary, comparisons
    // ========================================================================

    fn emitFloatOp(v: *SsaValue) void {
        switch (v.op) {
            // f64 arithmetic — float locals are f64, no reinterpret needed.
            // Zig gen.zig:609-667
            SsaOp.wasm_f64_add => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.f64_add)
            },
            SsaOp.wasm_f64_sub => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.f64_sub)
            },
            SsaOp.wasm_f64_mul => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.f64_mul)
            },
            SsaOp.wasm_f64_div => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.f64_div)
            },
            SsaOp.wasm_f64_neg => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.f64_neg)
            },
            SsaOp.wasm_f64_abs => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.f64_abs)
            },
            SsaOp.wasm_f64_ceil => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.f64_ceil)
            },
            SsaOp.wasm_f64_floor => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.f64_floor)
            },
            SsaOp.wasm_f64_trunc => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.f64_trunc)
            },
            SsaOp.wasm_f64_nearest => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.f64_nearest)
            },
            SsaOp.wasm_f64_sqrt => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.f64_sqrt)
            },
            SsaOp.wasm_f64_min => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.f64_min)
            },
            SsaOp.wasm_f64_max => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.f64_max)
            },
            SsaOp.wasm_f64_copysign => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.f64_copysign)
            },

            // f64 comparisons (produce i32) — inputs are f64, output is i32
            SsaOp.wasm_f64_eq => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.f64_eq)
            },
            SsaOp.wasm_f64_ne => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.f64_ne)
            },
            SsaOp.wasm_f64_lt => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.f64_lt)
            },
            SsaOp.wasm_f64_le => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.f64_le)
            },
            SsaOp.wasm_f64_gt => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.f64_gt)
            },
            SsaOp.wasm_f64_ge => {
                self.getValue64(v.args.get(0))
                self.getValue64(v.args.get(1))
                self.builder.append(As.f64_ge)
            },

            // f32 arithmetic — f32 locals stored in i64 locals, need reinterpret
            SsaOp.wasm_f32_add => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.f32_add)
                self.builder.append(As.i32_reinterpret_f32)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_f32_sub => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.f32_sub)
                self.builder.append(As.i32_reinterpret_f32)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_f32_mul => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.f32_mul)
                self.builder.append(As.i32_reinterpret_f32)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_f32_div => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.f32_div)
                self.builder.append(As.i32_reinterpret_f32)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_f32_neg => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.f32_neg)
                self.builder.append(As.i32_reinterpret_f32)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_f32_abs => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.f32_abs)
                self.builder.append(As.i32_reinterpret_f32)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_f32_ceil => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.f32_ceil)
                self.builder.append(As.i32_reinterpret_f32)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_f32_floor => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.f32_floor)
                self.builder.append(As.i32_reinterpret_f32)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_f32_trunc => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.f32_trunc)
                self.builder.append(As.i32_reinterpret_f32)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_f32_nearest => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.f32_nearest)
                self.builder.append(As.i32_reinterpret_f32)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_f32_sqrt => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.f32_sqrt)
                self.builder.append(As.i32_reinterpret_f32)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_f32_min => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.f32_min)
                self.builder.append(As.i32_reinterpret_f32)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_f32_max => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.f32_max)
                self.builder.append(As.i32_reinterpret_f32)
                self.builder.append(As.i64_extend_i32_u)
            },
            SsaOp.wasm_f32_copysign => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.f32_copysign)
                self.builder.append(As.i32_reinterpret_f32)
                self.builder.append(As.i64_extend_i32_u)
            },

            // f32 comparisons — inputs need reinterpret, output is i32
            SsaOp.wasm_f32_eq => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.f32_eq)
            },
            SsaOp.wasm_f32_ne => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.f32_ne)
            },
            SsaOp.wasm_f32_lt => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.f32_lt)
            },
            SsaOp.wasm_f32_gt => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.f32_gt)
            },
            SsaOp.wasm_f32_le => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.f32_le)
            },
            SsaOp.wasm_f32_ge => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.append(As.f32_reinterpret_i32)
                self.builder.append(As.f32_ge)
            },
            else => {},
        }
    }

    fn emitI64MemOp(v: *SsaValue) void {
        switch (v.op) {
            SsaOp.wasm_i64_load => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.appendFrom(As.i64_load, constAddr(v.aux_int))
            },
            SsaOp.wasm_i64_load8_s => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.appendFrom(As.i64_load8_s, constAddr(v.aux_int))
            },
            SsaOp.wasm_i64_load8_u => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.appendFrom(As.i64_load8_u, constAddr(v.aux_int))
            },
            SsaOp.wasm_i64_load16_s => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.appendFrom(As.i64_load16_s, constAddr(v.aux_int))
            },
            SsaOp.wasm_i64_load16_u => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.appendFrom(As.i64_load16_u, constAddr(v.aux_int))
            },
            SsaOp.wasm_i64_load32_s => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.appendFrom(As.i64_load32_s, constAddr(v.aux_int))
            },
            SsaOp.wasm_i64_load32_u => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.appendFrom(As.i64_load32_u, constAddr(v.aux_int))
            },
            SsaOp.wasm_i64_store => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.appendTo(As.i64_store, constAddr(v.aux_int))
            },
            SsaOp.wasm_i64_store8 => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.appendTo(As.i64_store8, constAddr(v.aux_int))
            },
            SsaOp.wasm_i64_store16 => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.appendTo(As.i64_store16, constAddr(v.aux_int))
            },
            SsaOp.wasm_i64_store32 => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.appendTo(As.i64_store32, constAddr(v.aux_int))
            },
            else => {},
        }
    }

    fn emitI32MemOp(v: *SsaValue) void {
        switch (v.op) {
            SsaOp.wasm_i32_load => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.builder.appendFrom(As.i32_load, constAddr(v.aux_int))
            },
            SsaOp.wasm_i32_store => {
                self.getValue64(v.args.get(0))
                self.builder.append(As.i32_wrap_i64)
                self.getValue64(v.args.get(1))
                self.builder.append(As.i32_wrap_i64)
                self.builder.appendTo(As.i32_store, constAddr(v.aux_int))
            },
            SsaOp.wasm_i32_load8_s => {
                self.getValue64(v.args.get(0))
