/// Wasm Driver — orchestrates the full Wasm compilation pipeline.
///
/// Zig reference: compiler/driver.zig generateWasmCode()
///
/// Pipeline: IR funcs/globals + TypeRegistry → Linker setup → runtime registration
///           → func_indices → SSA build → 6 passes → codegen → .wasm binary
///
/// Split into multiple functions to avoid stack overflow (Cot compiler limitation
/// with many locals in a single function).

import "std/list"
import "std/map"
import "std/string"
import "../../build/ir"
import "../../check/types"
import "../../build/ssa"
import "../../build/builder"
import "../../optimize/copyelim"
import "../../optimize/decompose"
import "../../optimize/cse"
import "../../optimize/deadcode"
import "../../optimize/schedule"
import "../../optimize/layout"
import "lower"
import "passes"
import "../../debug"

import "passes_dec"
import "link"
import "gen"
import "preprocess"
import "assemble"
import "mem"
import "slice"
import "print"
import "wasi"
import "test"
import "bench"

// ============================================================================
// Memory layout constants
// ============================================================================

const HEAP_START: int = 0x800000      // 8MB — after stack
const MEMORY_PAGES: int = 256         // 256 * 64KB = 16MB

// ============================================================================
// RuntimeIndices — holds all runtime function indices after registration
// ============================================================================

struct RuntimeIndices {
    mem: MemFunctions,
    slice_fns: SliceFunctions,
    print: PrintFunctions,
    wasi: WasiFunctions,
    test_fns: TestFunctions,
    bench_fns: BenchFunctions,
    heap_ptr_global: int,
    runtime_func_count: int,
}

// ============================================================================
// CompileOptions — configuration for Wasm compilation
// ============================================================================

struct CompileOptions {
    is_wasi: bool,
    test_mode: bool,
    bench_mode: bool,
    bench_n: int,
}

// ============================================================================
// Top-level entry point
// ============================================================================

/// Generate a complete Wasm binary from IR functions, globals, and type registry.
/// Returns the binary as List(int) (byte values).
fn generateWasmCode(ir: IR, types: *TypeRegistry, opts: CompileOptions) List(int) {
    debug_log(.codegen, "driver: generating Wasm for ${ir.funcs.count} functions")
    var linker = Linker.init()

    // Configure memory: 256 pages = 16MB
    linker.setMemory(MEMORY_PAGES, null)

    // Global 1: CTXT (closure context pointer)
    // Layout: SP(0), CTXT(1), heap_ptr(2)
    linker.addGlobal(WasmGlobal { val_type: VT_I64, mutable: true, init_val: 0 })

    // Global 2: heap_ptr (bump allocator, starts at 8MB)
    const heap_ptr_dynamic_idx = linker.addGlobal(WasmGlobal { val_type: VT_I32, mutable: true, init_val: HEAP_START })
    const heap_ptr_global = heap_ptr_dynamic_idx + 1 // Offset by SP (global 0)

    // Register all runtime functions
    const rt = addAllRuntimeFunctions(&linker, heap_ptr_global, opts)

    // Build function index map
    var func_indices: Map(string, int) = .{}
    populateRuntimeIndices(&func_indices, &rt)
    populateUserFuncIndicesFromIR(&func_indices, ir, rt.runtime_func_count)

    // Set minimum table size for call_indirect
    linker.setTableSize(1)

    // Build function table: all user functions get table entries
    var func_table_indices: Map(string, int) = .{}
    addUserTableEntries(&linker, ir, rt.runtime_func_count, &func_table_indices)

    // Collect string literals from all functions
    var string_offsets: Map(string, int) = .{}
    collectAllStringLiterals(&linker, &string_offsets, ir)

    // Null sentinel for metadata at offset 0
    var null_data: List(int) = .{}
    var j = 0
    while (j < 8) {
        null_data.append(0)
        j += 1
    }
    linker.addDataSegment(null_data)

    // Generate code for each function
    generateAllFunctions(&linker, ir, types, &func_indices, &string_offsets, &func_table_indices, rt.runtime_func_count)

    // Add _start wrapper for WASI compatibility (wasmtime expects _start, not main).
    // Zig reference: driver.zig lines 6381-6408
    addStartWrapper(&linker, &func_indices, ir, types)

    return linker.emit()
}

// ============================================================================
// Runtime registration (split to avoid stack overflow)
// ============================================================================

/// Register all runtime modules with the linker.
fn addAllRuntimeFunctions(linker: *Linker, heap_ptr_global: int, opts: CompileOptions) RuntimeIndices {
    // WASI host imports MUST be registered FIRST — Wasm requires imports at
    // indices 0..N-1, module functions at N onwards. addFunc() returns
    // imports.count + funcs.count, so imports must exist before any addFunc call.
    const ws = addWasiRuntime(linker, opts.is_wasi)
    const mem = addMemRuntime(linker, heap_ptr_global)
    const sl = addSliceRuntime(linker, heap_ptr_global)
    var wasi_write_override: int = -1
    if (opts.is_wasi) {
        wasi_write_override = ws.fd_write_simple_idx
    }
    const pr = addPrintRuntime(linker, wasi_write_override)
    const tf = addTestRuntime(linker, pr.write_idx, pr.eprint_int_idx, ws.time_idx)
    const bf = addBenchRuntime(linker, pr.write_idx, pr.eprint_int_idx, ws.time_idx, opts.bench_n)

    const runtime_func_count = linker.funcCount()

    return RuntimeIndices {
        mem: mem,
        slice_fns: sl,
        print: pr,
        wasi: ws,
        test_fns: tf,
        bench_fns: bf,
        heap_ptr_global: heap_ptr_global,
        runtime_func_count: runtime_func_count,
    }
}

// ============================================================================
// Function index map population (split into multiple functions)
// ============================================================================

/// Populate func_indices with all runtime function names → indices.
fn populateRuntimeIndices(func_indices: *Map(string, int), rt: *RuntimeIndices) void {
    populateMemIndices(func_indices, &rt.mem)
    populateSliceIndices(func_indices, &rt.slice_fns)
    populatePrintIndices(func_indices, &rt.print)
    populateWasiIndices(func_indices, &rt.wasi)
    populateTestIndices(func_indices, &rt.test_fns)
    populateBenchIndices(func_indices, &rt.bench_fns)
}

fn populateMemIndices(m: *Map(string, int), f: *MemFunctions) void {
    m.set(ALLOC_NAME, f.alloc_idx)
    m.set(DEALLOC_NAME, f.dealloc_idx)
    m.set(REALLOC_NAME, f.realloc_idx)
    m.set(MEMCPY_NAME, f.memcpy_idx)
    m.set(MEMSET_ZERO_NAME, f.memset_zero_idx)
    m.set(STRING_EQ_NAME, f.string_eq_idx)
    m.set(STRING_CONCAT_NAME, f.string_concat_idx)
    m.set(ALLOC_RAW_NAME, f.alloc_raw_idx)
    m.set(REALLOC_RAW_NAME, f.realloc_raw_idx)
    m.set(DEALLOC_RAW_NAME, f.dealloc_raw_idx)
    m.set(RETAIN_NAME, f.retain_idx)
    m.set(RELEASE_NAME, f.release_idx)
}

fn populateSliceIndices(m: *Map(string, int), f: *SliceFunctions) void {
    m.set(GROWSLICE_NAME, f.growslice_idx)
    m.set(NEXTSLICECAP_NAME, f.nextslicecap_idx)
}

