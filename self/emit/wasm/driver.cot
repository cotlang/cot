fn populateWasiIndices(m: *Map(string, int), f: *WasiFunctions) void {
    populateWasiIndicesCore(m, f)
    populateWasiIndicesNet(m, f)
    populateWasiIndicesEventLoop(m, f)
    populateWasiIndicesProcess(m, f)
    populateWasiIndicesDir(m, f)
}

