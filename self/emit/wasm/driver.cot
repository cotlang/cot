/// Add user function names to func_indices (offset by runtime count).
fn populateUserFuncIndicesFromIR(func_indices: *Map(string, int), ir: IR, runtime_func_count: int) void {
    var i = 0
    while (i < ir.funcs.count) {
        const f = ir.funcs.get(i)
        func_indices.set(f.name, i + runtime_func_count)
        i += 1
    }
}

// ============================================================================
// Function table entries
// ============================================================================

/// Add all user functions to the indirect call table, building table index map.
fn addUserTableEntries(linker: *Linker, ir: IR, runtime_func_count: int, func_table_indices: *Map(string, int)) void {
    var i = 0
    while (i < ir.funcs.count) {
        const func_idx = i + runtime_func_count
        const table_idx = linker.addTableFunc(func_idx)
        func_table_indices.set(ir.funcs.get(i).name, table_idx)
        i += 1
    }
}

// ============================================================================
// String literal collection
// ============================================================================

/// Collect all string literals from IR functions, dedup, add to linker data segments.
fn collectAllStringLiterals(linker: *Linker, string_offsets: *Map(string, int), ir: IR) void {
    var i = 0
    while (i < ir.funcs.count) {
        const f = ir.funcs.get(i)
        var j = 0
        while (j < f.string_literals.count) {
            const s = f.string_literals.get(j)
            if (!string_offsets.contains(s)) {
                const data = stringToData(s)
                const offset = linker.addDataSegment(data)
                string_offsets.set(s, offset)
            }
            j += 1
        }
        i += 1
    }
}

/// Convert a string to List(int) byte data for a data segment.
fn stringToData(s: string) List(int) {
    var data: List(int) = .{}
    const ptr = @ptrOf(s)
    const len = @lenOf(s)
    var i = 0
    while (i < len) {
        const b = @intCast(int, @intToPtr(*u8, ptr + i).*)
        data.append(b)
        i += 1
    }
    return data
}

// ============================================================================
// Per-function code generation
// ============================================================================

/// Generate code for all IR functions and add them to the linker.
fn generateAllFunctions(linker: *Linker, ir: IR, types: *TypeRegistry, func_indices: *Map(string, int), string_offsets: *Map(string, int), func_table_indices: *Map(string, int), runtime_func_count: int) void {
    var i = 0
    while (i < ir.funcs.count) {
        const ir_func = ir.funcs.get(i)
        generateAndAddFunc(linker, ir_func, ir, types, func_indices, string_offsets, func_table_indices)
        i += 1
    }
}

/// Build SSA, run passes, generate Wasm bytecode, and add function to linker.
fn generateAndAddFunc(linker: *Linker, ir_func: Func, ir: IR, types: *TypeRegistry, func_indices: *Map(string, int), string_offsets: *Map(string, int), func_table_indices: *Map(string, int)) void {
    // Build SSA from IR
    var builder = SSABuilder.init(ir_func, ir.globals, types)
    var ssa_func = builder.build()

    // Record the function's return type so gen can use it for compound returns
    ssa_func.type_idx = ir_func.return_type

    // Run Wasm-specific SSA passes (Go pass order)
    // Reference: Go compile.go — timed pass loop with per-pass µs reporting.
    // Zig reference: driver.zig lines 6158-6167
    var t = debug_timestamp()
    copyelim(ssa_func)
    debug_log_timed(.copyelim, "  pass copyelim", debug_timestamp() - t)

    t = debug_timestamp()
    passRewriteGeneric(ssa_func, string_offsets)
    debug_log_timed(.codegen, "  pass rewritegeneric", debug_timestamp() - t)

    t = debug_timestamp()
    decompose(ssa_func)
    debug_log_timed(.codegen, "  pass decompose", debug_timestamp() - t)

    t = debug_timestamp()
    passRewriteDec(ssa_func)
    debug_log_timed(.codegen, "  pass rewritedec", debug_timestamp() - t)

    t = debug_timestamp()
    copyelim(ssa_func)
    debug_log_timed(.copyelim, "  pass copyelim2", debug_timestamp() - t)

    t = debug_timestamp()
    cse(ssa_func)
    debug_log_timed(.codegen, "  pass cse", debug_timestamp() - t)

    t = debug_timestamp()
    deadcode(ssa_func)
    debug_log_timed(.deadcode, "  pass deadcode", debug_timestamp() - t)

    t = debug_timestamp()
    schedule(ssa_func)
    debug_log_timed(.schedule, "  pass schedule", debug_timestamp() - t)

    t = debug_timestamp()
    layout(ssa_func)
    debug_log_timed(.codegen, "  pass layout", debug_timestamp() - t)

    t = debug_timestamp()
    lower(ssa_func)
    debug_log_timed(.codegen, "  pass lower_wasm", debug_timestamp() - t)

    // Determine function type
    const type_idx = registerFuncType(linker, ir_func, types)

    // Generate Prog chain → preprocess (dispatch loop) → assemble (bytecode)
    var sym = generateFunc(ssa_func, func_indices, string_offsets, func_table_indices)
    preprocess(&sym)
    const body = assemble(&sym)

    // Free all per-function SSA data — mirrors Zig compiler's arena.deinit() pattern
    ssa_func.free()
    builder.free()

    println("  add...")
    // Add to linker
    linker.addFunc(WasmFunc.init(ir_func.name, type_idx, body, true))
}

/// Register a function's type signature with the linker.
/// Decomposes compound params (string/slice → 2xi64, large struct → Nxi64).
fn registerFuncType(linker: *Linker, ir_func: Func, types: *TypeRegistry) int {
    var params: List(int) = .{}
    buildFuncParams(&params, ir_func, types)

    var results: List(int) = .{}
    buildFuncResults(&results, ir_func, types)

    const idx = linker.addType(params, results)
    params.free()
    results.free()
    return idx
}

/// Build Wasm param types from IR function parameters.
/// Decompose compound types: string/slice → 2xi64, large struct → Nxi64.
fn buildFuncParams(params: *List(int), ir_func: Func, types: *TypeRegistry) void {
    var i = 0
    while (i < ir_func.params.count) {
        const param = ir_func.params.get(i)
        addParamType(params, param, types)
        i += 1
    }
}

/// Add Wasm param type(s) for a single IR parameter.
fn addParamType(params: *List(int), param: Local, types: *TypeRegistry) void {
    const param_type = types.get(param.type_idx)
    const is_string_or_slice = param.type_idx == STRING or param_type.tag == TAG_SLICE
    const type_size = types.sizeOf(param.type_idx)
    const is_compound_opt = param_type.tag == TAG_OPTIONAL and types.get(switch (param_type) { Type.optional |o| => o.elem, else => 0 }).tag != TAG_POINTER
    const is_large_struct = (param_type.tag == TAG_STRUCT or param_type.tag == TAG_UNION or param_type.tag == TAG_TUPLE or is_compound_opt) and type_size > 8

    const is_float = param.type_idx == F64 or param.type_idx == F32

    if (is_string_or_slice) {
        params.append(VT_I64)
        params.append(VT_I64)
    } else if (is_large_struct) {
        const num_slots = (type_size + 7) / 8
        var k = 0
        while (k < num_slots) {
            params.append(VT_I64)
            k += 1
        }
    } else if (is_float) {
        // Float params declared as f64 in Wasm type section — matches f64 locals
        // Zig driver.zig:6456-6458
        params.append(VT_F64)
    } else {
        params.append(VT_I64)
    }
}

/// Build Wasm result types from IR function return type.
fn buildFuncResults(results: *List(int), ir_func: Func, types: *TypeRegistry) void {
    if (ir_func.return_type == VOID) { return }

    const ret_type_info = types.get(ir_func.return_type)
    const ret_is_compound = ir_func.return_type == STRING or ret_type_info.tag == TAG_SLICE
    const ret_is_float = ir_func.return_type == F64 or ir_func.return_type == F32

    if (ret_is_compound) {
        results.append(VT_I64)
        results.append(VT_I64)
    } else if (ret_is_float) {
        // Float returns declared as f64 — matches f64 locals in body
        // Zig driver.zig:6480-6481
        results.append(VT_F64)
    } else {
        results.append(VT_I64)
    }
}

// ============================================================================
// _start wrapper — WASI compatibility
// Zig reference: driver.zig lines 6381-6408
// ============================================================================

/// Add _start function that calls main and drops its return value (if any).
/// WASI requires _start as the entry point; wasmtime won't run main directly.
fn addStartWrapper(linker: *Linker, func_indices: *Map(string, int), ir: IR, types: *TypeRegistry) void {
    // Find main function — may be qualified as "module.main"
    var main_name: string = ""
    var main_returns_value = false
    var i = 0
    while (i < ir.funcs.count) {
        const f = ir.funcs.get(i)
        if (f.name == "main" or endsWith(f.name, ".main")) {
            main_name = f.name
            if (f.return_type != VOID) {
                main_returns_value = true
            }
        }
        i += 1
    }
    if (main_name == "") { return }
    const main_idx = func_indices.get(main_name)

    // _start: () -> void
    var params: List(int) = .{}
    var results: List(int) = .{}
    const start_type = linker.addType(params, results)

    // Build body manually: [0x00 (no locals), call opcode, ULEB128(main_idx), maybe drop, end]
    var body: List(int) = .{}
    body.append(0x00) // 0 local declarations
    body.append(0x10) // call opcode
    // Encode main_idx as unsigned LEB128
    var idx = main_idx
    while (idx >= 128) {
        body.append((idx & 0x7F) | 0x80)
        idx = idx >> 7
    }
    body.append(idx & 0x7F)
    if (main_returns_value) {
        body.append(0x1A) // drop opcode
    }
    body.append(0x0B) // end opcode

    linker.addFunc(WasmFunc.init("_start", start_type, body, true))
}

// ============================================================================
// Tests
// ============================================================================

test "stringToData converts string bytes" {
    const data = stringToData("ABC")
    @assertEq(data.count, 3)
    @assertEq(data.get(0), 65)
    @assertEq(data.get(1), 66)
    @assertEq(data.get(2), 67)
}

test "stringToData empty string" {
    const data = stringToData("")
    @assertEq(data.count, 0)
}

test "buildFuncResults void returns nothing" {
    var types = TypeRegistry.init()
    var results: List(int) = .{}
    const f = makeDriverTestFunc("void_fn", VOID)
    buildFuncResults(&results, f, &types)
    @assertEq(results.count, 0)
}

test "buildFuncResults int returns i64" {
    var types = TypeRegistry.init()
    var results: List(int) = .{}
    const f = makeDriverTestFunc("int_fn", INT)
    buildFuncResults(&results, f, &types)
    @assertEq(results.count, 1)
    @assertEq(results.get(0), VT_I64)
}

test "buildFuncResults float returns f64" {
    var types = TypeRegistry.init()
    var results: List(int) = .{}
    const f = makeDriverTestFunc("float_fn", F64)
    buildFuncResults(&results, f, &types)
    @assertEq(results.count, 1)
    @assertEq(results.get(0), VT_F64)
}

test "buildFuncParams empty params" {
    var types = TypeRegistry.init()
    var params: List(int) = .{}
    const f = makeDriverTestFunc("empty_fn", VOID)
    buildFuncParams(&params, f, &types)
    @assertEq(params.count, 0)
}

test "buildFuncParams int param produces i64" {
    var types = TypeRegistry.init()
    var params: List(int) = .{}
    var f = makeDriverTestFunc("int_fn", VOID)
    f.params.append(Local.initParam("x", INT, 0, 8))
    buildFuncParams(&params, f, &types)
    @assertEq(params.count, 1)
    @assertEq(params.get(0), VT_I64)
}

test "buildFuncParams string param produces 2xi64" {
    var types = TypeRegistry.init()
    var params: List(int) = .{}
    var f = makeDriverTestFunc("str_fn", VOID)
    f.params.append(Local.initParam("s", STRING, 0, 16))
    buildFuncParams(&params, f, &types)
    @assertEq(params.count, 2)
    @assertEq(params.get(0), VT_I64)
    @assertEq(params.get(1), VT_I64)
}

test "CompileOptions default" {
    const opts = CompileOptions {
        is_wasi: true,
        test_mode: false,
        bench_mode: false,
        bench_n: -1,
    }
    @assertEq(opts.is_wasi, true)
    @assertEq(opts.bench_n, -1)
}

test "populateMemIndices sets function names" {
    var m: Map(string, int) = .{}
    var f = MemFunctions {
        alloc_idx: 0,
        dealloc_idx: 1,
        realloc_idx: 2,
        memcpy_idx: 3,
        memset_zero_idx: 4,
        string_eq_idx: 5,
        string_concat_idx: 6,
        alloc_raw_idx: 7,
        realloc_raw_idx: 8,
        dealloc_raw_idx: 9,
        retain_idx: 10,
        release_idx: 11,
        destructor_type: 0,
    }
    populateMemIndices(&m, &f)
    @assert(m.contains("alloc"))
    @assert(m.contains("dealloc"))
    @assert(m.contains("realloc"))
    @assert(m.contains("memcpy"))
    @assert(m.contains("memset_zero"))
    @assert(m.contains("string_eq"))
    @assert(m.contains("string_concat"))
    @assert(m.contains("alloc_raw"))
    @assert(m.contains("realloc_raw"))
    @assert(m.contains("dealloc_raw"))
    @assert(m.contains("retain"))
    @assert(m.contains("release"))
    @assertEq(m.get("alloc"), 0)
    @assertEq(m.get("string_concat"), 6)
    @assertEq(m.get("retain"), 10)
    @assertEq(m.get("release"), 11)
}

/// Helper: create a minimal Func for testing.
fn makeDriverTestFunc(name: string, return_type: int) Func {
    var fp: List(Local) = .{}
    var fl: List(Local) = .{}
    var fblocks: List(Block) = .{}
    var fn_nodes: List(Node) = .{}
    var fs: List(string) = .{}
    const sp = Span { start: 0, end: 0 }
    return Func {
        name: name,
        type_idx: 0,
        return_type: return_type,
        params: fp,
        locals: fl,
        blocks: fblocks,
        entry: 0,
        nodes: fn_nodes,
        span: sp,
        frame_size: 0,
        string_literals: fs,
        is_destructor: false,
        is_export: false,
    }
}
