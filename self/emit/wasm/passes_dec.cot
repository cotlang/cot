/// SSA Pass Wrapper — rewritedec pass with unique name.
///
/// Separated because rewritegeneric and rewritedec both export `rewrite`.

import "../../build/ssa"
import "../../optimize/rewritedec"

/// Run the decomposition rewrite pass (string/slice decomposition).
fn passRewriteDec(func: *SsaFunc) void {
    rewrite(func)
}
