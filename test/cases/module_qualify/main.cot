import "module_a"
import "module_b"
import "module_c"

test "module-qualified function names prevent collision" {
    @assertEq(getA(), 100)
    @assertEq(getB(), 200)
}

test "cross-module new calls correct destructor" {
    {
        var t = new Tracker { value: 42 }
    }
    @assertEq(getDeinitMarker(), 42)
}

test "cross-module method calls resolve correctly" {
    var c = Counter { .value = 10 }
    c.increment()
    c.increment()
    @assertEq(c.get(), 12)
}

test "transitive import method calls resolve correctly" {
    var w = makeWrapper(5)
    w.counter.increment()
    w.counter.increment()
    w.counter.increment()
    @assertEq(w.counter.get(), 8)
}
