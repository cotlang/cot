test "comparison eq" {
    @assert(42 == 42)
}

test "comparison ne" {
    @assert(42 != 43)
}

test "comparison lt" {
    @assert(5 < 10)
}

test "comparison gt" {
    @assert(10 > 5)
}

test "comparison le" {
    @assert(10 <= 10)
}

test "comparison ge" {
    @assert(10 >= 10)
}

test "if true" {
    var result: i64 = 0
    if (1 == 1) {
        result = 1
    }
    @assertEq(result, 1)
}

test "if false" {
    var result: i64 = 0
    if (1 == 2) {
        result = 1
    }
    @assertEq(result, 0)
}

test "if else" {
    var result: i64 = 0
    if (5 > 10) {
        result = 10
    } else {
        result = 20
    }
    @assertEq(result, 20)
}

test "nested if" {
    var x: i64 = 15
    var result: i64 = 0
    if (x > 10) {
        if (x > 20) {
            result = 1
        } else {
            if (x > 14) {
                result = 3
            } else {
                result = 2
            }
        }
    }
    @assertEq(result, 3)
}

test "while simple" {
    var i: i64 = 0
    while (i < 10) {
        i += 1
    }
    @assertEq(i, 10)
}

test "while break" {
    var i: i64 = 0
    while (i < 100) {
        if (i == 5) {
            break
        }
        i += 1
    }
    @assertEq(i, 5)
}

test "while continue" {
    var sum: i64 = 0
    var i: i64 = 0
    while (i < 10) {
        i += 1
        if (i % 2 != 0) {
            continue
        }
        sum += i
    }
    @assertEq(sum, 30)
}

test "nested while" {
    var count: i64 = 0
    var i: i64 = 0
    while (i < 3) {
        var j: i64 = 0
        while (j < 2) {
            count += 1
            j += 1
        }
        i += 1
    }
    @assertEq(count, 6)
}

// --- Labeled block expressions ---

test "labeled block basic" {
    const x = blk: {
        break :blk 42
    }
    @assertEq(x, 42)
}

test "labeled block with conditional" {
    const cond = true
    const x = blk: {
        if (cond) {
            break :blk 10
        }
        break :blk 20
    }
    @assertEq(x, 10)
}

test "labeled block false branch" {
    const cond = false
    const x = blk: {
        if (cond) {
            break :blk 10
        }
        break :blk 20
    }
    @assertEq(x, 20)
}

test "labeled block nested" {
    const x = outer: {
        const y = inner: {
            break :inner 5
        }
        break :outer y * 2
    }
    @assertEq(x, 10)
}

test "labeled block in binary expr" {
    const y = 5 + blk: {
        break :blk 3
    }
    @assertEq(y, 8)
}

test "labeled block multi-branch" {
    const n = 3
    const result = blk: {
        if (n == 1) { break :blk 100 }
        if (n == 2) { break :blk 200 }
        if (n == 3) { break :blk 300 }
        break :blk 0
    }
    @assertEq(result, 300)
}

test "labeled block with var" {
    var x: int = 0
    const result = blk: {
        x = 42
        break :blk x
    }
    @assertEq(result, 42)
}
