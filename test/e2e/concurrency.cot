// Concurrency tests — Swift-style async/await (Phase 1: eager evaluation)

test "basic async await returns value" {
    async fn getValue() int {
        return 42
    }

    let result = await getValue()
    @assertEq(result, 42)
}

test "async fn with parameters" {
    async fn add(a: int, b: int) int {
        return a + b
    }

    let result = await add(10, 20)
    @assertEq(result, 30)
}

test "async fn with computation" {
    async fn factorial(n: int) int {
        var result = 1
        var i = 1
        while (i <= n) {
            result = result * i
            i = i + 1
        }
        return result
    }

    @assertEq(await factorial(5), 120)
}

test "actor with methods requires await" {
    actor Counter {
        count: int,

        fn increment() void {
            self.count = self.count + 1
        }

        fn getCount() int {
            return self.count
        }
    }

    var c = Counter { .count = 0 }
    await c.increment()
    await c.increment()
    await c.increment()
    @assertEq(await c.getCount(), 3)
}

test "nonisolated actor method callable without await" {
    actor Greeter {
        nonisolated fn hello() string {
            return "hello"
        }

        fn getName() string {
            return self.name
        }

        name: string,
    }

    var g = Greeter { .name = "world" }
    let greeting = g.hello()
    @assertEq(greeting, "hello")
    let name = await g.getName()
    @assertEq(name, "world")
}

test "task cancellation flag" {
    async fn longTask() int {
        // Phase 1: runs immediately, cancellation checked cooperatively
        return 42
    }

    let result = await longTask()
    @assertEq(result, 42)
    // Phase 2+ will test: task.cancel() sets flag, Task.isCancelled reads it
}

test "multiple awaits in sequence" {
    async fn getX() int { return 10 }
    async fn getY() int { return 20 }

    async fn combined() int {
        let x = await getX()
        let y = await getY()
        return x + y
    }

    @assertEq(await combined(), 30)
}
