// Concurrency tests — Swift-style async/await (Phase 1: eager evaluation)

test "basic async await returns value" {
    async fn getValue() int {
        return 42
    }

    let result = await getValue()
    @assertEq(result, 42)
}

test "async fn with parameters" {
    async fn add(a: int, b: int) int {
        return a + b
    }

    let result = await add(10, 20)
    @assertEq(result, 30)
}

test "async fn with computation" {
    async fn factorial(n: int) int {
        var result = 1
        var i = 1
        while (i <= n) {
            result = result * i
            i = i + 1
        }
        return result
    }

    @assertEq(await factorial(5), 120)
}

test "actor with methods requires await" {
    actor Counter {
        count: int,

        fn increment() void {
            self.count = self.count + 1
        }

        fn getCount() int {
            return self.count
        }
    }

    var c = Counter { .count = 0 }
    await c.increment()
    await c.increment()
    await c.increment()
    @assertEq(await c.getCount(), 3)
}

test "nonisolated actor method callable without await" {
    actor Greeter {
        nonisolated fn hello() string {
            return "hello"
        }

        fn getName() string {
            return self.name
        }

        name: string,
    }

    var g = Greeter { .name = "world" }
    let greeting = g.hello()
    @assertEq(greeting, "hello")
    let name = await g.getName()
    @assertEq(name, "world")
}

test "global actor MainActor isolation" {
    @MainActor fn updateUI() int {
        return 42
    }

    @MainActor fn helperUI() int {
        // Same global actor — no await needed
        return updateUI()
    }

    // From outside @MainActor, await is required
    let result = await updateUI()
    @assertEq(result, 42)
}

test "task cancellation flag" {
    async fn longTask() int {
        // Phase 1: runs immediately, cancellation checked cooperatively
        return 42
    }

    let result = await longTask()
    @assertEq(result, 42)
    // Phase 2+ will test: task.cancel() sets flag, Task.isCancelled reads it
}

test "async fn returning string" {
    async fn greet(name: string) string {
        return "hello " ++ name
    }

    let msg = await greet("world")
    @assertEq(msg, "hello world")
}

test "nested async calls" {
    async fn double(x: int) int { return x * 2 }
    async fn quadruple(x: int) int {
        let d = await double(x)
        return await double(d)
    }

    @assertEq(await quadruple(5), 20)
}

test "actor field access requires await" {
    actor Timer {
        elapsed: int,

        fn tick() void {
            self.elapsed = self.elapsed + 1
        }

        fn getElapsed() int {
            return self.elapsed
        }

        nonisolated fn name() string {
            return "Timer"
        }
    }

    var t = Timer { .elapsed = 0 }
    await t.tick()
    await t.tick()
    await t.tick()
    @assertEq(await t.getElapsed(), 3)
    @assertEq(t.name(), "Timer")
}

test "multiple awaits in sequence" {
    async fn getX() int { return 10 }
    async fn getY() int { return 20 }

    async fn combined() int {
        let x = await getX()
        let y = await getY()
        return x + y
    }

    @assertEq(await combined(), 30)
}

test "async fn returning zero" {
    async fn zero() int {
        return 0
    }

    @assertEq(await zero(), 0)
}

test "actor with multiple fields" {
    actor BankAccount {
        balance: int,
        name: string,

        fn deposit(amount: int) void {
            self.balance = self.balance + amount
        }

        fn withdraw(amount: int) void {
            if (self.balance >= amount) {
                self.balance = self.balance - amount
            }
        }

        fn getBalance() int {
            return self.balance
        }

        nonisolated fn accountType() string {
            return "checking"
        }
    }

    var acct = BankAccount { .balance = 100, .name = "savings" }
    await acct.deposit(50)
    await acct.withdraw(30)
    @assertEq(await acct.getBalance(), 120)
    @assertEq(acct.accountType(), "checking")
}

test "async fn chain of three" {
    async fn a() int { return 1 }
    async fn b() int { return await a() + 2 }
    async fn c() int { return await b() + 3 }

    @assertEq(await c(), 6)
}

test "async fn with loop" {
    async fn sumTo(n: int) int {
        var total = 0
        var i = 1
        while (i <= n) {
            total = total + i
            i = i + 1
        }
        return total
    }

    @assertEq(await sumTo(10), 55)
}

// === @Sendable closure tests (SE-0302) ===

test "sendable closure with Sendable capture" {
    const x = 42
    const f = @Sendable fn() i64 { return x }
    @assertEq(f(), 42)
}

test "sendable closure no captures" {
    const f = @Sendable fn(a: i64) i64 { return a * 2 }
    @assertEq(f(5), 10)
}

test "sendable closure captures multiple Sendable values" {
    const a = 10
    const b = 20
    const f = @Sendable fn() i64 { return a + b }
    @assertEq(f(), 30)
}
