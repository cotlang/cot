// TaskGroup tests — Swift structured concurrency (SE-0304)
import "std/task_group"

test "task group addTask and next" {
    var group = TaskGroup(int).init()
    group.addTask(10)
    group.addTask(20)
    group.addTask(30)

    let a = group.next()
    @assert(a != null)
    @assertEq(a.?, 10)

    let b = group.next()
    @assert(b != null)
    @assertEq(b.?, 20)

    let c = group.next()
    @assert(c != null)
    @assertEq(c.?, 30)

    let d = group.next()
    @assert(d == null)
}
