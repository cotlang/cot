// TaskGroup tests — Swift structured concurrency (SE-0304)
import "std/task_group"

test "task group addTask and next" {
    var group = TaskGroup(int).init()
    group.addTask(10)
    group.addTask(20)
    group.addTask(30)

    let a = group.next()
    @assert(a != null)
    @assertEq(a.?, 10)

    let b = group.next()
    @assert(b != null)
    @assertEq(b.?, 20)

    let c = group.next()
    @assert(c != null)
    @assertEq(c.?, 30)

    let d = group.next()
    @assert(d == null)
}

test "task group for-await iteration" {
    var group = TaskGroup(int).init()
    group.addTask(1)
    group.addTask(2)
    group.addTask(3)
    group.addTask(4)
    group.addTask(5)

    var sum = 0
    for await val in group {
        sum = sum + val
    }
    @assertEq(sum, 15)
}

test "empty task group next returns null" {
    var group = TaskGroup(int).init()
    let result = group.next()
    @assert(result == null)
}

test "task group single element" {
    var group = TaskGroup(int).init()
    group.addTask(42)

    let val = group.next()
    @assert(val != null)
    @assertEq(val.?, 42)

    let done = group.next()
    @assert(done == null)
}

test "for-await over empty group does nothing" {
    var group = TaskGroup(int).init()
    var count = 0
    for await val in group {
        count = count + 1
    }
    @assertEq(count, 0)
}
