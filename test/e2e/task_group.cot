// TaskGroup tests — Swift structured concurrency (SE-0304)
import "std/task_group"
import "std/sys"

test "task group addTask with closure and next" {
    var group = TaskGroup(int).init()
    group.addTask(fn() int { return 10 })
    group.addTask(fn() int { return 20 })
    group.addTask(fn() int { return 30 })

    let a = group.next()
    @assert(a != null)
    @assertEq(a.?, 10)

    let b = group.next()
    @assert(b != null)
    @assertEq(b.?, 20)

    let c = group.next()
    @assert(c != null)
    @assertEq(c.?, 30)

    let d = group.next()
    @assert(d == null)
}

test "task group addValue convenience" {
    var group = TaskGroup(int).init()
    group.addValue(10)
    group.addValue(20)
    group.addValue(30)

    let a = group.next()
    @assert(a != null)
    @assertEq(a.?, 10)

    let b = group.next()
    @assert(b != null)
    @assertEq(b.?, 20)

    let c = group.next()
    @assert(c != null)
    @assertEq(c.?, 30)

    let d = group.next()
    @assert(d == null)
}

test "task group for-await iteration" {
    var group = TaskGroup(int).init()
    group.addTask(fn() int { return 1 })
    group.addTask(fn() int { return 2 })
    group.addTask(fn() int { return 3 })
    group.addTask(fn() int { return 4 })
    group.addTask(fn() int { return 5 })

    var sum = 0
    for await val in group {
        sum = sum + val
    }
    @assertEq(sum, 15)
}

test "empty task group next returns null" {
    var group = TaskGroup(int).init()
    let result = group.next()
    @assert(result == null)
}

test "task group single element" {
    var group = TaskGroup(int).init()
    group.addTask(fn() int { return 42 })

    let val = group.next()
    @assert(val != null)
    @assertEq(val.?, 42)

    let done = group.next()
    @assert(done == null)
}

test "for-await over empty group does nothing" {
    var group = TaskGroup(int).init()
    var count = 0
    for await val in group {
        count = count + 1
    }
    @assertEq(count, 0)
}

test "task group closure captures" {
    var base = 100
    var group = TaskGroup(int).init()
    group.addTask(fn() int { return base + 1 })
    group.addTask(fn() int { return base + 2 })
    group.addTask(fn() int { return base + 3 })

    var sum = 0
    for await val in group {
        sum = sum + val
    }
    @assertEq(sum, 306)
}

test "task group cancelAll" {
    var group = TaskGroup(int).init()
    group.addTask(fn() int { return 1 })
    group.addTask(fn() int { return 2 })
    group.addTask(fn() int { return 3 })

    // Cancel all before consuming
    group.cancelAll()
    // Results still available (Phase 1: tasks already completed eagerly)
    // but task objects have cancelled flag set
    @assertEq(task_is_cancelled(group.tasks.get(0)), 1)
    @assertEq(task_is_cancelled(group.tasks.get(1)), 1)
    @assertEq(task_is_cancelled(group.tasks.get(2)), 1)
}

// --- M1.9: addTaskUnlessCancelled ---

test "task group addTaskUnlessCancelled" {
    var group = TaskGroup(int).init()
    var added = group.addTaskUnlessCancelled(fn() int { return 42 })
    @assert(added)
    var val = group.next()
    @assertEq(val.?, 42)
}

test "task group addTaskUnlessCancelled after cancel" {
    var group = TaskGroup(int).init()
    group.addTask(fn() int { return 1 })
    group.cancelAll()
    var added = group.addTaskUnlessCancelled(fn() int { return 99 })
    @assert(!added)
}
