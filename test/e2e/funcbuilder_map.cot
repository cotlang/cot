import "std/list"
import "std/map"

struct Local {
    name: string,
    type_idx: int,
    mutable: bool,
    is_param: bool,
    param_idx: int,
    size: int,
    alignment: int,
    offset: int,
}

struct ShadowEntry {
    name: string,
    old_idx: ?int,
}

struct Span { start: int, end: int }

struct Node { data: int }

struct Block { idx: int }

struct FuncBuilder {
    name: string,
    type_idx: int,
    return_type: int,
    span: Span,
    locals: List(Local),
    blocks: List(Block),
    nodes: List(Node),
    string_literals: List(string),
    current_block: int,
    local_map: Map(string, int),
    shadow_stack: List(ShadowEntry),
    sret_return_type: ?int,
    is_destructor: bool,
    is_export: bool,
}

impl FuncBuilder {
    static fn initHeap(n: string) *FuncBuilder {
        var blocks: List(Block) = .{}
        var b0 = Block { .idx = 0 }
        blocks.append(b0)
        var sp = Span { .start = 0, .end = 0 }
        return new FuncBuilder {
            name: n, type_idx: 0, return_type: 0,
            span: sp,
            locals: .{}, blocks: blocks, nodes: .{},
            string_literals: .{}, current_block: 0,
            local_map: .{}, shadow_stack: .{},
            sret_return_type: null, is_destructor: false, is_export: false,
        }
    }

    fn addParam(self: *FuncBuilder, param_name: string, t: int, idx: int, sz: int) int {
        const i = self.locals.len()
        var loc = Local {
            .name = param_name, .type_idx = t, .mutable = false,
            .is_param = true, .param_idx = idx, .size = sz,
            .alignment = 8, .offset = 0,
        }
        self.locals.append(loc)
        self.local_map.set(param_name, i)
        return i
    }

    fn addLocalWithSize(self: *FuncBuilder, param_name: string, t: int, mutable: bool, sz: int) int {
        const i = self.locals.len()
        var loc = Local {
            .name = param_name, .type_idx = t, .mutable = mutable,
            .is_param = false, .param_idx = 0, .size = sz,
            .alignment = 8, .offset = 0,
        }
        self.locals.append(loc)
        var se = ShadowEntry { .name = param_name, .old_idx = self.local_map.getOrNull(param_name) }
        self.shadow_stack.append(se)
        self.local_map.set(param_name, i)
        return i
    }

    fn lookupLocal(self: *FuncBuilder, param_name: string) ?int {
        return self.local_map.getOrNull(param_name)
    }
}

test "exact selfcot FuncBuilder types" {
    var fb = FuncBuilder.initHeap("test")
    fb.addParam("self", 5, 0, 8)
    fb.addLocalWithSize("a", 3, false, 8)
    const r = fb.lookupLocal("a")
    if (r) |v| { @assertEq(v, 1) }
    else { @assert(false) }
}
