// Channel tests — Go-style buffered channel with backpressure
import "std/channel"

test "channel send and recv" {
    var ch = Channel(int).init(10)
    @assert(ch.send(42))
    @assert(ch.send(100))
    @assert(ch.send(7))

    let a = ch.recv()
    @assert(a != null)
    @assertEq(a.?, 42)

    let b = ch.recv()
    @assert(b != null)
    @assertEq(b.?, 100)

    let c = ch.recv()
    @assert(c != null)
    @assertEq(c.?, 7)

    let d = ch.recv()
    @assert(d == null)
}

test "channel for-await iteration" {
    var ch = Channel(int).init(10)
    @assert(ch.send(10))
    @assert(ch.send(20))
    @assert(ch.send(30))
    ch.close()

    var sum = 0
    for await val in ch {
        sum = sum + val
    }
    @assertEq(sum, 60)
}

test "channel close prevents send" {
    var ch = Channel(int).init(10)
    @assert(ch.send(1))
    ch.close()
    @assert(!ch.send(2))

    let a = ch.recv()
    @assert(a != null)
    @assertEq(a.?, 1)

    let b = ch.recv()
    @assert(b == null)
}

test "channel recv from empty returns null" {
    var ch = Channel(int).init(10)
    let result = ch.recv()
    @assert(result == null)
}

test "channel multiple send recv cycles" {
    var ch = Channel(int).init(5)
    @assert(ch.send(1))
    @assertEq(ch.recv().?, 1)
    @assert(ch.send(2))
    @assert(ch.send(3))
    @assertEq(ch.recv().?, 2)
    @assertEq(ch.recv().?, 3)
    @assert(ch.recv() == null)
}

test "channel capacity enforcement" {
    var ch = Channel(int).init(2)
    @assert(ch.send(1))
    @assert(ch.send(2))
    // Buffer full (capacity 2, 2 items buffered)
    @assert(!ch.send(3))
    // Consume one — now space available
    @assertEq(ch.recv().?, 1)
    @assert(ch.send(3))
    @assertEq(ch.recv().?, 2)
    @assertEq(ch.recv().?, 3)
}

test "channel len" {
    var ch = Channel(int).init(10)
    @assertEq(ch.len(), 0)
    @assert(ch.send(1))
    @assertEq(ch.len(), 1)
    @assert(ch.send(2))
    @assertEq(ch.len(), 2)
    ch.recv()
    @assertEq(ch.len(), 1)
}
