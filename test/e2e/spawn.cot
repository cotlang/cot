// Spawn E2E tests — work-stealing scheduler
import "std/sys"

// ============================================================================
// Basic spawn
// ============================================================================

var flag: i64 = 0

test "spawn basic" {
    flag = 0
    spawn {
        @atomicStore(&flag, 42)
    }
    while (@atomicLoad(&flag) == 0) {}
    @assertEq(@atomicLoad(&flag), 42)
}

// ============================================================================
// Spawn with capture
// ============================================================================

var result: i64 = 0

test "spawn with capture" {
    result = 0
    var expected: i64 = 99
    spawn {
        @atomicStore(&result, expected)
    }
    while (@atomicLoad(&result) == 0) {}
    @assertEq(@atomicLoad(&result), 99)
}

// ============================================================================
// Spawn parallel — multiple tasks
// ============================================================================

var par_count: i64 = 0

test "spawn parallel" {
    par_count = 0
    var i: i64 = 0
    while (i < 100) {
        spawn {
            @atomicAdd(&par_count, 1)
        }
        i = i + 1
    }
    while (@atomicLoad(&par_count) < 100) {}
    @assertEq(@atomicLoad(&par_count), 100)
}

// ============================================================================
// Spawn with multiple captures
// ============================================================================

var multi_result: i64 = 0

test "spawn multiple captures" {
    multi_result = 0
    var a: i64 = 10
    var b: i64 = 20
    var c: i64 = 3
    spawn {
        @atomicStore(&multi_result, a + b + c)
    }
    while (@atomicLoad(&multi_result) == 0) {}
    @assertEq(@atomicLoad(&multi_result), 33)
}

// ============================================================================
// Spawn no captures
// ============================================================================

var no_cap: i64 = 0

test "spawn no captures" {
    no_cap = 0
    spawn {
        @atomicStore(&no_cap, 1)
    }
    while (@atomicLoad(&no_cap) == 0) {}
    @assertEq(@atomicLoad(&no_cap), 1)
}
