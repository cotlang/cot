// Select E2E tests — Go-style channel select
import "std/channel"
import "std/sys"

// ============================================================================
// Select with recv + default (non-blocking)
// ============================================================================

test "select recv with default empty" {
    var ch = Channel(i64).init(1)
    // Channel is empty, should take default path
    var took_default: i64 = 0
    select {
        val from ch => {
            @assertEq(val, 0) // should not reach here
        }
        default => {
            took_default = 1
        }
    }
    @assertEq(took_default, 1)
    ch.destroy()
}

test "select recv with default ready" {
    var ch = Channel(i64).init(1)
    ch.send(42)
    // Channel has data, should take recv path
    var received: i64 = 0
    select {
        val from ch => {
            received = val
        }
        default => {
            received = -1
        }
    }
    @assertEq(received, 42)
    ch.destroy()
}

// ============================================================================
// Select with send + default (non-blocking)
// ============================================================================

test "select send with default full" {
    var ch = Channel(i64).init(1)
    ch.send(10) // fill the channel
    // Channel is full, trySend should fail → take default
    var took_default: i64 = 0
    select {
        ch.trySend(99) => {
            took_default = 0
        }
        default => {
            took_default = 1
        }
    }
    @assertEq(took_default, 1)
    // Original value still there
    @assertEq(ch.recv(), 10)
    ch.destroy()
}

test "select send with default has space" {
    var ch = Channel(i64).init(2)
    // Channel has space, trySend should succeed
    var sent: i64 = 0
    select {
        ch.trySend(77) => {
            sent = 1
        }
        default => {
            sent = 0
        }
    }
    @assertEq(sent, 1)
    @assertEq(ch.recv(), 77)
    ch.destroy()
}

// ============================================================================
// Channel tryRecv/trySend methods
// ============================================================================

test "tryRecv empty returns null" {
    var ch = Channel(i64).init(1)
    var result = ch.tryRecv()
    @assert(result == null)
    ch.destroy()
}

test "tryRecv with data returns value" {
    var ch = Channel(i64).init(1)
    ch.send(55)
    var result = ch.tryRecv()
    if (result) |val| {
        @assertEq(val, 55)
    } else {
        @assert(false) // should not reach here
    }
    ch.destroy()
}

test "trySend full returns false" {
    var ch = Channel(i64).init(1)
    ch.send(10)
    @assert(!ch.trySend(20))
    @assertEq(ch.recv(), 10)
    ch.destroy()
}

test "trySend with space returns true" {
    var ch = Channel(i64).init(2)
    @assert(ch.trySend(30))
    @assert(ch.trySend(40))
    @assertEq(ch.recv(), 30)
    @assertEq(ch.recv(), 40)
    ch.destroy()
}

test "channel len" {
    var ch = Channel(i64).init(3)
    @assertEq(ch.len(), 0)
    ch.send(1)
    @assertEq(ch.len(), 1)
    ch.send(2)
    @assertEq(ch.len(), 2)
    var discard = ch.recv()
    @assertEq(ch.len(), 1)
    ch.destroy()
}
