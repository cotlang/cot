// Executor tests — Swift CooperativeExecutor faithful port.
// Tests the cooperative event loop: priority queue, timer queue, run loop.
// M4: Executor protocol conformance (SerialExecutor, SchedulingExecutor).

import "std/executor"
import "std/executor_traits"
import "std/duration"
import "std/instant"
import "std/sys"

test "executor init and empty run" {
    var exec = CooperativeExecutor_init()
    CooperativeExecutor_run(&exec)
    @assert(!exec.should_stop)
}

test "executor enqueue and run" {
    var exec = CooperativeExecutor_init()
    CooperativeExecutor_enqueueDefault(&exec, 0, 0)
    CooperativeExecutor_enqueueDefault(&exec, 0, 0)
    CooperativeExecutor_enqueueDefault(&exec, 0, 0)
    @assertEq(exec.run_queue.len(), 3)
    CooperativeExecutor_run(&exec)
    @assertEq(exec.run_queue.len(), 0)
}

test "executor priority ordering" {
    var exec = CooperativeExecutor_init()
    CooperativeExecutor_enqueue(&exec, 0, 40, PRIORITY_BACKGROUND)
    CooperativeExecutor_enqueue(&exec, 0, 10, PRIORITY_HIGH)
    CooperativeExecutor_enqueue(&exec, 0, 30, PRIORITY_LOW)
    CooperativeExecutor_enqueue(&exec, 0, 20, PRIORITY_MEDIUM)
    @assertEq(exec.run_queue.get(0).context, 10)
    @assertEq(exec.run_queue.get(1).context, 20)
    @assertEq(exec.run_queue.get(2).context, 30)
    @assertEq(exec.run_queue.get(3).context, 40)
}

test "executor timer queue ordering" {
    var exec = CooperativeExecutor_init()
    CooperativeExecutor_enqueueDelayed(&exec, 0, 30, PRIORITY_DEFAULT, 3000000000)
    CooperativeExecutor_enqueueDelayed(&exec, 0, 10, PRIORITY_DEFAULT, 1000000000)
    CooperativeExecutor_enqueueDelayed(&exec, 0, 20, PRIORITY_DEFAULT, 2000000000)
    @assertEq(exec.timer_queue.get(0).context, 10)
    @assertEq(exec.timer_queue.get(1).context, 20)
    @assertEq(exec.timer_queue.get(2).context, 30)
}

test "executor stop" {
    var exec = CooperativeExecutor_init()
    CooperativeExecutor_stop(&exec)
    @assert(exec.should_stop)
}

test "executor drain timer queue" {
    var exec = CooperativeExecutor_init()
    CooperativeExecutor_insertTimerByDeadline(&exec, ExecutorJob {
        .poll_fn = 0,
        .context = 42,
        .priority = PRIORITY_DEFAULT,
        .deadline = 1,
    })
    @assertEq(exec.timer_queue.len(), 1)
    @assertEq(exec.run_queue.len(), 0)
    CooperativeExecutor_drainTimerQueue(&exec)
    @assertEq(exec.timer_queue.len(), 0)
    @assertEq(exec.run_queue.len(), 1)
    @assertEq(exec.run_queue.get(0).context, 42)
}

// --- M4: SchedulingExecutor with Duration ---

test "executor enqueueAfter with Duration" {
    var exec = CooperativeExecutor_init()
    var delay = Duration.seconds(10)
    CooperativeExecutor_enqueueAfter(&exec, 0, 77, PRIORITY_HIGH, delay)
    @assertEq(exec.timer_queue.len(), 1)
    @assertEq(exec.timer_queue.get(0).context, 77)
    @assertEq(exec.timer_queue.get(0).priority, PRIORITY_HIGH)
    @assert(exec.timer_queue.get(0).deadline > 0)
}

test "executor enqueueAt with Instant" {
    var exec = CooperativeExecutor_init()
    // Deadline 10 seconds in the future
    var now = Instant.now()
    var delay = Duration.seconds(10)
    var deadline = now.advanced(delay)
    CooperativeExecutor_enqueueAt(&exec, 0, 88, PRIORITY_LOW, deadline)
    @assertEq(exec.timer_queue.len(), 1)
    @assertEq(exec.timer_queue.get(0).context, 88)
}

test "executor enqueueAt past deadline goes to run queue" {
    var exec = CooperativeExecutor_init()
    // Deadline in the past
    var deadline = Instant.fromNanoseconds(1)
    CooperativeExecutor_enqueueAt(&exec, 0, 99, PRIORITY_DEFAULT, deadline)
    @assertEq(exec.run_queue.len(), 1)
    @assertEq(exec.run_queue.get(0).context, 99)
    @assertEq(exec.timer_queue.len(), 0)
}

// --- M4: SerialExecutor ---

test "executor isSameExclusiveExecutionContext" {
    var exec = CooperativeExecutor_init()
    // Phase 1: single-threaded, always same context
    @assert(CooperativeExecutor_isSameExclusiveExecutionContext(&exec, 0))
}

test "executor checkIsolated no crash" {
    var exec = CooperativeExecutor_init()
    CooperativeExecutor_checkIsolated(&exec)
}

test "executor isIsolatingCurrentContext" {
    var exec = CooperativeExecutor_init()
    @assert(CooperativeExecutor_isIsolatingCurrentContext(&exec))
}

test "executor isMainExecutor" {
    var exec = CooperativeExecutor_init()
    @assert(CooperativeExecutor_isMainExecutor(&exec))
}
